Cell[BoxData[
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"y", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{
             RowBox[{"y", "[", "t", "]"}], "^", "2"}]}], ")"}]}], "-", 
         RowBox[{"x", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", 
        RowBox[{"-", "1"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.956993710124426*^9, 3.9569937787014503`*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"277ae378-c3a8-724b-8667-1c276c1d34e9"],

