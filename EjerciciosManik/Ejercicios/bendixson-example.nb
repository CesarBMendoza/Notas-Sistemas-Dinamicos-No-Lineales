       RowBox[{
        RowBox[{
         RowBox[{"-", "x"}], "/", "3"}], "+", "2"}]}], "&&", 
      RowBox[{"x", "<", "6"}], "&&", 
      RowBox[{"y", ">", 
       RowBox[{"-", "2"}]}], "&&", 
      RowBox[{"y", ">", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "x"}], "/", "3"}], "-", "2"}]}], "&&", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "^", "2"}], "+", 
        RowBox[{"y", "^", "2"}]}], ">", 
       RowBox[{"1", "/", "3"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "7"}], ",", "7"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
     RowBox[{"PlotPoints", "->", "100"}]}], "]"}], ",", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], ",", 
         RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "sol1"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "900", ",", "1000"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Red", ",", "Thick"}], "}"}]}]}], "]"}]}], "]"}]], "Input",
