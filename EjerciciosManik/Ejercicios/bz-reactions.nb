Cell[BoxData[
 RowBox[{"scyc", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"8", "-", 
        RowBox[{"x", "[", "t", "]"}], "-", 
        RowBox[{"4", "*", 
         RowBox[{"x", "[", "t", "]"}], "*", 
