Notebook[{

Cell[CellGroupData[{
Cell["Ecuaciones en diferencias", "Title",
 CellChangeTimes->{{3.9237270497472515`*^9, 
  3.9237270545921383`*^9}},ExpressionUUID->"aa28cf9c-3383-fa41-b634-\
af5e9c20ac43"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["x", "TI"], 
         RowBox[{
           StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", "cosh", 
        RowBox[{"[", 
          FractionBox[
           RowBox[{
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["n", "TI"]], "-", "1"}], "2"], "]"}]}], 
      TraditionalForm], "errors" -> {}, "input" -> 
    "x_{n+1}=\\cosh[\\frac{x_n-1}{2}]", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"e9dd3b92-a60d-ff47-b6ae-ac45de4eb7eb"]], \
"Text",
 CellChangeTimes->{
  3.923728003529722*^9},ExpressionUUID->"bc76097e-2337-2348-9b01-\
b890addcf9be"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"n", "+", "1"}], "]"}], "==", 
        RowBox[{"Cosh", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "[", "n", "]"}], "-", "1"}], ")"}], "/", "2"}], 
         "]"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "2"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "10"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.923728574923277*^9, 3.923728634711172*^9}, {
   3.923728698943613*^9, 3.923728699377756*^9}, {3.9237288903251305`*^9, 
   3.9237288908288136`*^9}, 3.92373182438698*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"49e3c9af-46b4-bc42-8ce5-3938ca3a549a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"apxy", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"8", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "8"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"2", "^", "n"}], ")"}]}]}], "+", "1"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "10"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.923728647561131*^9, 3.923728708828295*^9}, {
  3.92372883683791*^9, 3.923728837236065*^9}, {3.923728913170698*^9, 
  3.923728913486868*^9}, {3.9237318176606503`*^9, 3.9237318411574345`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"aae87167-e1ed-de46-83c7-5a2639652a42"],

