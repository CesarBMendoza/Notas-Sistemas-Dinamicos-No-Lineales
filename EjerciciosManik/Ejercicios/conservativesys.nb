       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", "^", "2"}], ")"}], "/", "2"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", "^", "4"}], ")"}], "/", "4"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", 
        RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "\[Rule]", "\"\<Curvas de nivel\>\""}], ",", 
      RowBox[{"Contours", "\[Rule]", "50"}]}], "]"}]}], "}"}], "]"}]], "Input",
