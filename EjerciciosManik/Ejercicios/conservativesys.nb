Notebook[{

Cell[CellGroupData[{
Cell["Sistemas conservativos", "Title",
 CellChangeTimes->{{3.888331456973107*^9, 
  3.888331460433626*^9}},ExpressionUUID->"7c579c08-6366-4a7f-8547-\
5aac3d4bd345"],

Cell[CellGroupData[{

Cell["Ejemplo:", "Section",
 CellChangeTimes->{{3.8883352606481695`*^9, 
  3.888335263953143*^9}},ExpressionUUID->"635d6f9e-e57e-423e-bed3-\
a99b3f041074"],

Cell[TextData[{
 "Consideremos el sistema mec\[AAcute]nico ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["m", "TI"], 
         OverscriptBox[
          StyleBox["x", "TI"], "\:0308"], "\[LongEqual]", 
         StyleBox["F", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "m\\ddot{x}=F(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dfa547ce-aa4f-4fd6-8acd-db94fa692dad"],
 ", donde la energ\[IAcute]a potencial est\[AAcute] dada por ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["V", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "-", 
         FractionBox["1", "2"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "+", 
         FractionBox["1", "4"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "4"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "V(x)=-\\frac{1}{2}x^2+\\frac{1}{4}x^4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c353e75d-7188-437e-81ed-ea547fe0bfd9"],
 ". Entonces, considerando que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["F", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "-", 
         FractionBox[
          StyleBox["d", FontSlant -> "Plain"], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["x", "TI"]}]], 
         StyleBox["V", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "F(x)=-\\frac{\\mathrm{d}}{\\mathrm{d}x}V", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "98e042f4-5e43-443a-9221-8b8a320c4659"],
 ", y tomando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["m", "TI"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "m=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e3dc253b-315c-4488-9201-3c147e3e86d4"],
 ", la ecuci\[OAcute]n diferencial es:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "\:0308"], "\[LongEqual]", 
         StyleBox["x", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\ddot{x}=x-x^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7897e2d8-77f5-434d-aedd-362aa973c4e6"],
 ". Definiendo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4c89f2b3-111d-4430-b02c-cc44255bc969"],
 ", transformamos esta ecuaci\[OAcute]n en el sistema\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b01f2914-1326-4d5a-b57c-64c113434b68"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", 
         StyleBox["x", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{y}=x-x^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5584a67b-ba13-4549-b82b-f3329a7088fc"],
 "\ny la cantidad conservada es la energ\[IAcute]a, definida por\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["E", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox["1", "2"], 
         SuperscriptBox[
          StyleBox["y", "TI"], "2"], "-", 
         FractionBox["1", "2"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "+", 
         FractionBox["1", "4"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "4"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "E(x,y)=\\frac{1}{2}y^2-\\frac{1}{2}x^2+\\frac{1}{4}x^4", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "343013b6-0c81-4c4f-b469-f7decc596321"],
 ". \nLas soluciones son las curvas de nivel de la energ\[IAcute]a, como \
podemos observar:"
}], "Text",
 CellChangeTimes->{{3.8883352785861087`*^9, 3.888335323442541*^9}, {
   3.888335377290223*^9, 3.8883354341691*^9}, {3.888335486328796*^9, 
