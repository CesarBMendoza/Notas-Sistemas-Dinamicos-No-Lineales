Notebook[{

Cell[CellGroupData[{
Cell["Bifurcaciones en ecuaciones en diferencias", "Title",
 CellChangeTimes->{{3.8921275792889695`*^9, 
  3.892127588863373*^9}},ExpressionUUID->"02af3e5d-3f73-48f0-9360-\
29ddb6aba7b8"],

Cell[TextData[{
 "Tomemos la ecuaci\[OAcute]n en diferencias\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", "sin", 
         RowBox[{"(", 
           RowBox[{"\[Omega]", 
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["n", "TI"]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{n+1}=\\sin(\\omega x_n)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3a0560c3-b73a-46e6-8631-453ba9029d6f"],
 "\ndonde ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Omega]", ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\omega>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c161a7ef-e3f7-46c0-a153-6112e854c722"],
 " es un par\[AAcute]metro.\nPrimero, veamos c\[OAcute]mo cambia el lado \
derecho respecto a la identidad al variar el par\[AAcute]metro:"
}], "Text",
 CellChangeTimes->{{3.8921276076284623`*^9, 3.8921276190211887`*^9}, {
  3.892127690745779*^9, 
  3.8921277341808076`*^9}},ExpressionUUID->"6b179b61-c2aa-48b1-894e-\
cef731809209"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"Sin", "[", 
        RowBox[{"w", "*", "x"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1.2"}], ",", "1.2"}], "}"}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"x", ",", "n"}], "]"}], ",", 
        RowBox[{"Subscript", "[", 
         RowBox[{"x", ",", 
          RowBox[{"n", "+", "1"}]}], "]"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"w", ",", "0", ",", "2"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.892127756632187*^9, 3.8921278536360483`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"22f00a4c-eb38-4fbd-b27a-17fa556d502f"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`w$$ = 0., Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{
      Hold[$CellContext`w$$], 0, 2}}, Typeset`size$$ = {
    360., {113., 117.15056779635086`}}, Typeset`update$$ = 0, 
    Typeset`initDone$$, Typeset`skipInitDone$$ = True}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, "Variables" :> {$CellContext`w$$ = 0}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> Plot[{$CellContext`x, 
         Sin[$CellContext`w$$ $CellContext`x]}, {$CellContext`x, -1.2, 1.2}, 
        AxesLabel -> {
          Subscript[$CellContext`x, $CellContext`n], 
          Subscript[$CellContext`x, $CellContext`n + 1]}], 
      "Specifications" :> {{$CellContext`w$$, 0, 2}}, "Options" :> {}, 
      "DefaultOptions" :> {}],
     ImageSizeCache->{631., {144.13403328722342`, 149.86596671277658`}},
     SingleEvaluation->True],
    Deinitialization:>None,
