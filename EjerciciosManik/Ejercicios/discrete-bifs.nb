Cell[CellGroupData[{

Cell[TextData[{
 "Caso ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Omega]", "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\omega=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "90b5a001-24db-4906-8ac8-027759481eb2"]
}], "Section",
 CellChangeTimes->{{3.892128175805352*^9, 
  3.892128182978896*^9}},ExpressionUUID->"d268a933-f96c-4738-b563-\
a07e8ac303b5"],

Cell["\<\
Las soluciones tienden a cero como una ley de potencias, pero el cero sigue \
siendo estable. Estamos en el punto cr\[IAcute]tico de la bifurcaci\[OAcute]n.\
\>", "Text",
 CellChangeTimes->{{3.8921281874515133`*^9, 
  3.8921282122310686`*^9}},ExpressionUUID->"6712bf52-406e-4930-a709-\
266c50fafdce"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"n", "+", "1"}], "]"}], "==", 
        RowBox[{"Sin", "[", 
         RowBox[{"x", "[", "n", "]"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "1"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"sol2", ",", 
   RowBox[{"Mesh", "\[Rule]", "Full"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"n", ",", 
      RowBox[{"Subscript", "[", 
       RowBox[{"x", ",", "n"}], "]"}]}], "}"}]}], ",", 
   RowBox[{"Joined", "->", "True"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.8921282187895594`*^9, 3.8921282323704743`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"9f6e80bc-3897-4be3-baf4-4f8c416487d3"],

