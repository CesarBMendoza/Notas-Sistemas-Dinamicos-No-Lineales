Cell["\<\
Vemos que siempre son estables cuando existen, porque el eigenvalor tiene \
valor absoluto menor a uno, pero a partir de 1.56 aproximadamente, se vuelve \
negativo, lo que indica la presencia de oscilaciones.
Con esta informaci\[OAcute]n podemos graficar el diagrama de bifurcaci\
\[OAcute]n, recordando que graficamos con l\[IAcute]neas punteadas los \
equilibrios inestables y con lineas continuas los equilibrios estables.\
\>", "Text",
 CellChangeTimes->{{3.892128950808015*^9, 
  3.8921290721084876`*^9}},ExpressionUUID->"02ba4c0b-4328-4d1b-8721-\
15d203c202f9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"eqpos", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", 
       RowBox[{"x", "/.", 
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{"x", "==", 
           RowBox[{"Sin", "[", 
            RowBox[{"w", "*", "x"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "1"}], "}"}]}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"w", ",", "1", ",", "2", ",", "0.001"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqneg", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", 
       RowBox[{"x", "/.", 
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{"x", "==", 
           RowBox[{"Sin", "[", 
            RowBox[{"w", "*", "x"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"w", ",", "1", ",", "2", ",", "0.001"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
