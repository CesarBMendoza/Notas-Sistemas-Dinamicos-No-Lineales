    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
   Deployed->True,
   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
 CellChangeTimes->{{3.8921278221505013`*^9, 3.8921278541056385`*^9}},
 CellLabel->"Out[2]=",ExpressionUUID->"2d693d00-83b1-474e-92c4-dcb8d47fd505"]
}, Open  ]],

Cell["Ahora veamos las soluciones para cada valor del par\[AAcute]metro.", \
"Text",
 CellChangeTimes->{{3.8921279184564605`*^9, 
  3.892127964260009*^9}},ExpressionUUID->"31d9b290-ef46-4fd8-a8cf-\
3dae8f7f9e6c"],

Cell[CellGroupData[{

Cell[TextData[{
 "Caso ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Omega]", "<", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\omega<1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3c06050f-cc06-4073-bd1f-9aeaebd3349c"]
}], "Section",
 CellChangeTimes->{{3.892127975358136*^9, 
  3.8921279768693085`*^9}},ExpressionUUID->"6211a51b-7870-4858-ba75-\
29f7f59a0b3c"],

Cell["\<\
Las soluciones tienden exponencialmente a cero, por lo que el cero es una \
soluci\[OAcute]n de equilibrio estable.\
\>", "Text",
 CellChangeTimes->{{3.892128136482686*^9, 
  3.892128157473647*^9}},ExpressionUUID->"2ccb7661-ff26-49a7-8749-\
533c971b7c5a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"n", "+", "1"}], "]"}], "==", 
        RowBox[{"Sin", "[", 
         RowBox[{"0.7", "*", 
          RowBox[{"x", "[", "n", "]"}]}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "1"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "20"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"sol1", ",", 
   RowBox[{"Mesh", "\[Rule]", "Full"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"n", ",", 
      RowBox[{"Subscript", "[", 
       RowBox[{"x", ",", "n"}], "]"}]}], "}"}]}], ",", 
   RowBox[{"Joined", "->", "True"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.8921280019188576`*^9, 3.892128115315524*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"652f4124-7e08-4a9a-8af1-71eff5a87db6"],

