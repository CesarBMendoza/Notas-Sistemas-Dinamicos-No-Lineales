Cell[CellGroupData[{

Cell[TextData[{
 "Caso ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "<", "\[Omega]", "<", "1.56"}], TraditionalForm], 
     "errors" -> {}, "input" -> "1<\\omega<1.56", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b240f7b2-d17e-4bc7-93ef-ffcad06ee0dc"]
}], "Section",
 CellChangeTimes->{{3.8921282809155445`*^9, 
  3.8921282824553566`*^9}},ExpressionUUID->"65ca9dec-7088-414e-af49-\
13042548bb8b"],

Cell["\<\
Las soluciones se alejan del cero y tienden a alguno de los dos puntos de \
equilibrio sim\[EAcute]tricos de manera mon\[OAcute]tona. El cero es \
inestable y los dos puntos de equilibrio adicionales son estables.\
\>", "Text",
 CellChangeTimes->{{3.8921283255583286`*^9, 
  3.89212836935917*^9}},ExpressionUUID->"07337635-c4c0-482a-b769-\
5f0f303f3a18"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol3", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"n", "+", "1"}], "]"}], "==", 
        RowBox[{"Sin", "[", 
         RowBox[{"1.2", "*", 
          RowBox[{"x", "[", "n", "]"}]}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "0.01"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "50"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"sol3", ",", 
   RowBox[{"Mesh", "\[Rule]", "Full"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"n", ",", 
      RowBox[{"Subscript", "[", 
       RowBox[{"x", ",", "n"}], "]"}]}], "}"}]}], ",", 
   RowBox[{"Joined", "->", "True"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.892128399720913*^9, 3.8921284296101947`*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"19ddafaf-5175-4906-9bf8-2dcc14390f32"],

