Cell[BoxData[
 RowBox[{
  RowBox[{"stst", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", 
       RowBox[{"x", "/.", 
        RowBox[{"FindRoot", "[", 
