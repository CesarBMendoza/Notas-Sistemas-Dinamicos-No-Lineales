Cell[CellGroupData[{
Cell["Sistemas de ecuaciones en diferencias", "Title",
 CellChangeTimes->{{3.9545462539621983`*^9, 
  3.9545462596278877`*^9}},ExpressionUUID->"403a2350-fa1a-dd46-8cd9-\
ffaa1d2dd5b4"],

Cell[CellGroupData[{

Cell["Ejemplo I", "Section",
 CellChangeTimes->{{3.954546804841833*^9, 
  3.9545468076670647`*^9}},ExpressionUUID->"87c8d46c-cd7d-764d-8bde-\
b998f309aa81"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], "+", "1"}]], "\[LongEqual]", 
         FractionBox["1", "2"], 
         SubscriptBox[
          StyleBox["y", "TI"], 
          StyleBox["k", "TI"]], "+", 
         FractionBox["1", "2"], 
         SubscriptBox[
          StyleBox["z", "TI"], 
          StyleBox["k", "TI"]], "+", 
         SubscriptBox[
          StyleBox["y", "TI"], 
          StyleBox["k", "TI"]], 
         RowBox[{"[", 
           RowBox[{"1", "-", "tanh", 
             RowBox[{"(", 
               SubscriptBox[
                StyleBox["y", "TI"], 
                StyleBox["k", "TI"]], ")"}]}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "y_{k+1}=\\frac{1}{2}y_k+\\frac{1}{2}z_k+y_k[1-\\tanh(y_k)]", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a9c08a1f-0df8-254a-a3ce-6224d4af716a"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["z", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], "+", "1"}]], "\[LongEqual]", 
         FractionBox["1", "4"], 
         SubscriptBox[
          StyleBox["y", "TI"], 
          StyleBox["k", "TI"]], "+", 
         FractionBox["1", "2"], 
         SubscriptBox[
          StyleBox["z", "TI"], 
          StyleBox["k", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "z_{k+1}=\\frac{1}{4}y_k+\\frac{1}{2}z_k", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2b0b67e1-4e0c-104e-b93f-8eb04ca5d5c8"],
 "\nPunto de equilibrio no trivial:"
}], "Text",
 CellChangeTimes->{
  3.95454682164184*^9, {3.95454689113488*^9, 3.9545468937211742`*^9}, {
   3.954546933509676*^9, 
   3.954546953167593*^9}},ExpressionUUID->"25cf453a-3ed8-1346-bec0-\
0e9994fad249"],

