    RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
    RowBox[{"Joined", "\[Rule]", "True"}], ",", 
    RowBox[{"Mesh", "\[Rule]", "All"}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Subscript", "[", 
        RowBox[{"y", ",", "k"}], "]"}], ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"z", ",", "k"}], "]"}]}], "}"}]}]}], "]"}]}]], "Input",
