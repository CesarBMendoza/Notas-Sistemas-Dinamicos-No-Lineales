Cell["\<\
Surgen dos nuevos puntos de equilibrio. Con condiciones iniciales cerca del \
equilibrio estable, las soluciones se alejan y convergen a los nuevos puntos \
de equilibrio, dependiendo del valor preciso de la condici\[OAcute]n inicial:\
\>", "Text",
 CellChangeTimes->{{3.954547433995634*^9, 
  3.9545474910819664`*^9}},ExpressionUUID->"04b8f0a8-db22-924d-857f-\
b0d929a6a193"],

Cell[BoxData[
 RowBox[{
  RowBox[{"spsb", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"n", "+", "1"}], "]"}], "==", 
        RowBox[{"Sin", "[", 
         RowBox[{"3", "*", 
          RowBox[{
           RowBox[{"x", "[", "n", "]"}], "/", "2"}]}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "0.00001"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "50"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8618802771420183`*^9, 3.8618803105073433`*^9}, {
  3.8618803556529655`*^9, 3.861880370002909*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"0c439d50-a4c1-43be-a721-0fb8bf8bd911"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lp7", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{"spsb", ",", 
    RowBox[{"Joined", "\[Rule]", "True"}], ",", 
    RowBox[{"Mesh", "\[Rule]", "All"}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"n", ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"x", ",", "n"}], "]"}]}], "}"}]}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}]], "Input",
