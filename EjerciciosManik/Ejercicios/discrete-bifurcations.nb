Cell["Matriz Jacobiana:", "Text",
 CellChangeTimes->{{3.9545469763721943`*^9, 
  3.9545469795979176`*^9}},ExpressionUUID->"2d7cd0ac-6556-f341-acd8-\
e3197508e9ad"],

Cell[BoxData[
 RowBox[{
  RowBox[{"j1", "[", "x_", "]"}], ":=", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       RowBox[{"1", "/", "2"}], "+", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Tanh", "[", "x", "]"}]}], ")"}], "-", 
       RowBox[{"x", "*", 
        RowBox[{
         RowBox[{"Sech", "[", "x", "]"}], "^", "2"}]}]}], 
      RowBox[{"1", "/", "2"}]},
     {
      RowBox[{"1", "/", "4"}], 
      RowBox[{"1", "/", "2"}]}
    }], "\[NoBreak]", ")"}]}]], "Input",
 CellChangeTimes->{{3.861871409375177*^9, 3.8618714241759496`*^9}, {
  3.8618714642748585`*^9, 3.861871502191651*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"e9e53c7e-9494-456c-add8-d35b18a1e1df"],

