Cell["Trayectoria con condiciones iniciales cercanas al origen:", "Text",
 CellChangeTimes->{{3.9545470561139145`*^9, 
  3.9545470669583054`*^9}},ExpressionUUID->"04e7628f-445d-ad48-aa17-\
02d5f8ea3bc9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sist1", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "[", "k", "]"}], "/", "2"}], "+", 
         RowBox[{
          RowBox[{"z", "[", "k", "]"}], "/", "2"}], "+", 
         RowBox[{
          RowBox[{"y", "[", "k", "]"}], "*", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"Tanh", "[", 
             RowBox[{"y", "[", "k", "]"}], "]"}]}], ")"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"z", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "[", "k", "]"}], "/", "4"}], "+", 
         RowBox[{
          RowBox[{"z", "[", "k", "]"}], "/", "2"}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1", "]"}], "==", "0.00001"}], ",", 
       RowBox[{
        RowBox[{"z", "[", "1", "]"}], "==", "0.00001"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "z"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "100"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8618782944409714`*^9, 3.8618784640449514`*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"9f200a35-ffb2-45fa-a659-fdef4475aa56"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lp1", "=", 
  RowBox[{"ListPlot", "[", 
