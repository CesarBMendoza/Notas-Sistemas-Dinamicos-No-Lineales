             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["n", "TI"]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{n+1}=\\sin(\\omega x_n)", "state" -> 
     "Boxes"|>,
