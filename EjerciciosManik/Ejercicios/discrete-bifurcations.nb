Cell["\<\
Graficando el diagrama de bifurcaci\[OAcute]n de manera num\[EAcute]rica, \
observamos que muestra la forma t\[IAcute]pica de una bifurcaci\[OAcute]n de \
tridente supercr\[IAcute]tica:\
\>", "Text",
 CellChangeTimes->{{3.9545475954050198`*^9, 
  3.954547634040577*^9}},ExpressionUUID->"6c69e228-2f56-3848-ba59-\
1383225fa20a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"stst2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", 
       RowBox[{"x", "/.", 
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{"x", "==", 
           RowBox[{"Sin", "[", 
            RowBox[{"w", "*", "x"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"w", ",", "1", ",", "2", ",", "0.00001"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.861880923406584*^9, 3.8618809324597664`*^9}, {
