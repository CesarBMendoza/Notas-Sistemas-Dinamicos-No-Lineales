Cell["Esto indica que las soluciones se vuelven oscilatorias:", "Text",
 CellChangeTimes->{{3.9545475758159943`*^9, 
  3.9545475850324535`*^9}},ExpressionUUID->"3a6e0028-61c6-fc4a-84af-\
ce893b7e3a32"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sinex", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"n", "+", "1"}], "]"}], "==", 
        RowBox[{"Sin", "[", 
         RowBox[{
          RowBox[{"x", "[", "n", "]"}], "*", "1.9"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "0.94"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "15"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.861880778067844*^9, 3.8618808982389145`*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"487e5b34-0c70-43a5-8752-fd8af4aa3323"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lp10", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{"sinex", ",", 
    RowBox[{"Joined", "\[Rule]", "True"}], ",", 
    RowBox[{"Mesh", "\[Rule]", "All"}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"n", ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"x", ",", "n"}], "]"}]}], "}"}]}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8618808318415203`*^9, 3.8618808334415855`*^9}, {
  3.8618823115227757`*^9, 3.8618823164363117`*^9}},
 CellLabel->"In[99]:=",ExpressionUUID->"1ee64c88-8f34-419f-b3cd-e354de391b7d"],

