Cell[BoxData[{
 RowBox[{
  RowBox[{"c", "=", "2.38"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"r", "=", "3.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"t", "+", "1"}], "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"r", "+", "1"}], ")"}], "*", 
          RowBox[{"x", "[", "t", "]"}]}], "-", 
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}], "-", 
         RowBox[{"c", "*", 
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"t", "+", "1"}], "]"}], "==", 
        RowBox[{"c", "*", 
         RowBox[{"x", "[", "t", "]"}], "*", 
         RowBox[{"y", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", 
        RowBox[{
         RowBox[{"1", "/", "c"}], "+", "0.001"}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1", "]"}], "==", 
        RowBox[{
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"c", "-", "1"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"c", "^", "2"}], ")"}]}]}], "-", "0.001"}]}]}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "10000", ",", "80000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"sol2", ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}]}], ",", 
   RowBox[{"Mesh", "->", "All"}], ",", 
