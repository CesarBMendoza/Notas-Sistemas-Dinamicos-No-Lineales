 CellChangeTimes->{{3.9084729217683992`*^9, 3.9084729229278193`*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"99a8a922-100c-4b9a-be50-2e1d09824f14"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "==", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"r", "+", "1"}], ")"}], "*", "x"}], "-", 
       RowBox[{"r", "*", 
        RowBox[{"x", "^", "2"}]}], "-", 
       RowBox[{"c", "*", "x", "*", "y"}]}]}], ",", 
     RowBox[{"y", "==", 
      RowBox[{"c", "*", "x", "*", "y"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9084729070310373`*^9, 3.9084729620591536`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"4a3024f5-9177-44a9-ba31-79f22c92c8f8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", 
      FractionBox["1", "c"]}], ",", 
     RowBox[{"y", "\[Rule]", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "c"}], ")"}], " ", "r"}], 
       SuperscriptBox["c", "2"]]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", "0"}], ",", 
     RowBox[{"y", "\[Rule]", "0"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", "1"}], ",", 
     RowBox[{"y", "\[Rule]", "0"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9084729626994944`*^9},
 CellLabel->"Out[13]=",ExpressionUUID->"00b70509-bf50-4236-81fa-c3f00b49a4ca"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"c", "=", "2.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"r", "=", "3.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"t", "+", "1"}], "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"r", "+", "1"}], ")"}], "*", 
          RowBox[{"x", "[", "t", "]"}]}], "-", 
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}], "-", 
         RowBox[{"c", "*", 
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"t", "+", "1"}], "]"}], "==", 
        RowBox[{"c", "*", 
         RowBox[{"x", "[", "t", "]"}], "*", 
         RowBox[{"y", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", 
        RowBox[{
         RowBox[{"1", "/", "c"}], "+", "0.001"}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1", "]"}], "==", 
        RowBox[{
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"c", "-", "1"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"c", "^", "2"}], ")"}]}]}], "-", "0.001"}]}]}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "10000", ",", "10500"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"sol2", ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}]}], ",", 
   RowBox[{"Mesh", "->", "All"}], ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", ",", 
      RowBox[{"PointSize", "[", "Medium", "]"}], ",", 
      RowBox[{"Point", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", "c"}], ",", 
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"c", "-", "1"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"c", "^", "2"}], ")"}]}]}]}], "}"}], "]"}]}], "}"}]}]}], 
  "]"}]}], "Input",
