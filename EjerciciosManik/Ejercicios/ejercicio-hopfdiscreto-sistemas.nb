Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"c", "=", "2.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"r", "=", "3.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"t", "+", "1"}], "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"r", "+", "1"}], ")"}], "*", 
          RowBox[{"x", "[", "t", "]"}]}], "-", 
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}], "-", 
         RowBox[{"c", "*", 
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"t", "+", "1"}], "]"}], "==", 
        RowBox[{"c", "*", 
         RowBox[{"x", "[", "t", "]"}], "*", 
         RowBox[{"y", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", 
        RowBox[{
         RowBox[{"1", "/", "c"}], "+", "0.001"}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1", "]"}], "==", 
        RowBox[{
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"c", "-", "1"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"c", "^", "2"}], ")"}]}]}], "-", "0.001"}]}]}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "1", ",", "500"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"sol1", ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}]}], ",", 
   RowBox[{"Joined", "->", "True"}], ",", 
   RowBox[{"Mesh", "->", "All"}], ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", ",", 
      RowBox[{"PointSize", "[", "Medium", "]"}], ",", 
      RowBox[{"Point", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", "c"}], ",", 
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"c", "-", "1"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"c", "^", "2"}], ")"}]}]}]}], "}"}], "]"}]}], "}"}]}]}], 
  "]"}]}], "Input",
