Cell[TextData[{
 "Usando las soluciones, encuentra el lugar geom\[EAcute]trico de las \
condiciones iniciales ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["x", "TI"], "0"], ",", 
           SubscriptBox[
            StyleBox["y", "TI"], "0"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(x_0,y_0)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d0ed52a6-f724-4441-be32-5263ff9cad78"],
 " en el espacio fase tal que las soluciones tienden al punto de equilibrio \
en el l\[IAcute]mte ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "t\\rightarrow\\infty", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "78b161a9-04e8-4c72-8608-b952b7d7c908"],
 ". \[CapitalEAcute]sta es la variedad estable."
}], "Item",
 CellChangeTimes->{{3.9071616906386185`*^9, 
  3.907161735625595*^9}},ExpressionUUID->"2b1c5291-ff62-42f8-b1e5-\
934c7762c96c"],

Cell[TextData[{
 "El punto de equilibrio es el origen, por lo que necesitamos encontrar ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["x", "TI"], "0"], ",", 
           SubscriptBox[
            StyleBox["y", "TI"], "0"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(x_0,y_0)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1dd02fe0-e725-4942-bff7-ca15443386ff"],
 " tales que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], 
          LimitsPositioning -> True], 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lim_{t\\rightarrow\\infty}x(t)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "437d9e5b-909a-4ede-ab51-5b01291087d1"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], 
          LimitsPositioning -> True], 
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lim_{t\\rightarrow\\infty}y(t)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "096239fa-ec8d-41a5-8d30-a2126aceaa35"],
 ".\nVemos que, sin importar el valor de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["x", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f8e9b809-9ce1-4fd4-93c3-81a1b6f875c6"],
 ", siempre se cumple que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], 
          LimitsPositioning -> True], 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lim_{t\\rightarrow\\infty}x(t)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "96e053bf-4a05-4cfb-b457-b6d66968b5fd"],
 ". Por otro lado, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "y(t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3e743ebe-b19f-4781-8e0d-eddbe1e02abd"],
 " por lo general diverge, excepto si el coeficiente de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"2", 
          StyleBox["t", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "e^{2t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1cde4e2c-1fe8-4b4d-a362-9e6145d07df9"],
 " es cero. Por lo tanto, tenemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], 
          LimitsPositioning -> True], 
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lim_{t\\rightarrow\\infty}y(t)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a6ef52ce-2db3-448c-9147-d8722f801bec"],
 " s\[OAcute]lo si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], "0"], "-", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "y_0-x_0^2=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "03e3068c-693a-406a-8cb3-96a99294d67c"],
 ", es decir si \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], "0"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "y_0=x_0^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "263052dc-ae36-4c04-a263-6b919b625ef2"],
 ".\nEl lugar geom\[EAcute]trico en el espacio fase de estas condiciones \
iniciales es una par\[AAcute]bola unitaria con v\[EAcute]rtice en el origen."
}], "Text",
 CellChangeTimes->{{3.9071617482987185`*^9, 3.9071619872822742`*^9}, {
  3.907162057556737*^9, 
  3.9071620586467676`*^9}},ExpressionUUID->"98757089-7453-47b6-a6ec-\
dc0e85c67e51"],

Cell[TextData[{
 "Usando las soluciones, encuentra el lugar geom\[EAcute]trico de las \
condiciones iniciales ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["x", "TI"], "0"], ",", 
           SubscriptBox[
            StyleBox["y", "TI"], "0"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(x_0,y_0)", "state" -> "Boxes"|>,
