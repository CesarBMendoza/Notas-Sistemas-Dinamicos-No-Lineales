  "614965d0-cac7-4ed4-8bf9-c78e34b19fea"],
 " en el espacio fase tal que las soluciones tienden al punto de equilibrio \
en el l\[IAcute]mte ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["t", "TI"], "\[Rule]", "-", "\[Infinity]"}], 
       TraditionalForm], "errors" -> {}, "input" -> "t\\rightarrow-\\infty", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1fc73f97-4f1b-4893-b75b-4ea275d07d17"],
 ". \[CapitalEAcute]sta es la variedad inestable."
}], "Item",
 CellChangeTimes->{{3.9071620736927342`*^9, 
  3.9071620855250497`*^9}},ExpressionUUID->"8e62daad-27e7-47dc-80e6-\
141875141977"],

Cell[TextData[{
 "En este caso, tenemos que encontrar ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["x", "TI"], "0"], ",", 
           SubscriptBox[
            StyleBox["y", "TI"], "0"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(x_0,y_0)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a49a0566-e255-4da3-bc20-a73bf9ecb6a6"],
 " tales que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[Rule]", "-", "\[Infinity]"}], 
          LimitsPositioning -> True], 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lim_{t\\rightarrow-\\infty}x(t)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dee579e4-d227-40c8-a0c3-c8d986086903"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[Rule]", "-", "\[Infinity]"}], 
          LimitsPositioning -> True], 
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lim_{t\\rightarrow-\\infty}y(t)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "eeaec9be-07e2-49ba-90d2-87d3cea2720e"],
 ". En este caso vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "08f430e0-a867-4327-95aa-a56cac6992f9"],
 " diverge en este l\[IAcute]mite excepto si es cero para toda ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> "t", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "794c94ae-cb18-483c-9818-3a88814fffcd"],
 ". Esto s\[OAcute]lo se cumple si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_0=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "11ccb18c-46c6-430b-bda5-ad65730403ad"],
 ". ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "y(t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b9558083-9620-4065-a2d4-112c731a000d"],
 " tambi\[EAcute]n diverge en general, excepto cuando el coeficiente de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"-6", 
          StyleBox["t", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "e^{-6t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f877fad2-d3bb-4b2e-98a1-533735bb4348"],
 " es cero, es decir, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_0=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f9a7151b-16df-418f-85a6-61167ae5709d"],
 " tambi\[EAcute]n. Es decir, el lugar geom\[EAcute]trico de condiciones \
iniciales en el espacio fase que tienden al punto de equilibrio en el l\
\[IAcute]mite especificado es la recta vertical ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_0=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ce03e086-2696-4107-a261-3a7587613f1c"],
 "."
}], "Text",
 CellChangeTimes->{{3.9071620963191357`*^9, 
  3.9071622835977015`*^9}},ExpressionUUID->"f2bd4c3b-4120-4402-a5a6-\
4eb9ee97a32b"],

