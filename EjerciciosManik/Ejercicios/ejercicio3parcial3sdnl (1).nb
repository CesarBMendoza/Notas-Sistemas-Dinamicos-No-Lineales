Cell[CellGroupData[{
Cell["Retrato fase 2D", "Title",
 CellChangeTimes->{{3.907160404759912*^9, 
  3.9071604085281267`*^9}},ExpressionUUID->"99e2a274-0a71-46b7-932e-\
193d4652df0b"],

Cell[TextData[{
 "El sistema\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", "-3", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=-3x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c77fe4ed-06c8-4782-97bf-b15eeeab9b69"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", "-8", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "+", "2", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=-8x^2+2y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "82bdabee-1906-469d-aafd-1759599a9e18"],
 "\ntiene un solo punto de equilibrio en el origen."
}], "Text",
 CellChangeTimes->{{3.9071604143578105`*^9, 
  3.9071604600411787`*^9}},ExpressionUUID->"329df768-0588-4fc5-a178-\
f4bf3a0f9529"],

Cell["Clasifica al punto de equilibrio.", "Item",
 CellChangeTimes->{{3.907160523306729*^9, 
  3.907160533092884*^9}},ExpressionUUID->"9e682a54-e0de-45e5-96a6-\
b3aea11d4175"],

Cell["Calculamos la matriz Jacobiana", "Text",
 CellChangeTimes->{{3.907160542688715*^9, 
  3.907160548478751*^9}},ExpressionUUID->"25fd383e-5ba0-49c6-8a74-\
25338a050493"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"J", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "3"}], "*", "x"}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "3"}], "*", "x"}], ",", "y"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", "8"}], "*", 
          RowBox[{"x", "^", "2"}]}], "+", 
         RowBox[{"1", "*", "y"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", "8"}], "*", 
          RowBox[{"x", "^", "2"}]}], "+", 
         RowBox[{"1", "*", "y"}]}], ",", "y"}], "]"}]}], "}"}]}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.9071605532186947`*^9, 3.9071606023315964`*^9}, {
  3.907160643142353*^9, 3.907160643277906*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"c26ff85b-07c6-460b-8ce7-3386d6c86975"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "3"}], ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "16"}], " ", "x"}], ",", "1"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9071606032303047`*^9, 3.907160643635518*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"800c91ae-8f78-4177-bde6-127b6d0f898b"]
}, Open  ]],

Cell["Evaluamos en el origen", "Text",
 CellChangeTimes->{{3.9071606163985844`*^9, 
  3.9071606227779408`*^9}},ExpressionUUID->"adcc834d-121e-4722-ad35-\
64e60224f6a0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"J", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "->", "0"}], ",", 
     RowBox[{"y", "->", "0"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9071606264302444`*^9, 3.907160637520218*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"e49b2ac7-807f-4eef-9f4b-f33bb30aff35"],

Cell[BoxData[
 FormBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"-", "3"}], "0"},
     {"0", "1"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}], TraditionalForm]], "Output",
 CellChangeTimes->{{3.9071606379555254`*^9, 3.90716064567725*^9}},
 CellLabel->
  "Out[4]//TraditionalForm=",ExpressionUUID->"08623936-5d20-4701-aa17-\
687b20b16280"]
}, Open  ]],

Cell["\<\
La matriz es diagonal, por lo que los eigenvalores son los elementos en la \
diagonal. Un eigenvalor es negativo y otro es positivo, por lo que tenemos un \
punto silla. Equivalentemente, el determinante es negativo, lo que tambi\
\[EAcute]n indica un punto silla.\
\>", "Text",
 CellChangeTimes->{{3.9071606519662123`*^9, 
  3.9071607129849806`*^9}},ExpressionUUID->"2de227ee-bace-4c9b-9f80-\
3b1effbf0d3d"],

Cell[TextData[{
 "Encuentra la soluci\[OAcute]n exacta del sistema con condiciones iniciales ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(0)=x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8480331a-2ba5-4a8c-b234-41a5baad761d"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["y", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "y(0)=y_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "29ca6a18-cce3-4eef-a8d6-0a2d735741ad"],
 "."
}], "Item",
 CellChangeTimes->{{3.9071607316413403`*^9, 
  3.907160757071451*^9}},ExpressionUUID->"79e9d5fa-f15f-43ed-adfc-\
0222ba575166"],

Cell[TextData[{
 "La primera ecuaci\[OAcute]n est\[AAcute] desacoplada y es lineal, por lo \
que podemos encontrar la soluci\[OAcute]n de manera trivial como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["C", "TI"], "1"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-3", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)=C_1e^{-3t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ee323e0d-1d09-4b29-8187-3e5b549bd85d"],
 ". Necesitamos usar la condici\[OAcute]n inicial ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(0)=x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b6bc7404-10a7-4492-9b6a-107251ffcb84"],
 ". Sustituyendo en la soluci\[OAcute]n encontramos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["C", "TI"], "1"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "C_1=x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a66460ef-1309-4fb4-bb48-02c2c7703ebd"],
 ", por lo que la soluci\[OAcute]n particular con condiciones iniciales es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-3", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)=x_0e^{-3t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b6ec4c77-4527-4e30-adfe-17d41ba5a018"],
 ".\nSustituimos esta soluci\[OAcute]n en la segunda ecuaci\[OAcute]n y \
encontramos la ecuaci\[OAcute]n lineal inhomog\[EAcute]nea\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", "-8", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-6", 
            StyleBox["t", "TI"]}]], "+", "2", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=-8x_0^2e^{-6t}+2y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "78d7741c-0d39-4457-aad9-8c3de0c89c2b"],
 "\nEsta la podemos resolver ya sea con factor integrante o como combinaci\
\[OAcute]n lineal de la homog\[EAcute]nea m\[AAcute]s una particular de la \
inhomog\[EAcute]nea. Usando factor integrante tenemos:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "-", "2", 
         StyleBox["y", "TI"], "\[LongEqual]", "-8", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-6", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{y}-2y=-8x_0^2e^{-6t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6a3d140e-2510-48ed-a625-061b851dbf5b"],
 "\nEl factor integrante es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mu(t)=e^{-2t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e77c8899-152e-4f69-81bb-4f7aea4dbd86"],
 ", multiplicamos de ambos lados y obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["t", "TI"]}]], 
         OverscriptBox[
          StyleBox["y", "TI"], "."], "-", "2", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["t", "TI"]}]], 
         StyleBox["y", "TI"], "\[LongEqual]", "-8", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-8", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "e^{-2t}\\dot{y}-2e^{-2t}y=-8x_0^2e^{-8t}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "904df0a4-366e-4dd6-b56e-34913f5d2805"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          StyleBox["d", FontSlant -> "Plain"], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-2", 
                StyleBox["t", "TI"]}]], 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", "-8", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-8", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{\\mathrm{d}}{\\mathrm{d}t}(e^{-2t}y)=-8x_0^2e^{-8t}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9d5ac11d-de51-43cc-8f1d-4d8b43ee1e0c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["t", "TI"]}]], 
         StyleBox["y", "TI"], "\[LongEqual]", "-8", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-8", 
            StyleBox["t", "TI"]}]], 
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "e^{-2t}y=-8x_0^2\\int e^{-8t}\\mathrm{d}t", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1390327b-5334-4085-a148-112019aca94e"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["t", "TI"]}]], 
         StyleBox["y", "TI"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-8", 
                StyleBox["t", "TI"]}]], "+", 
             SubscriptBox[
              StyleBox["C", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "e^{-2t}y=x_0^2(e^{-8t}+C_2)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b1dd5f4b-a7b8-46c9-abee-8c891a238050"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"2", 
            StyleBox["t", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-8", 
                StyleBox["t", "TI"]}]], "+", 
             SubscriptBox[
              StyleBox["C", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y(t)=x_0^2e^{2t}(e^{-8t}+C_2)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "36bfa012-608a-40ff-a45b-f2ca5d50687c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-6", 
                StyleBox["t", "TI"]}]], "+", 
             SubscriptBox[
              StyleBox["C", "TI"], "2"], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"2", 
                StyleBox["t", "TI"]}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y(t)=x_0^2(e^{-6t}+C_2e^{2t})", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a2068c24-0aab-4818-bbb0-39b5c82d3187"],
 "\nUsamos la condici\[OAcute]n inicial ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["y", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "y(0)=y_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cb7c9e28-e888-4ba9-af47-1f8845527741"],
 " y obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], "0"], "\[LongEqual]", 
         StyleBox["y", "TI"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             SubscriptBox[
              StyleBox["C", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y_0=y(0)=x_0^2(1+C_2)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2885737e-ff03-4694-8c4e-1ffce46eb189"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["C", "TI"], "2"], "\[LongEqual]", 
         FractionBox[
          SubscriptBox[
           StyleBox["y", "TI"], "0"], 
          SubsuperscriptBox[
           StyleBox["x", "TI"], "0", "2"]], "-", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "C_2=\\frac{y_0}{x_0^2}-1", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6e06bae8-7932-4c4c-8074-279667241bd7"],
 "\nSustituyendo obtenemos la soluci\[OAcute]n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         RowBox[{"[", 
           RowBox[{
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-6", 
                StyleBox["t", "TI"]}]], "+", 
             RowBox[{"(", 
               RowBox[{
                 FractionBox[
                  SubscriptBox[
                   StyleBox["y", "TI"], "0"], 
                  SubsuperscriptBox[
                   StyleBox["x", "TI"], "0", "2"]], "-", "1"}], ")"}], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"2", 
                StyleBox["t", "TI"]}]]}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "y(t)=x_0^2[e^{-6t}+(\\frac{y_0}{x_0^2}-1)e^{2t}]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0bd3b9fe-82cf-48b8-bb06-58a4db428ffa"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-6", 
            StyleBox["t", "TI"]}]], "+", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["y", "TI"], "0"], "-", 
             SubsuperscriptBox[
              StyleBox["x", "TI"], "0", "2"]}], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"2", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "y(t)=x_0^2e^{-6t}+(y_0-x_0^2)e^{2t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "92c3e6a5-58d1-4f31-a728-99767440873f"],
 "\nPor lo que la soluci\[OAcute]n al sistema son las funciones\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-3", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)=x_0e^{-3t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "24c3aff1-1d8f-4401-a0af-846511584db9"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "0", "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-6", 
            StyleBox["t", "TI"]}]], "+", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["y", "TI"], "0"], "-", 
             SubsuperscriptBox[
              StyleBox["x", "TI"], "0", "2"]}], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"2", 
            StyleBox["t", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "y(t)=x_0^2e^{-6t}+(y_0-x_0^2)e^{2t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "980c7f78-525b-4ac4-8902-84fd58be58a9"]
}], "Text",
 CellChangeTimes->{{3.9071607622595596`*^9, 3.9071608665504694`*^9}, {
  3.9071609469099855`*^9, 3.9071609701421013`*^9}, {3.907161007260449*^9, 
