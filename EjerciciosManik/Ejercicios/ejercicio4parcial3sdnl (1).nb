Notebook[{

Cell[CellGroupData[{
Cell["Soluci\[OAcute]n ciclo l\[IAcute]mite", "Title",
 CellChangeTimes->{{3.907168262857091*^9, 
  3.9071682667243166`*^9}},ExpressionUUID->"e5404f55-b741-46fd-99d1-\
1691dfdc43e0"],

Cell[TextData[{
 "El sistema\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["y", "TI"], "2"], "-", "2", 
             StyleBox["x", "TI"], "-", "3"}], ")"}], "-", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=x(x^2+y^2-2x-3)-y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ac3f94f0-71d9-4297-9411-e1dd6daaf1f2"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["y", "TI"], "2"], "-", "2", 
             StyleBox["x", "TI"], "-", "3"}], ")"}], "+", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=y(x^2+y^2-2x-3)+x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e66c3311-8bf3-42b2-b641-dca1dd4ad825"],
 "\ntiene un ciclo l\[IAcute]mite."
}], "Text",
 CellChangeTimes->{{3.9071682745453196`*^9, 3.9071682766193495`*^9}, {
  3.907168342510562*^9, 
  3.907168401017358*^9}},ExpressionUUID->"914352a7-6c3c-46a7-8166-\
cc88526ea2f6"],

Cell["\<\
Usa el teorema de Poincar\[EAcute]-Bendixson para encontrar una \
regi\[OAcute]n anular dentro de la cual se encuentra el ciclo l\[IAcute]mite.\
\>", "Item",
 CellChangeTimes->{{3.907168417205263*^9, 
  3.9071684401895227`*^9}},ExpressionUUID->"02caa521-c621-41fe-9641-\
c4b3367796d6"],

Cell[TextData[{
 "En coordenadas polares, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", 
         StyleBox["r", "TI"], "cos", "\[Theta]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=r\\cos\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dd3fbde7-25be-4859-9559-55ebf88b745c"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "\[LongEqual]", 
         StyleBox["r", "TI"], "sin", "\[Theta]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "y=r\\sin\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a55eabf6-aed0-4e5c-823f-30083215f14d"],
 ". Tenemos que el radio y el \[AAcute]ngulo est\[AAcute]n dados por \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "+", 
         SuperscriptBox[
          StyleBox["y", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r^2=x^2+y^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "83631fdf-9dae-4ae9-a15d-e45c317be170"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"tan", "\[Theta]", "\[LongEqual]", 
         FractionBox[
          StyleBox["y", "TI"], 
          StyleBox["x", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\tan \\theta=\\frac{y}{x}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9354fdc8-da0d-45b3-9279-509279373751"],
 "\nDerivando la primera ecuaci\[OAcute]n con la regla de cadena y dividiendo \
de ambos lados entre dos, obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         StyleBox["x", "TI"], 
         OverscriptBox[
          StyleBox["x", "TI"], "."], "+", 
         StyleBox["y", "TI"], 
         OverscriptBox[
          StyleBox["y", "TI"], "."]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r\\dot{r}=x\\dot{x}+y\\dot{y}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "14f7107c-a2e4-4f96-b12d-dd7410129799"],
 "\nSustituimos las ecuaciones diferenciales y obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         StyleBox["x", "TI"], 
         RowBox[{"[", 
           RowBox[{
             StyleBox["x", "TI"], 
             RowBox[{"(", 
               RowBox[{
                 SuperscriptBox[
                  StyleBox["x", "TI"], "2"], "+", 
                 SuperscriptBox[
                  StyleBox["y", "TI"], "2"], "-", "2", 
                 StyleBox["x", "TI"], "-", "3"}], ")"}], "-", 
             StyleBox["y", "TI"]}], "]"}], "+", 
         StyleBox["y", "TI"], 
         RowBox[{"[", 
           RowBox[{
             StyleBox["y", "TI"], 
             RowBox[{"(", 
               RowBox[{
                 SuperscriptBox[
                  StyleBox["x", "TI"], "2"], "+", 
                 SuperscriptBox[
                  StyleBox["y", "TI"], "2"], "-", "2", 
                 StyleBox["x", "TI"], "-", "3"}], ")"}], "+", 
             StyleBox["x", "TI"]}], "]"}]}], TraditionalForm], "errors" -> {},
      "input" -> "r\\dot{r}=x[x(x^2+y^2-2x-3)-y]+y[y(x^2+y^2-2x-3)+x]", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6d7729c2-d2ba-4098-b9d5-b137d3fb4e89"],
 "\nSeguimos simplificando usando las identidades de las coordenadas polares\n\
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["y", "TI"], "2"]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["y", "TI"], "2"], "-", "2", 
             StyleBox["x", "TI"], "-", "3"}], ")"}], "-", 
         StyleBox["x", "TI"], 
         StyleBox["y", "TI"], "+", 
         StyleBox["x", "TI"], 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r\\dot{r}=(x^2+y^2)(x^2+y^2-2x-3)-xy+xy", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9bf4080f-d165-4651-9745-e8ea29cdc2ba"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["r", "TI"], "2"], "-", "2", 
             StyleBox["r", "TI"], "cos", "\[Theta]", "-", "3"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "r\\dot{r}=r^2(r^2-2r\\cos\\theta-3)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "490820e1-5bba-4e7f-b472-6fb99ebeb80f"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["r", "TI"], "2"], "-", "2", 
             StyleBox["r", "TI"], "cos", "\[Theta]", "-", "3"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{r}=r(r^2-2r\\cos\\theta-3)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c7787455-9b25-447c-9208-12173f28760d"],
 "\nEs la primera ecuaci\[OAcute]n diferencial en coordenadas polares. Ahora \
derivamos la segunda ecuaci\[OAcute]n y proseguimos de manera similar.\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["sec", "2"], "\[Theta]", 
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            OverscriptBox[
             StyleBox["y", "TI"], "."], 
            StyleBox["x", "TI"], "-", 
            OverscriptBox[
             StyleBox["x", "TI"], "."], 
            StyleBox["y", "TI"]}], 
          SuperscriptBox[
           StyleBox["x", "TI"], "2"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\sec^2\\theta\\dot{\\theta}=\\frac{\\dot{y}x-\\dot{x}y}{x^2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "41e95e9d-064a-44a3-a0c4-76fbe61f412a"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["sec", "2"], "\[Theta]", 
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["x", "TI"], 
            RowBox[{"[", 
              RowBox[{
                StyleBox["y", "TI"], 
                RowBox[{"(", 
                  RowBox[{
                    SuperscriptBox[
                    StyleBox["x", "TI"], "2"], "+", 
                    SuperscriptBox[
                    StyleBox["y", "TI"], "2"], "-", "2", 
                    StyleBox["x", "TI"], "-", "3"}], ")"}], "+", 
                StyleBox["x", "TI"]}], "]"}], "-", 
            StyleBox["y", "TI"], 
            RowBox[{"[", 
              RowBox[{
                StyleBox["x", "TI"], 
                RowBox[{"(", 
                  RowBox[{
                    SuperscriptBox[
                    StyleBox["x", "TI"], "2"], "+", 
                    SuperscriptBox[
                    StyleBox["y", "TI"], "2"], "-", "2", 
                    StyleBox["x", "TI"], "-", "3"}], ")"}], "-", 
                StyleBox["y", "TI"]}], "]"}]}], 
          SuperscriptBox[
           StyleBox["x", "TI"], "2"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\sec^2\\theta\\dot{\\theta}=\\frac{x[y(x^2+y^2-2x-3)+x]-y[x(x^2+y^2-2x-\
3)-y]}{x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b45a75e8-57cb-4f75-87a3-2da1ca8e36c6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["sec", "2"], "\[Theta]", 
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["x", "TI"], 
            StyleBox["y", "TI"], 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox[
                 StyleBox["x", "TI"], "2"], "+", 
                SuperscriptBox[
                 StyleBox["y", "TI"], "2"], "-", "2", 
                StyleBox["x", "TI"], "-", "3"}], ")"}], "+", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"], "-", 
            StyleBox["y", "TI"], 
            StyleBox["x", "TI"], 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox[
                 StyleBox["x", "TI"], "2"], "+", 
                SuperscriptBox[
                 StyleBox["y", "TI"], "2"], "-", "2", 
                StyleBox["x", "TI"], "-", "3"}], ")"}], "+", 
            SuperscriptBox[
             StyleBox["y", "TI"], "2"]}], 
          SuperscriptBox[
           StyleBox["x", "TI"], "2"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\sec^2\\theta\\dot{\\theta}=\\frac{xy(x^2+y^2-2x-3)+x^2-yx(x^2+y^2-2x-\
3)+y^2}{x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6d5c3e9c-c51d-4b65-b8ef-879972d5f135"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["sec", "2"], "\[Theta]", 
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["x", "TI"], "2"], "+", 
            SuperscriptBox[
             StyleBox["y", "TI"], "2"]}], 
          SuperscriptBox[
           StyleBox["x", "TI"], "2"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\sec^2\\theta\\dot{\\theta}=\\frac{x^2+y^2}{x^2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3666701d-126b-40f3-9d36-443dea39e0b4"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["sec", "2"], "\[Theta]", 
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], 
          RowBox[{
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], 
            SuperscriptBox["cos", "2"], "\[Theta]"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\sec^2\\theta\\dot{\\theta}=\\frac{r^2}{r^2\\cos^2\\theta}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6a60837e-5b35-4580-97f3-eb7ed1257d47"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["sec", "2"], "\[Theta]", 
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{
            SuperscriptBox["cos", "2"], "\[Theta]"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\sec^2\\theta\\dot{\\theta}=\\frac{1}{\\cos^2\\theta}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0ef8bc7d-cae8-4bfb-9591-5f28ac72a76d"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["sec", "2"], "\[Theta]", 
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", 
         SuperscriptBox["sec", "2"], "\[Theta]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\sec^2\\theta\\dot{\\theta}=\\sec^2\\theta",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2151fd9b-95c9-48f7-9f9c-b0aed80b8c09"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\dot{\\theta}=1", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "524f2124-827f-45b2-b951-3d6652a1e764"],
 "\nEl sistema en coordenadas polares es\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["r", "TI"], "2"], "-", "2", 
             StyleBox["r", "TI"], "cos", "\[Theta]", "-", "3"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{r}=r(r^2-2r\\cos\\theta-3)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9fb42871-8b74-4088-87eb-c5df8bdf507f"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\dot{\\theta}=1", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "063e0f14-2f51-4955-af23-d0e856f5086b"],
 "\nLa segunda ecuaci\[OAcute]n est\[AAcute] desacoplada, tiene soluci\
\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Theta]", 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["t", "TI"], "+", 
         StyleBox["C", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\theta(t)=t+C", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "51a40228-62d1-4846-bc15-6438381ed785"],
 ", lo que indica que las soluciones giran a velocidad angular constante en \
direcci\[OAcute]n contraria de las manecillas del reloj, independientemente \
de la posici\[OAcute]n radial. Recordemos que, si tenemos un c\[IAcute]rculo \
centrado en el origen, las soluciones salen de ese c\[IAcute]rculo si el \
radio crece, es decir si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], ">", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\dot{r}>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "01d41e12-b65e-4b08-9309-e8c03d727353"],
 ", y entra al c\[IAcute]rculo si el radio decrece, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\dot{r}<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "07cc137f-5ddc-44aa-b8f7-11e49481591e"],
 ". Por lo tanto, basta encontrar un c\[IAcute]rculo donde la derivada radial \
sea negativa, y un c\[IAcute]rculo donde la derivada radial sea positiva. \
Entonces, en uno de los c\[IAcute]rculos se debe cumplir que\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\dot{r}<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bd68df09-2e71-4f74-9e76-c1f3de072f8d"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["r", "TI"], "2"], "-", "2", 
             StyleBox["r", "TI"], "cos", "\[Theta]", "-", "3"}], ")"}], "<", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "r(r^2-2r\\cos\\theta-3)<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a9772ed3-abe1-412a-9e99-ff473fc7bfd6"],
 "\nRecordemos que el radio es la distancia de las soluciones al origen, por \
lo que no puede ser negativo. Por lo tanto, podemos dividir entre ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4707214a-ad1c-47ae-8248-41923210626c"],
 " (puesto que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "857ac8d0-a49c-4726-b044-a7517884a3e6"],
 " corresponde al origen, el cual no pertence a ninguno de los \
c\[IAcute]rculos conc\[EAcute]ntricos) y obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "-", "2", 
         StyleBox["r", "TI"], "cos", "\[Theta]", "-", "3", "<", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "r^2-2r\\cos\\theta-3<0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e147f7ba-4307-4715-8390-51216db5031f"],
 "\nRecordamos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cos", "\[Theta]", "\[Element]", 
         RowBox[{"[", 
           RowBox[{"-1", ",", "1"}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\cos\\theta\\in[-1,1]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9b7f50f2-b049-4fe1-ab13-de3116b1a7a3"],
 ", por lo que, a lo m\[AAcute]s, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cos", "\[Theta]", "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\cos\\theta=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "67aab1c4-144c-4c0e-aa8e-205fbf8ce348"],
 ". Esto nos permite obtener la siguiente desigualdad\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "-", "2", 
         StyleBox["r", "TI"], "cos", "\[Theta]", "-", "3", "\[LessEqual]", 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "-", "2", 
         StyleBox["r", "TI"], "-", "3", "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r^2-2r\\cos\\theta-3\\leq r^2-2r-3<0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "28b14fcd-7561-47ff-bac1-5774a84d89fa"],
 "\nVemos que esta expresi\[OAcute]n es exactamente cero en las \
ra\[IAcute]ces del polinomio\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", "\[PlusMinus]", 
            SqrtBox[
             RowBox[{"4", "+", "12"}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=\\frac{2\\pm\\sqrt{4+12}}{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "490a31fb-d32a-43cf-b292-0f5fc669f47b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", "\[PlusMinus]", 
            SqrtBox["16"]}], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r=\\frac{2\\pm\\sqrt{16}}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "86f35836-84f6-4cf7-8cbc-35b0fdb986a4"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", "\[PlusMinus]", "4"}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=\\frac{2\\pm4}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "416608c7-6b4e-4c40-ad11-4e8b36a47355"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], "1"], "\[LongEqual]", "3"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r_1=3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f51d0dfb-9bf9-4038-a78f-f8bc10126698"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], "2"], "\[LongEqual]", "-1"}], TraditionalForm],
      "errors" -> {}, "input" -> "r_2=-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5e1e7323-a019-4960-bd30-fdf83426cda1"],
 "\nComo ya se mencion\[OAcute], el radio s\[OAcute]lo puede ser positivo, \
por lo tanto, el radio m\[AAcute]ximo donde la derivada radial es negativa es \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "3"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b2b9fcbe-41da-464f-b51e-92abfb1d5daa"],
 ". El l\[IAcute]mite exterior de la regi\[OAcute]n atrapante es un \
c\[IAcute]rculo de radio tres.\nAhora procedemos de manera similar con el \
segundo radio, donde necesitamos que la derivada sea positiva, por lo que\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], ">", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\dot{r}>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "53663f76-8477-47de-8e49-c3243fc2e943"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["r", "TI"], "2"], "-", "2", 
             StyleBox["r", "TI"], "cos", "\[Theta]", "-", "3"}], ")"}], ">", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "r(r^2-2r\\cos\\theta-3)>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bcb0fe16-71fd-44bf-94ce-f626c0b4c672"],
 "\nDe igual manera, el coseno en la expresi\[OAcute]n vale como \
m\[IAcute]nimo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cos", "\[Theta]", "\[LongEqual]", "-1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\cos\\theta=-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8385e7bd-aa29-4f5d-88ee-0a85f8b16f24"],
 ", por lo que podemos acotar de la siguiente manera\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "-", "2", 
         StyleBox["r", "TI"], "cos", "\[Theta]", "-", "3", "\[GreaterEqual]", 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "+", "2", 
         StyleBox["r", "TI"], "-", "3", ">", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r^2-2r\\cos\\theta-3\\geq r^2+2r-3>0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "99016ae5-029d-4ca2-8c69-2d32bd972d8f"],
 "\nEsta cota inferior es igual a cero en las ra\[IAcute]ces del polinomio, \
dadas por\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-2", "\[PlusMinus]", 
            SqrtBox[
             RowBox[{"4", "+", "12"}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=\\frac{-2\\pm\\sqrt{4+12}}{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0c8d4fdf-614c-405c-a01e-365061ffb23b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-2", "\[PlusMinus]", "4"}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=\\frac{-2\\pm4}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "336b390f-99cb-445b-8c87-af166754c99d"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], "1"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r_1=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fa285570-20ca-4355-bec0-18081355d08c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], "2"], "\[LongEqual]", "-3"}], TraditionalForm],
      "errors" -> {}, "input" -> "r_2=-3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3ea66058-3d8c-4656-a035-3ee47c5113dc"],
 "\nEl radio positivo es el \[UAcute]nico que tiene sentido, por lo que el \
radio interior debe ser al menos de uno. Por lo tanto, la regi\[OAcute]n \
anular atrapante donde est\[AAcute] contenido el ciclo l\[IAcute]mite es el \
anillo con radio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "<", 
         StyleBox["r", "TI"], "<", "3"}], TraditionalForm], "errors" -> {}, 
     "input" -> "1<r<3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9c243062-cb6b-45d9-9f98-890ffecc0a18"],
 "."
}], "Text",
