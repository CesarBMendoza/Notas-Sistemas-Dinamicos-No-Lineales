Cell[CellGroupData[{

Cell["\<\
Comprueba el resultado del inciso anterior graficando el retrato fase y la \
regi\[OAcute]n que encontraste. Bas\[AAcute]ndote en la informaci\[OAcute]n \
visual del retrato fase, \[DownQuestion]el ciclo l\[IAcute]mite es estable o \
inestable?\
\>", "Item",
 CellChangeTimes->{{3.907170527143569*^9, 
  3.9071705707247467`*^9}},ExpressionUUID->"b954ec30-00f2-4a4f-b6ac-\
59e1d83b8e43"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], "^", "2"}], "+", 
            RowBox[{
             RowBox[{"y", "[", "t", "]"}], "^", "2"}], "-", 
            RowBox[{"2", "*", 
             RowBox[{"x", "[", "t", "]"}]}], "-", "3"}], ")"}]}], "-", 
         RowBox[{"y", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], "^", "2"}], "+", 
            RowBox[{
             RowBox[{"y", "[", "t", "]"}], "^", "2"}], "-", 
            RowBox[{"2", "*", 
             RowBox[{"x", "[", "t", "]"}]}], "-", "3"}], ")"}]}], "+", 
         RowBox[{"x", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1000", "]"}], "==", "2"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1000", "]"}], "==", "0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.907170593965931*^9, 3.907170688602104*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"c49f3321-981a-40c0-967b-76763c997ec1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"StreamPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "+", 
            RowBox[{"y", "^", "2"}], "-", 
            RowBox[{"2", "*", "x"}], "-", "3"}], ")"}]}], "-", "y"}], ",", 
        RowBox[{
         RowBox[{"y", "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "+", 
            RowBox[{"y", "^", "2"}], "-", 
            RowBox[{"2", "*", "x"}], "-", "3"}], ")"}]}], "+", "x"}]}], "}"}],
       ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", 
        RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "]"}], ",", 
    RowBox[{"RegionPlot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"y", "^", "2"}]}], "<", "9"}], ")"}], "&&", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"y", "^", "2"}]}], ">", "1"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", 
        RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "]"}], ",", 
    RowBox[{"ParametricPlot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], ",", 
          RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "sol1"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Thick"}], "}"}]}]}], "]"}]}], "}"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.907167380407382*^9, 3.9071674562180843`*^9}, {
  3.907170698069318*^9, 3.9071707336869183`*^9}},
