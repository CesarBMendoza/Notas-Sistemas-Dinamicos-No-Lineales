       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[Element]", 
         RowBox[{"(", 
           RowBox[{"-", "\[Infinity]", ",", 
             StyleBox["b", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "x_0\\in(-\\infty,b)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "65ca765d-7803-4641-a51b-9bc1f4e0ec8c"],
