Cell[CellGroupData[{

Cell["Pregunta 2", "Section",
 CellChangeTimes->{{3.8852288982243443`*^9, 
  3.8852289002354803`*^9}},ExpressionUUID->"62ab9f21-ae73-4b27-9e9d-\
869dec8a0b49"],

Cell[TextData[{
 "Usando s\[OAcute]lo las gr\[AAcute]ficas de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["e", "TI"], 
        StyleBox["x", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "e^x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6c308d5d-8858-4989-a922-9ac282bbf9f5"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cos", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\cos x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5a57bd7c-0588-4dbd-9250-ed1715c0bc3e"],
 " estima el valor de los primeros cuatro puntos de equilibrio del sistema ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          StyleBox["x", "TI"]], "-", "cos", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=e^x-\\cos x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "18425523-ef32-4649-aaa6-452482cbf947"],
 " m\[AAcute]s cercanos a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
