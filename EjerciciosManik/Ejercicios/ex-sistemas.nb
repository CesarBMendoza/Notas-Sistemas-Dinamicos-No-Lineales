         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "c-x_0<b-x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1aeb88ed-9a41-46a3-9dda-ea271ba0a35f"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], "<", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "c<b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "012f42bf-be93-4fa0-afd0-e2389e5ba5ba"],
 " lo cual es una contradicci\[OAcute]n, por lo tanto debemos pedir que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "-", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], ">", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "b-x_0>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0e5e8728-8611-40fb-9fe2-18f80c6700ad"],
 " y tenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], "-", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], ">", 
         StyleBox["b", "TI"], "-", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "c-x_0>b-x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8445fc35-5bba-45d1-b4bd-0b900b88fa02"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], ">", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "c>b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ec6743ac-7de0-466c-8a16-e7aad3ca0847"],
 "\nPor lo tanto vemos que necesariamente, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6f803e1a-d59a-4ea2-a68d-d4c6f14c0a1f"],
 " requerimos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "-", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], ">", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "b-x_0>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8b48ae6f-0569-4411-9428-db91e0bec557"],
 " o en otras palabras que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "<", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0<b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aa40506f-0c46-4ba2-8751-88e2a07a6447"],
 " lo cual, por los requerimientos anteriormente vistos, s\[OAcute]lo se \
puede cumplir cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "<", 
         StyleBox["b", "TI"], "<", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0<b<c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c680140e-ad47-4a80-a37a-32ff2bf93876"],
 ", es decir, cuando la condici\[OAcute]n inicial est\[AAcute] por debajo de \
ambas soluciones de equilibrio."
}], "Text",
