Cell[CellGroupData[{
Cell["Examen parcial I", "Title",
 CellChangeTimes->{{3.8852285816931286`*^9, 
  3.8852285847018967`*^9}},ExpressionUUID->"3e2a2a13-5a6d-45e6-afa4-\
5f103ab9c644"],

Cell[CellGroupData[{

Cell["Pregunta 1", "Section",
 CellChangeTimes->{{3.8852286014616814`*^9, 
  3.885228604609432*^9}},ExpressionUUID->"8d26d66d-0285-4a74-91a5-\
02459b83be94"],

Cell[TextData[{
 "Grafica el espacio fase del sistema ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", "-", "sinh", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=-\\sinh x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "012088f3-f841-4b54-9070-498fc4064e7f"],
 " y us\[AAcute]ndolo encuentra todas sus soluciones de equilibrio y \
determina su estabilidad.\n\nSoluci\[OAcute]n:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "372eea0c-5537-4a93-893b-f47823a3841e"],
 " es la \[UAcute]nica soluci\[OAcute]n de equilibrio y es estable."
}], "Text",
 CellChangeTimes->{{3.885228620793933*^9, 3.8852286949957743`*^9}, {
  3.885228847512536*^9, 
  3.885228876187644*^9}},ExpressionUUID->"34130988-2c91-4eb3-8565-\
25683dd3d2f0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"p1", "=", 
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"Sinh", "[", "x", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
      RowBox[{"Frame", "->", 
       RowBox[{"{", 
        RowBox[{"True", ",", "True", ",", "False", ",", "False"}], "}"}]}], 
      ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], ",", 
         RowBox[{"OverDot", "[", "x", "]"}]}], "}"}]}], ",", 
      RowBox[{"Epilog", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"PointSize", "[", "Medium", "]"}], ",", 
         RowBox[{"Point", "[", 
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}], "}"}], "]"}]}], "}"}]}]}], "]"}], 
    ",", 
    RowBox[{"NumberLinePlot", "[", 
     RowBox[{
      RowBox[{"Interval", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "6"}], ",", "Infinity"}], "}"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "6"}], ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
      RowBox[{"Spacings", "\[Rule]", "0"}]}], "]"}], ",", 
    RowBox[{"NumberLinePlot", "[", 
     RowBox[{
      RowBox[{"Interval", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "Infinity"}], ",", "6"}], "}"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "1", ",", "6"}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
      RowBox[{"Spacings", "\[Rule]", "0"}]}], "]"}]}], "]"}]}]], "Input",
