   3.885235049633313*^9, 3.885235051187806*^9}, {3.8852351388616204`*^9, 
   3.885235169949494*^9}, {3.885235216919444*^9, 3.8852352185693035`*^9}, {
   3.885235256764917*^9, 3.885235258113076*^9}, {3.885235290776867*^9, 
