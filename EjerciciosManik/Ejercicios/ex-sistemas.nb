Cell[TextData[{
 "El sistema din\[AAcute]mico ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["r", "TI"], 
            StyleBox["x", "TI"]}], 
          RowBox[{
            StyleBox["x", "TI"], "+", 
            StyleBox["A", "TI"]}]], "-", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=\\frac{rx}{x+A}-x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e71fee8c-cac0-42ca-9bf3-16071e20d49e"],
 ", con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c3df06f9-dbd9-48f0-b99f-5b9587099459"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> "A", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b54d6e42-1118-4e60-945f-1eca190d49b2"],
 " dos constantes positivas es com\[UAcute]nmente usado para modelar \
poblaciones de instectos. Recordando que las densidades de poblaci\[OAcute]n \
s\[OAcute]lo pueden ser cantidades no negativas, explica qu\[EAcute] \
tendencia poblacional predice el modelo en el l\[IAcute]mite ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "t\\rightarrow\\infty", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4a97acee-805b-46e2-918c-965b6894d2cc"],
 ", con respecto a los valores de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "95dbf1cb-3610-411a-b390-5ba80ec948e5"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> "A", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf6c4a52-6b14-4189-b6ac-399de5bf756f"],
 ", de acuerdo al an\[AAcute]lisis de estabilidad lineal.\n\n\
Soluci\[OAcute]n:\nEn este caso, tenemos que el lado derecho de la igualdad \
es la funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["r", "TI"], 
            StyleBox["x", "TI"]}], 
          RowBox[{
            StyleBox["x", "TI"], "+", 
            StyleBox["A", "TI"]}]], "-", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "f(x)=\\frac{rx}{x+A}-x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "225861ca-ee81-49bc-919c-0d5af0485748"],
 ". Primero necesitamos encontrar las soluciones de equilibrio, las cuales \
obedecen la relaci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"0", "\[LongEqual]", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "0=f\\left(x^{\\star}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f77a5a1c-1dab-433a-84ea-d39b1c34dde1"],
 ":"
}], "Text",
 CellChangeTimes->{{3.885231235697691*^9, 3.885231250224413*^9}, {
  3.885231288235256*^9, 
  3.8852314932240176`*^9}},ExpressionUUID->"542b41ec-57de-43ff-b960-\
1b18e819d59a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"r", "*", 
      RowBox[{"x", "/", 
       RowBox[{"(", 
        RowBox[{"x", "+", "A"}], ")"}]}]}], "-", "x"}], "==", "0"}], ",", 
   "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.885231495246467*^9, 3.885231509428483*^9}},
 CellLabel->"In[23]:=",ExpressionUUID->"79553e71-1bfb-4bb5-b626-c3f0f1782fc3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", 
     RowBox[{
      RowBox[{"-", "A"}], "+", "r"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.8852315098837233`*^9},
 CellLabel->"Out[23]=",ExpressionUUID->"8d489082-67dc-4a00-8a83-100f6b37b477"]
}, Open  ]],

Cell[TextData[{
 "Vemos que tiene dos soluciones de equilibrio, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b7c7996b-fb2e-425e-aad4-b264c36cf2e1"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=r-A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3dbbde5b-9e61-459b-8b40-b1ba17bb786d"],
 ". Para determinar su estabilidad, necesitamos evaluar la derivada de la \
funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d3c1ee49-562b-4862-9c4f-3cb2c968e20c"],
 " en cada punto de equilibrio. Encontramos que, para cada uno:"
}], "Text",
 CellChangeTimes->{{3.8852315221414843`*^9, 3.885231548770686*^9}, {
  3.885231598094714*^9, 
  3.8852316341913767`*^9}},ExpressionUUID->"1100f1e5-9699-430c-bebe-\
a5d12af1266c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"r", "*", 
      RowBox[{"x", "/", 
       RowBox[{"(", 
        RowBox[{"x", "+", "A"}], ")"}]}]}], "-", "x"}], ",", "x"}], "]"}], "/.", 
  RowBox[{"{", 
   RowBox[{"x", "->", "0"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.885231637920123*^9, 3.8852316474811735`*^9}, {
  3.885231695133951*^9, 3.8852316998292994`*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"3e4d41a8-649a-449e-9b07-9d8ac371d37f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "1"}], "+", 
  FractionBox["r", "A"]}]], "Output",
 CellChangeTimes->{3.885231700463885*^9},
 CellLabel->"Out[24]=",ExpressionUUID->"699ebce3-c38c-4626-bd8f-3ef010d2683b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"r", "*", 
      RowBox[{"x", "/", 
       RowBox[{"(", 
        RowBox[{"x", "+", "A"}], ")"}]}]}], "-", "x"}], ",", "x"}], "]"}], "/.", 
  RowBox[{"{", 
   RowBox[{"x", "->", 
    RowBox[{"r", "-", "A"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.885231714061285*^9, 3.8852317152418833`*^9}},
