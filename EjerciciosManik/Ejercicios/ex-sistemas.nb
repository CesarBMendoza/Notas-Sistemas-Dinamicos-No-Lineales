 CellLabel->"Out[25]=",ExpressionUUID->"16370d0a-82c4-45ee-9ccb-3bcc987884ff"]
}, Open  ]],

Cell[TextData[{
 "Para que la soluci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d298ec59-cbbe-4b06-a0dd-c77c4004871e"],
 " sea estable, necesitamos entonces que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-1", "+", 
         FractionBox[
          StyleBox["r", "TI"], 
          StyleBox["A", "TI"]], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "-1+\\frac{r}{A}<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d70c2716-ac4e-4995-8b25-ad9c8a7d5752"],
 ", o despejando, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r<A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d2ce2247-89b8-4ec9-93ed-aa8a47d379cc"],
 ". Por otro lado, para que la soluci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=r-A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c0ab7173-0a16-4a46-98de-3ed39aebd18f"],
 " sea estable, necesitamos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         FractionBox[
          RowBox[{"-", 
            StyleBox["A", "TI"], "+", 
            StyleBox["r", "TI"]}], 
          StyleBox["r", "TI"]], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "-\\frac{-A+r}{r}<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "64664f76-651b-4f61-84fb-f5bfea269b46"],
 ", o puesto de otra forma, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["A", "TI"], "<", 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "A<r", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "215a281c-febb-4a01-a347-c8eb89742549"],
 ", tomando en cuenta que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "29c24deb-dd86-48dc-88c0-4d4c915f2000"],
 ". Sus condiciones de equilibrio son contrarias, por lo que, cuando una es \
estable, la otra es inestable y viceversa. Como no hay otra soluci\[OAcute]n \
de equilibrio, en el l\[IAcute]mite cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "t\\rightarrow\\infty", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7394fc4c-156f-4fc8-855e-3fd83b72cc1f"],
 " s\[OAcute]lo pueden pasar 2 cosas (tomando en cuenta que s\[OAcute]lo \
tiene sentido que las condiciones iniciales ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[GreaterEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(0)=x_0\\geq0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a5ad37f0-6b79-4fec-8841-441591bc75aa"],
 ")."
}], "Text",
 CellChangeTimes->{{3.885231735316634*^9, 3.8852318582235003`*^9}, {
  3.8852319331468444`*^9, 
  3.8852320562236934`*^9}},ExpressionUUID->"8a4598bb-87a3-4c02-9a3b-\
3c01a454db65"],

Cell[TextData[{
 "La poblaci\[OAcute]n tiende a cero cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> "t", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e83768f8-6b0a-4fcf-beb2-ae8a5642ca9a"],
 " tiende a infinito si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r<A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cc5935d7-91cf-4858-958d-d38a8849a9bb"],
 ", puesto que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "179e654c-83be-46b2-b7f3-4864a61db9d7"],
 " es estable y el segundo punto de equilibrio, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["x", "TI"], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
          StyleBox["r", "TI"], "-", 
          StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
      "x(t)=r-A", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], "<", "0"}], TraditionalForm]],ExpressionUUID->
  "8301fe86-2971-4827-9900-853712ff52dc"],
 "."
}], "Item",
 CellChangeTimes->{{3.8852320720804048`*^9, 
  3.8852321794105186`*^9}},ExpressionUUID->"ee208bbf-723f-473c-af28-\
50a71f0b4e65"],

Cell[TextData[{
 "La poblaci\[OAcute]n tiende a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "-", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r-A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "98535785-f1a9-496b-8d9a-166f3189d8b8"],
 " cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> "t", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2790019d-3252-42c6-b30a-066393851c97"],
 " tiende a infinito si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r>A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "61486a23-cdce-4c97-86bb-a16fc99902e5"],
 ", puesto que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=r-A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "236c3d0b-ec92-4035-be0a-ac8f74593917"],
 " es estable y positiva."
