Cell[TextData[{
 "Comportamiento y explosi\[OAcute]n:\nSi ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "a=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ec43fdcf-f11e-42a6-a2ee-7aa28530bdda"],
 " entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{
            StyleBox["a", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                StyleBox["c", "TI"]}], ")"}], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["e", "TI"], "0"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "e^{a(b-c)t}=e^0=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "40f8fcbc-848b-406a-b0be-9a8f58097d8c"],
 " por lo que:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["b", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["c", "TI"], "-", 
                SubscriptBox[
                 StyleBox["x", "TI"], "0"]}], ")"}], "-", 
            StyleBox["c", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                SubscriptBox[
                 StyleBox["x", "TI"], "0"]}], ")"}]}], 
          RowBox[{
            StyleBox["c", "TI"], "-", 
            SubscriptBox[
             StyleBox["x", "TI"], "0"], "-", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                SubscriptBox[
                 StyleBox["x", "TI"], "0"]}], ")"}]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "x(t)=\\frac{b\\left(c-x_0\\right)-c\\left(b-x_0\\right)}{c-x_0-\\left(b-\
x_0\\right)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fdade571-de2b-4322-a736-9b54ba68e0d6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["b", "TI"], 
            StyleBox["c", "TI"], "-", 
            StyleBox["b", "TI"], 
            SubscriptBox[
             StyleBox["x", "TI"], "0"], "-", 
            StyleBox["c", "TI"], 
            StyleBox["b", "TI"], "+", 
            StyleBox["c", "TI"], 
            SubscriptBox[
             StyleBox["x", "TI"], "0"]}], 
          RowBox[{
            StyleBox["c", "TI"], "-", 
            SubscriptBox[
             StyleBox["x", "TI"], "0"], "-", 
            StyleBox["b", "TI"], "+", 
            SubscriptBox[
             StyleBox["x", "TI"], "0"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "x(t)=\\frac{bc-bx_0-cb+cx_0}{c-x_0-b+x_0}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c6d6746a-4412-4924-969e-dbceae9f37b5"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["c", "TI"], 
            SubscriptBox[
             StyleBox["x", "TI"], "0"], "-", 
            StyleBox["b", "TI"], 
            SubscriptBox[
             StyleBox["x", "TI"], "0"]}], 
          RowBox[{
            StyleBox["c", "TI"], "-", 
            StyleBox["b", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)=\\frac{cx_0-bx_0}{c-b}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1c2e077d-bbc4-4ed5-9d4e-f064fe3a6186"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["x", "TI"], "0"], "(", 
            RowBox[{
              StyleBox["c", "TI"], "-", 
              StyleBox["b", "TI"]}], ")"}], 
          RowBox[{
            StyleBox["c", "TI"], "-", 
            StyleBox["b", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)=\\frac{x_0(c-b)}{c-b}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "96ad5af0-7bea-49e5-b43c-8850b7a23b33"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[ForAll]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=x_0\\forall t", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a2298fe2-2c9e-4a7d-a1ca-600107a6d003"],
 "\nToda condici\[OAcute]n inicial resulta en una soluci\[OAcute]n de \
equilibrio.\nSi ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0=b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9aecc14a-6de3-420f-9ffa-04d76ba98d8c"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "-", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "b-x_0=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "896d40a8-c15c-4447-bb5b-26d659d30dc3"],
 " y tenemos:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["b", "TI"], "(", 
            RowBox[{
              StyleBox["c", "TI"], "-", 
              SubscriptBox[
               StyleBox["x", "TI"], "0"]}], ")"}], 
          RowBox[{
            StyleBox["c", "TI"], "-", 
            SubscriptBox[
             StyleBox["x", "TI"], "0"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "x(t)=\\frac{b\\left(c-x_0\\right)}{c-x_0}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5a2b7a12-881f-430f-8d2f-31fb3823b763"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "144a78a8-dca3-4453-9628-cd06de439ea1"],
 " es una soluci\[OAcute]n de equilibrio para toda ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["a", "TI"], TraditionalForm], "errors" -> {}, "input" -> "a", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "57d4009e-ace1-4be7-979f-2c6c811d710a"],
 ".\nSi ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0=c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a4d7e138-a403-4b63-b6b6-309d8d742ab4"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], "-", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "c-x_0=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d6f7fb1e-4e8f-4fee-9a86-a97827d396f5"],
 " y tenemos:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-", 
            StyleBox["c", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                StyleBox["c", "TI"]}], ")"}], 
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{
               StyleBox["a", "TI"], 
               RowBox[{"(", 
                 RowBox[{
                   StyleBox["b", "TI"], "-", 
                   StyleBox["c", "TI"]}], ")"}], 
               StyleBox["t", "TI"]}]]}], 
          RowBox[{"-", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                StyleBox["c", "TI"]}], ")"}], 
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{
               StyleBox["a", "TI"], 
               RowBox[{"(", 
                 RowBox[{
                   StyleBox["b", "TI"], "-", 
                   StyleBox["c", "TI"]}], ")"}], 
               StyleBox["t", "TI"]}]]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)=\\frac{-c(b-c)e^{a(b-c)t}}{-(b-c)e^{a(b-c)t}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "47481f51-b3f2-40bc-9bfe-46e356c2d852"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3d2b7f9f-1376-4fda-b727-28d82d1735cf"],
 " es una soluci\[OAcute]n de equilibrio para toda ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["a", "TI"], TraditionalForm], "errors" -> {}, "input" -> "a", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4ac803f0-a678-4e66-b0bf-0e073d4cd978"],
 ".\nSi ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "\[NotEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "a\\neq0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "476d2f32-f530-4ea7-9773-56a4f5f4f3cf"],
 " hay que recordar que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "<", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "b<c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "62fe3aed-68b5-4e99-916b-6c3c2a07be31"],
 " por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "-", 
         StyleBox["c", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "b-c<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e829c15f-9fb2-4372-a482-93a90430cad5"],
 ".\nSi ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b61b965a-8790-4440-879d-c88282868437"],
 " entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["b", "TI"], "-", 
             StyleBox["c", "TI"]}], ")"}], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "a(b-c)<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "15e543b6-158c-44be-95ed-14d4cecdf627"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{
          StyleBox["a", "TI"], 
          RowBox[{"(", 
            RowBox[{
              StyleBox["b", "TI"], "-", 
              StyleBox["c", "TI"]}], ")"}], 
          StyleBox["t", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "e^{a(b-c)t}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b241e743-fca9-4b3e-b027-8791df040c62"],
 " es una exponencial decreciente por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], 
          LimitsPositioning -> True], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{
            StyleBox["a", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                StyleBox["c", "TI"]}], ")"}], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\lim_{t\\rightarrow\\infty}e^{a(b-c)t}=0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a0a86a3b-40da-4301-8971-156f7546dabb"],
 " y tenemos:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], 
          LimitsPositioning -> True], 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["b", "TI"], "(", 
            RowBox[{
              StyleBox["c", "TI"], "-", 
              SubscriptBox[
               StyleBox["x", "TI"], "0"]}], ")"}], 
          RowBox[{
            StyleBox["c", "TI"], "-", 
            SubscriptBox[
             StyleBox["x", "TI"], "0"]}]], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\lim_{t\\rightarrow\\infty}x(t)=\\frac{b\\left(c-x_0\\right)}{c-x_0}=\
b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "822946b4-5f39-462d-8133-2906fa66dd57"],
 "\nSin embargo, vemos que el denominador puede ser cero, con lo que la \
soluci\[OAcute]n diverge para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["t", "TI"], "\[LongEqual]", 
         StyleBox["T", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "t=T", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c8bcb4e-40e5-4aa5-8c95-252063ab490c"],
 ":\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], "-", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "-", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["b", "TI"], "-", 
             SubscriptBox[
              StyleBox["x", "TI"], "0"]}], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{
            StyleBox["a", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                StyleBox["c", "TI"]}], ")"}], 
            StyleBox["T", "TI"]}]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "c-x_0-\\left(b-x_0\\right)e^{a(b-c)T}=0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d4832f85-8a5b-463f-b8be-ceea6a2af41c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{
             StyleBox["b", "TI"], "-", 
             SubscriptBox[
              StyleBox["x", "TI"], "0"]}], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{
            StyleBox["a", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                StyleBox["c", "TI"]}], ")"}], 
            StyleBox["T", "TI"]}]], "\[LongEqual]", 
         StyleBox["c", "TI"], "-", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\left(b-x_0\\right)e^{a(b-c)T}=c-x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3a52b00b-43bc-4612-8852-f6f2c6f5f886"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{
            StyleBox["a", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", 
                StyleBox["c", "TI"]}], ")"}], 
            StyleBox["T", "TI"]}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["c", "TI"], "-", 
            SubscriptBox[
             StyleBox["x", "TI"], "0"]}], 
          RowBox[{
            StyleBox["b", "TI"], "-", 
            SubscriptBox[
             StyleBox["x", "TI"], "0"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "e^{a(b-c)T}=\\frac{c-x_0}{b-x_0}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "31a2d675-d694-4afc-bb83-c7c7e31a054a"],
 "\nEl lado izquierdo de la ecuaci\[OAcute]n siempre es positivo, pues la \
exponencial real siempre es positiva, por lo que esta expresi\[OAcute]n s\
\[OAcute]lo tiene sentido cuando el lado derecho tambi\[EAcute]n es positivo, \
es decir para que la soluci\[OAcute]n diverja, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], "<", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "c<x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b55a1507-0c2f-4c4d-ad6a-e0f89e702b10"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "<", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "b<x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cb1dc1b8-9308-4fba-b18a-862e4576c41a"],
 ", pero como por hip\[OAcute]tesis ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "<", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "b<c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9b669cb5-ab5c-42f4-9755-e1395d800313"],
 ", esto siempre se cumple si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], ">", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0>c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5bed79df-64cf-4095-9349-5b9a2e30c1ae"],
 ", o bien si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], ">", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "c>x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "35983978-f86a-45b3-b5fd-624bc4e722b0"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], ">", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "b>x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d53fae6e-8f54-4fca-b0dd-ed29c21ab630"],
 " pero como ",
 Cell[BoxData[
  FormBox[
