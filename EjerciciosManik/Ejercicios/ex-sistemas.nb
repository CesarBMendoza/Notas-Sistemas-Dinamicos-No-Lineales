Cell[CellGroupData[{

Cell["Pregunta 3", "Section",
 CellChangeTimes->{{3.8852300176407623`*^9, 
  3.8852300239530993`*^9}},ExpressionUUID->"943fe2af-19be-4403-b913-\
61928ac1addc"],

Cell[TextData[{
 "Explica porqu\[EAcute] el sistema din\[AAcute]mico ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         SqrtBox[
          RowBox[{"1", "-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "\\dot{x}=\\sqrt{1-x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "20c0839b-f38d-49cd-a67d-202ea901551c"],
 Cell[BoxData[
  FormBox[" ", TraditionalForm]],ExpressionUUID->
  "1c496c7f-baa7-49dd-a7fd-88398db0c3c8"],
 "con condiciones iniciales ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x(0)=2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "91b92d06-d27b-4c5e-981f-1d272799c2e0"],
 " no tiene soluci\[OAcute]n.\n\nSoluci\[OAcute]n:\nLa funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         SqrtBox[
          RowBox[{"1", "-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "f(x)=\\sqrt{1-x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "09a3fa20-4833-4f18-924d-712dcc943785"],
 " no toma valores reales en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "01c9af2c-cb32-41fe-8bcc-1f169412bfe9"],
 "."
}], "Text",
 CellChangeTimes->{{3.8852300406340656`*^9, 
  3.885230189140816*^9}},ExpressionUUID->"3b7579d6-f984-4a19-b5eb-\
ba7f742c114b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pregunta 4", "Section",
 CellChangeTimes->{{3.885230226766996*^9, 
  3.885230228196649*^9}},ExpressionUUID->"a7c397d2-b98f-4089-940b-\
90d0902c372f"],

Cell[TextData[{
 "Muestra que la funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7af50c01-a21d-421c-8a98-2a725c6266d2"],
 " definida como"
}], "Text",
 CellChangeTimes->{{3.885230254222067*^9, 
  3.8852302837545133`*^9}},ExpressionUUID->"96525e46-0074-4b75-8ac8-\
4f9a99733a5e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{
   RowBox[{"x", "[", "t", "]"}], "==", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{"0", "<", "t", "<", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"t", "-", "1"}], ")"}], "^", "3"}], ",", 
        RowBox[{"1", "<=", "t", "<", "2"}]}], "}"}]}], "}"}], "]"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.8852306256708326`*^9, 3.8852306793843594`*^9}, {
  3.885233519402484*^9, 3.885233521715313*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"d966a0d2-d3b4-4c34-ae30-fe2b46aba8b8"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"x", "(", "t", ")"}], "\[LongEqual]", 
   RowBox[{"(", 
    TagBox[GridBox[{
       {"\[Piecewise]", GridBox[{
          {"0", 
           RowBox[{"0", "<", "t", "<", "1"}]},
          {
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"t", "-", "1"}], ")"}], "3"], 
           RowBox[{"1", "\[LessEqual]", "t", "<", "2"}]}
         },
         AllowedDimensions->{2, Automatic},
         Editable->True,
         GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
         GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
         GridBoxSpacings->{"Columns" -> {
             Offset[0.27999999999999997`], {
              Offset[0.84]}, 
             Offset[0.27999999999999997`]}, "Rows" -> {
             Offset[0.2], {
              Offset[0.4]}, 
             Offset[0.2]}},
         Selectable->True]}
      },
