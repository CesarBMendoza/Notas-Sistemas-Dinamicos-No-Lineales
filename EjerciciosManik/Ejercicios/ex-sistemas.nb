Cell[TextData[{
 "Vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0713c082-b231-440b-b4c4-0d3fb4eaa745"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a2aa987a-bbd4-4dea-a9dc-f3d21c5a3dde"],
 " siempre son soluciones de equilibrio en todos los casos."
}], "Text",
 CellChangeTimes->{{3.885233431938002*^9, 3.885233456540575*^9}, {
  3.8852335857005973`*^9, 
  3.8852335976078367`*^9}},ExpressionUUID->"7e2be809-a372-4461-ad56-\
ccfcdc94e5f4"],

Cell[TextData[{
 "Si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ef967e89-bad4-45d2-bd76-ee77bbe3b4fa"],
 ", entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "79969cd7-9b50-418f-b0cc-7a9566955265"],
 " es estable y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x(t)=c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a2b0082f-a331-41b8-83de-5c2ddfd05f39"],
 " es inestable, por lo que en el l\[IAcute]mite cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "t\\rightarrow\\infty", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "00085c98-1a27-4809-a9ee-159a9af28d55"],
 ", las soluciones con condiciones iniciales ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[Element]", 
         RowBox[{"(", 
           RowBox[{"-", "\[Infinity]", ",", 
             StyleBox["c", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "x_0\\in(-\\infty,c)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "06bb1a2d-6628-4525-ab3d-6fd5ad1fd8cf"],
 " tienden a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["b", "TI"], TraditionalForm], "errors" -> {}, "input" -> "b", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "762e65af-169e-456a-a22b-2fcb3f32e112"],
 ", la soluci\[OAcute]n con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0=c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6fef315e-846d-4288-9d51-a8a6a20ba337"],
 " se mantiene constante, y las soluciones con condiciones iniciales en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[Element]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["c", "TI"], ",", "\[Infinity]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> "x_0\\in(c,\\infty)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d263de3f-446b-4551-b24a-e47c16fbdef9"],
 " tienden a infinito."
}], "Item",
