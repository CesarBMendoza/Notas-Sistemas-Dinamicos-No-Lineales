Cell[CellGroupData[{

Cell["Pregunta 6", "Section",
 CellChangeTimes->{{3.8852323580499578`*^9, 
  3.885232360074119*^9}},ExpressionUUID->"60076acb-f011-4e8a-8474-\
3db9427fe7ae"],

Cell[TextData[{
 "Considera el sistema ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["a", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], "-", 
             StyleBox["b", "TI"]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], "-", 
             StyleBox["c", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\dot{x}=a(x-b)(x-c)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ccdffd74-c978-4bc3-937d-9eed82d95752"],
 ", donde ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["a", "TI"], TraditionalForm], "errors" -> {}, "input" -> "a", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bed9a7b6-26b3-44fe-bac2-b6b29efd1a6c"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["b", "TI"], TraditionalForm], "errors" -> {}, "input" -> "b", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "079fa4f6-8d0c-4ad6-8aad-e3e33ee2976a"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["c", "TI"], TraditionalForm], "errors" -> {}, "input" -> "c", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7e6f9900-5901-45e2-8d15-30d4430516ec"],
 " son constantes tales que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "<", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "b<c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "caa7e302-91f2-4890-9b2e-565ab87bcb81"],
 ", con condiciones iniciales ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(0)=x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "523de98d-cd39-41f6-aa4f-d160347dfa10"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[Element]", 
         StyleBox["R", FontSlant -> "Plain"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_0\\in\\mathbb{R}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c5f6ebce-6869-4866-8031-75de0477f16b"],
 "."
}], "Text",
 CellChangeTimes->{{3.8852323872987967`*^9, 
  3.885232480951431*^9}},ExpressionUUID->"bf695b4b-e036-4465-9e31-\
542329115d9d"],

Cell[TextData[{
 "Grafica el campo de pendientes y el espacio fase. Para cada ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["x", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "75fb0854-a7c2-4fa6-9182-8e4acf2a8b52"],
 " posible, usa la informaci\[OAcute]n de estas dos gr\[AAcute]ficas para \
determinar el comportamiento de las soluciones cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["t", "TI"], "\[Rule]", "\[Infinity]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "t\\rightarrow\\infty", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "83cf2b38-0c8d-41de-94b5-1d3c6f913821"],
 ". Considera los casos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c9bdfb95-d208-49a2-9f7e-a7b60a6ba300"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "a=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "babc549f-a46b-4ccc-ad86-f8d146408319"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf6fe33a-44e7-42bb-a542-1d352be891fb"],
 "."
}], "ItemNumbered",
 CellChangeTimes->{{3.8852325684992824`*^9, 3.8852326695710864`*^9}, {
  3.8852327039410863`*^9, 
  3.8852327039450874`*^9}},ExpressionUUID->"ef7ca99a-bd36-43f4-9174-\
d274873690ac"],

Cell["\<\
Resuelve la ecuaci\[OAcute]n diferencial de forma exacta (tomando en cuenta \
las condiciones iniciales) usando fracciones parciales. Verifica que el \
comportamiento de estas expresiones concuerde con el que encontraste \
cualitativamente en el inciso anterior.\
\>", "ItemNumbered",
 CellChangeTimes->{{3.8852325684992824`*^9, 3.8852326695710864`*^9}, {
  3.885232710207076*^9, 
  3.8852327737921963`*^9}},ExpressionUUID->"bec23f85-cca7-46a6-bdb9-\
b81f0ddbeb16"],

Cell[TextData[{
 "Usando las soluciones exactas del inciso anterior, muestra que si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b2a0782d-41a7-4bf4-ae81-e70b33d359a5"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], ">", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0>c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d20c1186-8fe2-44fa-bdf1-f5b73aa727ef"],
 ", \[OAcute] si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e713e2ff-94b3-4d79-9598-7e37761ae94a"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "<", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_0<b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d0f81aba-d759-4cee-afe9-c150aef5d1f0"],
 ", las soluciones explotan en un tiempo positivo finito. Encuentra el \
intervalo m\[AAcute]ximo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"[", 
         RowBox[{"0", ",", 
           StyleBox["T", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "[0,T)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8a2b2148-036b-40e0-9023-7476ef398815"],
 " en el cual existe la soluci\[OAcute]n."
}], "ItemNumbered",
 CellChangeTimes->{{3.8852325684992824`*^9, 3.8852326695710864`*^9}, {
  3.885232710207076*^9, 
  3.885232907615512*^9}},ExpressionUUID->"9dc1198d-6bfc-4334-b8b7-\
f486e7914ff4"],

