Cell[CellGroupData[{

Cell["Ejercicio 1", "Section",
 CellChangeTimes->{{3.892051901367446*^9, 
  3.8920519048477287`*^9}},ExpressionUUID->"aace8e45-c2fe-45ad-a6e1-\
306440cc0e55"],

Cell[TextData[{
 "a) La ecuaci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "\:0308"], "\[LongEqual]", 
         StyleBox["a", "TI"], "-", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          StyleBox["x", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\ddot{x}=a-e^x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "50bddbac-43f4-49e5-becc-8b2794a63daa"],
 " puede escribirse como el sistema\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3d2d7249-3aad-4cb8-95fa-cd64496d75e2"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", 
         StyleBox["a", "TI"], "-", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          StyleBox["x", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=a-e^x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0085631c-c8db-4cdb-8053-2b5f06969a74"],
 "\nSus soluciones de equilibrio son ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "y=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b6cbd48e-0ac7-4041-a3c0-7330e188be4e"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "ln", 
         RowBox[{"(", 
           StyleBox["a", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x=\\ln(a)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6371520f-6966-4743-8e05-adcd305b90f3"],
 ", por lo que s\[OAcute]lo existe para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5963d4ec-5de2-4a40-9896-095dded6f886"],
 ".\nb) Calculamos los eigenvalores con la matriz Jacobiana:"
}], "Text",
 CellChangeTimes->{{3.892051913679802*^9, 3.892051954624318*^9}, {
  3.89205200510075*^9, 
  3.8920521176835227`*^9}},ExpressionUUID->"24cd1eeb-77e0-4adc-9e33-\
eb97cdf9be6d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"J1", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"y", ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{"y", ",", "y"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"a", "-", 
         RowBox[{"Exp", "[", "x", "]"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"a", "-", 
         RowBox[{"Exp", "[", "x", "]"}]}], ",", "y"}], "]"}]}], "}"}]}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.8920521467360477`*^9, 3.8920521985043774`*^9}, {
  3.892052321303055*^9, 3.8920523214890995`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"bb082a0d-f9ea-406b-b8a1-f59225c7581e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["\[ExponentialE]", "x"]}], ",", "0"}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.8920522021468105`*^9, 3.89205232188212*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"599d2a5a-c71f-4793-9d1a-d41d80147728"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"J1", "=", 
  RowBox[{"J1", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "->", 
      RowBox[{"Log", "[", "a", "]"}]}], ",", 
     RowBox[{"y", "->", "0"}]}], "}"}]}]}]], "Input",
 CellChangeTimes->{{3.8920522088737125`*^9, 3.8920522223437233`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"05643cb1-e300-406c-b011-b139edba6861"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "a"}], ",", "0"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.8920522241872296`*^9, 3.892052323968388*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"4053796b-00b9-41c0-a476-3f3ead9960bd"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"Eigenvalues", "[", "J1", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.8920522631517043`*^9, 3.8920522721419315`*^9}},
 NumberMarks->False,
 CellLabel->"In[8]:=",ExpressionUUID->"436c1217-f1ae-4203-9a08-e3517ce79f44"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", 
    SqrtBox["a"]}], ",", 
   RowBox[{"\[ImaginaryI]", " ", 
    SqrtBox["a"]}]}], "}"}]], "Output",
 CellChangeTimes->{3.892052238671632*^9, 3.892052272543182*^9, 
  3.8920523368596125`*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"5eae216f-92e4-42ef-b5a3-8bc78edc279b"]
}, Open  ]],

Cell[TextData[{
 "Los eigenvalores son puramente reales. Sin embargo, recordemos que si la \
parte real de los eigenvalores es cero, no podemos decir nada acerca del \
punto de equilibrio, a menos de que el sistema sea conservativo o reversible. \
En este caso, el sistema es conservativo y reversible dado que la ecuaci\
\[OAcute]n puede escribirse como el sistema mec\[AAcute]nico ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "\:0308"], "\[LongEqual]", 
         StyleBox["F", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\ddot{x}=F(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "914eacb4-8cfc-4a45-9e95-9d34f27ccdc4"],
 " (por lo que es conservativo), y porque el lado derecho de la primera \
igualdad es impar en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["y", "TI"], TraditionalForm], "errors" -> {}, "input" -> "y", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e9c77634-5dab-49bd-8014-feab71741036"],
 " y el lado derecho de la segunda igualdad es par en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["y", "TI"], TraditionalForm], "errors" -> {}, "input" -> "y", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "28f2d632-e579-4da9-b87b-874871030f6f"],
 ". Por lo tanto el punto de equilibrio es un centro verdadero del sistema no \
lineal.\nc) La gr\[AAcute]fica del espacio fase es:"
}], "Text",
 CellChangeTimes->{{3.892052343008464*^9, 3.8920524548856897`*^9}, {
  3.892052485050375*^9, 
  3.892052561761117*^9}},ExpressionUUID->"ce8587be-509b-4c7c-8dbd-\
e990e382ccaa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"StreamPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"a", "-", 
        RowBox[{"Exp", "[", "x", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
