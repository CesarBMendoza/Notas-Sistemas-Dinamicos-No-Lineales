Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"0.08", "*", 
         RowBox[{"x", "[", "t", "]"}]}], "+", 
        RowBox[{"y", "[", "t", "]"}], "-", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"x", "[", "t", "]"}]}], "+", 
        RowBox[{"0.08", "*", 
         RowBox[{"y", "[", "t", "]"}]}], "+", 
        RowBox[{"2", "*", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "0.001"}], ",", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "==", 
       RowBox[{"-", "0.001"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "100"}], "}"}]}], "]"}]}]], "Input",
