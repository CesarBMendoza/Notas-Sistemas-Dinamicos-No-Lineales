Cell[TextData[{
 "Cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "<", "1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\mu<1$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "60cb4f30-d7e0-4d7e-a6ec-88dc6684fce8"],
 ", la traza es negativa y el determinante es positivo, por lo que la soluci\
\[OAcute]n con signo negativo es el nodo estable, y la soluci\[OAcute]n con \
signo positivo debe ser el punto silla. Finalmente, si nos fijamos en la \
forma de los puntos de equlibrio, vemos que tienen las normas ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["z", "TI"], "-", "\[FivePointedStar]"], "\[LongEqual]", 
         SqrtBox["5"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             SqrtBox[
              RowBox[{"1", "-", "\[Mu]"}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "z_{-}^\\star=\\sqrt{5}(1-\\sqrt{1-\\mu})", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "51c6d465-b100-4894-836c-931803a4eaad"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["z", "TI"], "+", "\[FivePointedStar]"], "\[LongEqual]", 
         SqrtBox["5"], 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             SqrtBox[
              RowBox[{"1", "-", "\[Mu]"}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "z_{+}^\\star=\\sqrt{5}(1+\\sqrt{1-\\mu})", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "515900a3-434c-41c8-843c-f7b72c5eea8f"],
 ". Graficamos estos valores tomando en cuenta que el nodo estable se grafica \
con una l\[IAcute]nea continua y el punto silla (inestable) se grafica con \
una l\[IAcute]nea punteada:"
}], "Text",
 CellChangeTimes->{{3.8920546992618713`*^9, 3.8920547238881826`*^9}, {
  3.8920547739129763`*^9, 3.8920548289614797`*^9}, {3.892055015404248*^9, 
  3.892055067855998*^9}, {3.892055136541233*^9, 3.892055155289031*^9}, {
  3.892055188927915*^9, 3.892055241430462*^9}, {3.8920553351101036`*^9, 
  3.8920553388921022`*^9}},ExpressionUUID->"30e950e6-9680-4503-a611-\
1d2ae885ec4c"],

