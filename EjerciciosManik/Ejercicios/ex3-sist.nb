Cell[TextData[{
 "Comprobamos que cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "<", "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6e1f2b7d-ff8b-4338-afdd-aa4e108d31d5"],
 " es una espiral estable y cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", ">", "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2ffef94-d6c8-4cc9-94d1-52867bd50667"],
 " es una espiral inestable, atravesando el eje imaginario cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "960de732-0731-4ca6-80a5-4dc49a9d90d9"],
 "."
}], "Text",
 CellChangeTimes->{{3.8920602385000257`*^9, 
  3.8920602958999815`*^9}},ExpressionUUID->"89f155a9-9cb9-4b63-a4b5-\
691f20d9d0ba"],

Cell["\<\
c) El ciclo l\[IAcute]mite es la frontera entre la soluci\[OAcute]n que \
tiende al punto de equilibrio y la que se aleja del punto de equilibrio\
\>", "Text",
 CellChangeTimes->{{3.892060076853146*^9, 
  3.892060113521047*^9}},ExpressionUUID->"5a9044e7-3d58-4761-92ce-\
fdc5ed164bd3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"y", "[", "t", "]"}]}], "-", 
        RowBox[{"0.03", "*", 
         RowBox[{"x", "[", "t", "]"}]}], "+", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "*", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], "-", 
        RowBox[{"0.03", "*", 
         RowBox[{"y", "[", "t", "]"}]}], "-", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "500", "]"}], "==", "0.05"}], ",", 
      RowBox[{
       RowBox[{"y", "[", "500", "]"}], "==", "0.05"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "500"}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"sol2", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"y", "[", "t", "]"}]}], "-", 
        RowBox[{"0.03", "*", 
         RowBox[{"x", "[", "t", "]"}]}], "+", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "*", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], "-", 
        RowBox[{"0.03", "*", 
         RowBox[{"y", "[", "t", "]"}]}], "-", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "500", "]"}], "==", 
       RowBox[{"-", "0.5"}]}], ",", 
      RowBox[{
       RowBox[{"y", "[", "500", "]"}], "==", "0"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "500"}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"ParametricPlot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], ",", 
          RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "sol2"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "500"}], "}"}], ",", 
      RowBox[{"PlotPoints", "->", "100"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "Red"}]}], "]"}], ",", 
    RowBox[{"ParametricPlot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], ",", 
          RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "sol"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "500"}], "}"}], ",", 
      RowBox[{"PlotPoints", "->", "100"}]}], "]"}]}], "}"}], "]"}]}], "Input",
 CellChangeTimes->{{3.8920592833488684`*^9, 3.892059330150094*^9}, {
  3.892059366556594*^9, 3.8920595073306007`*^9}, {3.892059649877209*^9, 
  3.892059672936269*^9}, {3.892059724282572*^9, 3.892059801295562*^9}, {
