Cell[CellGroupData[{

Cell["Ejercicio 2", "Section",
 CellChangeTimes->{{3.892054154123642*^9, 
  3.8920541559857717`*^9}},ExpressionUUID->"03154aef-52f9-47fc-9acd-\
e9982ef140a2"],

Cell[TextData[{
 "Sistema:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"], "-", "2", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=y-2x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "04ecf646-786f-45fb-908f-3d7d7d3a38ef"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", "\[Mu]", "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "-", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=\\mu+x^2-y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "43423282-f92a-4cd3-8cf6-0601d466e633"],
 "\na) Gr\[AAcute]fica de ceroclinas"
}], "Text",
 CellChangeTimes->{{3.8920541663554554`*^9, 3.892054184870567*^9}, {
  3.8920542530326433`*^9, 
  3.8920542632610364`*^9}},ExpressionUUID->"c7b7aa26-a656-4594-9378-\
71c5fc83af31"],

Cell[CellGroupData[{

