Cell[TextData[{
 "Las ceroclinas son una par\[AAcute]bola y una recta que se intersectan. \
Pueden haber cero, una o dos intersecciones que corresponden a cero, uno o \
dos puntos de equilibrio mientras ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Mu]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a22e7bc0-0db2-42b1-96db-4477f8567b8c"],
 " var\[IAcute]a, por lo que ocurre una bifurcaci\[OAcute]n de nodo-silla.\n\
c) Primero encontramos los puntos de equilibrio"
}], "Text",
 CellChangeTimes->{{3.8920544045902257`*^9, 
  3.892054500187154*^9}},ExpressionUUID->"7219fc5a-eac3-42b0-b7e6-\
405446fc73fd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"0", "==", 
      RowBox[{"y", "-", 
       RowBox[{"2", "*", "x"}]}]}], ",", 
     RowBox[{"0", "==", 
      RowBox[{"\[Mu]", "+", 
       RowBox[{"x", "^", "2"}], "-", "y"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8920545316686926`*^9, 3.8920545336432853`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"471c495b-41e1-4d3c-b637-0d4dcaa8dc98"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", 
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", "\[Mu]"}]]}]}], ",", 
     RowBox[{"y", "\[Rule]", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SqrtBox[
          RowBox[{"1", "-", "\[Mu]"}]]}], ")"}]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", 
      RowBox[{"1", "+", 
       SqrtBox[
        RowBox[{"1", "-", "\[Mu]"}]]}]}], ",", 
     RowBox[{"y", "\[Rule]", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SqrtBox[
          RowBox[{"1", "-", "\[Mu]"}]]}], ")"}]}]}]}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.892054510756812*^9, 3.8920545344039593`*^9}},
 CellLabel->"Out[17]=",ExpressionUUID->"0045fc9f-e816-48bf-a2af-c38451d1ef0f"]
}, Open  ]],

Cell[TextData[{
 "Vemos que los puntos de equilibrio son iguales cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "43868e4b-4d9c-4bf2-be1d-8a1848a4517c"],
 ", y no existen cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", ">", "1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6428184e-e19b-454f-a12e-f9fdc75db2b5"],
 ", por lo que la bifurcaci\[OAcute]n ocurre en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f753f418-05af-4676-8df9-8202ca2ca5cb"],
 " en el punto ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"1", ",", "2"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "(1,2)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "378228e3-caff-4b45-b120-d715bd664e6c"],
 ". Calculamos la matriz Jacobiana y evaluamos en un punto de equilibrio:"
}], "Text",
 CellChangeTimes->{{3.892054517182152*^9, 
  3.8920546263235493`*^9}},ExpressionUUID->"731f4ab2-c31c-4d9e-bfe0-\
00778698c71b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"J2", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"y", "-", 
         RowBox[{"2", "*", "x"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"y", "-", 
         RowBox[{"2", "*", "x"}]}], ",", "y"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"m", "+", 
         RowBox[{"x", "^", "2"}], "-", "y"}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"m", "+", 
         RowBox[{"x", "^", "2"}], "-", "y"}], ",", "y"}], "]"}]}], "}"}]}], 
   "}"}]}]], "Input",
