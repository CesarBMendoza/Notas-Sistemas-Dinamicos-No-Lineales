Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sol1", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"0.036", "*", 
         RowBox[{"x", "[", "t", "]"}]}], "+", 
        RowBox[{"y", "[", "t", "]"}], "-", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"x", "[", "t", "]"}]}], "+", 
        RowBox[{"0.036", "*", 
         RowBox[{"y", "[", "t", "]"}]}], "+", 
        RowBox[{"2", "*", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "0.001"}], ",", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "==", 
       RowBox[{"-", "0.001"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "500"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.861124759885975*^9, 3.8611247664537516`*^9}, {
  3.8611247990283804`*^9, 3.861124799795579*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"66bf736c-ae91-41d7-b312-e850f7a50280"],

