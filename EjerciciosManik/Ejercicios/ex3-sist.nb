Cell[CellGroupData[{

Cell["Ejercicio 4", "Section",
 CellChangeTimes->{{3.8920518236554127`*^9, 
  3.892051829439968*^9}},ExpressionUUID->"bcd739d0-4991-488f-871e-\
5607ad3fd1a6"],

Cell[TextData[{
 "Tenemos que ver el espacio fase cerca del origen, y podemos usar el teorema \
de la bisecci\[OAcute]n para aproximar el punto en el cual pasamos de tener \
soluciones oscilatorias para todo tiempo a soluciones que divergen en tiempo \
finito. El punto cr\[IAcute]tico est\[AAcute] aproximadamente en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", 
          StyleBox["c", "TI"]], "\[LongEqual]", "0.0665"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu_c=0.0665", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3bb4527f-bea4-4a3a-8d93-a8d2b88c54da"],
 "."
}], "Text",
