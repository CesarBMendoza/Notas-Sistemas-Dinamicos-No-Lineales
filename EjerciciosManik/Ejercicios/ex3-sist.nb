Cell[CellGroupData[{

Cell["Ejercicio 3", "Section",
 CellChangeTimes->{{3.8920558958511486`*^9, 
  3.89205589777591*^9}},ExpressionUUID->"f98c8664-2bad-4ca2-aad9-\
ba953e979b1e"],

Cell[TextData[{
 "Si comparamos las ecuaciones 3 y 4 y las ecuaciones 6 y 7, vemos que son \
equivalentes con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Omega]", "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\omega=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a1c673eb-3112-4d41-8656-555a3b53adb6"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", 
         StyleBox["x", "TI"], 
         SuperscriptBox[
          StyleBox["y", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x,y)=xy^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dfc1c44f-6953-407d-8ecf-3966d4ea522b"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "g(x,y)=-x^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aa7c0673-c2d2-463c-86ba-cb730ba3747b"],
 ".\na) Calculamos la cantidad deseada:"
}], "Text",
 CellChangeTimes->{{3.8920577876265526`*^9, 3.8920578340009055`*^9}, {
  3.8920578900559473`*^9, 
  3.892057927239438*^9}},ExpressionUUID->"92be44e9-aa04-4713-8a32-\
8e5cc807e66f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{"x", "*", 
    RowBox[{"y", "^", "2"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{"-", 
    RowBox[{"x", "^", "2"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.892057930585829*^9, 3.8920579525180964`*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"ddfb3325-d8e8-448d-ba7e-2c98e1e6d3b5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "3"}], "}"}]}], "]"}], "+", 
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "1"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "2"}], "}"}]}], "]"}], "+", 
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{"g", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "1"}], "}"}]}], "]"}], "+", 
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{"g", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "3"}], "}"}]}], "]"}], "+", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{"x", ",", "y"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "1"}], "}"}]}], "]"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"f", "[", 
          RowBox[{"x", ",", "y"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "2"}], "}"}]}], "]"}], "+", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"f", "[", 
          RowBox[{"x", ",", "y"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", "2"}], "}"}]}], "]"}]}], ")"}]}], "-", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"x", ",", "y"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "1"}], "}"}]}], "]"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"D", "[", 
