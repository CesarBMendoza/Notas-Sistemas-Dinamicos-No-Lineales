Cell[TextData[{
 "La cual, evaluada en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"0", ",", "0"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "(0,0)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9e68af13-67b4-4179-a29c-b8217de99780"],
 " es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["2", TraditionalForm], "errors" -> {}, "input" -> "2", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dabc7181-156e-4c8d-985b-fa3450a6fa01"],
 ".\nb) Vemos que las ecuaciones 8 y 9 son exactamente las 6 y 7 con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "967b9e5c-d963-409c-9579-c3b7c5a66ca5"],
 ", por lo que si en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "38ddc962-b543-4da3-b2a9-92d509839759"],
 " ocurre una bifurcaci\[OAcute]n de Hopf, la cantidad calculada \
anteriormente, evaluada en el origen nos dice si la bifurcaci\[OAcute]n es \
supercr\[IAcute]tica, subcr\[IAcute]tica  degenerada. En este caso es \
positiva por lo que debe ser subcr\[IAcute]tica. S\[OAcute]lo debemos \
comprobar que, efectivamente, en el origen hay una bifurcaci\[OAcute]n de \
Hopf cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "44fd7f02-b2b8-4a40-a3ee-96390553a2b1"],
 ". Es obvio que el origen es un punto de equilibrio, dadas las ecuaciones. S\
\[OAcute]lo basta con encontrar los eigenvalores en el origen:"
}], "Text",
 CellChangeTimes->{{3.8920582406565104`*^9, 3.8920582875292683`*^9}, {
  3.8920584442717896`*^9, 3.8920584846645036`*^9}, {3.892058565108157*^9, 
  3.892058669862075*^9}, {3.892060146242456*^9, 
  3.8920601989056444`*^9}},ExpressionUUID->"0aada3b5-4817-491c-ae29-\
acfe69c0037f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"J3", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "y"}], "+", 
         RowBox[{"m", "*", "x"}], "+", 
         RowBox[{"x", "*", 
          RowBox[{"y", "^", "2"}]}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "y"}], "+", 
         RowBox[{"m", "*", "x"}], "+", 
         RowBox[{"x", "*", 
          RowBox[{"y", "^", "2"}]}]}], ",", "y"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", "+", 
         RowBox[{"m", "*", "y"}], "-", 
         RowBox[{"x", "^", "2"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", "+", 
         RowBox[{"m", "*", "y"}], "-", 
         RowBox[{"x", "^", "2"}]}], ",", "y"}], "]"}]}], "}"}]}], 
   "}"}]}]], "Input",
 CellLabel->"In[61]:=",ExpressionUUID->"e9dc3211-e834-4b61-9b3a-c8b81553f708"],

