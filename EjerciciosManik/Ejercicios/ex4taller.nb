Cell[CellGroupData[{

Cell["Pregunta 4", "Section",
 CellChangeTimes->{{3.893770706580945*^9, 3.89377070744003*^9}, {
  3.8937769458669386`*^9, 
  3.8937769459794264`*^9}},ExpressionUUID->"bc5525f2-6862-4358-8c02-\
b5ff4d3eaae6"],

Cell[TextData[{
 "Sea ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", "-", 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             StyleBox["r", "TI"]}], ")"}], 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "-", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"], "2"], "-", "2", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x_{n+1}=-(1+r)x_n-x_n^2-2x_n^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c3609bde-550e-4fbb-8aac-80b98b6bf245"]
}], "Text",
 CellChangeTimes->{{3.893770718346055*^9, 3.8937707325555735`*^9}, 
   3.8937707788160124`*^9, 
   3.8937708364003053`*^9},ExpressionUUID->"2ea97d30-5074-489b-a431-\
b1738fd97449"],

Cell[TextData[{
 "Calcula la estabilidad del punto de equilibrio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_n=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5cbcef53-6337-4a73-a85e-ab002180ad40"],
 ", y demuestra que existe una bifurcaci\[OAcute]n de flip en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "583f86e7-f58a-41ba-b18e-bffe5ce966c2"],
 "."
}], "Item",
 CellChangeTimes->{{3.8937708564582376`*^9, 
  3.893770895499442*^9}},ExpressionUUID->"5eabf464-7b5d-4804-ae7a-\
57fa9fc9c846"],

Cell[TextData[{
 "Para la estabilidad, calculamos la derivada\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "-", 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             StyleBox["r", "TI"]}], ")"}], 
         StyleBox["x", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "-", "2", 
         SuperscriptBox[
          StyleBox["x", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)=-(1+r)x-x^2-2x^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7f0e4def-5fb2-459e-a685-02d48488fc47"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "-", 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             StyleBox["r", "TI"]}], ")"}], "-", "2", 
         StyleBox["x", "TI"], "-", "6", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f'(x)=-(1+r)-2x-6x^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bc5fee16-91f0-421e-a377-12a28a1bcbe3"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", "-", 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             StyleBox["r", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "f'(0)=-(1+r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bcc1d6ff-40ea-44a0-a708-194702673c7a"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", "-", 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             StyleBox["r", "TI"]}], ")"}], "|", "<", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|-(1+r)|<1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "41b7d5e7-5f65-4db6-9448-145525ea23c4"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-1", "<", "-", 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             StyleBox["r", "TI"]}], ")"}], "<", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "-1<-(1+r)<1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d249017-7c48-464f-a751-5aa4d299eae9"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", ">", "1", "+", 
         StyleBox["r", "TI"], ">", "-1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "1>1+r>-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1146bcc7-6c98-4b2f-b77c-4307f26f1d07"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"0", ">", 
         StyleBox["r", "TI"], ">", "-2"}], TraditionalForm], "errors" -> {}, 
     "input" -> "0>r>-2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6d080ce0-01f7-4027-aae6-4a2c74d9742b"],
 "\nVemos que hay p\[EAcute]rdida de estabilidad del punto de equilibrio en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6153c11e-f247-49da-a22b-8f526bd91170"],
 ". Para saber que la bifurcaci\[OAcute]n es de flip, tenemos que ver que la \
derivada es negativa y disminuye de mayor a -1 a menor a -1. Entonces vemos c\
\[OAcute]mo es la derivada para n\[UAcute]meros positivos:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "413d69d1-027f-46ae-9a1c-d6e3a29b8323"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "+", 
         StyleBox["r", "TI"], ">", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "1+r>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "798f0836-bdb7-4c57-a23c-81079498731c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             StyleBox["r", "TI"]}], ")"}], "<", "-1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "-(1+r)<-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ea2affe2-a1dd-4960-b542-67b6dcbf749f"],
 "\nPor lo tanto, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ecf859a3-51f1-458a-9d25-bb4a334ff4d5"],
 ", la derivada es menor a -1 y el punto de equlibrio es inestable, y cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6876be59-db32-42e7-bd25-36cfbb7e838c"],
 " (pero cerca de cero), la derivada es negativa pero mayor a -1 por lo que \
es estable, y hay una bifurcaci\[OAcute]n de flip."
}], "Text",
 CellChangeTimes->{{3.8937709242450385`*^9, 3.893771254677737*^9}, {
  3.8937743227935696`*^9, 
  3.8937743308440704`*^9}},ExpressionUUID->"2a134699-0251-4106-b1f1-\
2031a70fcd74"],

Cell[TextData[{
 "Usando la serie de Taylor del segundo iterado hasta orden tres, muestra que \
hay un ciclo l\[IAcute]mite de periodo dos para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "428a29d9-0afc-47bc-9977-94fa123edfc5"],
 ", que coalesce con el punto de equilibrio en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d3826d04-ec21-4807-aee1-2c8109492409"],
 ". Argumenta porqu\[EAcute] esto indica que hay una bifurcaci\[OAcute]n de \
flip subcr\[IAcute]tica."
}], "Item",
 CellChangeTimes->{{3.893774273233*^9, 3.89377430733985*^9}, {
  3.893774341455612*^9, 
  3.89377437402942*^9}},ExpressionUUID->"a4aad372-5276-46dd-ad65-\
004c0fbf6acd"],

Cell["Definimos el lado derecho de la ecuaci\[OAcute]n:", "Text",
 CellChangeTimes->{{3.8937744052814293`*^9, 
  3.893774413928402*^9}},ExpressionUUID->"bea08cb3-4963-47b2-9187-\
46898f018f26"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x_", ",", "r_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"1", "+", "r"}], ")"}]}], "*", "x"}], "-", 
    RowBox[{"x", "^", "2"}], "-", 
    RowBox[{"2", "*", 
     RowBox[{"x", "^", "3"}]}]}]}], ";"}]], "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"adacaa51-1a4b-497d-a592-c483954a5e64"],

Cell["Y expandimos su segundo iterado hasta tercer orden:", "Text",
 CellChangeTimes->{{3.8937744299767647`*^9, 
  3.8937744429863763`*^9}},ExpressionUUID->"6f3345a4-966f-4b9e-a578-\
073f336c535f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Series", "[", 
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "r"}], "]"}], ",", "r"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[32]:=",ExpressionUUID->"9caf8440-8121-4382-8cc0-ffc64268f36a"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "-", "r"}], ")"}], "2"], " ", "x"}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "r"}], "-", 
      SuperscriptBox["r", "2"]}], ")"}], " ", 
    SuperscriptBox["x", "2"]}], "+", 
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"3", " ", "r"}], "+", 
      RowBox[{"3", " ", 
       SuperscriptBox["r", "2"]}], "+", 
      SuperscriptBox["r", "3"]}], ")"}], " ", 
    SuperscriptBox["x", "3"]}], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "x", "]"}], "4"],
    SeriesData[$CellContext`x, 0, {}, 1, 4, 1],
    Editable->False]}],
  SeriesData[$CellContext`x, 
   0, {(-1 - $CellContext`r)^2, -$CellContext`r - $CellContext`r^2, 
    2 (1 + 3 $CellContext`r + 3 $CellContext`r^2 + $CellContext`r^3)}, 1, 4, 
   1],
  Editable->False]], "Output",
 CellChangeTimes->{3.8937744518245673`*^9},
 CellLabel->"Out[32]=",ExpressionUUID->"5db0cc6b-b524-4c87-9d41-246ebd9df7e3"]
}, Open  ]],

Cell[TextData[{
 "Calculamos las soluciones de equilibrio del segundo iterado como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["f", "TI"], "(", 
             StyleBox["x", "TI"], ")"}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=f(f(x))", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1dd3c90e-0422-4a3a-8e60-ebe7c73d1715"]
}], "Text",
 CellChangeTimes->{{3.893774472471841*^9, 
  3.89377449020019*^9}},ExpressionUUID->"ced7e3b7-644c-4ca4-9f95-\
eb56cc059064"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"x", "==", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "-", "r"}], ")"}], "2"], " ", "x"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "r"}], "-", 
        SuperscriptBox["r", "2"]}], ")"}], " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"3", " ", "r"}], "+", 
        RowBox[{"3", " ", 
         SuperscriptBox["r", "2"]}], "+", 
        SuperscriptBox["r", "3"]}], ")"}], " ", 
