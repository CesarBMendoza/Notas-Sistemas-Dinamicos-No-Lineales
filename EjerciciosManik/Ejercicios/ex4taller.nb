            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]]}]], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["x", "TI"], 
            StyleBox["n", "TI"]], ")"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["e", "TI"], 
           RowBox[{"-2", "\[Pi]"}]], 
          SuperscriptBox[
           RowBox[{"[", 
             RowBox[{
               SuperscriptBox[
                StyleBox["e", "TI"], 
                RowBox[{"-2", "\[Pi]"}]], "+", 
               SubscriptBox[
                StyleBox["x", "TI"], 
                StyleBox["n", "TI"]], 
               RowBox[{"(", 
                 RowBox[{"1", "-", 
                   SuperscriptBox[
                    StyleBox["e", "TI"], 
                    RowBox[{"-2", "\[Pi]"}]]}], ")"}]}], "]"}], "2"]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{\\mathrm{d}f}{\\mathrm{d}x_n}(x_n)=\\frac{e^{-2\\pi}}{[e^{-2\\pi}\
+x_n(1-e^{-2\\pi})]^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "64919b66-daee-421c-ab20-40aa7823a7aa"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]]}]], 
         RowBox[{"(", "1", ")"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["e", "TI"], 
           RowBox[{"-2", "\[Pi]"}]], 
          SuperscriptBox[
           RowBox[{"[", 
             RowBox[{
               SuperscriptBox[
                StyleBox["e", "TI"], 
                RowBox[{"-2", "\[Pi]"}]], "+", 
               RowBox[{"(", 
                 RowBox[{"1", "-", 
                   SuperscriptBox[
                    StyleBox["e", "TI"], 
                    RowBox[{"-2", "\[Pi]"}]]}], ")"}]}], "]"}], "2"]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{\\mathrm{d}f}{\\mathrm{d}x_n}(1)=\\frac{e^{-2\\pi}}{[e^{-2\\pi}+(\
1-e^{-2\\pi})]^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2d4d6ae4-2e52-48c0-8b14-31c9c44fad24"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]]}]], 
         RowBox[{"(", "1", ")"}], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
