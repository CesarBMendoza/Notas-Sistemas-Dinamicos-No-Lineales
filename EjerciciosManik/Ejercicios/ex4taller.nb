Cell["Una soluci\[OAcute]n despu\[EAcute]s de la bifurcaci\[OAcute]n:", "Text",
 CellChangeTimes->{{3.893775478666283*^9, 
  3.893775495493831*^9}},ExpressionUUID->"34d7efe2-aeb1-4107-8c45-\
e8d5822fb93b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"n", "+", "1"}], "]"}], "==", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{"x", "[", "n", "]"}], ",", "0.05"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "0.001"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "100"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"sol2", ",", 
   RowBox[{"Joined", "->", "True"}], ",", 
   RowBox[{"Mesh", "->", "All"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.8937754998407164`*^9, 3.893775574804578*^9}},
 CellLabel->"In[57]:=",ExpressionUUID->"31f94bf9-183e-4af8-8329-65f6cc41eaad"],

