Cell[TextData[{
 "Demuestra que, para toda funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "g(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1373d31d-79a9-435b-ae3e-ccd504fa2125"],
 ", las ra\[IAcute]ces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "g(x)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d3d0e1d9-f40d-4136-98c5-4411fcc1a305"],
 " son puntos de equilibrio superestables de la ecuaci\[OAcute]n en \
diferencias del m\[EAcute]todo de Newton."
}], "Item",
 CellChangeTimes->{{3.8937661170828857`*^9, 
  3.893766172576317*^9}},ExpressionUUID->"a553cd0e-5161-4cb8-9b3f-\
95d408b05134"],

Cell[TextData[{
 "Suponemos que existe ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["x", "TI"], "\[FivePointedStar]"], TraditionalForm], 
     "errors" -> {}, "input" -> "x^\\star", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8613d0e9-e5f0-4878-bdbb-1d01514aa09f"],
 " tal que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]",
          "0"}], TraditionalForm], "errors" -> {}, "input" -> "g(x^\\star)=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b782c23b-34fa-445a-9562-fd9deee505ed"],
 ". Ahora, tomamos la condici\[OAcute]n inicial ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_0=x^\\star", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2418c51c-aa30-4606-9692-7321def93a6e"],
 ", y calculamos la soluci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], ",", 
         StyleBox["n", "TI"], ">", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x_n, n>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0ed51793-ce5e-4836-8ac1-7faceaa75261"],
 " iterando.\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "-", 
         FractionBox[
          RowBox[{
            StyleBox["g", "TI"], "(", 
            SuperscriptBox[
             StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], 
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]"], "(", 
            SuperscriptBox[
             StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "x_1=x^\\star-\\frac{g(x^\\star)}{g'(x^\\star)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1f788630-9892-40b9-b110-9c5be6b9f8e9"],
 " \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "-", 
         FractionBox["0", 
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]"], "(", 
            SuperscriptBox[
             StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "x_1=x^\\star-\\frac{0}{g'(x^\\star)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7e57a891-906c-41cf-b943-cd44351adfa0"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_1=x^\\star", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "df44a8b4-2de0-40d9-a10e-20997fa6a874"],
 "\nDonde usamos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]",
          "0"}], TraditionalForm], "errors" -> {}, "input" -> "g(x^\\star)=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ed7ba7e1-202a-4545-ad59-f82d76d2c9a7"],
 " por ser ra\[IAcute]z, y supusimos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["g", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[NotEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "g'(x^\\star)\\neq0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b72d26d5-031c-4266-9beb-2a69c1401036"],
 "\nVemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_{n+1}=x_n", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "103048eb-9ab8-43f3-8d8f-4697918af3d9"],
 " para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "n=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "78cffbed-4cd4-41ed-8faf-c8ac575ccba6"],
 " y por lo tanto para cualquier otra ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d7a3878-2ab6-447b-a8d3-1094f0ddfa32"],
 ", por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["x", "TI"], "\[FivePointedStar]"], TraditionalForm], 
     "errors" -> {}, "input" -> "x^\\star", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e1cebabc-8d95-4a26-9942-be3a10472ff0"],
 " es soluci\[OAcute]n de equilibrio. Ahora calculamos la estabilidad \
calculando el lado derecho de la ecuaci\[OAcute]n.\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["x", "TI"], 
            StyleBox["n", "TI"]], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "-", 
         FractionBox[
          RowBox[{
            StyleBox["g", "TI"], "(", 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]], ")"}], 
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]"], "(", 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]], ")"}]]}], TraditionalForm], "errors" -> {},
      "input" -> "f(x_n)=x_n-\\frac{g(x_n)}{g'(x_n)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4a57a0ee-d06a-4223-af6a-02a0847d7121"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "1", "-", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             RowBox[{"[", 
               RowBox[{
                 SuperscriptBox[
                  StyleBox["g", "TI"], "\[Prime]"], "(", 
                 StyleBox["x", "TI"], ")"}], "]"}], "2"], "-", 
            StyleBox["g", "TI"], 
            RowBox[{"(", 
              StyleBox["x", "TI"], ")"}], 
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]\[Prime]"], 
            RowBox[{"(", 
              StyleBox["x", "TI"], ")"}]}], 
          SuperscriptBox[
           RowBox[{"[", 
             RowBox[{
               SuperscriptBox[
                StyleBox["g", "TI"], "\[Prime]"], "(", 
               StyleBox["x", "TI"], ")"}], "]"}], "2"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "f'(x)=1-\\frac{[g'(x)]^2-g(x)g''(x)}{[g'(x)]^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "123cab8e-2850-44cd-a70e-8aefff72ff09"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "1", "-", "1", "+", 
         FractionBox[
          RowBox[{
            StyleBox["g", "TI"], 
            RowBox[{"(", 
              StyleBox["x", "TI"], ")"}], 
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]\[Prime]"], 
            RowBox[{"(", 
              StyleBox["x", "TI"], ")"}]}], 
          SuperscriptBox[
           RowBox[{"[", 
             RowBox[{
               SuperscriptBox[
                StyleBox["g", "TI"], "\[Prime]"], "(", 
               StyleBox["x", "TI"], ")"}], "]"}], "2"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "f'(x)=1-1+\\frac{g(x)g''(x)}{[g'(x)]^2}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c9304729-2748-45e5-82d1-cb0178d6b8ec"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["g", "TI"], 
            RowBox[{"(", 
              StyleBox["x", "TI"], ")"}], 
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]\[Prime]"], 
            RowBox[{"(", 
              StyleBox["x", "TI"], ")"}]}], 
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]"], 
            SuperscriptBox[
             RowBox[{"(", 
               StyleBox["x", "TI"], ")"}], "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "f'(x)=\\frac{g(x)g''(x)}{g'(x)^2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "be6cb90f-e323-4bfa-bd81-8fd777db258f"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["g", "TI"], 
            RowBox[{"(", 
              SuperscriptBox[
               StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], 
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]\[Prime]"], 
            RowBox[{"(", 
              SuperscriptBox[
               StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}]}], 
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]"], 
            SuperscriptBox[
             RowBox[{"(", 
               SuperscriptBox[
                StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "2"]}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f'(x^\\star)=\\frac{g(x^\\star)g''(x^\\star)}{g'(x^\\star)^2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cad66110-6429-4956-a893-f8650e2a6640"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"0", 
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]\[Prime]"], 
            RowBox[{"(", 
              SuperscriptBox[
               StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}]}], 
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]"], 
            SuperscriptBox[
             RowBox[{"(", 
               SuperscriptBox[
                StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "2"]}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f'(x^\\star)=\\frac{0g''(x^\\star)}{g'(x^\\star)^2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "069488f1-36f8-496e-9281-95be2bb761df"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]",
          "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "f'(x^\\star)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "587fbeee-3463-4c9f-8c30-b54622f3ffae"],
 "\ndonde usamos  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]",
          "0"}], TraditionalForm], "errors" -> {}, "input" -> "g(x^\\star)=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "81854996-fcab-438a-bbf3-b2fc75df5143"],
 " por ser ra\[IAcute]z, y supusimos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["g", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[NotEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "g'(x^\\star)\\neq0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b8d0adb0-8a66-494f-9585-bd1f33a29ac3"],
 ". Por lo tanto, las ra\[IAcute]ces son puntos de equilibrio superestables \
de la ecuaci\[OAcute]n en diferencias, pero el m\[EAcute]todo podr\[IAcute]a \
tener problemas cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["x", "TI"], "\[FivePointedStar]"], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d8bc6c47-8adf-45b8-93d2-3d69258688bc"],
 " adem\[AAcute]s de ser una ra\[IAcute]z tambi\[EAcute]n es un punto cr\
\[IAcute]tico."
}], "Text",
 CellChangeTimes->{{3.8937661825002556`*^9, 3.8937662718588896`*^9}, {
  3.89376632134671*^9, 3.893766412920291*^9}, {3.893766450328003*^9, 
  3.8937665441561646`*^9}, {3.8937666013721104`*^9, 3.8937666026857643`*^9}, {
  3.893766636885712*^9, 3.8937666704555206`*^9}, {3.8937667142423253`*^9, 
  3.8937668253176193`*^9}},ExpressionUUID->"0ceef261-2ff8-49c1-98b0-\
8f4e4a82a175"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pregunta 3", "Section",
 CellChangeTimes->{{3.8937565396617365`*^9, 3.8937565410888705`*^9}, {
  3.8937594047898207`*^9, 3.893759405637416*^9}, {3.8937769422699423`*^9, 
  3.893776942366982*^9}},ExpressionUUID->"9015bf2e-5f6f-4872-a7dc-\
92f320003e5e"],

Cell[TextData[{
 "Considera el sistema en coordenadas polares\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{r}=r-r^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1c6f2535-60ac-4cd3-b4db-0cee92c51cd5"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\dot{\\theta}=1", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b3456c06-8ec1-4d93-8562-ac7b91918885"],
 "\nUsando el mapeo de Poincar\[EAcute] generado por la secci\[OAcute]n de \
Poincar\[EAcute] ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["S", "TI"], "\[LongEqual]", 
         RowBox[{"{", 
           RowBox[{
             StyleBox["x", "TI"], ">", "0", ":", 
             StyleBox["x", "TI"], "\[Element]", 
             StyleBox["R", FontSlant -> "Plain"]}], "}"}]}], TraditionalForm],
      "errors" -> {}, "input" -> "S=\\{x>0:x\\in\\mathbb{R}\\}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "628572c1-41b4-4f33-85ff-675ae56fc296"],
 ", muestra que existe un \[UAcute]nico ciclo l\[IAcute]mite y determina su \
estabilidad.\n\nSoluci\[OAcute]n:\nVemos que el sistema est\[AAcute] \
desacoplado y el \[AAcute]ngulo crece como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Theta]", 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\theta(t)=t", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dacd0666-3915-4301-8e72-9abd13562532"],
 ", salvo una constante, por lo que las soluciones giran a la derecha y \
llegan a un punto con el mismo \[AAcute]ngulo despu\[EAcute]s de un tiempo de \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", "\[Pi]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "2\\pi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0d9a39db-d4c3-4f22-aee8-8b1a9b0ae684"],
 ". Vemos que la secci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["S", "TI"], TraditionalForm], "errors" -> {}, "input" -> "S", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "59051a50-aace-4766-a50f-db1890aa5b8a"],
 " puede verse como todos aquellos puntos con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Theta]", "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\theta=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "99874736-deda-4fcc-8efa-1f3f6bef0a68"],
 ", por lo que una soluci\[OAcute]n que intersecta a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["S", "TI"], TraditionalForm], "errors" -> {}, "input" -> "S", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "edbc5155-3276-464b-8af6-7701c7bc9864"],
 " en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["x", "TI"], 
        StyleBox["n", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "x_n", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "24d567e6-badf-494a-af72-261100089bdb"],
 ", intersecta en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["x", "TI"], 
        RowBox[{
          StyleBox["n", "TI"], "+", "1"}]], TraditionalForm], "errors" -> {}, 
     "input" -> "x_{n+1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c6caeb8c-85f6-45db-8c7e-fa9cadfa2750"],
 " en un tiempo igual a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", "\[Pi]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "2\\pi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c85d2063-3480-4406-8b3c-a0a7965b2a49"],
 ". Por lo tanto, tenemos la siguiente relaci\[OAcute]n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Integral]", 
          SubscriptBox[
           StyleBox["x", "TI"], 
           StyleBox["n", "TI"]], 
          SubscriptBox[
           StyleBox["x", "TI"], 
           RowBox[{
             StyleBox["n", "TI"], "+", "1"}]]], 
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["t", "TI"], "\[LongEqual]", "2", "\[Pi]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\int_{x_n}^{x_{n+1}}\\mathrm{d}t=2\\pi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5634333a-aebb-499e-baad-596388a69271"],
 "\nUsando la relga de la cadena tenemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["t", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["r", "TI"]}]], 
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mathrm{d}t=\\frac{\\mathrm{d}t}{\\mathrm{d}r}\\mathrm{d}r", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0b73739e-3e4c-4be1-a435-6f4f17724423"],
 ",  y por el teorema de la funci\[OAcute]n impl\[IAcute]cita, tenemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         FractionBox["1", 
          FractionBox[
           RowBox[{
             StyleBox["d", FontSlant -> "Plain"], 
             StyleBox["r", "TI"]}], 
           RowBox[{
             StyleBox["d", FontSlant -> "Plain"], 
             StyleBox["t", "TI"]}]]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\frac{\\mathrm{d}t}{\\mathrm{d}t}=\\frac{1}{\\frac{\\mathrm{d}r}{\\\
mathrm{d}t}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "42189809-2278-4537-8569-f2d0dd2319de"],
 ", y recordando que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["r", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{\\mathrm{d}r}{\\mathrm{d}t}=\\dot{r}=r-r^2", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aa793196-6d6f-4b01-90a5-1b69c39bca7f"],
 " por la primera ecuaci\[OAcute]n diferencial, sustituyendo en la integral \
obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", "\[Pi]", "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", 
          SubscriptBox[
           StyleBox["x", "TI"], 
           StyleBox["n", "TI"]], 
          SubscriptBox[
           StyleBox["x", "TI"], 
           RowBox[{
             StyleBox["n", "TI"], "+", "1"}]]], 
         FractionBox["1", 
          RowBox[{
            StyleBox["r", "TI"], "-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], 
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "2\\pi=\\int_{x_n}^{x_{n+1}}\\frac{1}{r-r^2}\\mathrm{d}r", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "34ef3914-7107-4328-bf54-197a6eac5808"],
 "\nUsando fracciones parciales podemos llegar a que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["1", 
          RowBox[{
            StyleBox["r", "TI"], "-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], "\[LongEqual]", 
         FractionBox["1", 
          StyleBox["r", "TI"]], "+", 
         FractionBox["1", 
          RowBox[{"1", "-", 
            StyleBox["r", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{1}{r-r^2}=\\frac{1}{r}+\\frac{1}{1-r}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f302507-1b0c-4e28-8493-3f2d0631668b"],
 ", sustituyendo:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", "\[Pi]", "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", 
          SubscriptBox[
           StyleBox["x", "TI"], 
           StyleBox["n", "TI"]], 
          SubscriptBox[
           StyleBox["x", "TI"], 
           RowBox[{
             StyleBox["n", "TI"], "+", "1"}]]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", 
              StyleBox["r", "TI"]], "+", 
             FractionBox["1", 
              RowBox[{"1", "-", 
                StyleBox["r", "TI"]}]]}], ")"}], 
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "2\\pi=\\int_{x_n}^{x_{n+1}}(\\frac{1}{r}+\\frac{1}{1-r})\\mathrm{d}r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bae46093-8a50-453b-9404-aedb05153459"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SubsuperscriptBox[
          RowBox[{
            RowBox[{"ln", 
              RowBox[{"(", 
                StyleBox["r", "TI"], ")"}], "-", "ln", 
              RowBox[{"(", 
                RowBox[{"1", "-", 
                  StyleBox["r", "TI"]}], ")"}]}], "\[VerticalSeparator]"}], 
          SubscriptBox[
           StyleBox["x", "TI"], 
           StyleBox["n", "TI"]], 
