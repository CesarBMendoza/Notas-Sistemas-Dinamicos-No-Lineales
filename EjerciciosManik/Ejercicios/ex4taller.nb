       SuperscriptBox["r", "2"], "-", 
       SqrtBox[
        RowBox[{
         RowBox[{"-", "8"}], "-", 
         RowBox[{"40", " ", "r"}], "-", 
         RowBox[{"79", " ", 
          SuperscriptBox["r", "2"]}], "-", 
         RowBox[{"78", " ", 
          SuperscriptBox["r", "3"]}], "-", 
         RowBox[{"39", " ", 
          SuperscriptBox["r", "4"]}], "-", 
         RowBox[{"8", " ", 
          SuperscriptBox["r", "5"]}]}]]}], 
      RowBox[{"4", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"3", " ", "r"}], "+", 
         RowBox[{"3", " ", 
          SuperscriptBox["r", "2"]}], "+", 
         SuperscriptBox["r", "3"]}], ")"}]}]]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", 
     FractionBox[
      RowBox[{"r", "+", 
       SuperscriptBox["r", "2"], "+", 
       SqrtBox[
        RowBox[{
         RowBox[{"-", "8"}], "-", 
         RowBox[{"40", " ", "r"}], "-", 
         RowBox[{"79", " ", 
          SuperscriptBox["r", "2"]}], "-", 
         RowBox[{"78", " ", 
          SuperscriptBox["r", "3"]}], "-", 
         RowBox[{"39", " ", 
