Cell[BoxData[{
 RowBox[{
  RowBox[{"cyc1", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", 
       RowBox[{"x", "/.", 
        RowBox[{"FindRoot", "[", 
