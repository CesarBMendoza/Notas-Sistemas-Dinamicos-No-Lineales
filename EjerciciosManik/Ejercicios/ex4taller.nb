Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "-", "r"}], ")"}], "2"], " ", "x"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "r"}], "-", 
        SuperscriptBox["r", "2"]}], ")"}], " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"3", " ", "r"}], "+", 
        RowBox[{"3", " ", 
         SuperscriptBox["r", "2"]}], "+", 
        SuperscriptBox["r", "3"]}], ")"}], " ", 
      SuperscriptBox["x", "3"]}]}], "==", "0"}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.8937695872383056`*^9, 3.8937696328672647`*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"c4774223-4ab1-4967-bfa3-9def69524990"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", "0"}], "}"}], ",", 
   RowBox[{"{", 
