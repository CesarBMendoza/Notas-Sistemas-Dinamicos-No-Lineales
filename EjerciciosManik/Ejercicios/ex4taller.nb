Cell[CellGroupData[{
Cell["Examen parcial IV", "Title",
 CellChangeTimes->{{3.8937565025040545`*^9, 
  3.8937565052379637`*^9}},ExpressionUUID->"905b3990-be54-42cf-bbff-\
a524f0164822"],

Cell[CellGroupData[{

Cell["Pregunta 1", "Section",
 CellChangeTimes->{{3.8937594164815416`*^9, 3.8937594199619107`*^9}, {
  3.893776935159507*^9, 
  3.893776935314343*^9}},ExpressionUUID->"f2f55685-3671-461e-bb85-\
6b08ee7db06b"],

Cell[TextData[{
 "Sea \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"], "2"], "-", "5", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "+", 
         SubscriptBox[
          StyleBox["y", "TI"], 
          StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_{n+1}=x_n^2-5x_n+y_n", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0e0d44ad-e48b-4edf-b8c9-15a53e5fd34e"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "y_{n+1}=x_n^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0e9e6831-a305-454a-ad9b-ff5ef2ac01c4"],
 "\nEncuentra y clasifica todas las soluciones de equilibrio.\n\nSoluci\
\[OAcute]n:\nBuscamos soluciones ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{n+1}=x^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cb9f2de2-d55e-4b3d-ae1d-2111c528c730"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y_{n+1}=y^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "31cd654a-f9f5-487f-bec2-52f53840e80d"],
 " para toda ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[Element]", 
         StyleBox["N", FontSlant -> "Plain"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "n\\in\\mathbb{N}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e08d9373-89de-4bde-a0a9-dbf72d4d2c33"],
 ". Sustituimos en la primera ecuaci\[OAcute]n y obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", "5", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "+", 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "x^{\\star}=x^{\\star2}-5x^{\\star}+y^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9aff7f15-434c-4bc4-9040-5d7998fadbec"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", "6", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "+", 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star2}-6x^{\\star}+y^{\\star}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "85e37790-ff87-4339-8c14-ccd52800ee83"],
 "\nDe la segunda ecuaci\[OAcute]n obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{\\star2}=y^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4fd348d7-33a6-4084-95dd-28276987370b"],
 "\nSustituyendo esta ecuaci\[OAcute]n en la anterior obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", "6", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star2}-6x^{\\star}+x^{\\star2}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "522adade-c1e4-483b-983e-c792ca6dea72"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", "6", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "2x^{\\star2}-6x^{\\star}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cbd16388-70c2-401e-989c-9766ed2472b4"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", "3", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star2}-3x^{\\star}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "238b59ff-a302-4def-92e5-006b1fc99df5"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "\[FivePointedStar]"], "-", "3"}], ")"}], 
         "\[LongEqual]", "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star}(x^{\\star}-3)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bc247bad-d2d7-47ae-9296-de1b214d1ad3"],
 "\nPor lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "x_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3ff2ecbc-e8a3-47d8-8679-ccca7c08fb72"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         "3"}], TraditionalForm], "errors" -> {}, "input" -> "x_2^{\\star}=3",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f9a093b-88ff-4753-a678-93570a5c77a3"],
 "\nDe la otra ecuaci\[OAcute]n tenemos entonces que:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["y", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "y_1^\\star=0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2f8bc05b-bcbe-42e4-bbde-e30d0e011c12"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["y", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         "9"}], TraditionalForm], "errors" -> {}, "input" -> "y_2^{\\star}=9",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "91068d32-df9e-4c2c-9e77-57baac6d07a3"],
 "\nEntonces los puntos de equilibrio son ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"0", ",", "0"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "(0,0)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c58528d7-a38c-4fe7-abe7-ca4ffcddc5eb"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"3", ",", "9"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "(3,9)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e895737b-51ef-4c69-8809-a1013975ede3"],
 ".\nCalculamos la matriz Jacobiana del sistema"
}], "Text",
 CellChangeTimes->{{3.8937594295025167`*^9, 3.893759433741661*^9}, {
  3.893759466331193*^9, 3.8937594733252125`*^9}, {3.8937595085676365`*^9, 
  3.8937596151331167`*^9}, {3.893759659926425*^9, 3.8937598130671067`*^9}, {
  3.893759853071068*^9, 3.8937599100917196`*^9}, {3.8937644817793894`*^9, 
  3.893764524627948*^9}},ExpressionUUID->"98e045b3-b012-4150-9418-\
b42502f488a0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"J1", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], "-", 
          RowBox[{"5", "*", "x"}], "+", "y"}], ",", "x"}], "]"}], ",", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], "-", 
          RowBox[{"5", "*", "x"}], "+", "y"}], ",", "y"}], "]"}]}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"x", "^", "2"}], ",", "x"}], "]"}], ",", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"x", "^", "2"}], ",", "y"}], "]"}]}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"MatrixForm", "[", "J1", "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.8937645291419964`*^9, 3.893764598946151*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"695c7f54-3b21-4073-8fdb-4f499709f5fd"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        RowBox[{"2", " ", "x"}], "-", "5"}], "1"},
      {
       RowBox[{"2", " ", "x"}], "0"}
     },
     GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
     GridBoxSpacings->{"Columns" -> {
         Offset[0.27999999999999997`], {
          Offset[0.7]}, 
         Offset[0.27999999999999997`]}, "Rows" -> {
         Offset[0.2], {
          Offset[0.4]}, 
         Offset[0.2]}}], "\[NoBreak]", ")"}],
   Function[BoxForm`e$, 
    MatrixForm[BoxForm`e$]]], TraditionalForm]], "Output",
 CellChangeTimes->{{3.8937645886460648`*^9, 3.893764599364818*^9}},
 CellLabel->
  "Out[6]//TraditionalForm=",ExpressionUUID->"d7d3c3ba-9514-470c-82ff-\
825d98b4686c"]
}, Open  ]],

Cell["Primero evaluamos en el origen y calculamos los eigenvalores", "Text",
 CellChangeTimes->{{3.8937646130800185`*^9, 
  3.8937646264085984`*^9}},ExpressionUUID->"c024ee16-3d01-475a-9a8f-\
66a91049a9ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Eigenvalues", "[", 
  RowBox[{"J1", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "->", "0"}], ",", 
     RowBox[{"y", "->", "0"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8937646367479167`*^9, 3.893764648471893*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"56fe5bbf-6025-4445-a5b3-1f9e5caa6030"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "5"}], ",", "0"}], "}"}]], "Output",
 CellChangeTimes->{3.8937646525488043`*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"d15b8c9b-63c9-450e-9c0f-b3f982ff2991"]
}, Open  ]],

Cell[TextData[{
 "Vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-1", "<", "0", "<", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "-1<0<1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3fb8a915-9bb9-4d19-b1cf-08e2927b8fe1"],
 " pero ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-5", "<", "-1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "-5<-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a7acdfa4-edf5-44a6-bfc4-4251adc671d5"],
 ", por lo que el punto de equilibrio atrae por una direcci\[OAcute]n y \
repele por otra, es un punto silla oscilatorio.\nAhora calculamos los \
eigenvalores del ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"3", ",", "9"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "(3,9)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0e7899bc-3590-4a36-a4ae-6e0218771f16"]
}], "Text",
 CellChangeTimes->{{3.8937646580377235`*^9, 3.893764750513034*^9}, {
  3.8937650655495653`*^9, 
  3.8937650671867456`*^9}},ExpressionUUID->"1f95b925-f285-4f9d-a329-\
ad910ed80a8b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Eigenvalues", "[", 
  RowBox[{"J1", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "->", "3"}], ",", 
     RowBox[{"x", "->", "9"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.893764752620598*^9, 3.8937647713018403`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"e7679ddf-e297-429d-a4a3-5b141d6ab437"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"3", ",", 
   RowBox[{"-", "2"}]}], "}"}]], "Output",
 CellChangeTimes->{3.8937647723529477`*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"1940bd51-e672-4452-a1bb-77f2adafd861"]
}, Open  ]],

Cell[TextData[{
 "En este caso, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"3", ">", "1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "3>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "15e92ecd-7d18-4424-923f-00047a5f2869"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-2", "<", "-1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "-2<-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "43fc3e20-0aa1-4445-8000-8d16813efb5a"],
 ", por lo que repele a lo largo de ambas direcciones, por lo tanto es un \
punto de equilibrio inestable (similar a una espiral estable, pero con un \
eigenvalor negativo, en lugar de eigenvalores complejos)."
}], "Text",
 CellChangeTimes->{{3.8937647851589737`*^9, 
  3.8937648599740767`*^9}},ExpressionUUID->"fb5cf69d-0aa0-44ea-988b-\
b41238fcfb46"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pregunta 2", "Section",
 CellChangeTimes->{{3.893765362617379*^9, 3.893765363630473*^9}, {
  3.893776937882161*^9, 
  3.8937769388633*^9}},ExpressionUUID->"9b86b5fb-3d8e-45ac-a05f-de16224cf6fe"],

Cell[TextData[{
 "El m\[EAcute]todo de Newton para encontrar num\[EAcute]ricamente las ra\
\[IAcute]ces de una funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "g(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2636403f-a733-49cc-9390-6f7dd59e083e"],
 " consiste en iterar la ecuaci\[OAcute]n en diferencias finitas\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "-", 
         FractionBox[
          RowBox[{
            StyleBox["g", "TI"], "(", 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]], ")"}], 
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "\[Prime]"], "(", 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]], ")"}]]}], TraditionalForm], "errors" -> {},
      "input" -> "x_{n+1}=x_n-\\frac{g(x_n)}{g'(x_n)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e2cdf52f-9c06-4677-90df-b92799cd24cf"]
}], "Text",
 CellChangeTimes->{{3.893765369550372*^9, 3.893765427129146*^9}, {
  3.8937654744994316`*^9, 
  3.893765495540475*^9}},ExpressionUUID->"e15ef5b1-a808-498f-bc32-\
9ee5e04d3f18"],

Cell[TextData[{
 "Escribe la ecuaci\[OAcute]n en diferencias con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "-", "4"}], TraditionalForm], 
     "errors" -> {}, "input" -> "g(x)=x^2-4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "70276d95-0174-4f99-b196-1c007a9b9604"],
 ", muestra que la ecuaci\[OAcute]n tiene dos puntos de equilibrio \
superestables, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "\[LongEqual]", "\[PlusMinus]", "2"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x_n=\\pm2", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1869ba40-eea4-42c7-bbf8-340a51bd85fa"],
 ", y encuentra las soluciones num\[EAcute]ricas con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_0=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "375a7140-193f-492c-9eb0-0ac1859407b9"]
}], "Item",
 CellChangeTimes->{{3.893765506107582*^9, 
  3.893765597029257*^9}},ExpressionUUID->"43523e87-c8e8-478e-af67-\
6fd4e470e39e"],

Cell[TextData[{
 "La ecuaci\[OAcute]n ser\[IAcute]a \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "-", 
         FractionBox[
          RowBox[{
            SubsuperscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"], "2"], "-", "4"}], 
          RowBox[{"2", 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x_{n+1}=x_n-\\frac{x_n^2-4}{2x_n}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5f366953-a022-4397-a148-ad716e7d01f9"],
 "\nLas soluciones de equilibrio se dan cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_n=x^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "989eb71f-575a-4084-804b-28661d9b57c1"],
 ". Sustituyendo, obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "-", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["x", "TI"], 
             RowBox[{"\[FivePointedStar]", "2"}]], "-", "4"}], 
          RowBox[{"2", 
            SuperscriptBox[
             StyleBox["x", "TI"], "\[FivePointedStar]"]}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star}=x^{\\star}-\\frac{x^{\\star2}-4}{2x^\\star}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2e12d9c3-f1a0-4f4b-a08f-9fd65652a617"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"0", "\[LongEqual]", "-", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["x", "TI"], 
             RowBox[{"\[FivePointedStar]", "2"}]], "-", "4"}], 
          RowBox[{"2", 
            SuperscriptBox[
             StyleBox["x", "TI"], "\[FivePointedStar]"]}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "0=-\\frac{x^{\\star2}-4}{2x^{\\star}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c265ab1-d97a-46ad-a776-6764fd78d4d5"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", "4", "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star2}-4=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6fe88ccc-a193-45fe-9d7e-0ee7a69446b8"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"1", ",", "2"}], "\[FivePointedStar]"], "\[LongEqual]", 
         "\[PlusMinus]", "2"}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star}_{1,2}=\\pm2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "81faa520-d577-42d6-9c03-9ed3462709c9"],
 "\nPara la estabilidad, calculamos la derivada del lado derecho y evaluamos \
en los puntos de equilibrio:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["x", "TI"], 
            StyleBox["n", "TI"]], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "-", 
         FractionBox[
          RowBox[{
            SubsuperscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"], "2"], "-", "4"}], 
          RowBox[{"2", 
            SubscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["n", "TI"]]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x_n)=x_n-\\frac{x_n^2-4}{2x_n}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c556a853-0159-4258-98da-82a477c53857"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "1", "-", 
         FractionBox[
          RowBox[{"4", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"], "-", "2", 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox[
                 StyleBox["x", "TI"], "2"], "-", "4"}], ")"}]}], 
          RowBox[{"4", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "f'(x)=1-\\frac{4x^2-2(x^2-4)}{4x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9b1cacd0-3db1-4d49-b7aa-edbb6d6bb8d9"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "1", "-", "1", "+", 
         FractionBox[
          RowBox[{"2", "(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["x", "TI"], "2"], "-", "4"}], ")"}], 
          RowBox[{"4", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "f'(x)=1-1+\\frac{2(x^2-4)}{4x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c7b42194-638a-411d-8b62-a836cf746025"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"], "-", "8"}], 
          RowBox[{"4", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "f'(x)=\\frac{2x^2-8}{4x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "48158c9d-a85c-4b8a-b858-349932be62d4"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           RowBox[{"\[PlusMinus]", "2"}], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{"\[PlusMinus]", "2"}], ")"}], "2"], "-", "8"}], 
          RowBox[{"4", 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{"\[PlusMinus]", "2"}], ")"}], "2"]}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f'(\\pm2)=\\frac{2(\\pm2)^2-8}{4(\\pm2)^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a7cd909d-71d8-4bcd-ad91-d688b36cc6e1"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           RowBox[{"\[PlusMinus]", "2"}], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"8", "-", "8"}], "16"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f'(\\pm2)=\\frac{8-8}{16}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c0d6e47c-1977-4a9d-85a8-28bdde93d2be"],
 "\nPor lo tanto son superestables. Vemos la soluci\[OAcute]n con condici\
\[OAcute]n inicial ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "0"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_0=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d226f24-19a2-4f69-b5aa-0225861ad433"]
}], "Text",
 CellChangeTimes->{{3.8937656023118296`*^9, 3.893765607342368*^9}, {
  3.8937656646581893`*^9, 3.8937656831208177`*^9}, {3.8937657148645763`*^9, 
