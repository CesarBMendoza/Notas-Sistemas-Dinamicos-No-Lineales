Notebook[{

Cell[CellGroupData[{
Cell["Examen parcial II", "Title",
 CellChangeTimes->{{3.8862552037960205`*^9, 
  3.88625520791263*^9}},ExpressionUUID->"b20275db-8632-409a-bce1-\
3f1c826fffcb"],

Cell[CellGroupData[{

Cell["Ejercicio I:", "Section",
 CellChangeTimes->{{3.886255321987038*^9, 
  3.886255347855401*^9}},ExpressionUUID->"2fb28b08-d986-47a8-a19d-\
2f53f1882871"],

Cell[TextData[{
 "Clasifica las bifurcaciones de los siguientes sistemas, calcula el valor cr\
\[IAcute]tico ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["r", "TI"], 
        StyleBox["c", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "r_c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "efd57c24-e9f0-47bd-9af9-dd4ea3752468"],
 " en el cual ocurre la bifurcaci\[OAcute]n y grafica el diagrama de \
bifurcaci\[OAcute]n"
}], "Text",
 CellChangeTimes->{{3.8862553524578733`*^9, 3.886255373161259*^9}, {
  3.8862555260168962`*^9, 
  3.8862555602299156`*^9}},ExpressionUUID->"d50b0f4b-3941-4fec-9249-\
66515543424d"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", 
        StyleBox["r", "TI"], 
        StyleBox["x", "TI"], "-", 
        FractionBox[
         StyleBox["x", "TI"], 
         RowBox[{"1", "+", 
           SuperscriptBox[
            StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {}, 
    "input" -> "\\dot{x}=rx-\\frac{x}{1+x^2}", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"d1a0e9fc-2f8f-4313-a0af-a69c82caee98"]], \
"Item",
 CellChangeTimes->{
  3.8862557186893272`*^9},ExpressionUUID->"429a2499-2386-4766-b034-\
f529bc9d4224"],

Cell[TextData[{
 "Los primeros tres incisos son f\[AAcute]ciles calculando los puntos de \
equilibrio. Empezamos por ver que, de inmediato, el lado izquierdo de la \
ecuaci\[OAcute]n es cero cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1b6c7647-3d9c-4592-82ba-7603afef4024"],
 ", por lo que siempre existe el punto de equilibrio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x_1(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "30d73dcb-af84-4287-bf80-7822dd3c0e33"],
 ". Ahora igualamos el lado derecho de la igualdad a cero y dividimos entre ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "309ca4f9-e7d1-4da0-907f-3375f633678b"],
 " para encontrar los dem\[AAcute]s puntos de equilibrio:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "-", 
         FractionBox["1", 
          RowBox[{"1", "+", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "r-\\frac{1}{1+x^2}=0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fb6363c8-d6b5-4dd9-9dca-09b8dee381de"],
 "\nMultiplicando por ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "1+x^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fa3d5622-a6de-48ac-8556-ba2c1354224f"],
 " de ambos lados:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             SuperscriptBox[
              StyleBox["x", "TI"], "2"]}], ")"}], "-", "1", "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "r\\left(1+x^2)-1=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4ef71103-b68d-4708-bd6c-f6006554e605"],
 "\nExpandiendo y dividiendo entre ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ee500918-6576-4c71-9e59-20222e223720"],
 ":\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "+", "1", "-", 
         FractionBox["1", 
          StyleBox["r", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x^2+1-\\frac{1}{r}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "97cb35ce-5541-483a-a71a-7a5a97ecc3fb"],
 "\nDespejando:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"2", ",", "3"}]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "\[PlusMinus]", 
         SqrtBox[
          RowBox[{
            FractionBox["1", 
             StyleBox["r", "TI"]], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{2,3}(t)=\\pm\\sqrt{\\frac{1}{r}-1}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "377ebc70-5397-4535-997f-7054903f1af6"],
 "\nVemos que todos los puntos de equilibrio son iguales cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "698fbe4d-fd7a-4e84-a985-ac8d69dd9aea"],
 " y cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4715f441-4ec9-4aa2-95f1-d5f57a56963a"],
 " s\[OAcute]lo existe la soluci\[OAcute]n de equilibrio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f7b00bca-a30c-40de-a3a3-cc9e276549c5"],
 ", por lo que debe ser una bifurcaci\[OAcute]n de tridente con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["c", "TI"]], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r_c=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1ea2b2b7-7e59-4cb7-8b90-44b4b26d8017"],
 ". Para determinar si es supercr\[IAcute]tica o subcr\[IAcute]tica, basta \
con calcular si la soluci\[OAcute]n de equilibrio que siempre existe es \
estable cuando existen o no existen las otras dos soluciones. Derivamos el \
lado derecho de la ecuaci\[OAcute]n:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}]], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         FractionBox[
          RowBox[{"1", "+", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"], "-", "2", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"1", "+", 
               SuperscriptBox[
                StyleBox["x", "TI"], "2"]}], ")"}], "2"]], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         FractionBox[
          RowBox[{"1", "-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"1", "+", 
               SuperscriptBox[
                StyleBox["x", "TI"], "2"]}], ")"}], "2"]]}], TraditionalForm],
      "errors" -> {}, "input" -> 
     "\\frac{df}{dx}=r-\\frac{1+x^2-2x^2}{\\left(1+x^2\\right)^2}=r-\\frac{1-\
x^2}{\\left(1+x^2\\right)^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f3c3640f-f9e9-450e-857c-2180d8d631fc"],
 "\nEvaluamos en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ea78f5a3-5018-42d9-a5aa-90e0e31ba492"],
 ":\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{df}{dx}(0)=r-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "434d01db-e537-45e5-b359-afedbc9dc9c7"],
 "\nVemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "-", "1", "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r-1<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "803c0cee-59ed-46d3-b124-5fe5b30d02f0"],
 " cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r<1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0f66659c-ee9e-4df9-9df5-ad961a33d44c"],
 ", por lo que es estable en este rango, y similarmente, es inestable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a3800086-9ab9-422a-92c2-e6153ae1ee07"],
 ". La soluci\[OAcute]n cero es estable cuando los otros dos puntos de \
equilibrio existen e inestable cuando s\[OAcute]lo ella existe, por lo que es \
una bifurcaci\[OAcute]n de tridente subcr\[IAcute]tica. Usando esta informaci\
\[OAcute]n podemos graficar el diagrama:"
}], "Text",
 CellChangeTimes->{{3.886255814836234*^9, 3.886255978614662*^9}, {
   3.8862560173502793`*^9, 3.8862560214752874`*^9}, 3.886256109372921*^9, {
   3.8862561834567194`*^9, 3.8862563512252927`*^9}, {3.886256486919136*^9, 
   3.8862567018305707`*^9}, {3.886256767566966*^9, 
   3.8862567698698826`*^9}},ExpressionUUID->"b86cd969-5fea-4d6b-95fd-\
f1738929a97f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "1"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Thick"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"r", ",", 
        RowBox[{"SuperStar", "[", "x", "]"}]}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "2"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "5"}], ",", "5"}], "}"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Thick", ",", "Dashed"}], "}"}]}]}], "]"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"1", "/", "r"}], "-", "1"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", 
       RowBox[{"1", "/", "26"}], ",", "1"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Red", ",", "Dashed", ",", "Thick"}], "}"}]}]}], "]"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"1", "/", "r"}], "-", "1"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", 
       RowBox[{"1", "/", "26"}], ",", "1"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Red", ",", "Dashed", ",", "Thick"}], "}"}]}]}], "]"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.8862567721902885`*^9, 3.8862568550127974`*^9}, {
  3.886256885992326*^9, 3.8862570239963665`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"c686cdd1-d8f4-4a3b-85ac-92ede54faf42"],

