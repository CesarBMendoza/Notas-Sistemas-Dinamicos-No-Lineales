Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", "5", "-", 
        StyleBox["r", "TI"], 
        SuperscriptBox[
         StyleBox["e", "TI"], 
         RowBox[{"-", 
           SuperscriptBox[
            StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {}, 
    "input" -> "\\dot{x}=5-re^{-x^2}", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"3556223a-8b6a-4094-a28d-f51575e5eef0"]], \
"Item",
 CellChangeTimes->{{3.8862601523254347`*^9, 3.8862601717488127`*^9}, 
   3.8862602652823477`*^9},ExpressionUUID->"ec0f0d27-69b8-4508-9dd9-\
97fce0e0cf43"],

Cell[TextData[{
 "Aqu\[IAcute] conviene una estrategia un poco diferente. Vemos que si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ed20002f-cff9-48c3-b906-bc17374a63d6"],
 ", entonces el lado derecho de la igualdad es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"5", "-", 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "5-r", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d4e30d69-1c18-4835-bfb6-2a1f2fdd15ca"],
 ", por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "40a536e1-b0ba-430b-b50e-e1bde8d0262d"],
 " es una soluci\[OAcute]n de equilibrio si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "5"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=5", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3c9e8245-934e-45ce-81bb-0f776360e0ad"],
 ". Como ya identificamos un punto de equilibrio que podr\[IAcute]a estar \
involucrado en la bifurcaci\[OAcute]n, podemos expandir en series de Taylor \
alrededor de ese valor, donde necesitamos las derivadas de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"-", 
          SuperscriptBox[
           StyleBox["x", "TI"], "2"]}]], TraditionalForm], "errors" -> {}, 
     "input" -> "e^{-x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "587f1ed7-55f3-48be-ba08-d5646f0866ed"],
 ". Lo haremos hasta segundo orden en caso de que la bifurcaci\[OAcute]n sea \
nodo-silla o transcr\[IAcute]tica. Podemos hacer esto de manera \
num\[EAcute]rica o a mano:"
}], "Text",
 CellChangeTimes->{{3.8862602704482183`*^9, 3.88626037382835*^9}, {
  3.88626044821564*^9, 
  3.8862605164401903`*^9}},ExpressionUUID->"8c972a2b-55e8-47a9-91e1-\
c5696172852c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Series", "[", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{"-", 
     RowBox[{"x", "^", "2"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "2"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.886260518725323*^9, 3.8862605288677015`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"4c65f6bc-35ec-4651-bec1-3361648f00be"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"1", "-", 
   SuperscriptBox["x", "2"], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "x", "]"}], "3"],
    SeriesData[$CellContext`x, 0, {}, 0, 3, 1],
    Editable->False]}],
  SeriesData[$CellContext`x, 0, {1, 0, -1}, 0, 3, 1],
  Editable->False]], "Output",
 CellChangeTimes->{3.8862605293214207`*^9},
 CellLabel->"Out[14]=",ExpressionUUID->"b72614d8-16ca-40a3-b2b8-c36542a0ffd1"]
}, Open  ]],

Cell[TextData[{
 "Sustituimos en la ecuaci\[OAcute]n:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", "5", "-", 
         StyleBox["r", "TI"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]], "\[TildeTilde]", "5", "-", 
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             SuperscriptBox[
              StyleBox["x", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\dot{x}=5-re^{-x^2}\\approx 5-r\\left(1-x^2\\right)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "af2c632c-73da-42b3-9188-f8fb3dd74624"],
 "\nDistribuimos el producto \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", "5", "-", 
         StyleBox["r", "TI"], "+", 
         StyleBox["r", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{x}=5-r+rx^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "95ecdf66-a965-40e7-8f72-7bc4a0c53b97"],
 "\nMultiplicamos de ambos lados por ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3ca90bfd-423c-4f14-924a-bf038f398ed4"],
 " y usamos la linealidad de la derivada:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          StyleBox["d", "TI"], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], 
             StyleBox["x", "TI"]}], ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"5", "-", 
             StyleBox["r", "TI"]}], ")"}], "+", 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{d}{dt}(rx)=r(5-r)+r^2x^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e272c506-a802-46d7-93a3-40851e405842"],
 "\nHacemos el cambio de variable ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["u", "TI"], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "u=rx", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "18fdc993-5b10-4b62-a4a3-740d6262b901"],
 ":\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["u", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"5", "-", 
             StyleBox["r", "TI"]}], ")"}], "+", 
         SuperscriptBox[
          StyleBox["u", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{u}=r(5-r)+u^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "49e5526f-04fd-4f14-a8d1-c1af8d7eb596"],
 "\nFinalmente, definimos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["R", "TI"], ":", "\[LongEqual]", 
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"5", "-", 
             StyleBox["r", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "R:= r(5-r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "49e1579a-a7d0-4ba6-8ed0-ff306d69a19d"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["u", "TI"], "."], "\[LongEqual]", 
         StyleBox["R", "TI"], "+", 
         SuperscriptBox[
          StyleBox["u", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{u}=R+u^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "389f5a36-999d-49de-b184-99058b934e83"],
 "\nla cual es la forma normal de la bifurcaci\[OAcute]n de nodo silla. La \
bifurcaci\[OAcute]n ocurre cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["R", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "R=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "260fd551-f72e-4dfa-918d-d783d8b3f292"],
 ", es decir, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "5"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=5", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b2ceb7da-6018-478f-874d-e5fbbc093fa1"],
 " (este es el punto donde la ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "af01fb00-333f-4424-bd79-714574f0922c"],
 " alrededor de donde estamos expandiendo es soluci\[OAcute]n). Para las \
estabilidades a la hora de dibujar el diagrama de bifurcaci\[OAcute]n, \
conviene saber de qu\[EAcute] lado es estable y de qu\[EAcute] lado es \
inestable el punto de equilibrio en la bifurcaci\[OAcute]n, ya que los puntos \
de equilibrio despu\[EAcute]s de la bifurcaci\[OAcute]n heredan esta \
antisimetr\[IAcute]a en estabilidad. Cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "5"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=5", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "806797d3-643c-4d9c-b212-b0b577b45c67"],
 ", podemos reescribir la ecuaci\[OAcute]n de la forma: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", "5", 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 StyleBox["x", "TI"], "2"]}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\dot{x}=5\\left(1-e^{-x^2}\\right)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "32d4da47-7153-4830-8178-e42076c155eb"],
 ". Ahora, sabemos que la funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"0", "<", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]], "\[LessEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "0<e^{-x^2}\\leq1", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1e6598d9-33a0-43d5-988f-e6d18ad4e748"],
 ", donde la igualdad se da en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e1772f3b-03b0-4030-b83c-292821005908"],
 ". Esto quiere decir que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "-", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]], "\[GreaterEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "1-e^{-x^2}\\geq0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8c84981a-c735-4453-aabb-b042445f1734"],
 ", por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[GreaterEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\dot{x}\\geq0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "93fadc8f-4d23-498e-a6e3-bd8f0f8252ea"],
 ", es decir, todas las soluciones son no decrecientes. Como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b4e0596b-8bc7-4c3f-81f9-7601ab84e0e5"],
 " es una soluci\[OAcute]n de equilibrio, esto quiere decir que las \
soluciones se acercan al equilibrio por la izquierda y se alejan por la \
derecha. De igual forma, despu\[EAcute]s de la bifurcaci\[OAcute]n, el menor \
de los puntos de equilibrio es estable y el mayor es inestable.\nEl diagrama \
de bifurcaci\[OAcute]n en este caso es num\[EAcute]rico, y se puede encontrar \
como:"
}], "Text",
 CellChangeTimes->{{3.8862605553213606`*^9, 3.886260566021649*^9}, {
  3.8862606325246563`*^9, 3.8862606747649612`*^9}, {3.8862607093087797`*^9, 
  3.8862607262063456`*^9}, {3.8862607613455334`*^9, 3.8862607734329844`*^9}, {
  3.886260818295268*^9, 3.886260833643738*^9}, {3.8862608706912537`*^9, 
  3.8862609216843853`*^9}, {3.8862609552565584`*^9, 3.8862610426223392`*^9}, {
  3.8862610835297155`*^9, 3.886261225747795*^9}, {3.8862612637760963`*^9, 
  3.8862613528716555`*^9}, {3.8862615450505114`*^9, 3.8862616790992637`*^9}, {
  3.886261715059185*^9, 
  3.886261718592825*^9}},ExpressionUUID->"d509ee57-54f6-4f55-a64d-\
1a215968d72c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"branch1", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", 
       RowBox[{"x", "/.", 
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"5", "-", 
            RowBox[{"r", "*", 
             RowBox[{"Exp", "[", 
              RowBox[{"-", 
               RowBox[{"x", "^", "2"}]}], "]"}]}]}], "==", "0"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "5", ",", "10", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"branch2", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", 
       RowBox[{"x", "/.", 
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"5", "-", 
            RowBox[{"r", "*", 
             RowBox[{"Exp", "[", 
              RowBox[{"-", 
               RowBox[{"x", "^", "2"}]}], "]"}]}]}], "==", "0"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "1"}], "}"}]}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "5", ",", "10", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"ListPlot", "[", 
    RowBox[{"branch1", ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"r", ",", 
        RowBox[{"SuperStar", "[", "x", "]"}]}], "}"}]}], ",", 
     RowBox[{"Joined", "\[Rule]", "True"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Red", ",", "Thick"}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"4", ",", "10"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"ListPlot", "[", 
    RowBox[{"branch2", ",", 
     RowBox[{"Joined", "\[Rule]", "True"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
