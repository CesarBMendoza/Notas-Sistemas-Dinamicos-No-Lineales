Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", 
        StyleBox["r", "TI"], 
        StyleBox["x", "TI"], "-", 
        FractionBox[
         StyleBox["x", "TI"], 
         RowBox[{"1", "+", 
           StyleBox["x", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
    "input" -> "\\dot{x}=rx-\\frac{x}{1+x}", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"00b38d6a-bd1e-49fe-bb96-f9022de96da1"]], \
"Item",
 CellChangeTimes->{
  3.886257178209647*^9},ExpressionUUID->"96a79384-e740-450d-b51e-\
54f37519c3ab"],

Cell[TextData[{
 "Procediendo de la misma forma que en el caso anterior, vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x_1(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e1f3285a-9534-4fe6-a763-c25115b5727b"],
 " siempre  es una soluci\[OAcute]n de equilibrio. Calculando su estabilidad:\
\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}]], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         FractionBox[
          RowBox[{"1", "+", 
            StyleBox["x", "TI"], "-", 
            StyleBox["x", "TI"]}], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"1", "+", 
               StyleBox["x", "TI"]}], ")"}], "2"]], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         FractionBox["1", 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"1", "+", 
               StyleBox["x", "TI"]}], ")"}], "2"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\frac{df}{dx}=r-\\frac{1+x-x}{(1+x)^2}=r-\\frac{1}{(1+x)^2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5cd74d23-c93b-4830-945a-e10ae8ca1d88"],
 "\nEvaluando:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{df}{dx}(0)=r-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3f33cb3d-332d-441b-a556-dca684fa0833"],
 "\nIgual que en el caso anterior, esta soluci\[OAcute]n de equilibrio es \
estable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r<1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "438af494-73e8-43ce-8d7a-9d79d7ef9b2f"],
 " e inestable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "94724c1b-970e-444e-85f5-eb90bdf12fbf"],
 ", por lo que la bifurcaci\[OAcute]n ocurre cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["c", "TI"]], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r_c=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "47fec879-59aa-4444-a22a-46479363773a"],
 ". Calculamos otros puntos de equilibrio igual que antes\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         StyleBox["x", "TI"], "-", 
         FractionBox[
          StyleBox["x", "TI"], 
          RowBox[{"1", "+", 
            StyleBox["x", "TI"]}]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "rx-\\frac{x}{1+x}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "263acc6d-be37-40ab-a8ba-951a1bee4263"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "-", 
         FractionBox["1", 
          RowBox[{"1", "+", 
            StyleBox["x", "TI"]}]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r-\\frac{1}{1+x}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d1d36e54-c102-4f22-8fe0-c209dfe8a0c2"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             StyleBox["x", "TI"]}], ")"}], "-", "1", "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "r(1+x)-1=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "661b471d-afd6-43bf-8028-7b9bde0c1718"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "+", 
         StyleBox["x", "TI"], "-", 
         FractionBox["1", 
          StyleBox["r", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "1+x-\\frac{1}{r}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cfb8364d-1d80-4fe3-b799-25e8b255719f"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", 
         FractionBox["1", 
          StyleBox["r", "TI"]], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x=\\frac{1}{r}-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6bc209af-bcf3-4c5c-ac0b-68a13f602098"],
 "\nVemos que el punto de equilibrio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "2"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          StyleBox["r", "TI"]], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x_2(t)=\\frac{1}{r}-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d16855d5-34a6-4ebd-86a1-8c5c25f8209e"],
 " existe siempre que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[NotEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r\\neq0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "48dfa6b0-b64d-42b6-9c3e-5909b7c7743d"],
 " y en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1323a104-6894-4881-b31e-332bfa86d268"],
 " ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], "2"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x_1(t)=x_2(t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ca6825d7-6dd5-44d2-912d-5930b4594e5e"],
 " lo que confirma que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["c", "TI"]], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r_c=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9323622b-f900-437b-8d61-a99c8e245d04"],
 ". Como en este punto uno de los puntos de equilibrio cambia de estabilidad, \
pero el otro no deja de existir, concluimos que debe ser una bifurcaci\
\[OAcute]n transcr\[IAcute]tica. Lo comprobamos mediante el diagrama de \
bifurcaci\[OAcute]n (no es necesario calcular la estabilidad del segundo \
punto de equilibrio, ya que el cero cambia de estabilidad cuando colisionan, \
podemos estar seguros que el otro intercambia estabilidad)."
}], "Text",
 CellChangeTimes->{{3.8862572054834194`*^9, 3.8862572158210754`*^9}, {
  3.8862572460761995`*^9, 3.886257271911697*^9}, {3.8862573287516885`*^9, 
  3.8862573932121754`*^9}, {3.886257435049243*^9, 
  3.886257709787435*^9}},ExpressionUUID->"7d166b9f-7d17-4c99-a3c2-\
54e935a4c1a3"],

