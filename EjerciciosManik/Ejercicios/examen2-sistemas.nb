Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", 
        StyleBox["r", "TI"], 
        StyleBox["x", "TI"], "-", 
        FractionBox[
         SuperscriptBox[
          StyleBox["x", "TI"], "3"], 
         RowBox[{"1", "-", 
           SuperscriptBox[
            StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {}, 
    "input" -> "\\dot{x}=rx-\\frac{x^3}{1-x^2}", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"5c25dc6f-991f-48b8-8858-02fd450e7929"]], \
"Item",
 CellChangeTimes->{{3.88625810087667*^9, 
  3.8862581263232803`*^9}},ExpressionUUID->"ec3ec0cb-f0eb-40a2-b575-\
9b311a96388d"],

Cell[TextData[{
 "Aqu\[IAcute] tambi\[EAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x_1(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5da3924e-5f2a-4b18-99b1-5a135d99102c"],
 " y para calcular su estabilidad evaluamos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}]], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         FractionBox[
          RowBox[{"3", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"], 
            RowBox[{"(", 
              RowBox[{"1", "-", 
                SuperscriptBox[
                 StyleBox["x", "TI"], "2"]}], ")"}], "+", "2", 
            SuperscriptBox[
             StyleBox["x", "TI"], "4"]}], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"1", "-", 
               SuperscriptBox[
                StyleBox["x", "TI"], "2"]}], ")"}], "2"]]}], TraditionalForm],
      "errors" -> {}, "input" -> 
     "\\frac{df}{dx}=r-\\frac{3x^2\\left(1-x^2\\right)+2x^4}{\\left(1-x^2\\\
right)^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8181c18b-4c29-4614-91f9-770d4ac0e635"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{df}{dx}(0)=r", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9632e546-955e-4f9b-a708-715db42407cc"],
 ", por lo que la soluci\[OAcute]n es estable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8641a958-0e19-4022-9999-af0a7efdd139"],
 " e inestable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "64e97264-db44-4f83-95f0-7046753edac4"],
 ". Podemos intuir que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["c", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r_c=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c71605f0-a296-4d53-9f0f-28b5d369582d"],
 ". Calculando los otros puntos de equilibrio:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         StyleBox["x", "TI"], "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["x", "TI"], "3"], 
          RowBox[{"1", "-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "rx-\\frac{x^3}{1-x^2}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "438e7f8c-efb3-4b11-8976-b07b3f721df3"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["x", "TI"], "2"], 
          RowBox[{"1", "-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "r-\\frac{x^2}{1-x^2}=0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "da579bfe-4c47-4980-b057-7b5adb000436"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             SuperscriptBox[
              StyleBox["x", "TI"], "2"]}], ")"}], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r\\left(1-x^2\\right)-x^2=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b840d8a3-a357-4cc7-afa6-c47264c859ce"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], "+", "1"}], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "r-x^2(r+1)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f393228f-0a96-42cf-9ba4-df70762a6e00"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"2", ",", "3"}]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "\[PlusMinus]", 
         SqrtBox[
          FractionBox[
           StyleBox["r", "TI"], 
           RowBox[{
             StyleBox["r", "TI"], "+", "1"}]]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{2,3}(t)=\\pm\\sqrt{\\frac{r}{r+1}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ff0f6d4c-a95b-4bcc-82cf-64fb2006a943"],
 "\nVemos que, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f7e5e6fd-082c-4c7e-8d81-3904903c3ec5"],
 ", los tres puntos de equilibrio son iguales. Los \[UAcute]ltimos dos puntos \
de equilibrio existen cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          StyleBox["r", "TI"], 
          RowBox[{
            StyleBox["r", "TI"], "+", "1"}]], ">", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\frac{r}{r+1}>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d5b394d8-5feb-4be2-abd0-b88e7929b131"],
 " es decir, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f36ed495-8932-4db5-8df5-617c343c30f5"],
 ". Esto quiere decir que la bifurcaci\[OAcute]n es de tridente supercr\
\[IAcute]tica cuando pues la \[UAcute]nica soluci\[OAcute]n de equilibrio \
estable se divide en una soluci\[OAcute]n de equilibrio inestable y dos \
estables.\nCon esto ya podemos dibujar el diagrama de bifurcaci\[OAcute]n:"
}], "Text",
 CellChangeTimes->{{3.886258137891841*^9, 3.886258143414117*^9}, {
  3.8862581980181646`*^9, 3.8862582121276865`*^9}, {3.886258309495348*^9, 
  3.8862583125258408`*^9}, {3.88625836843119*^9, 3.8862585105926943`*^9}, {
  3.886258676644153*^9, 3.886258678508055*^9}, {3.8862587392315865`*^9, 
  3.8862588055062027`*^9}, {3.8862588366022916`*^9, 3.8862589404277287`*^9}, {
  3.886258976161338*^9, 3.8862591918053904`*^9}, {3.8862597346863403`*^9, 
  3.8862597984226418`*^9}},ExpressionUUID->"42148898-3994-4a1c-80ee-\
b993d856b839"],

