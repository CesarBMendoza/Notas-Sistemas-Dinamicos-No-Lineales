Cell[CellGroupData[{

Cell["Ejercicio II:", "Section",
 CellChangeTimes->{{3.886252761831499*^9, 3.886252764208359*^9}, {
  3.886262228417059*^9, 
  3.8862622327537737`*^9}},ExpressionUUID->"af5d8ed4-27ee-49f6-a085-\
2a5aa63b12fa"],

Cell[TextData[{
 "La aproximaci\[OAcute]n a tercer orden de un modelo real que describe el \
ordenamiento autoorganizado de un cristal l\[IAcute]quido est\[AAcute] dada \
por\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["Q", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         StyleBox["k", "TI"], 
         StyleBox["Q", "TI"], 
         RowBox[{"[", 
           RowBox[{
             FractionBox["\[Beta]\[Rho]", "4"], 
             RowBox[{"(", 
               RowBox[{"1", "-", 
                 FractionBox[
                  SuperscriptBox["\[Beta]", "2"], "8"], 
                 SuperscriptBox[
                  StyleBox["Q", "TI"], "2"]}], ")"}], "-", "1"}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{dQ}{dt}=kQ\\left[\\frac{\\beta\\rho}{4}\\left(1-\\frac{\\beta^2}{\
8}Q^2\\right)-1\\right]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e609f8ad-e300-4e1e-8232-ff685c907948"],
 "\ndonde ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "81e51c35-3b16-4f37-bdd2-9f7320f6e9e2"],
 " es llamado el director nem\[AAcute]tico, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> "t", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c9850e45-1d75-4e63-b25a-b4a468119c5d"],
 " es el tiempo, y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "00a57332-2ff0-48fc-bf40-3a21146a8200"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1c18adfe-e946-45a1-9fa0-bdab39c0abfc"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Rho]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\rho", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8d6b6084-e209-4f05-b459-3a5aa42f2b7f"],
 " son par\[AAcute]metros."
}], "Text",
 CellChangeTimes->{{3.886252773895426*^9, 
  3.886252962454323*^9}},ExpressionUUID->"5c36572e-6a76-4fd7-a980-\
14f4f108ddf5"],

Cell[TextData[{
 "Si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "faebe77d-ee70-4784-93cb-264f880ab14b"],
 " tiene unidades de tiempo",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["\[Null]", "-1"], TraditionalForm], "errors" -> {}, 
     "input" -> "^{-1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d287c0f0-9117-46bd-b732-74009d6d7682"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Rho]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\rho", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "02ecdfca-28bb-442d-a3b5-867c6b3472ef"],
 " tiene unidades de densidad, y la ecuaci\[OAcute]n es dimensionalmente \
correcta, \[DownQuestion]cu\[AAcute]les son las unidades de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "163d284b-39d0-41f2-a478-67a4fe41d27b"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "89bbacea-f128-4c57-a353-0d4bacd1bd18"],
 "?"
}], "Item",
 CellChangeTimes->{{3.8862529756666613`*^9, 
  3.8862530864364333`*^9}},ExpressionUUID->"2490e386-23d7-455e-a639-\
f25385c05287"],

Cell[TextData[{
 "Como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       FractionBox[
        RowBox[{
          StyleBox["d", "TI"], 
          StyleBox["Q", "TI"]}], 
        RowBox[{
          StyleBox["d", "TI"], 
          StyleBox["t", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{dQ}{dt}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "695c38db-b111-4c31-b682-deb80543ad5d"],
 " es el l\[IAcute]mite de una divisi\[OAcute]n de incrementos de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "998cbb16-2080-490a-8f85-77a968800625"],
 " entre incrementos de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> "t", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "572e648d-5051-455f-8f31-0bdc1b7dac4c"],
 ", \[EAcute]sta debe tener unidades de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8a0b3a3d-acc6-4555-989e-0f3b4d9225b7"],
 " entre tiempo. Como la ecuaci\[OAcute]n es dimensionalmente correcta, el \
lado derecho de la igualdad tambipen tiene unidades de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "422d5539-6ebe-465c-ae07-8f689a44b021"],
 " entre tiempo. Vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["k", "TI"], 
         StyleBox["Q", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "kQ", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "22e1f061-34dd-4c50-bf7e-a01194c40c02"],
 " tambi\[EAcute]n tiene unidades de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4bfac36e-e1b5-49ff-a8a9-71055ef3a202"],
 " entre tiempo, dadas las unidades de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b8bdd3ba-9799-4bf3-bfc9-99e051240bf4"],
 ". Esto quiere decir que el factor que est\[AAcute] multiplicando a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["k", "TI"], 
         StyleBox["Q", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "kQ", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dac30511-e9e7-41e1-912f-662557aaa027"],
 " no debe tener unidades. Ahora, el par\[EAcute]ntesis m\[AAcute]s interno \
tiene a un n\[UAcute]mero (sin unidades) restando a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Beta]", "2"], 
         SuperscriptBox[
          StyleBox["Q", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta^2Q^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "27371e52-3020-4702-9cb1-cec98515ae73"],
 ". Para que esto sea correcto, se necesita que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Beta]", "2"], 
         SuperscriptBox[
          StyleBox["Q", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta^2Q^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "28553480-fdbf-42c0-ac60-3b5bcf4db571"],
 " tampoco tenga unidades, por lo que las unidades de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f0ec0cba-9c57-4bd6-9b61-125d45729a7c"],
 " y de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6d916a21-d7d9-4420-a24e-c90d6a9fed52"],
 " deben ser rec\[IAcute]procos. Finalmente, como acabamos de discutir, el \
par\[EAcute]ntesis interno no tiene unidades, por lo que al multiplicar por ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]\[Rho]", TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta\\rho", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "643099eb-483b-450a-a38c-83779d116e10"],
 ", todo esto tiene unidades de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]\[Rho]", TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta\\rho", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b9d4b405-656a-45ff-9a4c-82875261b769"],
 ", pero como ya hab\[IAcute]amos discutido, todo lo del par\[EAcute]ntesis \
externo tampoco debe tener unidades (esto tambi\[EAcute]n se puede ver porque \
hay un ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["-1", TraditionalForm], "errors" -> {}, "input" -> 
     "-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "754510da-3652-4494-bdec-45ef05427e50"],
 " restando que no tiene unidades), por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cd8e30b8-ee11-494c-a5ee-e77ea985b475"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Rho]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\rho", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b4ca4724-8d08-41d9-8a18-979ea620cf80"],
 " tambi\[EAcute]n deben tener unidades rec\[IAcute]procas. Como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Rho]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\rho", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2193571-a260-4049-94c1-03c30b3b6eb6"],
 " tiene unidades de densidad, entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3f30528c-a248-485f-9077-120be6d79336"],
 " tiene unidades de densidad",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["\[Null]", "-1"], TraditionalForm], "errors" -> {}, 
     "input" -> "^{-1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8a025981-0c03-4ea0-b61e-fd6723333832"],
 ", por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "465bbbba-34b7-475d-b589-c632703d2e09"],
 " tiene unidades de densidad."
}], "Text",
 CellChangeTimes->{{3.8862531018679094`*^9, 
  3.886253518039779*^9}},ExpressionUUID->"c639f865-6eed-4405-a81e-\
9a670a21c19c"],

Cell["\<\
Encuentra la soluci\[OAcute]n de equilibrio trivial de la ecuaci\[OAcute]n, y \
determina su estabilidad. \[DownQuestion]Cu\[AAcute]l deber\[IAcute]a ser el \
punto donde ocurre la bifurcaci\[OAcute]n?\
\>", "Item",
 CellChangeTimes->{{3.8862535863674555`*^9, 
  3.88625366399253*^9}},ExpressionUUID->"bd610f39-aaa4-4550-89e8-\
49aca043304e"],

Cell[TextData[{
 "Vemos que cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "Q=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8125fa37-fd32-49e7-838e-6992dad9a76a"],
 ", el lado derecha de la ecuaci\[OAcute]n es cero, por lo que la soluci\
\[OAcute]n de equilibrio trivial es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "Q(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d17463d-95b6-49ec-a517-0b7017bcca90"],
 ". Para determinar su estabilidad derivamos el lado derecho de la igualdad \
respecto de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["Q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "Q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6e996429-a6d9-4e05-bf37-6d2f2fd9c4ed"],
 " y evaluamos en la soluci\[OAcute]n de equilibrio:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["Q", "TI"]}]], 
         RowBox[{"(", 
           StyleBox["Q", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["k", "TI"], 
         RowBox[{"[", 
           RowBox[{
             FractionBox["\[Beta]\[Rho]", "4"], 
             RowBox[{"(", 
               RowBox[{"1", "-", 
                 FractionBox[
                  SuperscriptBox["\[Beta]", "2"], "8"], 
                 SuperscriptBox[
                  StyleBox["Q", "TI"], "2"]}], ")"}], "-", "1"}], "]"}], "+", 
         StyleBox["k", "TI"], 
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{"-", 
             FractionBox[
              RowBox[{
                SuperscriptBox["\[Beta]", "3"], "\[Rho]"}], "16"], 
             StyleBox["Q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\frac{df}{dQ}(Q)=k\\left[\\frac{\\beta\\rho}{4}\\left(1-\\frac{\\beta^\
2}{8}Q^2\\right)-1\\right]+kQ\\left(-\\frac{\\beta^3\\rho}{16}Q\\right)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9e148660-6831-4ee1-967a-08496cfcb121"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["Q", "TI"]}]], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         StyleBox["k", "TI"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["\[Beta]\[Rho]", "4"], "-", "1"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{df}{dQ}(0)=k\\left(\\frac{\\beta\\rho}{4}-1\\right)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a65e695b-24f7-464c-833e-f2021058576c"],
 "\nEl eigenvalor cambia de signo cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Beta]\[Rho]", "\[LongEqual]", "4"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\beta\\rho=4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "70912e09-9052-4324-b505-0eca5169ddb4"],
 ", por lo que en este punto deber\[IAcute]a ocurrir la bifurcaci\[OAcute]n"
}], "Text",
 CellChangeTimes->{{3.8862537146554985`*^9, 3.886253786928032*^9}, {
  3.886253946368956*^9, 3.8862539479917307`*^9}, {3.8862540502838693`*^9, 
  3.886254083513126*^9}},ExpressionUUID->"f14d718b-1998-41ae-8b54-\
c4ffa3ff9eaf"],

Cell["\<\
Determina el tipo de bifurcaci\[OAcute]n que ocurre y lleva la \
ecuaci\[OAcute]n a su forma normal. Suponiendo que los tres \
par\[AAcute]metros son estrictamente positivos. \[DownQuestion]Cu\[AAcute]les \
son los par\[AAcute]metros bifurcantes? Pista: No todos los \
par\[AAcute]metros juegan un papel en la bifurcaci\[OAcute]n en este caso.\
\>", "Item",
 CellChangeTimes->{{3.8862541942840047`*^9, 
  3.8862543079957933`*^9}},ExpressionUUID->"0f73860b-70a9-4f4d-bca6-\
4a0125aac02f"],

Cell[TextData[{
 "Como vimos, hay una soluci\[OAcute]n de equilibrio que siempre existe, por \
lo que no puede ser una bifurcaci\[OAcute]n de nodo-silla. Adem\[AAcute]s, la \
forma polinomial del lado derecho es c\[UAcute]bica, lo que sugiera que es \
una bifurcaci\[OAcute]n de tridente. Expandimos el lado derecho de la ecuaci\
\[OAcute]n diferencial:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["Q", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         StyleBox["k", "TI"], 
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["\[Beta]\[Rho]", "4"], "-", "1", "-", 
             FractionBox[
              RowBox[{
                SuperscriptBox["\[Beta]", "3"], "\[Rho]"}], "32"], 
             SuperscriptBox[
              StyleBox["Q", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\frac{dQ}{dt}=kQ\\left(\\frac{\\beta\\rho}{4}-1-\\frac{\\beta^3\\rho}{\
32}Q^2\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "211167e8-7886-40d4-8626-73a46b575625"],
 "\nvemos que el t\[EAcute]rmino c\[UAcute]bico es negativo, por lo que debe \
ser una bifurcaci\[OAcute]n de tridente supercr\[IAcute]tica. Empezamos por \
distribuir la ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "05d72755-37da-4316-9571-2086bbf34ed4"],
 " dentro del par\[EAcute]ntesis:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["Q", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              RowBox[{
                StyleBox["k", "TI"], "\[Beta]\[Rho]"}], "4"], "-", 
             StyleBox["k", "TI"], "-", 
             FractionBox[
              RowBox[{
                StyleBox["k", "TI"], 
                SuperscriptBox["\[Beta]", "3"], "\[Rho]"}], "32"], 
             SuperscriptBox[
              StyleBox["Q", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\frac{dQ}{dt}=Q\\left(\\frac{k\\beta\\rho}{4}-k-\\frac{k\\beta^3\\rho}{\
32}Q^2\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "69244026-c057-4807-8b1e-54b35f3cb79a"],
 "\nAhora ponemos las constantes dentro del t\[EAcute]rmino \
cuadr\[AAcute]tico:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["Q", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         StyleBox["Q", "TI"], 
         RowBox[{"[", 
           RowBox[{
             FractionBox[
              RowBox[{
                StyleBox["k", "TI"], "\[Beta]\[Rho]"}], "4"], "-", 
             StyleBox["k", "TI"], "-", 
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  SqrtBox[
                   FractionBox[
                    RowBox[{
                    StyleBox["k", "TI"], 
                    SuperscriptBox["\[Beta]", "3"], "\[Rho]"}], "32"]], 
                  StyleBox["Q", "TI"]}], ")"}], "2"]}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{dQ}{dt}=Q\\left[\\frac{k\\beta\\rho}{4}-k-\\left(\\sqrt{\\frac{k\
\\beta^3\\rho}{32}}Q\\right)^2\\right]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "635967c3-9ee0-4ad2-9e07-eafadc3ba981"],
 "\nMultiplicamos toda la ecuaci\[OAcute]n por la ra\[IAcute]z, y usamos la \
linealidad de la derivada:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          StyleBox["d", "TI"], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             SqrtBox[
              FractionBox[
               RowBox[{
                 StyleBox["k", "TI"], 
                 SuperscriptBox["\[Beta]", "3"], "\[Rho]"}], "32"]], 
             StyleBox["Q", "TI"]}], ")"}], "\[LongEqual]", 
         SqrtBox[
          FractionBox[
           RowBox[{
             StyleBox["k", "TI"], 
             SuperscriptBox["\[Beta]", "3"], "\[Rho]"}], "32"]], 
         StyleBox["Q", "TI"], 
         RowBox[{"[", 
           RowBox[{
             FractionBox[
              RowBox[{
                StyleBox["k", "TI"], "\[Beta]\[Rho]"}], "4"], "-", 
             StyleBox["k", "TI"], "-", 
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  SqrtBox[
                   FractionBox[
                    RowBox[{
                    StyleBox["k", "TI"], 
                    SuperscriptBox["\[Beta]", "3"], "\[Rho]"}], "32"]], 
                  StyleBox["Q", "TI"]}], ")"}], "2"]}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{d}{dt}\\left(\\sqrt{\\frac{k\\beta^3\\rho}{32}}Q\\right)=\\sqrt{\
\\frac{k\\beta^3\\rho}{32}}Q\\left[\\frac{k\\beta\\rho}{4}-k-\\left(\\sqrt{\\\
frac{k\\beta^3\\rho}{32}}Q\\right)^2\\right]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "551d9734-f1a9-4ea1-b87f-892c6b4be275"],
 "\nHacemos el cambio de variable ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", 
         SqrtBox[
          FractionBox[
           RowBox[{
             StyleBox["k", "TI"], 
             SuperscriptBox["\[Beta]", "3"], "\[Rho]"}], "32"]], 
         StyleBox["Q", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x=\\sqrt{\\frac{k\\beta^3\\rho}{32}}Q", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "043828f1-0245-4cfa-89a2-174f94b3d3cf"],
 ":\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              RowBox[{
                StyleBox["k", "TI"], "\[Beta]\[Rho]"}], "4"], "-", 
             StyleBox["k", "TI"], "-", 
             SuperscriptBox[
              StyleBox["x", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\frac{dx}{dt}=x\\left(\\frac{k\\beta\\rho}{4}-k-x^2\\right)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dbd0680d-035f-46ed-a637-bc59f2ea7ea6"],
 "\nDefinimos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["k", "TI"], "\[Beta]\[Rho]"}], "4"], "-", 
         StyleBox["k", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r=\\frac{k\\beta\\rho}{4}-k", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c34e2aca-c212-4c19-ac84-3b39ef525326"],
 ":\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], "-", 
             SuperscriptBox[
              StyleBox["x", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\frac{dx}{dt}=x\\left(r-x^2)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "73559e6d-be5c-4055-b05f-355f46bcdc46"],
 "\nDistribuimos el producto:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         StyleBox["x", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{dx}{dt}=rx-x^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7a8ba708-7641-45ce-84d5-09e986c18b5b"],
 "\nLa cual es la forma normal. Ahora, la bifurcaci\[OAcute]n se da en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7686ce42-012c-4c29-9a67-47142e5b100f"],
 ". Usando la definici\[OAcute]n de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a255de5d-ad5a-4e6a-baaa-3471b71c4439"],
 " vemos que la bifurcaci\[OAcute]n se da cuando\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["k", "TI"], "\[Beta]\[Rho]"}], "4"], "-", 
         StyleBox["k", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\frac{k\\beta\\rho}{4}-k=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3b6c634d-713d-49e9-b835-772e657164f6"],
 "\nComo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d9476d98-a4c0-4c1b-824c-0b92ba0630b0"],
 " es estrictamente positivo, podemos dividir de ambos lados y obtenemos la \
misma condici\[OAcute]n que antes:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Beta]\[Rho]", "\[LongEqual]", "4"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\beta\\rho=4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2afe55d9-1157-4cf8-826f-2b1ebd53d2cc"],
 ". Vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "46bc2968-3d46-4621-a8e8-9effa233d88a"],
 " no participa en la bifurcaci\[OAcute]n, por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "389303dc-bd4b-476e-b92b-4f1089eda588"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Rho]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\rho", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d10b8047-f031-4cd1-a492-4b7a6a999550"],
 " son los \[UAcute]nicos par\[AAcute]metros bifurcantes."
}], "Text",
 CellChangeTimes->{{3.886254324241034*^9, 3.88625457196581*^9}, {
  3.8862546132003155`*^9, 3.88625463283974*^9}, {3.886254708507221*^9, 
  3.886254735216472*^9}, {3.8862548223871193`*^9, 3.8862548308101254`*^9}, {
  3.8862548608450737`*^9, 3.8862548734804726`*^9}, {3.8862549284735036`*^9, 
  3.8862551509085836`*^9}},ExpressionUUID->"3fad67d8-f27e-4202-8fa2-\
37820176fdb4"]
}, Open  ]]
}, Open  ]]
},
