Notebook[{
Cell[CellGroupData[{
Cell[580, 22, 161, 3, 98, "Title",ExpressionUUID->"b20275db-8632-409a-bce1-3f1c826fffcb"],
Cell[CellGroupData[{
Cell[766, 29, 157, 3, 67, "Section",ExpressionUUID->"2fb28b08-d986-47a8-a19d-2f53f1882871"],
Cell[926, 34, 727, 18, 37, "Text",ExpressionUUID->"d50b0f4b-3941-4fec-9249-66515543424d"],
Cell[1656, 54, 705, 19, 48, "Item",ExpressionUUID->"429a2499-2386-4766-b034-f529bc9d4224"],
Cell[2364, 75, 10003, 255, 549, "Text",ExpressionUUID->"b86cd969-5fea-4d6b-95fd-f1738929a97f"],
