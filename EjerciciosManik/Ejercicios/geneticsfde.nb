Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f3", "[", "p_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"1", "*", "\[Alpha]", "*", 
       RowBox[{"p", "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], "*", "2", "*", "\[Beta]", "*", "p", 
       "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "p"}], ")"}]}], "+", 
      RowBox[{"0", "*", "\[Gamma]", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "p"}], ")"}], "^", "2"}]}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Alpha]", "*", 
       RowBox[{"p", "^", "2"}]}], "+", 
      RowBox[{"2", "*", "\[Beta]", "*", "p", "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "p"}], ")"}]}], "+", 
      RowBox[{"\[Gamma]", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "p"}], ")"}], "^", "2"}]}]}], ")"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.8419351339421415`*^9, 3.841935300712084*^9}},
