Cell[BoxData[
 RowBox[{"infppb", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"1", "-", 
     RowBox[{"Sin", "[", "x", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", 
      RowBox[{"2", "*", "Pi"}]}], "}"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"2", "*", "Pi"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "2"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", 
       RowBox[{"OverDot", "[", "\[Theta]", "]"}]}], "}"}]}], ",", 
    RowBox[{"Ticks", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"Pi", "/", "2"}], ",", "Pi", ",", 
         RowBox[{"3", "*", 
          RowBox[{"Pi", "/", "2"}]}], ",", 
         RowBox[{"2", "*", "Pi"}]}], "}"}], ",", "Automatic"}], "}"}]}]}], 
