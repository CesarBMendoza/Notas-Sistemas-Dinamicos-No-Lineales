Cell[BoxData[
 RowBox[{
  RowBox[{"pssn1", "=", 
   RowBox[{"StreamPlot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"TransformedField", "[", 
       RowBox[{
        RowBox[{"\"\<Polar\>\"", "\[Rule]", "\"\<Cartesian\>\""}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"-", "0.3"}], "*", "r"}], "+", 
           RowBox[{"r", "^", "3"}], "-", 
           RowBox[{"r", "^", "5"}]}], ",", 
          RowBox[{"0.1", "+", 
           RowBox[{"0.5", "*", 
            RowBox[{"r", "^", "2"}]}]}]}], "}"}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r", ",", "\[Theta]"}], "}"}], "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1.5"}], ",", "1.5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "1.5"}], ",", "1.5"}], "}"}], ",", 
     RowBox[{"StreamStyle", "\[Rule]", "LightGray"}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}]}], ",", 
     RowBox[{"StreamColorFunction", "\[Rule]", "None"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.835629326543058*^9, 3.8356293316872053`*^9}, 
   3.8608458186750546`*^9},
 CellLabel->"In[28]:=",ExpressionUUID->"e6d47131-33c8-4e01-8261-c1cad13d05bd"],

