Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"StreamPlot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"TransformedField", "[", 
       RowBox[{
        RowBox[{"\"\<Polar\>\"", "\[Rule]", "\"\<Cartesian\>\""}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"m", "*", "r"}], "+", 
           RowBox[{"r", "^", "3"}], "-", 
           RowBox[{"r", "^", "5"}]}], ",", 
          RowBox[{
           RowBox[{"1", "/", "10"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], "*", 
            RowBox[{"r", "^", "2"}]}]}]}], "}"}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r", ",", "\[Theta]"}], "}"}], "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"m", ",", 
     RowBox[{
      RowBox[{"-", "1"}], "/", "2"}], ",", "0"}], "}"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}]}]}], "]"}]], "Input",
