Cell[BoxData[
 RowBox[{
  RowBox[{"sipb2", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"r", "[", "t", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"r", "[", "t", "]"}], "^", "2"}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{"1", "-", 
         RowBox[{"Sin", "[", 
          RowBox[{"a", "[", "t", "]"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"r", "[", "0", "]"}], "\[Equal]", "1"}], ",", 
       RowBox[{
        RowBox[{"a", "[", "0", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"Pi", "/", "2"}], "+", "0.01"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "a"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.835632507351557*^9, 3.8356325077205343`*^9}, {
  3.8356326218494587`*^9, 3.8356326351897984`*^9}, {3.8356327478577547`*^9, 
  3.835632748021472*^9}},
