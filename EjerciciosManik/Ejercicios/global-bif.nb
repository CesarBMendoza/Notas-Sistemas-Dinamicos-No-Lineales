Cell[BoxData[
 RowBox[{
  RowBox[{"sipb1", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"r", "[", "t", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"r", "[", "t", "]"}], "^", "2"}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{"1.2", "-", 
         RowBox[{"Sin", "[", 
          RowBox[{"a", "[", "t", "]"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"r", "[", "0", "]"}], "\[Equal]", "2"}], ",", 
       RowBox[{
        RowBox[{"a", "[", "0", "]"}], "\[Equal]", "0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "a"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.8356308330955048`*^9, 3.835630845141097*^9}, {
  3.835630892301127*^9, 3.835630979420917*^9}, {3.8356310173709106`*^9, 
  3.8356310734892406`*^9}, {3.8356315326542807`*^9, 3.8356315328709707`*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"158e93f9-2b7a-4f67-b831-c32776a4ece8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ipsolpreb", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"r", "[", "t", "]"}], "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"a", "[", "t", "]"}], "]"}]}], "/.", "sipb1"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "25"}], "}"}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"t", ",", "x"}], "}"}]}]}], "]"}]}]], "Input",
