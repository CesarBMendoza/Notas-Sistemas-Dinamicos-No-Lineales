Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"shb3", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{"y", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "0.83"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}], "+", 
         RowBox[{"x", "[", "t", "]"}], "-", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}], "+", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "\[Equal]", "0.98"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "\[Equal]", "0.01"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], ";"}]], "Input",\

