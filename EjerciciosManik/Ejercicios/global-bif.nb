Cell[BoxData[
 RowBox[{
  RowBox[{"sipb3", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"r", "[", "t", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"r", "[", "t", "]"}], "^", "2"}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{
          RowBox[{"Sqrt", "[", "2", "]"}], "/", "2"}], "-", 
         RowBox[{"Sin", "[", 
          RowBox[{"a", "[", "t", "]"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"r", "[", "0", "]"}], "\[Equal]", "2.05"}], ",", 
       RowBox[{
        RowBox[{"a", "[", "0", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"3", "*", 
          RowBox[{"Pi", "/", "4"}]}], "+", "0.01"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "a"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.835634029598804*^9, 3.835634040933267*^9}, {
  3.83563411680895*^9, 3.8356341235368443`*^9}, {3.835634223764297*^9, 
  3.8356342239937468`*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"1d02725c-e786-49fc-a939-85be44bf6566"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ipsolposb", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"r", "[", "t", "]"}], "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"a", "[", "t", "]"}], "]"}]}], "/.", "sipb3"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "20"}], "}"}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<t\>\"", ",", "x"}], "}"}]}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.83563415189953*^9, 3.835634190100404*^9}, {
  3.835634235740768*^9, 3.8356342492381*^9}, {3.8608465651602535`*^9, 
