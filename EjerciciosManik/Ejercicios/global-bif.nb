Cell[BoxData[
 RowBox[{
  RowBox[{"psip2", "=", 
   RowBox[{"StreamPlot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"TransformedField", "[", 
       RowBox[{
        RowBox[{"\"\<Polar\>\"", "\[Rule]", "\"\<Cartesian\>\""}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"r", "*", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"r", "^", "2"}]}], ")"}]}], ",", 
          RowBox[{"1", "-", 
           RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r", ",", "\[Theta]"}], "}"}], "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1.5"}], ",", "1.5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "1.5"}], ",", "1.5"}], "}"}], ",", 
     RowBox[{"StreamStyle", "\[Rule]", "LightGray"}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}]}], ",", 
     RowBox[{"StreamColorFunction", "\[Rule]", "None"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.835631884580083*^9, 3.835631887830656*^9}, 
   3.860846262360137*^9},
 CellLabel->"In[45]:=",ExpressionUUID->"58cf487f-f3ec-4379-ab26-335f373f48db"],

