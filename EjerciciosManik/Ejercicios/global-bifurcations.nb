  "Out[165]=",ExpressionUUID->"6c171606-1606-4fa4-9bf6-2f5ce0ef46a5"]
}, Open  ]],

Cell[TextData[{
 "Y ahora vemos la soluci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f45d3b63-ebc0-4e2d-840a-61be5c3b921f"],
 ":"
}], "Text",
 CellChangeTimes->{{3.890938541666229*^9, 
  3.8909385507254515`*^9}},ExpressionUUID->"2a176731-aad1-4bc9-89f4-\
86c77bf2c06d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol5", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"r", "[", "t", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"r", "[", "t", "]"}], "^", "2"}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Theta]", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"1", "-", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"r", "[", "0", "]"}], "==", "1"}], ",", 
       RowBox[{
        RowBox[{"\[Theta]", "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"Pi", "/", "2"}], "+", "0.01"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "\[Theta]"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"LogLinearPlot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"r", "[", "t", "]"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}], "/.", "sol5"}], "]"}], 
   ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1000"}], "}"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<t\>\"", ",", "x"}], "}"}]}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.8909385537833805`*^9, 3.890938679347677*^9}, {
  3.89093872819234*^9, 3.8909387283175383`*^9}, {3.8909387668711376`*^9, 
  3.890938817609699*^9}},
 CellLabel->
  "In[179]:=",ExpressionUUID->"f885c2a1-857e-40a1-8e65-f94c8e9bbb90"],

