        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "0.8645"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}], "+", 
         RowBox[{"x", "[", "t", "]"}], "-", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}], "+", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "0.98"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "0.01"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "85"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
