Cell[TextData[{
 "Ejemplo:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", "\[Mu]", 
         StyleBox["r", "TI"], "+", 
         SuperscriptBox[
          StyleBox["r", "TI"], "3"], "-", 
         SuperscriptBox[
          StyleBox["r", "TI"], "5"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{r}=\\mu r+r^3-r^5", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "66989b6c-494b-4492-85a4-a74a3e92d5c7"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", "\[Omega]", "+", 
         StyleBox["b", "TI"], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{\\theta}=\\omega+br^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b00d614d-b043-40e0-be10-dab8876d7b79"],
 "\nEspacio fase de la parte radial:"
}], "Text",
