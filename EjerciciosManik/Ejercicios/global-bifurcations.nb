  3.890939517955324*^9}},ExpressionUUID->"cffd4f5e-73ae-40ba-86a6-\
0a91ca1199da"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol6", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"r", "[", "t", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"r", "[", "t", "]"}], "^", "2"}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Theta]", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"Sqrt", "[", "2", "]"}], "/", "2"}], "-", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"r", "[", "0", "]"}], "==", "2.05"}], ",", 
       RowBox[{
        RowBox[{"\[Theta]", "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"3", "*", 
          RowBox[{"Pi", "/", "4"}]}], "+", "0.01"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "\[Theta]"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "20"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"r", "[", "t", "]"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}], "/.", "sol6"}], "]"}], 
   ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "20"}], "}"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"t", ",", "x"}], "}"}]}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.8909395369536057`*^9, 3.890939598317744*^9}},
 CellLabel->
