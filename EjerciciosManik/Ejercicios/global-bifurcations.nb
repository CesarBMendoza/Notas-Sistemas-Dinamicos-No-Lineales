Cell[TextData[{
 "Y ahora vemos la soluci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x(t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9a7167b0-d4c3-465a-a8e8-b70025b2ddfe"],
 ":"
}], "Text",
 CellChangeTimes->{{3.8909374012384605`*^9, 
  3.890937414189239*^9}},ExpressionUUID->"0f3b514f-a2d5-4f52-9c65-\
b10082c47b83"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol4", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"r", "[", "t", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"r", "[", "t", "]"}], "^", "2"}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Theta]", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"1.2", "-", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"r", "[", "0", "]"}], "==", "2"}], ",", 
       RowBox[{
        RowBox[{"\[Theta]", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "\[Theta]"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "30"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"r", "[", "t", "]"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}], "/.", "sol4"}], "]"}], 
   ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "30"}], "}"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{"x", "[", "t", "]"}]}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.89093741849716*^9, 3.8909374227231703`*^9}, {
  3.8909374711161118`*^9, 3.890937649646014*^9}},
