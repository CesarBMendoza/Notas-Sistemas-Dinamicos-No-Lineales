Cell[CellGroupData[{

Cell["Bifurcaci\[OAcute]n de per\[IAcute]odo infinito", "Section",
 CellChangeTimes->{{3.890934675368871*^9, 
  3.890934683286973*^9}},ExpressionUUID->"370e972d-cf78-4a02-8a51-\
094b42f92942"],

Cell[TextData[{
 "Un ejemplo es el sistema\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             SuperscriptBox[
              StyleBox["r", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\dot{r}=r(1-r^2)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5a96d23d-64af-466c-98bc-7b2efcbc5c27"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", "\[Mu]", "-", "sin", 
         "\[Theta]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{\\theta}=\\mu-\\sin\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f4e1b196-ab0c-4704-8289-5892fd0b0f58"],
 "\nEspacio fase de la parte radial:"
}], "Text",
 CellChangeTimes->{{3.8909361426359406`*^9, 
  3.890936206219618*^9}},ExpressionUUID->"2b8fe838-d8c5-4638-af10-\
72fe09b15ab9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
