Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol10", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"y", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "0.8645"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}], "+", 
         RowBox[{"x", "[", "t", "]"}], "-", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}], "+", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"y", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "900", "]"}], "==", "0.01"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "900", "]"}], "==", 
        RowBox[{"0.01", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "0.8645"}], "-", 
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"0.8645", "^", "2"}], "+", "4"}], "]"}]}], ")"}], "/", 
          "2"}]}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "900"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol11", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
