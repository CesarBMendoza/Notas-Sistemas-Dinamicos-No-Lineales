  RowBox[{"{", 
   RowBox[{
    RowBox[{"StreamPlot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "@", 
       RowBox[{"TransformedField", "[", 
        RowBox[{
         RowBox[{"\"\<Polar\>\"", "\[Rule]", "\"\<Cartesian\>\""}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"r", "*", 
