Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"x", "[", "t", "]"}]}], "+", 
        RowBox[{"0.06", "*", 
         RowBox[{"y", "[", "t", "]"}]}], "+", 
        RowBox[{
         RowBox[{"y", "[", "t", "]"}], "*", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"0.6", "-", 
        RowBox[{"0.06", "*", 
         RowBox[{"y", "[", "t", "]"}]}], "-", 
        RowBox[{
         RowBox[{"y", "[", "t", "]"}], "*", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "0.001"}], ",", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "==", "0.001"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "30"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8594643448792963`*^9, 3.8594644902293468`*^9}, {
