Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rp3", "=", 
  RowBox[{"RegionPlot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"a", ">", "0"}], "&&", 
     RowBox[{"b", ">", "0"}], "&&", 
     RowBox[{
      RowBox[{"b", "^", "2"}], "<", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"2", "*", "a"}], "+", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", "-", 
           RowBox[{"8", "*", "a"}]}], "]"}]}], ")"}], "/", "2"}]}], "&&", 
     RowBox[{
      RowBox[{"b", "^", "2"}], ">", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"2", "*", "a"}], "-", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", "-", 
           RowBox[{"8", "*", "a"}]}], "]"}]}], ")"}], "/", "2"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{"a", ",", "0", ",", "0.14"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"b", ",", "0", ",", "1.2"}], "}"}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}]}]}], "]"}]}]], "Input",
