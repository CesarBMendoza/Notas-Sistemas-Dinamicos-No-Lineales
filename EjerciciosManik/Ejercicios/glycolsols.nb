Cell["\<\
Las ceroclinas nos ayudan a construir una regi\[OAcute]n atrapante, chequemos \
esta regi\[OAcute]n con el campo vectorial:\
\>", "Text",
 CellChangeTimes->{{3.888940848434729*^9, 
  3.8889408732300687`*^9}},ExpressionUUID->"5918049b-296e-4aeb-96d5-\
8365381c2fac"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"RegionPlot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"y", "<", 
         RowBox[{"b", "/", "a"}]}], ")"}], "&&", " ", 
       RowBox[{"(", 
        RowBox[{"y", ">", "0"}], ")"}], " ", "&&", " ", 
       RowBox[{"(", 
        RowBox[{"x", ">", "0"}], ")"}], " ", "&&", " ", 
       RowBox[{"(", 
        RowBox[{"y", "<", 
         RowBox[{
          RowBox[{"-", "x"}], "+", 
          RowBox[{"b", "*", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"1", "/", "a"}]}], ")"}]}]}]}], ")"}], "&&", 
       RowBox[{"(", 
        RowBox[{"x", "<", "3.722"}], ")"}], "&&", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x", "-", "b"}], ")"}], "^", "2"}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"y", "-", 
             RowBox[{"b", "/", 
              RowBox[{"(", 
               RowBox[{"a", "+", 
                RowBox[{"b", "^", "2"}]}], ")"}]}]}], ")"}], "^", "2"}]}], 
         ">", "0.02"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "4"}], "}"}]}], "]"}], ",", 
    RowBox[{"VectorPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "x"}], "+", 
         RowBox[{"a", "*", "y"}], "+", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", 
        RowBox[{"b", "-", 
         RowBox[{"a", "*", "y"}], "-", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "4"}], "}"}]}], "]"}], ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "/", 
         RowBox[{"(", 
          RowBox[{"0.16", "+", 
           RowBox[{"x", "^", "2"}]}], ")"}]}], ",", 
        RowBox[{"0.55", "/", 
         RowBox[{"(", 
          RowBox[{"0.16", "+", 
           RowBox[{"x", "^", "2"}]}], ")"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "4"}], "}"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "4"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "4"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"AxesLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}]}]}], "]"}]}], "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.8889408806329126`*^9, 3.888940980840131*^9}, {
