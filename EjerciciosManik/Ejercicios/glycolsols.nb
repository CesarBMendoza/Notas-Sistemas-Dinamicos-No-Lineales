Cell["\<\
Verificamos que exista un ciclo l\[IAcute]mite dentro de esta regi\[OAcute]n:\
\>", "Text",
 CellChangeTimes->{{3.888942330920454*^9, 
  3.8889423458669057`*^9}},ExpressionUUID->"20f3e676-3888-4047-836a-\
c7237b656bc3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", "0.08"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", "0.6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solcyc", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"x", "[", "t", "]"}]}], "+", 
         RowBox[{"a", "*", 
          RowBox[{"y", "[", "t", "]"}]}], "+", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"b", "-", 
         RowBox[{"a", "*", 
          RowBox[{"y", "[", "t", "]"}]}], "-", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "1"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "500"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"StreamPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "x"}], "+", 
         RowBox[{"a", "*", "y"}], "+", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", 
        RowBox[{"b", "-", 
         RowBox[{"a", "*", "y"}], "-", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "3"}], "}"}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}]}]}], "]"}], ",", 
    RowBox[{"ParametricPlot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], ",", 
          RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "solcyc"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "400", ",", "500"}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Thick"}], "}"}]}]}], "]"}]}], "}"}], 
  "]"}]}], "Input",
