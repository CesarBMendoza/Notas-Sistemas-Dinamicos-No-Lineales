Cell["\<\
S\[OAcute]lo basta que el punto de equilibrio sea repulsor para que las \
soluciones siempre salgan entren desde el c\[IAcute]rculo interior. \
Encontramos la matriz Jacobiana del sistema:\
\>", "Text",
 CellChangeTimes->{{3.888941801095003*^9, 3.888941807173481*^9}, {
  3.8889422006418304`*^9, 
  3.8889422348733788`*^9}},ExpressionUUID->"00287b82-6b76-4bd0-9f83-\
417313568e1e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "b", "]"}], "\[IndentingNewLine]", 
 RowBox[{"J", "=", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "x"}], "+", 
         RowBox[{"a", "*", "y"}], "+", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", "x"}], "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "x"}], "+", 
         RowBox[{"a", "*", "y"}], "+", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", "y"}], "]"}]},
     {
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"b", "-", 
         RowBox[{"a", "*", "y"}], "-", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", "x"}], "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"b", "-", 
         RowBox[{"a", "*", "y"}], "-", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", "y"}], "]"}]}
    }], "\[NoBreak]", ")"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.8889418096740913`*^9, 3.888941939800867*^9}},
 CellLabel->"In[34]:=",ExpressionUUID->"ca8356ff-2150-46be-a402-22c6559bb418"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"2", " ", "x", " ", "y"}]}], ",", 
     RowBox[{"a", "+", 
      SuperscriptBox["x", "2"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "2"}], " ", "x", " ", "y"}], ",", 
     RowBox[{
      RowBox[{"-", "a"}], "-", 
      SuperscriptBox["x", "2"]}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.888941882059622*^9, 3.8889419401106114`*^9},
 CellLabel->"Out[36]=",ExpressionUUID->"7d3aef98-1752-4806-8e9f-ef8648072fdc"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "[", "J", "]"}]], "Input",
 NumberMarks->False,
 CellLabel->"In[37]:=",ExpressionUUID->"50119996-4f7d-442b-911a-729bbe88cf06"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       RowBox[{"-", "1"}], "+", 
       RowBox[{"2", " ", "x", " ", "y"}]}], 
      RowBox[{"a", "+", 
       SuperscriptBox["x", "2"]}]},
     {
      RowBox[{
       RowBox[{"-", "2"}], " ", "x", " ", "y"}], 
      RowBox[{
       RowBox[{"-", "a"}], "-", 
       SuperscriptBox["x", "2"]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.8889419565881386`*^9},
 CellLabel->
  "Out[37]//MatrixForm=",ExpressionUUID->"71e6e6a8-9d0f-43d7-9307-\
9426942ca67c"]
}, Open  ]],

Cell["y la evaluamos en el putno de equilibrio:", "Text",
 CellChangeTimes->{{3.8889419810000277`*^9, 
  3.888941987278343*^9}},ExpressionUUID->"7cbbde2f-6043-44f5-ad01-\
8baf4957fa3e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"MatrixForm", "[", 
   RowBox[{"J", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "->", "b"}], ",", 
      RowBox[{"y", "->", 
       RowBox[{"b", "/", 
        RowBox[{"(", 
         RowBox[{"a", "+", 
          RowBox[{"b", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "]"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.88894198930786*^9, 3.8889420313774505`*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"b1b8faa3-b4e2-452b-9ef4-6bdaf44bae74"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"1", "-", 
       FractionBox[
        RowBox[{"2", " ", "a"}], 
        RowBox[{"a", "+", 
         SuperscriptBox["b", "2"]}]]}], 
      RowBox[{"a", "+", 
       SuperscriptBox["b", "2"]}]},
     {
      RowBox[{"-", 
       FractionBox[
        RowBox[{"2", " ", 
         SuperscriptBox["b", "2"]}], 
        RowBox[{"a", "+", 
         SuperscriptBox["b", "2"]}]]}], 
      RowBox[{
       RowBox[{"-", "a"}], "-", 
       SuperscriptBox["b", "2"]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{{3.8889420118687124`*^9, 3.888942031721724*^9}},
 CellLabel->
  "Out[39]//MatrixForm=",ExpressionUUID->"effd3581-c166-4115-bef5-\
1081b7eb7476"]
}, Open  ]],

Cell["La matriz tiene determinante:", "Text",
 CellChangeTimes->{{3.8889420469339075`*^9, 
  3.8889420522750406`*^9}},ExpressionUUID->"d488d7e1-1db4-4543-a51c-\
4014d9db5b5e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"Det", "[", 
   RowBox[{"J", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "->", "b"}], ",", 
      RowBox[{"y", "->", 
       RowBox[{"b", "/", 
        RowBox[{"(", 
         RowBox[{"a", "+", 
          RowBox[{"b", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "]"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.888942054296446*^9, 3.8889420727709646`*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"25690991-6bf4-411f-ab93-9377b2b9c68a"],

Cell[BoxData[
 RowBox[{"a", "+", 
  SuperscriptBox["b", "2"]}]], "Output",
 CellChangeTimes->{{3.888942062648717*^9, 3.8889420730220394`*^9}},
 CellLabel->"Out[41]=",ExpressionUUID->"c26b0a12-14f5-4d4f-a88f-c1908439200e"]
}, Open  ]],

Cell[TextData[{
 "el cual siempre es positivo para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], ",", 
         StyleBox["b", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a,b>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e9532604-3fbd-4b46-bd84-af95444b2625"],
 ", y traza:"
}], "Text",
 CellChangeTimes->{{3.8889420813090544`*^9, 
  3.888942094527305*^9}},ExpressionUUID->"9ff43406-2ece-46d4-ab98-\
77eb34fb55f0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"Tr", "[", 
   RowBox[{"J", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "->", "b"}], ",", 
      RowBox[{"y", "->", 
       RowBox[{"b", "/", 
        RowBox[{"(", 
         RowBox[{"a", "+", 
          RowBox[{"b", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "]"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.8889421020101604`*^9, 3.888942105190185*^9}},
 CellLabel->"In[42]:=",ExpressionUUID->"e860ff42-d885-4843-9e9b-b402f8abaa6f"],

Cell[BoxData[
 RowBox[{"1", "-", 
  SuperscriptBox["b", "2"], "+", 
  RowBox[{"a", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "-", 
     FractionBox["2", 
      RowBox[{"a", "+", 
       SuperscriptBox["b", "2"]}]]}], ")"}]}]}]], "Output",
 CellChangeTimes->{3.888942105963584*^9},
 CellLabel->"Out[42]=",ExpressionUUID->"9bcf5cb3-4691-421a-86c4-6a4db913bec4"]
}, Open  ]],

Cell["\<\
Esta expresi\[OAcute]n es dif\[IAcute]cil, pero podemos evaluar \
num\[EAcute]ricamente cuando la traza es positiva y, por lo tanto, el punto \
de equilibrio es repulsor, y se cumple el teorema de \
Poincar\[EAcute]-Bendixson:\
\>", "Text",
 CellChangeTimes->{{3.888942145739254*^9, 3.8889421881721582`*^9}, 
