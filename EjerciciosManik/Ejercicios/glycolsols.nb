Notebook[{

Cell[CellGroupData[{
Cell["Glic\[OAcute]lisis", "Title",
 CellChangeTimes->{{3.8889405526298666`*^9, 
  3.8889405543987474`*^9}},ExpressionUUID->"ab68cb3e-7c86-49a0-98b3-\
8d14bcb7db13"],

Cell[TextData[{
 "Las concentraciones de adenosindifosfato y fructosa-6-fosfato est\[AAcute]n \
dadas por el sistema de ecuaciones diferenciales no lineales:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", "-", 
         StyleBox["x", "TI"], "+", 
         StyleBox["a", "TI"], 
         StyleBox["y", "TI"], "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=-x+ay+x^2y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b9bc2f23-45df-4442-b279-2f59acfc9a8b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", 
         StyleBox["b", "TI"], "-", 
         StyleBox["a", "TI"], 
         StyleBox["y", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=b-ay-x^2y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7f2254f9-7f1e-4994-8963-4c0b191b5abc"],
 "\ndonde ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], ",", 
         StyleBox["b", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a,b>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "75cf97ae-72a0-44a6-b516-982c7cf3cce5"],
 " son par\[AAcute]metros. \nPrimero, veamos las ceroclinas:"
}], "Text",
 CellChangeTimes->{{3.8889405721605525`*^9, 
  3.8889406956891217`*^9}},ExpressionUUID->"019fb9a5-888f-4d35-9660-\
1e8c7eef6b4e"],

