Cell[BoxData[{
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"t", "+", "1"}], "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"r", "+", "1"}], ")"}], "*", 
          RowBox[{"A", "[", "t", "]"}]}], "-", 
         RowBox[{"r", "*", 
          RowBox[{
           RowBox[{"A", "[", "t", "]"}], "^", "2"}]}], "-", 
         RowBox[{"c", "*", 
          RowBox[{"A", "[", "t", "]"}], "*", 
          RowBox[{"B", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"B", "[", 
         RowBox[{"t", "+", "1"}], "]"}], "==", 
        RowBox[{"c", "*", 
         RowBox[{"A", "[", "t", "]"}], "*", 
         RowBox[{"B", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"A", "[", "1", "]"}], "==", "0.5"}], ",", 
       RowBox[{
        RowBox[{"B", "[", "1", "]"}], "==", "0.5"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"A", ",", "B"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "1000"}], "}"}]}], "]"}]}], 
