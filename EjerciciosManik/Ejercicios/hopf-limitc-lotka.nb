       RowBox[{"c", "*", "x", "*", "y"}]}], "<=", "1"}], "&&", 
     RowBox[{
      RowBox[{"y", "+", 
       RowBox[{"c", "*", "x", "*", "y"}]}], "<=", "1"}], "&&", 
     RowBox[{"0", "<", "x", "<", "1"}], "&&", 
     RowBox[{"0", "<", "y", "<", "1"}]}], "}"}], ",", 
