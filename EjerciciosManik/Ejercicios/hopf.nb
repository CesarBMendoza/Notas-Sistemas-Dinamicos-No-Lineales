Cell[TextData[{
 "Forma normal:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", "\[Mu]", 
         StyleBox["x", "TI"], "-", 
         StyleBox["y", "TI"], "-", 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["y", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\dot{x}=\\mu x-y-x(x^2+y^2)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "33b4e0ec-a995-45cf-ab5a-be74818996d8"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", 
         StyleBox["x", "TI"], "+", "\[Mu]", 
         StyleBox["y", "TI"], "-", 
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["y", "TI"], "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\dot{y}=x+\\mu y-y(x^2+y^2)", "state" -> 
     "Boxes"|>,
