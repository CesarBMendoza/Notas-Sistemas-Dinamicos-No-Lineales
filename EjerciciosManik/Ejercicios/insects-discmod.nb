Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"2", "*", "mu"}], "-", "2"}], "==", 
    RowBox[{
     RowBox[{"mu", "*", 
      RowBox[{"Log", "[", "s", "]"}]}], "-", 
     RowBox[{"mu", "*", 
      RowBox[{"Log", "[", "mu", "]"}]}]}]}], ",", "s"}], "]"}]], "Input",
 CellChangeTimes->{{3.8915457362572494`*^9, 3.891545806740039*^9}},
 CellLabel->"In[32]:=",ExpressionUUID->"6c5cf61f-8cef-46e0-a3b7-dbec922a4ba0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"s", "\[Rule]", 
    TemplateBox[{
      SuperscriptBox["\[ExponentialE]", 
       FractionBox[
        RowBox[{
          RowBox[{"-", "2"}], "+", 
          RowBox[{"2", " ", "mu"}], "+", 
          RowBox[{"mu", " ", 
            RowBox[{"Log", "[", "mu", "]"}]}]}], "mu"]], 
      RowBox[{
        RowBox[{"-", "\[Pi]"}], "<", 
        RowBox[{"Im", "[", 
          FractionBox[
           RowBox[{
             RowBox[{"-", "2"}], "+", 
             RowBox[{"2", " ", "mu"}], "+", 
             RowBox[{"mu", " ", 
               RowBox[{"Log", "[", "mu", "]"}]}]}], "mu"], "]"}], 
        "\[LessEqual]", "\[Pi]"}]},
     "ConditionalExpression"]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{3.8915457767885065`*^9, 3.891545807439538*^9},
 CellLabel->"Out[32]=",ExpressionUUID->"3d502ba8-3b9b-4608-a958-d6bb6d95a0f8"]
}, Open  ]],

Cell[CellGroupData[{

