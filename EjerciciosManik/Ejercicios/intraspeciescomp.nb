Cell[BoxData[
 RowBox[{
  RowBox[{"srisu", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"n", "+", "1"}], "]"}], "==", 
        RowBox[{"4", "*", 
         RowBox[{"x", "[", "n", "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "2"}], "*", 
           RowBox[{"x", "[", "n", "]"}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "0.01"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "15"}], "}"}]}], "]"}]}], ";"}]], "Input",
