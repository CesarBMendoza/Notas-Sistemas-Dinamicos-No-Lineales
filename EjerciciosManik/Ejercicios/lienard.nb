Cell[CellGroupData[{

Cell["Oscilaciones de relajaci\[OAcute]n", "Section",
 CellChangeTimes->{{3.893848273656912*^9, 
  3.8938482773642473`*^9}},ExpressionUUID->"69a37e70-e165-4e17-aec3-\
e616101fbf79"],

Cell[TextData[{
 "Caracterizaremos las oscilaciones de la ecuaci\[OAcute]n de van der Pol, un \
caso espec\[IAcute]fico de sistema de Li\[EAcute]nard\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[Prime]\[Prime]"], "+", "\[Mu]", 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "2"], "-", "1"}], ")"}], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[Prime]"], "+", 
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x''+\\mu(x^2-1)x'+x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1b80978f-5e3b-47a0-a8e8-b9f25b08b849"],
 "\nPrimero examinamos el espacio fase:"
}], "Text",
 CellChangeTimes->{{3.8938487908880615`*^9, 3.893848816998188*^9}, {
  3.893848859768214*^9, 
  3.8938488704538207`*^9}},ExpressionUUID->"bcf4c9e3-dc05-4d12-902d-\
6c0f1cde8dbf"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Mu]", "=", "50"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol2", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"\[Mu]", "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "-", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "[", "t", "]"}], "^", "3"}], "/", "3"}], "+", 
          RowBox[{"x", "[", "t", "]"}]}], ")"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"x", "[", "t", "]"}]}], "/", "\[Mu]"}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", 
       RowBox[{"-", "1"}]}], ",", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "300"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.8598959873896255`*^9, 3.8598960452203255`*^9}, {
  3.8598961191651373`*^9, 3.8598961297627416`*^9}, {3.859896171998834*^9, 
  3.859896200046091*^9}, {3.859896551486499*^9, 3.859896556214041*^9}, {
  3.8598966517214613`*^9, 3.8598966532408433`*^9}, {3.8938488779085245`*^9, 
  3.8938488940974965`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"760162ac-801e-4888-9ff0-0be9bef5218c"],

