Cell[TextData[{
 "La teor\[IAcute]a aproximada nos dice que el per\[IAcute]odo debe ser ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["T", "TI"], "\[TildeTilde]", "\[Mu]", 
         RowBox[{"(", 
           RowBox[{"3", "-", "2", "ln", "2"}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "T\\approx\\mu(3-2\\ln2)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e22a9328-e07e-4650-b53d-bb087af9e95f"]
}], "Text",
 CellChangeTimes->{{3.893848940302787*^9, 3.893848954107751*^9}, {
  3.8938490453893003`*^9, 
  3.8938490573920584`*^9}},ExpressionUUID->"4ceb072d-7073-418c-8c36-\
02cbbf0de834"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{"\[Mu]", "*", 
   RowBox[{"(", 
    RowBox[{"3", "-", 
     RowBox[{"2", "*", 
      RowBox[{"Log", "[", "2", "]"}]}]}], ")"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.893849059492506*^9, 3.8938490738933487`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"d0a2775e-b5dd-4d2c-a8f6-d488b09f773d"],

Cell[BoxData["80.68528194400547`"], "Output",
 CellChangeTimes->{3.8938490743626356`*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"7bd3f1fc-0369-457d-8bdb-2e69c9ed7d7c"]
}, Open  ]],

Cell["Num\[EAcute]ricamente encontramos:", "Text",
 CellChangeTimes->{{3.893849088825642*^9, 
  3.893849093576568*^9}},ExpressionUUID->"3d9df9b9-b392-46fc-8306-\
faf68158c78c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"xsolvdp", ",", "ysolvdp"}], "}"}], "=", 
   RowBox[{"NDSolveValue", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"\[Mu]", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"y", "[", "t", "]"}], "-", 
           RowBox[{
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], "^", "3"}], "/", "3"}], "+", 
           RowBox[{"x", "[", "t", "]"}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"x", "[", "t", "]"}]}], "/", "\[Mu]"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", 
        RowBox[{"-", "1"}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "500"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"t", "/.", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"xsolvdp", "[", "t", "]"}], "==", "0"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "170"}], "}"}]}], "]"}]}], ")"}], "-", 
   RowBox[{"(", 
    RowBox[{"t", "/.", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"xsolvdp", "[", "t", "]"}], "==", "0"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "90"}], "}"}]}], "]"}]}], ")"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.8938491002251015`*^9, 3.8938492833829794`*^9}, {
  3.8938493532590795`*^9, 3.893849370297083*^9}, {3.893849513460758*^9, 
  3.893849514109181*^9}, {3.893849569014209*^9, 3.8938495735320168`*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"2f4e7a9c-ff96-44c0-9a70-a814a2575daf"],

