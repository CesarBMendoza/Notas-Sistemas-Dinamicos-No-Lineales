Notebook[{

Cell[CellGroupData[{
Cell["Sistemas de Li\[EAcute]nard", "Title",
 CellChangeTimes->{{3.8938475657543163`*^9, 
  3.893847569752737*^9}},ExpressionUUID->"571e7e3d-15c0-4001-ac8d-\
874ba7d05d7a"],

Cell[TextData[{
 "Tienen la forma general:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[Prime]\[Prime]"], "+", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[Prime]"], "+", 
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x''+f(x)x'+g(x)=0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "19801f61-ff2d-4253-94ee-02c4b5005832"],
 "\nDonde ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "g(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3bf00230-455f-4ddd-9eb2-b0c5a2c1f08c"],
 " es una funci\[OAcute]n impar y positiva para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7255a1dc-8851-49b4-a654-08fbcdd8fe5d"],
 " positivas, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "445cec32-658c-4338-8d4a-e4f9b0bc9c0c"],
 " es una funci\[OAcute]n par tal que su integral sea negativa para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"0", "<", 
         StyleBox["x", "TI"], "<", 
         StyleBox["a", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "0<x<a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "162de82c-7078-4f1d-a09d-2d957f9aa798"],
 ", cero en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["a", "TI"], TraditionalForm], "errors" -> {}, "input" -> "a", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6f7aebe1-28c2-4e28-b7ba-7fb4381f6c07"],
 " y positiva para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], ">", 
         StyleBox["a", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x>a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e6059345-fb55-4d3b-a71b-4833cf2d9e4c"],
 "."
}], "Text",
 CellChangeTimes->{{3.893847576563966*^9, 3.8938475845195932`*^9}, {
  3.893847615935893*^9, 3.89384769475714*^9}, {3.8938477648585835`*^9, 
  3.8938477966025825`*^9}},ExpressionUUID->"def92fad-670f-44d3-a34b-\
974fa23dab07"],

Cell[CellGroupData[{

Cell[TextData[{
 "Ejemplo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[Prime]\[Prime]"], "-", "2", "cos", 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[Prime]"], "+", "tanh", 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "x''-2\\cos(x)x'+\\tanh(x)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "43e648fa-4de7-4973-a4a1-e3f8568fde58"]
}], "Section",
 CellChangeTimes->{{3.89384798883568*^9, 
  3.893847996586808*^9}},ExpressionUUID->"9bddf724-9e47-4a3b-a6f0-\
c1ee111b5a04"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sp1", "=", 
  RowBox[{"StreamPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{
       RowBox[{"2", "*", 
        RowBox[{"Cos", "[", "x", "]"}], "*", "y"}], "-", 
       RowBox[{"Tanh", "[", "x", "]"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{
       RowBox[{"-", "3"}], "*", "Pi"}], ",", 
      RowBox[{"3", "*", "Pi"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{
       RowBox[{"-", "3"}], "*", "Pi"}], ",", 
      RowBox[{"3", "*", "Pi"}]}], "}"}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"OverDot", "[", "x", "]"}]}], "}"}]}]}], "]"}]}]], "Input",
