Cell[BoxData[
 RowBox[{"sol1", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "''"}], "[", "t", "]"}], "-", 
        RowBox[{"2", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"x", "[", "t", "]"}], "]"}], "*", 
         RowBox[{
          RowBox[{"x", "'"}], "[", "t", "]"}]}], "+", 
        RowBox[{"Tanh", "[", 
         RowBox[{"x", "[", "t", "]"}], "]"}]}], "==", "0"}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "0", "]"}], "==", 
       RowBox[{"-", "0.01"}]}]}], "}"}], ",", "x", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "50"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.859895397376068*^9, 3.859895516037633*^9}, {
