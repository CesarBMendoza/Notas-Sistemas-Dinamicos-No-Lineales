Cell[TextData[{
 "Ecuaci\[OAcute]n del p\[EAcute]ndulo amortiguado:\nEcuaci\[OAcute]n del p\
\[EAcute]ndulo cl\[AAcute]sico:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5ee73d01-d2b5-4306-ab1e-669db00e2568"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", "-", 
         FractionBox[
          StyleBox["g", "TI"], 
          StyleBox["L", "TI"]], "sin", 
         StyleBox["x", "TI"], "-", 
         FractionBox[
          StyleBox["c", "TI"], 
          RowBox[{
            StyleBox["m", "TI"], 
            StyleBox["L", "TI"]}]], 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=-\\frac{g}{L}\\sin x-\\frac{c}{mL}y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "29360b45-ec2d-4199-96be-9bd07b7433c9"],
 "\nEnerg\[IAcute]a total (cin\[EAcute]tica m\[AAcute]s potencial):\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["V", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox["1", "2"], 
         StyleBox["m", "TI"], 
         SuperscriptBox[
          StyleBox["L", "TI"], "2"], 
         SuperscriptBox[
          StyleBox["y", "TI"], "2"], "+", 
         StyleBox["m", "TI"], 
         StyleBox["g", "TI"], 
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", "cos", 
             StyleBox["x", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "V(x,y)=\\frac{1}{2}mL^2y^2+mgL(1-\\cos x)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "deeea9de-8667-486e-a943-59562b1a85ae"],
 "\nLa energ\[IAcute]a en las soluciones:"
}], "Text",
 CellChangeTimes->{{3.890931124958206*^9, 
  3.8909311414963255`*^9}},ExpressionUUID->"8498ac7d-f4da-46b0-9aaa-\
dfeaf6203aff"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"c", "=", "0.3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"y", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "g"}], "*", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"x", "[", "t", "]"}], "]"}], "/", "L"}]}], "-", 
         RowBox[{"c", "*", 
          RowBox[{
           RowBox[{"y", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"m", "*", "L"}], ")"}]}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "6.5"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "30"}], "}"}]}], "]"}]}], ";", 
  RowBox[{"Show", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Plot3D", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "2"}], ")"}], "*", "m", "*", 
         RowBox[{"(", 
          RowBox[{"L", "^", "2"}], ")"}], "*", 
         RowBox[{"y", "^", "2"}]}], "+", 
        RowBox[{"m", "*", "g", "*", "L", "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"Cos", "[", "x", "]"}]}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "9"}], ",", "9"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "7"}], ",", "7"}], "}"}], ",", 
       RowBox[{"AxesLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y", ",", "V"}], "}"}]}], ",", 
