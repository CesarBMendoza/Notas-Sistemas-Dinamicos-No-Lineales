Notebook[{

Cell[CellGroupData[{
Cell["Funci\[OAcute]n de Lyapunov", "Title",
 CellChangeTimes->{{3.890930264317709*^9, 
  3.8909302675164833`*^9}},ExpressionUUID->"c6cd7b13-1d91-4134-976b-\
313a01b1e200"],

Cell[TextData[{
 "Ecuaci\[OAcute]n del p\[EAcute]ndulo cl\[AAcute]sico:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3ae97c48-c154-434c-90f4-f3e5364a357a"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", "-", 
         FractionBox[
          StyleBox["g", "TI"], 
          StyleBox["L", "TI"]], "sin", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=-\\frac{g}{L}\\sin x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "002e41b9-ea4f-4bd6-a03f-011cd8fe1e39"],
 "\nEnerg\[IAcute]a total (cin\[EAcute]tica m\[AAcute]s potencial):\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["V", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox["1", "2"], 
         StyleBox["m", "TI"], 
         SuperscriptBox[
          StyleBox["L", "TI"], "2"], 
         SuperscriptBox[
          StyleBox["y", "TI"], "2"], "+", 
         StyleBox["m", "TI"], 
         StyleBox["g", "TI"], 
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", "cos", 
             StyleBox["x", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "V(x,y)=\\frac{1}{2}mL^2y^2+mgL(1-\\cos x)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8ccb15ab-a471-4e54-bb8a-b760baadcde8"],
 "\nLa energ\[IAcute]a en las soluciones:"
}], "Text",
 CellChangeTimes->{{3.8909302723809547`*^9, 3.8909303396833825`*^9}, {
  3.8909305076693225`*^9, 
  3.890930546397379*^9}},ExpressionUUID->"a2581031-6c9c-437f-b9d3-\
6ac6fcbcbbbd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"g", "=", "9.81"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L", "=", 
   RowBox[{"1", "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"y", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "g"}], "*", 
         RowBox[{
          RowBox[{"Sin", "[", 
           RowBox[{"x", "[", "t", "]"}], "]"}], "/", "L"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "6.5"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "20"}], "}"}]}], "]"}]}], ";", 
  RowBox[{"Show", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Plot3D", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "2"}], ")"}], "*", "m", "*", 
         RowBox[{"(", 
          RowBox[{"L", "^", "2"}], ")"}], "*", 
         RowBox[{"y", "^", "2"}]}], "+", 
        RowBox[{"m", "*", "g", "*", "L", "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"Cos", "[", "x", "]"}]}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "9"}], ",", "9"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "7"}], ",", "7"}], "}"}], ",", 
       RowBox[{"AxesLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y", ",", "V"}], "}"}]}], ",", 
       RowBox[{"PlotPoints", "\[Rule]", "50"}]}], "]"}], ",", 
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], ",", 
           RowBox[{"y", "[", "t", "]"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "2"}], ")"}], "*", "m", "*", 
             RowBox[{"(", 
              RowBox[{"L", "^", "2"}], ")"}], "*", 
             RowBox[{
              RowBox[{"y", "[", "t", "]"}], "^", "2"}]}], "+", 
            RowBox[{"m", "*", "g", "*", "L", "*", 
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{"Cos", "[", 
                RowBox[{"x", "[", "t", "]"}], "]"}]}], ")"}]}]}]}], "}"}], "/.",
          "sol1"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "20"}], "}"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Blue", ",", "Thick"}], "}"}]}]}], "]"}]}], "}"}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.8909305531186647`*^9, 3.8909306537438407`*^9}, {
  3.8909306903428745`*^9, 3.8909307518978753`*^9}, {3.890930857280921*^9, 
  3.8909310515253525`*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"9c3522d0-48a2-4096-983b-0fc1c4677c0c"],

