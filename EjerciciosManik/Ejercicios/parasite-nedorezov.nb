Cell["Finalmente evaluando el \[UAcute]tlimo punto de equilibrio", "Text",
 CellChangeTimes->{{3.8437395215801096`*^9, 
  3.8437395365414314`*^9}},ExpressionUUID->"db79209f-a8a7-477b-b249-\
182a7a60d1c5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "[", 
  RowBox[{"jac1", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "->", "1"}], ",", 
     RowBox[{"y", "->", "1"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8437395742572236`*^9, 3.843739579552913*^9}},
 CellLabel->"In[52]:=",ExpressionUUID->"0bfddf97-a263-4615-8c8c-d592b3a5ee00"],

Cell[BoxData[
 TagBox[
  TagBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{"1", "-", "k1"}], 
       RowBox[{"k1", "-", "k2"}]},
      {
       RowBox[{"1", "-", "k1"}], 
       RowBox[{"1", "+", "k1", "-", "k2"}]}
     },
     GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
     GridBoxSpacings->{"Columns" -> {
         Offset[0.27999999999999997`], {
          Offset[0.7]}, 
         Offset[0.27999999999999997`]}, "Rows" -> {
         Offset[0.2], {
          Offset[0.4]}, 
         Offset[0.2]}}], "\[NoBreak]", ")"}],
   Function[BoxForm`e$, 
    MatrixForm[BoxForm`e$]]],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.843739579928014*^9},
 CellLabel->
  "Out[52]//MatrixForm=",ExpressionUUID->"2b7ef2c5-a5cd-49a4-9697-\
eac7c80cd22d"]
}, Open  ]],

Cell["Y calculando sus eigenvalores", "Text",
 CellChangeTimes->{{3.8437395884047008`*^9, 
  3.843739592963891*^9}},ExpressionUUID->"de900e1d-0f02-45fc-8f45-\
bcf1b4369d7b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Eigenvalues", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "-", "k1"}], ",", 
      RowBox[{"k1", "-", "k2"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "-", "k1"}], ",", 
      RowBox[{"1", "+", "k1", "-", "k2"}]}], "}"}]}], "}"}], "]"}]], "Input",
 NumberMarks->False,
 CellLabel->"In[53]:=",ExpressionUUID->"79be32f0-70bf-4c50-a6c8-92170100b909"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{"(", 
     RowBox[{"2", "-", "k2", "-", 
      SqrtBox[
       RowBox[{
        RowBox[{"4", " ", "k1"}], "-", 
        RowBox[{"4", " ", "k2"}], "+", 
        SuperscriptBox["k2", "2"]}]]}], ")"}]}], ",", 
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{"(", 
     RowBox[{"2", "-", "k2", "+", 
      SqrtBox[
       RowBox[{
        RowBox[{"4", " ", "k1"}], "-", 
        RowBox[{"4", " ", "k2"}], "+", 
        SuperscriptBox["k2", "2"]}]]}], ")"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.8437395856022053`*^9},
 CellLabel->"Out[53]=",ExpressionUUID->"29b4d879-5116-471d-852b-bf4d785817f9"]
}, Open  ]],

Cell["\<\
Los guardamos en variables para determinar donde su m\[OAcute]dulo es menor a \
uno despu\[EAcute]s:\
\>", "Text",
 CellChangeTimes->{{3.8437396045454655`*^9, 
  3.84373962100334*^9}},ExpressionUUID->"8f1a9a12-6dfc-4a2f-9fce-\
a914fbf4e23b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eig1", "=", 
   RowBox[{
    RowBox[{"Eigenvalues", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "-", "k1"}], ",", 
         RowBox[{"k1", "-", "k2"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "-", "k1"}], ",", 
         RowBox[{"1", "+", "k1", "-", "k2"}]}], "}"}]}], "}"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eig2", "=", 
   RowBox[{
    RowBox[{"Eigenvalues", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "-", "k1"}], ",", 
         RowBox[{"k1", "-", "k2"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "-", "k1"}], ",", 
         RowBox[{"1", "+", "k1", "-", "k2"}]}], "}"}]}], "}"}], "]"}], "[", 
    RowBox[{"[", "2", "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.843739632813009*^9, 3.843739649509802*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"a2729343-e54e-4722-aa4c-c01c398aed3a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RegionPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", "eig1", "]"}], "<", "1"}], " ", "&&", " ", 
    RowBox[{
     RowBox[{"Abs", "[", "eig2", "]"}], "<", "1"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"k1", ",", 
     RowBox[{"-", "1"}], ",", "5"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"k2", ",", 
     RowBox[{"-", "1"}], ",", "5"}], "}"}], ",", 
   RowBox[{"PlotPoints", "\[Rule]", "100"}], ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Subscript", "[", 
       RowBox[{"k", ",", "1"}], "]"}], ",", 
      RowBox[{"Subscript", "[", 
       RowBox[{"k", ",", "2"}], "]"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8437396740460215`*^9, 3.843739680592721*^9}},
 CellLabel->"In[56]:=",ExpressionUUID->"f91ce78b-8697-47e9-b14c-eecd1dd4d616"],

