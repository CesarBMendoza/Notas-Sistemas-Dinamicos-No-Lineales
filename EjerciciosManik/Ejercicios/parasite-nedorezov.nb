Cell["\<\
Poniendo las regiones de estabilidad juntas, obtenemos el diagrama de fases:\
\>", "Text",
 CellChangeTimes->{{3.84373987513575*^9, 
  3.843739895933112*^9}},ExpressionUUID->"f3b53e6d-0ebf-4d91-9b4c-\
e7fe2b9909fb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RegionPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Exp", "[", "k2", "]"}], "<", "1"}], ",", 
     RowBox[{
      RowBox[{"2", ">", "k2", ">", "0"}], " ", "&&", " ", 
      RowBox[{"k2", "<", "k1"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", "eig1", "]"}], "<", "1"}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"Abs", "[", "eig2", "]"}], "<", "1"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"k1", ",", "0", ",", "4"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"k2", ",", 
     RowBox[{"-", "1"}], ",", "4"}], "}"}], ",", 
   RowBox[{"PlotPoints", "\[Rule]", "100"}], ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Subscript", "[", 
       RowBox[{"k", ",", "1"}], "]"}], ",", 
      RowBox[{"Subscript", "[", 
       RowBox[{"k", ",", "2"}], "]"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.843739916128395*^9, 3.8437400299541917`*^9}},
