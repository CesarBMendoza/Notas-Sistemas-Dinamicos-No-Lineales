Cell["\<\
Ahora podemos estudiar el comportamiento de las soluciones en cada regi\
\[OAcute]n.
En la regi\[OAcute]n azul:\
\>", "Text",
 CellChangeTimes->{{3.8437400909856024`*^9, 
  3.843740115189131*^9}},ExpressionUUID->"710d2ec6-fc1c-4643-9c31-\
f793bb2b9905"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"A", "=", "0.9"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]", "=", "0.02"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", "0.5"}], ";"}]}], "Input",
 CellChangeTimes->{{3.84366604105123*^9, 3.843666099577747*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"2dce3d0f-3f0d-45eb-bda9-e3f48a297659"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sst", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{"A", "*", 
         RowBox[{"x", "[", "k", "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Alpha]"}], "*", 
            RowBox[{"x", "[", "k", "]"}]}], "-", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y", "[", "k", "]"}]}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{"A", "*", "b", "*", "\[Gamma]", "*", 
         RowBox[{"x", "[", "k", "]"}], "*", 
         RowBox[{"y", "[", "k", "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Alpha]"}], "*", 
            RowBox[{"x", "[", "k", "]"}]}], "-", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y", "[", "k", "]"}]}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "10"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1", "]"}], "==", "0.001"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "200"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.843666108381748*^9, 3.843666248895176*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"4450c949-f093-4ff0-879e-2ec234e0846d"],

