Cell[BoxData[
 RowBox[{
  RowBox[{"sst5", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{"A", "*", 
         RowBox[{"x", "[", "k", "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Alpha]"}], "*", 
            RowBox[{"x", "[", "k", "]"}]}], "-", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y", "[", "k", "]"}]}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{"A", "*", "b", "*", "\[Gamma]", "*", 
         RowBox[{"x", "[", "k", "]"}], "*", 
         RowBox[{"y", "[", "k", "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Alpha]"}], "*", 
            RowBox[{"x", "[", "k", "]"}]}], "-", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y", "[", "k", "]"}]}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "10"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1", "]"}], "==", "0.001"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "200"}], "}"}]}], "]"}]}], ";"}]], "Input",
