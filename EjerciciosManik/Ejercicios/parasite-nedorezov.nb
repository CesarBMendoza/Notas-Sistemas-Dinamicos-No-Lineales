Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"jac1", "=", 
  RowBox[{"MatrixForm", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"f1", "[", 
          RowBox[{"x", ",", "y"}], "]"}], ",", "x"}], "]"}], ",", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"f1", "[", 
          RowBox[{"x", ",", "y"}], "]"}], ",", "y"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"g1", "[", 
          RowBox[{"x", ",", "y"}], "]"}], ",", "x"}], "]"}], ",", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"g1", "[", 
          RowBox[{"x", ",", "y"}], "]"}], ",", "y"}], "]"}]}], "}"}]}], "}"}],
    "]"}]}]], "Input",
 CellChangeTimes->{{3.8437385904555054`*^9, 3.8437386171209097`*^9}},
 CellLabel->"In[29]:=",ExpressionUUID->"d58b9ad0-d595-4024-8d20-bcfb34cc4592"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"k2", " ", 
          RowBox[{"(", 
           RowBox[{"1", "-", "y"}], ")"}]}], "+", 
         RowBox[{"k1", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "x"}], "+", "y"}], ")"}]}]}]], "-", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"k2", " ", 
           RowBox[{"(", 
            RowBox[{"1", "-", "y"}], ")"}]}], "+", 
