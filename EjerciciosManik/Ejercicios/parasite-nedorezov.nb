            RowBox[{"x", "[", "k", "]"}]}], "-", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y", "[", "k", "]"}]}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{"A", "*", "b", "*", "\[Gamma]", "*", 
         RowBox[{"x", "[", "k", "]"}], "*", 
         RowBox[{"y", "[", "k", "]"}], "*", 
