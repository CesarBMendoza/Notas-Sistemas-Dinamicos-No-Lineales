Cell["Los lados derechos de las ecuaciones son las funciones:", "Text",
 CellChangeTimes->{{3.843738511203576*^9, 
  3.8437385212856092`*^9}},ExpressionUUID->"e3625f68-577b-44e3-b20b-\
df715323d61e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f1", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{"x", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"k1", "*", 
      RowBox[{"(", 
       RowBox[{"y", "-", "x"}], ")"}]}], "]"}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"k2", "*", 
      RowBox[{"(", 
       RowBox[{"1", "-", "y"}], ")"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g1", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{"x", "*", "y", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"k1", "*", 
      RowBox[{"(", 
       RowBox[{"y", "-", "x"}], ")"}]}], "]"}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"k2", "*", 
      RowBox[{"(", 
       RowBox[{"1", "-", "y"}], ")"}]}], "]"}]}]}], ";"}]}], "Input",
 CellLabel->"In[26]:=",ExpressionUUID->"85097a5d-5369-468a-8ca2-25cb13e1d697"],

