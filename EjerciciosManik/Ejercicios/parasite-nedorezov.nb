  RowBox[{"b", "=", "0.5"}], ";"}]}], "Input",
 CellChangeTimes->{3.8436667475542603`*^9},
 CellLabel->"In[79]:=",ExpressionUUID->"f0a0e439-64d8-4bc4-a629-31a9300592fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sst3", "=", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{"A", "*", 
         RowBox[{"x", "[", "k", "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Alpha]"}], "*", 
            RowBox[{"x", "[", "k", "]"}]}], "-", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y", "[", "k", "]"}]}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"k", "+", "1"}], "]"}], "==", 
        RowBox[{"A", "*", "b", "*", "\[Gamma]", "*", 
         RowBox[{"x", "[", "k", "]"}], "*", 
         RowBox[{"y", "[", "k", "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Alpha]"}], "*", 
            RowBox[{"x", "[", "k", "]"}]}], "-", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y", "[", "k", "]"}]}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], "==", "10"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1", "]"}], "==", "0.001"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "200"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8436667695196853`*^9, 3.8436667695975904`*^9}},
 CellLabel->"In[83]:=",ExpressionUUID->"080c71b6-f0ad-4e62-bbbc-a379fda919a8"],

