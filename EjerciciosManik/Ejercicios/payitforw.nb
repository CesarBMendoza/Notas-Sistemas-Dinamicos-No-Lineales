 RowBox[{
  RowBox[{
   RowBox[{"f2", "[", 
    RowBox[{"n_", ",", "A_"}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"a", "*", 
            RowBox[{"n", "/", "A"}]}], ")"}], "*", "n", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"P", "-", "n"}], ")"}], "/", "P"}]}], "-", 
         RowBox[{"m", "*", "n"}]}], ",", 
        RowBox[{"n", "<", "A"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "*", "n", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"P", "-", "n"}], ")"}], "/", "P"}]}], "-", 
         RowBox[{"m", "*", "n"}]}], ",", 
        RowBox[{"n", ">=", "A"}]}], "}"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9484633098421116`*^9, 3.948463442963375*^9}},
