Cell[CellGroupData[{

Cell["Segunda forma", "Section",
 CellChangeTimes->{{3.9484846255334644`*^9, 
  3.948484627158539*^9}},ExpressionUUID->"a5dd28b9-f081-5b45-967c-\
91545f5ed7ed"],

Cell[TextData[{
 "En segunda instancia, consideramos la forma funcional\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], 
         RowBox[{"(", 
           StyleBox["N", "TI"], ")"}], "\[LongEqual]", "\[Alpha]", 
         StyleBox["min", FontSlant -> "Plain"], 
         RowBox[{"{", 
           RowBox[{
             FractionBox[
              StyleBox["N", "TI"], 
              StyleBox["A", "TI"]], ",", "1"}], "}"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "c(N)=\\alpha\\mathrm{min}\\{\\frac{N}{A},1\\}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "eb60f0d2-f7a3-8447-b309-0a7a77a2aa4a"],
 "\nlo cual nos dice que, si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["N", "TI"], "<", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "N<A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f64aca38-c1d7-5840-85bd-829cf34f43c2"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], 
         RowBox[{"(", 
           StyleBox["N", "TI"], ")"}], "\[LongEqual]", "\[Alpha]", 
         FractionBox[
          StyleBox["N", "TI"], 
          StyleBox["A", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "c(N)=\\alpha\\frac{N}{A}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf8c8f56-bbc4-c145-aab8-85164f2d2454"],
 ", mientras que si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["N", "TI"], ">", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "N>A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "19895f3a-4c2c-864e-ba8c-935a85aecbb0"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], 
         RowBox[{"(", 
           StyleBox["N", "TI"], ")"}], "\[LongEqual]", "\[Alpha]"}], 
       TraditionalForm], "errors" -> {}, "input" -> "c(N)=\\alpha", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "98d7d5d9-dd46-a146-8ed4-e9a24e069db4"],
 ". Su gr\[AAcute]fica se ve como"
}], "Text",
 CellChangeTimes->{{3.9484846598012733`*^9, 3.9484846692758293`*^9}, {
  3.948484751624754*^9, 3.9484847544798145`*^9}, {3.9484847886876583`*^9, 
  3.948484853244646*^9}},ExpressionUUID->"07554c56-0761-ba46-982b-\
381fdac137b2"],

