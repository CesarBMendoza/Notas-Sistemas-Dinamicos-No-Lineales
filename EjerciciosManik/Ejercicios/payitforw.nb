      FormBox["A", TraditionalForm]}}, {{0.5, 
      FormBox[
       RowBox[{"0.5`", " ", "\[Alpha]"}], TraditionalForm]}, {1, 
      FormBox["\[Alpha]", TraditionalForm]}}}]], "Output",
 CellChangeTimes->{
