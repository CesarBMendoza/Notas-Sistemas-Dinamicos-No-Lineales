Cell[CellGroupData[{
Cell["El oscilador arm\[OAcute]nico amortiguado", "Title",
 CellChangeTimes->{{3.8908555103078833`*^9, 
  3.890855517312764*^9}},ExpressionUUID->"d31e0b1a-aac7-44e2-87e1-\
c8879566cc8b"],

Cell[TextData[{
 "Las ecuaciones de movimiento son:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1c179dd4-20e3-4e54-833e-9e2e192f3b19"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", "-", 
         SuperscriptBox["\[Omega]", "2"], "sin", 
         StyleBox["x", "TI"], "-", "\[Gamma]", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{y}=-\\omega^2\\sin x-\\gamma y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f7ee9879-dfe8-4bd3-a371-c28ed860f552"],
 "\nFijamos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Gamma]", "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\gamma=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3a3e475b-beaa-418c-9df2-0ae08656664c"],
 " y variamos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["\[Omega]", "2"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\omega^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aae9ba22-9f3c-4184-a76e-8b81f69f0eca"],
 " y vemos las trayectorias:"
}], "Text",
 CellChangeTimes->{{3.8908555233391733`*^9, 3.890855528252222*^9}, {
   3.890855566929744*^9, 3.8908555819768267`*^9}, 3.8908556956072893`*^9, {
   3.8908557677128897`*^9, 
   3.890855800581339*^9}},ExpressionUUID->"ab3e33e4-63c1-4ecd-8c8f-\
9ecd52e0af77"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"StreamPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"\[Omega]", "^", "2"}], ")"}]}], "*", 
         RowBox[{"Sin", "[", "x", "]"}]}], "-", "y"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}]}], ",", 
     RowBox[{"AspectRatio", "\[Rule]", 
      RowBox[{"1", "/", "2"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Omega]", ",", "0", ",", "1"}], "}"}]}], "]"}]], "Input",
