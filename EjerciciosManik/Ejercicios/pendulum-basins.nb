Cell[BoxData[
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"y", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "9"}], "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"x", "[", "t", "]"}], "]"}]}], "-", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "/", "5"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "1000", "]"}], "==", 
        RowBox[{"Pi", "+", 
         RowBox[{"0.001", "*", 
          RowBox[{"(", 
           RowBox[{"-", "0.32240735599563636`"}], ")"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "1000", "]"}], "==", "0.001"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8907462635296774`*^9, 3.8907463145602655`*^9}, {
  3.890746357063902*^9, 3.8907464164090996`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"a850c4a1-7ea1-419c-b7a9-8f70332b392c"],

