Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           RowBox[{"2", "-", 
             StyleBox["x", "TI"], "-", 
             StyleBox["y", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\dot{x}=x(2-x-y)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ecbe7c5f-8731-4727-a655-fb668994b4d2"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"], 
         RowBox[{"(", 
           RowBox[{"4", 
             StyleBox["x", "TI"], "-", 
             SuperscriptBox[
              StyleBox["x", "TI"], "2"], "-", "3"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\dot{y}=y(4x-x^2-3)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5190802f-d554-4d42-b1c3-b9e1552589ba"],
 "\nSea ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{
            StyleBox["x", "TI"], 
            StyleBox["y", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "g(x,y)=\\frac{1}{xy}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "04ea941b-77f3-409e-92be-3b9cc3dd5a54"],
 ", entonces:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Del]", "\[CenterDot]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["g", "TI"], 
             OverscriptBox[
              OverscriptBox[
               StyleBox["x", "TI"], "\[RightVector]"], "."]}], ")"}], 
         "\[LongEqual]", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["g", "TI"], 
             SubscriptBox[
              StyleBox["f", "TI"], "1"]}], ")"}], "+", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["y", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["g", "TI"], 
             SubscriptBox[
              StyleBox["f", "TI"], "2"]}], ")"}], "\[LongEqual]", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", 
           FractionBox[
            RowBox[{"2", "-", 
              StyleBox["x", "TI"], "-", 
              StyleBox["y", "TI"]}], 
            StyleBox["y", "TI"]], ")"}], "+", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["y", "TI"]}]], 
         RowBox[{"(", 
           FractionBox[
            RowBox[{"4", 
              StyleBox["x", "TI"], "-", 
              SuperscriptBox[
               StyleBox["x", "TI"], "2"], "-", "3"}], 
            StyleBox["x", "TI"]], ")"}], "\[LongEqual]", "-", 
         FractionBox["1", 
          StyleBox["y", "TI"]], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\nabla\\cdot(g\\dot{\\vec{x}})=\\frac{\\partial}{\\partial \
x}(gf_1)+\\frac{\\partial}{\\partial y}(gf_2)=\\frac{\\partial}{\\partial x}(\
\\frac{2-x-y}{y})+\\frac{\\partial}{\\partial \
y}(\\frac{4x-x^2-3}{x})=-\\frac{1}{y}<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2bc7bcff-c2ce-4e93-b748-875a5f464bf3"],
 "\npara toda ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "y>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "56960467-4f05-4506-93f4-7fb353132176"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Del]", "\[CenterDot]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["g", "TI"], 
             OverscriptBox[
              OverscriptBox[
               StyleBox["x", "TI"], "\[RightVector]"], "."]}], ")"}], ">", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\nabla\\cdot(g\\dot{\\vec{x}})>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "406e4498-51e2-447f-bf71-10c4887d3302"],
 " para toda ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "y<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9431ed0d-c85f-4d87-8e66-e1002c4194eb"],
 ".\nPor lo tanto, no pueden haber soluciones peri\[OAcute]dicas \
completamente contenidas en alguna de las dos mitades del eje ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["y", "TI"], TraditionalForm], "errors" -> {}, "input" -> "y", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "13d02cca-1b46-4ad2-83e9-5fc15f155beb"],
