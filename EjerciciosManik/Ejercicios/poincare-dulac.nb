Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "32812557-7a67-475c-9244-5bb1db1fe8c2"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["y", "TI"], "."], "\[LongEqual]", "-", 
         StyleBox["x", "TI"], "-", 
         StyleBox["y", "TI"], "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "+", 
         SuperscriptBox[
          StyleBox["y", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{y}=-x-y+x^2+y^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "547b98d7-d320-4381-98fb-72e343c2b157"],
 "\nSea ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["x", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "g(x,y)=e^{-2x}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5dc6fc3b-222f-411b-b91c-37ee354ebebd"],
 " entonces:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Del]", "\[CenterDot]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["g", "TI"], 
             OverscriptBox[
              OverscriptBox[
               StyleBox["x", "TI"], "\[RightVector]"], "."]}], ")"}], 
         "\[LongEqual]", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["g", "TI"], 
             SubscriptBox[
              StyleBox["f", "TI"], "1"]}], ")"}], "+", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["y", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["g", "TI"], 
             SubscriptBox[
              StyleBox["f", "TI"], "2"]}], ")"}], "\[LongEqual]", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["y", "TI"], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-2", 
                StyleBox["x", "TI"]}]]}], ")"}], "+", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["y", "TI"]}]], 
         RowBox[{"[", 
           RowBox[{
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-2", 
                StyleBox["x", "TI"]}]], "(", 
             RowBox[{"-", 
               StyleBox["x", "TI"], "-", 
               StyleBox["y", "TI"], "+", 
               SuperscriptBox[
                StyleBox["x", "TI"], "2"], "+", 
               SuperscriptBox[
                StyleBox["y", "TI"], "2"]}], ")"}], "]"}], "\[LongEqual]", 
         "-2", 
         StyleBox["y", "TI"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["x", "TI"]}]], "+", 
         RowBox[{"(", 
           RowBox[{"2", 
             StyleBox["y", "TI"], "-", "1"}], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["x", "TI"]}]], "\[LongEqual]", "-", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            StyleBox["x", "TI"]}]], "<", "0", "\[ForAll]", 
         StyleBox["x", "TI"], "\[Element]", 
         StyleBox["R", FontSlant -> "Plain"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\nabla\\cdot(g\\dot{\\vec{x}})=\\frac{\\partial}{\\partial \
x}(gf_1)+\\frac{\\partial}{\\partial y}(gf_2)=\\frac{\\partial}{\\partial \
x}(ye^{-2x})+\\frac{\\partial}{\\partial \
y}[e^{-2x}(-x-y+x^2+y^2)]=-2ye^{-2x}+(2y-1)e^{-2x}=-e^{-2x}<0\\forall \
x\\in\\mathbb{R}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7f181cc6-9e48-4999-b985-1266598208fd"],
 "\npor lo tanto, no hay soluciones peri\[OAcute]dicas en ning\[UAcute]n \
lugar de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["R", FontSlant -> "Plain"], "2"], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mathbb{R}^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "904c7edf-746e-4f14-9c94-94a86a334914"],
 "."
}], "Text",
