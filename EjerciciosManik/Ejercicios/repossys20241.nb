Cell[TextData[{
 "Si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "h<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "05f6c9c3-9ad1-47d8-b875-22c28cd8804c"],
 ", entonces tenemos un punto de equilibrio cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "\[LongEqual]", "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], "4"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "h=-\\frac{r^2}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "435d83b7-9313-4730-be1b-eda79cfcf5e6"],
 ". Vemos que esto se da cuando \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "\[LongEqual]", "-4", 
         StyleBox["h", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r^2=-4h", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7eff1c1d-0182-4af3-a6b8-42b6bf61d6d8"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "\[PlusMinus]", "2", 
         SqrtBox[
          RowBox[{"-", 
            StyleBox["h", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r=\\pm2\\sqrt{-h}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "22c8d584-114f-41f5-b473-b92b3cf2213a"],
 "\nLo cual est\[AAcute] bien definido porque ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["h", "TI"], TraditionalForm], "errors" -> {}, "input" -> "h", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "56585ad3-ee9e-4126-b886-bdaf5ea2868f"],
 " es negativo. Por lo tanto, deben haber dos valores de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b9361f77-ca7c-49dd-9cd3-73a29034b8a2"],
 " en el diagrama de bifurcaci\[OAcute]n donde hay un s\[OAcute]lo punto de \
equilibrio. Vemos entonces que no hay puntos de equilibrio cuando\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "<", "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], "4"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "h<-\\frac{r^2}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5cab2e55-d634-4cb7-9a6a-1dc2b05a5a29"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-4", 
         StyleBox["h", "TI"], ">", 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "-4h>r^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d0c98e72-1b29-438a-9d4f-4d05997f01b4"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         StyleBox["r", "TI"], "|", "<", "2", 
         SqrtBox[
          RowBox[{"-", 
            StyleBox["h", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "|r|<2\\sqrt{-h}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9b6e2a2b-0497-4e72-a2f5-dc87f95c5321"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-2", 
         SqrtBox[
          RowBox[{"-", 
            StyleBox["h", "TI"]}]], "<", 
         StyleBox["r", "TI"], "<", "2", 
         SqrtBox[
          RowBox[{"-", 
            StyleBox["h", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "-2\\sqrt{-h}<r<2\\sqrt{-h}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "001b1dbe-ca6f-492f-a7d0-602026033593"],
 "\nRecordando que cuando hay destrucci\[OAcute]n o creaci\[OAcute]n de \
puntos de equilibrio corresponde a una bifurcaci\[OAcute]n de silla-nodo, y \
que el diagrama de bifurcaci\[OAcute]n se ve como una par\[AAcute]bola \
horizontal, las condiciones anteriores quieren decir que el diagrama de \
bifurcaci\[OAcute]n consiste en dos par\[AAcute]bolas, con v\[EAcute]rtices \
en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "\[PlusMinus]", "2", 
         SqrtBox[
          RowBox[{"-", 
            StyleBox["h", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r=\\pm2\\sqrt{-h}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b3b41a26-4f17-4fda-8cbf-1660cf3ab0c9"],
 ", la de la izquierda abriendo a la izquierda (donde existen dos puntos de \
equilibrio porque ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", "-2", 
         SqrtBox[
          RowBox[{"-", 
            StyleBox["h", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r<-2\\sqrt{-h}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b00bd146-dcb2-436c-9fa1-80c2758292e7"],
 "), y la de la derecha abriendo hacia la derecha (donde se cumple la condici\
\[OAcute]n de existencia ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "2", 
         SqrtBox[
          RowBox[{"-", 
            StyleBox["h", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>2\\sqrt{-h}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "da8ee31a-e1eb-4e50-a029-4610a5543649"],
 "). El diagrama de bifurcaci\[OAcute]n debe verse como:"
}], "Text",
 CellChangeTimes->{{3.9102719887324843`*^9, 3.9102719997670627`*^9}, {
  3.9102720431990733`*^9, 3.9102720844285445`*^9}, {3.9102721169073286`*^9, 
  3.910272195985626*^9}, {3.910272251737032*^9, 3.9102722679641323`*^9}, {
  3.910272372624158*^9, 3.9102723739273376`*^9}, {3.9102724042039323`*^9, 
  3.910272572313012*^9}, {3.9102726285201635`*^9, 
  3.910272670032158*^9}},ExpressionUUID->"d3fa047d-f95e-47da-9e32-\
20de5e191871"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{
