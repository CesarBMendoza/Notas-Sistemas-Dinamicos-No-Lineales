Cell[TextData[{
 "En este caso tenemos eigenvalores repetidos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Lambda]", "\[LongEqual]", 
         StyleBox["a", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda=a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "78110da2-b8aa-49d8-8bec-4ea52adaeec3"],
 ", por lo que el ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"0", ",", "0"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "(0,0)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "054f066b-1c7f-4cdb-bea0-1bf12ba64a53"],
 " es estable si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-1", "<", 
         StyleBox["a", "TI"], "<", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "-1<a<1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "83b55fdc-f93b-4a24-a93a-bf43d7dc404b"],
 ", e inestable de otra forma. \nEvaluando el segundo punto de equilibrio \
encontramos "
}], "Text",
 CellChangeTimes->{{3.910293200493569*^9, 3.9102932138341827`*^9}, {
   3.9102932541571236`*^9, 3.9102933548597174`*^9}, 
   3.910296469827343*^9},ExpressionUUID->"dfcfc6fd-ff0d-4f1d-b73c-\
5efd21946746"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "[", 
  RowBox[{"J3", "/.", 
   RowBox[{"{", 
    RowBox[{"y", "->", 
     RowBox[{"-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "a"}], ")"}], "^", "2"}]}]}], "}"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.91029335909342*^9, 3.910293364133481*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"a7817f14-1a47-4a43-ae49-08c6a08938da"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"a", 
      RowBox[{"2", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", "a"}], ")"}], "2"]}]},
     {"1", "a"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
