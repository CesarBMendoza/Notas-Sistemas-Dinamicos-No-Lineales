Cell["Espacio de par\[AAcute]metros", "Item",
 CellChangeTimes->{{3.9102730616418047`*^9, 
  3.91027306745163*^9}},ExpressionUUID->"731e8a4b-763e-491e-9151-\
36180154bd50"],

Cell[TextData[{
 "El espacio de par\[AAcute]metros que se nos pide es f\[AAcute]cil, pues en \
el inciso anterior ya vemos que \n1. Si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "h>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0f6ecfad-6de5-4b57-b3e9-d5171827dbb0"],
 " no hay bifurcaciones\n2. Si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "h=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8bca8504-77c1-403e-8f61-ae514b32f7fb"],
 " hay una bifurcaci\[OAcute]n transcr\[IAcute]tica\n3. Si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "h<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "54dc771e-d77a-4961-8772-6c51d9d64204"],
 " hay dos bifurcaciones de silla-nodo.\nPor lo tanto, s\[OAcute]lo hay que \
dibujar el espacio con la l\[IAcute]nea recta ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "h=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d1841f38-b34a-491b-b677-b39e208bb52d"],
 " e indicar lo que pasa arriba, en y debajo de ella:"
}], "Text",
 CellChangeTimes->{{3.91027307566687*^9, 
  3.9102731766381073`*^9}},ExpressionUUID->"b15aeed4-7091-4af2-84eb-\
7d5a94f98f52"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RegionPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", ">", "0"}], ",", 
     RowBox[{"h", "<", "0"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"h", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"r", ",", "h"}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.910273180457719*^9, 3.9102732131412964`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"5ceadd5b-9649-45ce-9733-d95e5e2fad04"],

