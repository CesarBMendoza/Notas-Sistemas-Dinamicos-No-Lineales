Cell["\<\
En este caso habr\[IAcute]a que indicar lo siguiente: regi\[OAcute]n azul: \
dos puntos de equilibrio; regi\[OAcute]n verde: dos puntos de equilibrio; \
regi\[OAcute]n naranja: ning\[UAcute]n punto de equilibrio; l\[IAcute]nea \
recta en cero: bifurcaci\[OAcute]n de punto silla con dos puntos de \
equilibrio; par\[AAcute]bola: bifurcaciones de silla-nodo con un punto de \
equilibrio; intersecci\[OAcute]n de la par\[AAcute]bola con el cero: un punto \
de equilibrio con bifurcaci\[OAcute]n transcr\[IAcute]tica.\
\>", "Text",
 CellChangeTimes->{{3.9102734416696253`*^9, 
  3.910273628365622*^9}},ExpressionUUID->"ee87dc41-8ac9-4dfd-8871-\
f1f2e83e9b11"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Parcial III", "Chapter",
 CellChangeTimes->{{3.9102741344843864`*^9, 
  3.9102741362105646`*^9}},ExpressionUUID->"266e258a-13e6-4139-91aa-\
ea25b162c7ec"],

Cell[CellGroupData[{

Cell["Pregunta I", "Section",
 CellChangeTimes->{{3.9102741443562026`*^9, 
  3.9102741546763935`*^9}},ExpressionUUID->"9fd884f2-fcb4-48c1-8080-\
08f8a6788655"],

Cell[TextData[{
 "Calculamos los puntos de equilibrio de la ecuaci\[OAcute]n. De la segunda \
ecuaci\[OAcute]n obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "bx^{\\star}-x^{\\star 2}y^{\\star}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "74ca6e4f-1376-437e-9092-f497246affd7"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "x_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8c991def-17d7-4f2e-b1fc-0a8a93b19da1"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "b-x^{\\star}y^{\\star}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a2afba07-8b0d-461e-a1be-33b4b90d4bab"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star}y^{\\star}=b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "27bffb6d-73a7-40b8-b8b6-d4867dfdf9df"],
 "\nSustituyendo en la primera ecuaci\[OAcute]n, vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "x_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "01d8d303-ae57-4135-97e0-9ffe0f572056"],
 " no puede ser soluci\[OAcute]n de equilibrio a menos de que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "a=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "73f87e0b-519d-4ee6-8256-0f731c0453c1"],
 ". Sustituyendo la segunda ecuaci\[OAcute]n en el \[UAcute]ltimo \
t\[EAcute]rmino de la ecuaci\[OAcute]n obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "-", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["b", "TI"], "+", "1"}], ")"}], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "+", 
         StyleBox["b", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "a-(b+1)x^{\\star}+bx^{\\star}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "601c9380-da1a-407e-ad99-83348c7e7e07"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "a-x^{\\star}=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ef98b2c0-5ba3-4a09-a24b-1178fcbd7cf6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         StyleBox["a", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star}=a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7eccac6e-0028-45a1-9121-d271050a0c0b"],
 "\ny, sustituyendo en la condici\[OAcute]n de la primera ecuaci\[OAcute]n, \
obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "ay^{\\star}=b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c7d9f825-a07b-441f-a366-46c9c8e7bbd6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         FractionBox[
          StyleBox["b", "TI"], 
          StyleBox["a", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "y^{\\star}=\\frac{b}{a}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "65f5539a-2af7-4e5f-9d9a-c2813f94a327"],
 ".\nS\[OAcute]lo tenemos un punto de equilibrio, as\[IAcute] que no puede \
haber bifurcaciones transcr\[IAcute]ticas, de silla-nodo, ni de tridente. \
Podr\[IAcute]a haber una bifurcaci\[OAcute]n de Hopf si este \[UAcute]nico \
punto de equilibrio tiene eigenvalores complejos y cambian de tener parte \
real positiva a negativa. Calculamos la matriz Jacobiana para comprobarlo:"
}], "Text",
 CellChangeTimes->{{3.9102741924780145`*^9, 3.9102743037218866`*^9}, {
  3.910274366325262*^9, 3.910274428709832*^9}, {3.910274464471581*^9, 
  3.9102745251615567`*^9}, {3.910274605624938*^9, 
  3.910274695842765*^9}},ExpressionUUID->"1bdeb9d2-ef8f-42fb-b1c0-\
aee44156aad7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"J1", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"a", "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"b", "+", "1"}], ")"}], "*", "x"}], "+", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"a", "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"b", "+", "1"}], ")"}], "*", "x"}], "+", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", "y"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"b", "*", "x"}], "-", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"b", "*", "x"}], "-", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", "y"}], "]"}]}], "}"}]}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.910274698670746*^9, 3.910274762736802*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"3be5e0db-d8d6-4f5c-9cf2-75a54ca5298e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "-", "b", "+", 
      RowBox[{"2", " ", "x", " ", "y"}]}], ",", 
     SuperscriptBox["x", "2"]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"b", "-", 
      RowBox[{"2", " ", "x", " ", "y"}]}], ",", 
     RowBox[{"-", 
      SuperscriptBox["x", "2"]}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.910274763136051*^9},
 CellLabel->"Out[14]=",ExpressionUUID->"5a9b7d4e-07b8-41af-96ce-64f5065ffd86"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "[", "J1", "]"}]], "Input",
 NumberMarks->False,
 CellLabel->"In[15]:=",ExpressionUUID->"4977dcd2-de5f-441f-ac77-5f48bb8b6b3b"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       RowBox[{"-", "1"}], "-", "b", "+", 
       RowBox[{"2", " ", "x", " ", "y"}]}], 
      SuperscriptBox["x", "2"]},
     {
      RowBox[{"b", "-", 
       RowBox[{"2", " ", "x", " ", "y"}]}], 
      RowBox[{"-", 
       SuperscriptBox["x", "2"]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.9102747741072793`*^9},
 CellLabel->
  "Out[15]//MatrixForm=",ExpressionUUID->"a70d4ce8-5034-4647-8ca7-\
0917e4be8a43"]
}, Open  ]],

Cell["Evaluamos en el punto de equilibrio:", "Text",
 CellChangeTimes->{{3.910274803824256*^9, 
  3.91027481079426*^9}},ExpressionUUID->"fd990b16-01c4-4e1b-b284-\
2e4cbe2d5dfd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "[", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"J1", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "->", "a"}], ",", 
      RowBox[{"y", "->", 
       RowBox[{"b", "/", "a"}]}]}], "}"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.9102748165972567`*^9, 3.9102748369811635`*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"206ed768-002d-443f-9722-184ef5c88d6e"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       RowBox[{"-", "1"}], "+", "b"}], 
      SuperscriptBox["a", "2"]},
     {
      RowBox[{"-", "b"}], 
      RowBox[{"-", 
       SuperscriptBox["a", "2"]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.9102748375243225`*^9},
 CellLabel->
  "Out[16]//MatrixForm=",ExpressionUUID->"9f4d8c8c-f256-4cb7-82eb-\
4c3c99b9433c"]
}, Open  ]],

Cell[TextData[{
 "Si los eigenvalores son complejos, la traza es proporcional a la parte real \
(por un factor de un medio). En este caso la traza es\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "-", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "-", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "b-a^2-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "81c5a902-315f-4d04-bf64-783cf0bcafef"],
 "\nLa cual cambiar\[IAcute]a de positiva a negativa si\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "-", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "-", "1", "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "b-a^2-1=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "593553c3-d60f-4f94-ae48-86e0572571f1"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "+", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "b=a^2+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c76b41a-b9fc-4fb9-aa19-821a91d9b39a"],
 "\nS\[OAcute]lo basta comprobar en qu\[EAcute] rango de par\[AAcute]metros \
los eigenvalores son complejos. Esto sucede cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["tr", FontSlant -> "Plain"], 
         SuperscriptBox[
          StyleBox["J", "TI"], "2"], "-", "4", 
         StyleBox["det", FontSlant -> "Plain"], 
         StyleBox["J", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathrm{tr}J^2-4\\mathrm{det}J<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1c38861f-0c2e-4d34-8f28-bff594757db9"],
 ". En este caso el determinante es"
}], "Text",
 CellChangeTimes->{{3.9102748716945553`*^9, 3.910274916738924*^9}, {
  3.9102749507965794`*^9, 3.9102750208217783`*^9}, {3.910275055293431*^9, 
  3.9102750615577955`*^9}},ExpressionUUID->"8318e396-825c-4603-a6fd-\
6ca8176eb92f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Det", "[", 
  RowBox[{"J1", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "->", "a"}], ",", 
     RowBox[{"y", "->", 
      RowBox[{"b", "/", "a"}]}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9102750638554783`*^9, 3.9102750696485586`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"7639e7fa-4a46-4e67-99c1-8b5b9de98489"],

Cell[BoxData[
 SuperscriptBox["a", "2"]], "Output",
 CellChangeTimes->{3.910275070003271*^9},
 CellLabel->"Out[17]=",ExpressionUUID->"78384708-9e98-4647-a2ed-5a7f5b647833"]
}, Open  ]],

Cell[TextData[{
 "Entonces necesitamos que\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              StyleBox["b", "TI"], "-", 
              SuperscriptBox[
               StyleBox["a", "TI"], "2"], "-", "1"}], ")"}], "2"], "-", "4", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(b-a^2-1)^2-4a^2<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b787f549-5d86-431f-b886-5efbd41c0311"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"4", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], ">", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              StyleBox["b", "TI"], "-", 
              SuperscriptBox[
               StyleBox["a", "TI"], "2"], "-", "1"}], ")"}], "2"]}], 
       TraditionalForm], "errors" -> {}, "input" -> "4a^2>(b-a^2-1)^2", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1d9c3988-b813-4565-b221-bc818440c231"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"4", ">", 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox[
             RowBox[{
               StyleBox["b", "TI"], "-", 
               SuperscriptBox[
                StyleBox["a", "TI"], "2"], "-", "1"}], 
             StyleBox["a", "TI"]], ")"}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "4>(\\frac{b-a^2-1}{a})^2", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "285c9ceb-b1b9-4de6-9548-1ffdf55b3b18"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", ">", "|", 
         FractionBox[
          RowBox[{
            StyleBox["b", "TI"], "-", 
            SuperscriptBox[
             StyleBox["a", "TI"], "2"], "-", "1"}], 
          StyleBox["a", "TI"]], "|"}], TraditionalForm], "errors" -> {}, 
     "input" -> "2>|\\frac{b-a^2-1}{a}|", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "89d3dbc0-9bd6-4306-8acf-4c0e4d7c3cc2"],
 "\nS\[OAcute]lo basta examinar si esta condici\[OAcute]n se cumple cuando la \
traza cambia de positiva a negativa, es decir cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "+", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "b=a^2+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6f604a57-4b3f-4048-8718-8f8a7b58b273"],
 ". Sustituimos y obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", ">", "|", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["a", "TI"], "2"], "+", "1", "-", 
            SuperscriptBox[
             StyleBox["a", "TI"], "2"], "-", "1"}], 
          StyleBox["a", "TI"]], "|"}], TraditionalForm], "errors" -> {}, 
     "input" -> "2>|\\frac{a^2+1-a^2-1}{a}|", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2aa3f6ac-3e50-4a80-b404-d266ca58021c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", ">", "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "2>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "14dec2c6-063f-4124-9682-4fadff3334a8"],
 "\nEsto se cumple, as\[IAcute] que podemos concluir que hay una bifurcaci\
\[OAcute]n de Hopf en el sistema. Para saber qu\[EAcute] tipo de bifurcaci\
\[OAcute]n de Hopf espec\[IAcute]ficamente (super-, subcr\[IAcute]tica o \
degenerada) tendr\[IAcute]amos que mostrar que hay un centro en el punto de \
bifurcaci\[OAcute]n (para la degenerada), o que existe un ciclo \
l\[IAcute]mite cuando el punto de equilibrio es estable (Hopf \
subcr\[IAcute]tica), o que existe cuando es inestable (Hopf \
supercr\[IAcute]tica). En este caso en particular, la bifurcaci\[OAcute]n es \
superc\[IAcute]tica, como se puede ver debajo (no necesario para el examen):"
}], "Text",
 CellChangeTimes->{{3.9102750980732875`*^9, 3.9102751966683807`*^9}, 
   3.9102752546191835`*^9, {3.910275292055498*^9, 3.9102753574384866`*^9}, {
   3.9102753878162174`*^9, 3.9102753888158827`*^9}, {3.9102754238418484`*^9, 
   3.910275476169807*^9}, {3.9102755342707596`*^9, 3.910275610189186*^9}, {
   3.910275661285368*^9, 3.910275673869649*^9}, {3.9102763487532225`*^9, 
   3.9102763733507385`*^9}},ExpressionUUID->"d5f05d7d-25c9-4df4-ae47-\
fe2958f7179c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"2", "-", 
         RowBox[{"6.05", "*", 
          RowBox[{"x", "[", "t", "]"}]}], "+", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"5.05", "*", 
          RowBox[{"x", "[", "t", "]"}]}], "-", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "2.2"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "2.6"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "100"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9102760839900956`*^9, 3.910276149277376*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"67c0d1c3-8e84-4640-9d43-e0c6eb9e26ce"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"StreamPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"2", "-", 
         RowBox[{"6.05", "*", "x"}], "+", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}], ",", 
        RowBox[{
         RowBox[{"5.05", "*", "x"}], "-", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "1.5", ",", "2.5"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "2", ",", "3"}], "}"}]}], "]"}], ",", 
    RowBox[{"ParametricPlot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], ",", 
          RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "sol"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Thick"}], "}"}]}]}], "]"}]}], "}"}], 
  "]"}]], "Input",
