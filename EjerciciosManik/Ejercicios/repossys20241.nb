Cell[TextData[{
 "De la expresi\[OAcute]n de la soluci\[OAcute]n, es evidente que la soluci\
\[OAcute]n es real en el intervalo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"-", "\[Infinity]", ",", 
           FractionBox["1", "8"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "(-\\infty,\\frac{1}{8})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "52814bb7-5777-4114-ae1d-9e69e38a953d"],
 ". Graficamos el campo de pendientes para encontrar la soluci\[OAcute]n de \
manera gr\[AAcute]fica:"
}], "Text",
