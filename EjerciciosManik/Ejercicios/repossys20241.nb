        RowBox[{"r", ",", 
         RowBox[{"SuperStar", "[", "x", "]"}]}], "}"}]}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{"Automatic", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Thick", ",", "Dashed"}], "}"}]}]}], "]"}]}], 
   "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.9102712580881805`*^9, 3.91027134620717*^9}, {
  3.9102714100869246`*^9, 3.910271472063146*^9}},
