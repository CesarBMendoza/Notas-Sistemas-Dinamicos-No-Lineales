Cell[TextData[{
 "De aqu\[IAcute] vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderscriptBox["lim", 
          RowBox[{
            StyleBox["t", "TI"], "\[UpArrow]", 
