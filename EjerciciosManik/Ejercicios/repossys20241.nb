Cell[CellGroupData[{

Cell["Pregunta IV", "Section",
 CellChangeTimes->{{3.9102696327021904`*^9, 
  3.910269634243353*^9}},ExpressionUUID->"92123f68-8b37-43e7-8547-\
0fe3d4ea6e8e"],

Cell["Diagramas de bifurcaci\[OAcute]n", "Item",
 CellChangeTimes->{{3.9102696542445607`*^9, 
  3.9102696578323483`*^9}},ExpressionUUID->"9c85b28d-ef0e-46ee-a057-\
d3ee04640bfd"],

Cell[TextData[{
 "Recordamos que, en los diagramas de bifurcaci\[OAcute]n de sistemas en una \
dimensi\[OAcute]n, debemos graficar el valor del par\[AAcute]metro contra los \
puntos de equilibrio, identificando de manera diferente cuando son estables y \
cuando son inestables. Empezamos calculando los puntos de equilibrio:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "+", 
         StyleBox["r", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "h+rx^{\\star}-x^{\\star 2}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fb07fee2-fd57-48b5-9eac-71be697b940d"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", 
         StyleBox["r", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "-", 
         StyleBox["h", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{\\star 2}-rx^{\\star}-h=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c04f16d7-c879-4717-a879-1e5359de32f1"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["r", "TI"], "\[PlusMinus]", 
            SqrtBox[
             RowBox[{
               SuperscriptBox[
                StyleBox["r", "TI"], "2"], "+", "4", 
               StyleBox["h", "TI"]}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{\\star}=\\frac{r\\pm\\sqrt{r^2+4h}}{2}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d39c96aa-5981-45cd-8e0c-e7a920e30968"],
 "\nVemos que no hay puntos de equilibrio cuando\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], "+", "4", 
         StyleBox["h", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r^2+4h<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b58af89e-b042-4af7-9df0-8103a5d70a94"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "<", "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], "4"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "h<-\\frac{r^2}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "16fac2e3-be58-45a6-9f81-9bcc5f370ebd"],
 "\ntenemos s\[OAcute]lo un punto de equilibrio cuando\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], "\[LongEqual]", "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], "4"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "h=-\\frac{r^2}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5c4caf23-84ae-4c59-920c-2f9b92f69203"],
 "\ny dos puntos de equilibrio en cualquier otro caso.\nCalculamos la \
estabilidad de los equilibrios cuando existen. \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", "2", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], "\[PlusMinus]", 
             SqrtBox[
              RowBox[{
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"], "+", "4", 
                StyleBox["h", "TI"]}]]}], ")"}], "\[LongEqual]", 
         "\[MinusPlus]", 
         SqrtBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "+", "4", 
            StyleBox["h", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "f'(x^{\\star})=r-2x^{\\star}=r-(r\\pm\\sqrt{r^2+4h})=\\mp\\sqrt{r^2+4h}\
", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3d8904eb-8a6e-45ec-807f-ffc732198a1b"],
 "\nVemos entonces que el punto de equilibrio con signo positivo (el mayor de \
ambos), es siempre estable, y el que tiene signo negativo (el menor de ambos) \
es siempre inestable. Cuando s\[OAcute]lo hay un punto de equilibrio no se \
puede determinar la estabilidad, porque es un punto de bifurcaci\[OAcute]n.\n\
Finalmente, para dibujar el diagrama de bifurcaci\[OAcute]n, vems que el lado \
derecho de la ecuaci\[OAcute]n es una par\[AAcute]bola invertida, desplazada \
por ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["h", "TI"], TraditionalForm], "errors" -> {}, "input" -> "h", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8da5fe75-bb64-49f9-934a-96c0026b7a38"],
 ". Calculamos el m\[AAcute]ximo de la par\[AAcute]bola para saber \
qu\[EAcute] pasa durante la bifurcaci\[OAcute]n:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", "2", 
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "f'(x)=r-2x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ae464d1c-197c-40fe-a125-f9b47d0245ad"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["max", FontSlant -> "Plain"]], "\[LongEqual]", 
         FractionBox[
          StyleBox["r", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x_{\\mathrm{max}}=\\frac{r}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ec013a1a-0065-4974-8574-b8dc026d54ae"],
 "\nY calculamos la altura de este m\[AAcute]ximo\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["f", "TI"], 
          StyleBox["max", FontSlant -> "Plain"]], "\[LongEqual]", 
         StyleBox["h", "TI"], "+", 
         StyleBox["r", "TI"], 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["max", FontSlant -> "Plain"]], "-", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["max", FontSlant -> "Plain"], "2"], "\[LongEqual]", 
         StyleBox["h", "TI"], "+", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], "2"], "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], "4"], "\[LongEqual]", 
         StyleBox["h", "TI"], "+", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], "4"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "f_{\\mathrm{max}}=h+rx_{\\mathrm{max}}-x_{\\mathrm{max}}^2=h+\\frac{r^2}\
{2}-\\frac{r^2}{4}=h+\\frac{r^2}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "500a7c5a-0983-4ac1-ada2-8e05a6d7444b"],
 "\nVemos que si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "h>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "528a8fbf-b3e3-455c-a8f5-2f6425bb2c8b"],
 ", entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["f", "TI"], 
          StyleBox["max", FontSlant -> "Plain"]], ">", "0", "\[ForAll]", 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "f_\\mathrm{max}>0\\forall r", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "744b658c-4e29-4c4a-8c81-52dad839722e"],
 ". Recordamos que las bifurcaciones en una dimensi\[OAcute]n se dan cuando \
la funci\[OAcute]n se vuelve tangente al eje ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "38f64ed8-2dcd-4252-8e18-43f38c238d4a"],
 ", por lo que para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "h>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "36f7bf86-5745-4cb2-b44b-d192376d7518"],
 " no hay bifurcaciones, pues el m\[AAcute]ximo, que ser\[IAcute]a el \
\[UAcute]nico punto que podr\[IAcute]a ser tangente al eje (por tener \
pendiente cero), siempre est\[AAcute] por arriba del eje. Con esta informaci\
\[OAcute]n ya podemos dibujar los diagramas de bifurcaci\[OAcute]n:\nSi ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "h>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d5c83ee5-6d65-472f-b588-1320e263f830"],
 ", entonces necesariamente ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], ">", "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["r", "TI"], "2"], "4"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "h>-\\frac{r^2}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "12733ce2-ffed-41c4-a9a4-9a2a57e0ad8c"],
 ", tenemos dos puntos de equilibrio que no cambian de estabilidad, el de la \
izquierda inestable, y el de la derecha estable, por lo que debe verse como \
dos l\[IAcute]neas, la de arriba continua y la de abajo punteada:"
}], "Text",
 CellChangeTimes->{{3.9102696621136312`*^9, 3.910269735779272*^9}, {
   3.9102698397107215`*^9, 3.910269840004016*^9}, {3.910269872030615*^9, 
   3.910269873389681*^9}, {3.910269987633247*^9, 3.9102700170832524`*^9}, {
   3.9102701631576586`*^9, 3.9102701847533207`*^9}, {3.9102702163398457`*^9, 
   3.910270225429635*^9}, {3.9102702768148108`*^9, 3.9102702871600723`*^9}, {
   3.9102703460973673`*^9, 3.9102703491108093`*^9}, 3.9102703811988688`*^9, {
   3.9102705249086175`*^9, 3.9102706952660584`*^9}, {3.9102707266532526`*^9, 
   3.91027072802306*^9}, {3.9102707583773193`*^9, 3.910270788607394*^9}, {
   3.9102709139762125`*^9, 3.910270925832212*^9}, {3.910270970567156*^9, 
   3.9102711655305815`*^9}, {3.910271203953966*^9, 3.910271253088004*^9}, {
   3.910271510324311*^9, 
   3.9102715104526486`*^9}},ExpressionUUID->"b564fd02-99b8-4b38-8425-\
fc925a2a345e"],

