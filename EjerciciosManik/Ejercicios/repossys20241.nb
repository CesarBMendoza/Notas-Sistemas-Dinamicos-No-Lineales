Cell[CellGroupData[{

Cell["Parcial II", "Chapter",
 CellChangeTimes->{{3.9101828254750624`*^9, 
  3.910182831224661*^9}},ExpressionUUID->"d2530166-f903-46ca-8a5e-\
d6bdd029bf25"],

Cell[CellGroupData[{

Cell["Pregunta I", "Section",
 CellChangeTimes->{{3.910182841130828*^9, 3.9101828425067873`*^9}, {
  3.910184046814021*^9, 
  3.9101840586897697`*^9}},ExpressionUUID->"cfbd78ed-a8d5-4393-bd23-\
562a11835a1a"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", 
        StyleBox["p", "TI"], "-", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
    "\\dot{x}=p-x^n", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"28dc7222-4a73-47de-a2f7-cc54e427bfef"]], \
"Item",
 CellChangeTimes->{
  3.9101840682259817`*^9},ExpressionUUID->"5df89548-7d0e-4b33-8518-\
152c5f25df45"],

Cell[TextData[{
 "Para comprobar el tipo de bifurcaci\[OAcute]n necesitamos comprobar el n\
\[UAcute]mero de puntos de equilibrio y su estabilidad. En este caso los \
puntos de equilibrio son:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", 
            StyleBox["n", "TI"]}]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "p-x^{\\star n}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7e66307b-e53e-4f06-9291-b79f10e53384"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", 
            StyleBox["n", "TI"]}]], "\[LongEqual]", 
         StyleBox["p", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star n}=p", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "48ca4780-17c4-4ace-b62f-72a576a4e0d5"],
 "\nAl elevar a la ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "124a4878-fff5-4198-878a-3ef1280ad831"],
 ", el resultado siempre es positivo si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9ced43d9-54cd-4c91-b597-2028255b1d03"],
 " es par, mientras que el resultado mantiene su signo original si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f0c2d8a7-b8aa-4058-a975-8ea5c762833e"],
 " es impar, por lo que:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["p", "TI"], 
          FractionBox["1", 
           StyleBox["n", "TI"]]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star}=p^{\\frac{1}{n}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf045b77-a260-4bf1-80f0-73dcc007e5f9"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[ForAll]", 
         StyleBox["p", "TI"], "\[Element]", 
         StyleBox["R", FontSlant -> "Plain"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\forall p\\in\\mathbb{R}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d403da88-d5a9-4f2a-a18e-751a05bfacdb"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[LongEqual]", "2", 
         StyleBox["k", "TI"], "+", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "n=2k+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e48976db-bcef-40c9-947a-9d26f4b56334"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         "\[PlusMinus]", 
         SuperscriptBox[
          StyleBox["p", "TI"], 
          FractionBox["1", 
           StyleBox["n", "TI"]]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star}=\\pm p^{\\frac{1}{n}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "99ac9be6-bba0-4b6b-966e-b8ef3ddba7c4"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "\[GreaterEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "p\\geq0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fbea87a5-d607-4523-89ae-76ba2e51c7d3"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[LongEqual]", "2", 
         StyleBox["k", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "n=2k", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c59f08a2-8cbb-42d9-9b11-0a57cc9e7a3e"],
 "\nVemos entonces que, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a56f3b05-56ab-41fb-851b-9232094710c2"],
 " es par, no tenemos puntos de equilibrio cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "84fad35b-17df-4d32-be4d-162e22082e70"],
 ", tenemos un s\[OAcute]lo punto de equilibrio cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "p=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "327db7e7-9af8-4e29-b67a-4991bf8cd638"],
 ", y tenemos dos puntos de equilibrio cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ca16bb8d-2d2d-483c-8c0f-5d979eb67390"],
 ", por lo que ocurre una bifurcaci\[OAcute]n de silla nodo en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "p=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b012b971-e376-414f-9478-46693031866b"],
 ".\nPor otro lado, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1436f429-b84c-44fb-9965-949d01c0a456"],
 " es impar, siempre tenemos s\[OAcute]lo un punto de equilibrio. Adem\
\[AAcute]s si calculamos su estabilidad obtenemos: \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "-", 
         StyleBox["n", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "f'(x)=-nx^{n-1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "21217910-5253-445a-8bd4-11ec1d1a487c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]",
          "-", 
         StyleBox["n", "TI"], 
         SuperscriptBox[
          StyleBox["p", "TI"], 
          RowBox[{
            FractionBox["1", 
             StyleBox["n", "TI"]], "(", 
            RowBox[{
              StyleBox["n", "TI"], "-", "1"}], ")"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "f'(x^{\\star})=-np^{\\frac{1}{n}(n-1)}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0b42377d-07f0-4b88-a2e7-1f575485c6a3"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]",
          "-", 
         StyleBox["n", "TI"], 
         StyleBox["p", "TI"], 
         SuperscriptBox[
          StyleBox["p", "TI"], 
          RowBox[{"-", 
            FractionBox["1", 
             StyleBox["n", "TI"]]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f'(x^{\\star})=-npp^{-\\frac{1}{n}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "106ab222-f693-4388-97f0-ac7ffe10cedc"],
 "\nComo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["p", "TI"], TraditionalForm], "errors" -> {}, "input" -> "p", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3f034902-b940-451c-a14d-8ed3427b7857"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["p", "TI"], 
        RowBox[{"-", 
          FractionBox["1", 
           StyleBox["n", "TI"]]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "p^{-\\frac{1}{n}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ab85e1c8-1a86-4080-bffd-7fbd2e627597"],
 " tienen el mismo signo, entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "<", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "f'(x^{\\star}})<0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cd3218cd-c8b2-41e8-be52-b05f23fcd15f"],
 ", y el punto de equilibrio siempre es estable, por lo que no cambia su \
estabilidad, y no hay bifurcaci\[OAcute]n."
}], "Text",
 CellChangeTimes->{{3.9101841154011*^9, 3.9101842921400075`*^9}, {
   3.910184391664634*^9, 3.910184396672969*^9}, {3.9101844289916773`*^9, 
   3.9101846027635975`*^9}, {3.9101846818790956`*^9, 3.910184713811758*^9}, {
   3.9101847600707912`*^9, 3.9101847612622538`*^9}, {3.910184808854716*^9, 
   3.910184882777655*^9}, 3.9101915281653233`*^9, 
   3.9101916586978703`*^9},ExpressionUUID->"d0b33d48-7425-42d6-a0bc-\
b4110ec2d625"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", 
        StyleBox["p", "TI"], 
        StyleBox["x", "TI"], "-", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
    "\\dot{x}=px-x^n", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"6bf48d76-1d12-47f2-9278-6406ceb8f3f7"]], \
"Item",
 CellChangeTimes->{
  3.9101916674583783`*^9},ExpressionUUID->"53b0520d-ebc7-4a41-b42a-\
cb04410ea150"],

Cell[TextData[{
 "En este caso, los puntos de equilibrio son\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", 
            StyleBox["n", "TI"]}]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "px^{\\star}-x^{\\star n}=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7ebc0e9a-987f-43c7-bff3-ea4e6bb93d21"],
 "\nVemos que, independientemente de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d75975b7-8411-4453-8cd0-79a8a3deb969"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["p", "TI"], TraditionalForm], "errors" -> {}, "input" -> "p", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "252f8872-aa9f-4e72-aa7d-c3a80cf5ff69"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "x_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "88ea0709-d360-42b1-8dd1-181a98381bb0"],
 ". Prosiguiendo\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", 
            StyleBox["n", "TI"], "-", "1"}]], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "p-x^{\\star n-1}=0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6fce3a16-6f3e-4edb-9cce-0f17d63fbc4e"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["p", "TI"], 
          FractionBox["1", 
           RowBox[{
             StyleBox["n", "TI"], "-", "1"}]]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{\\star}=p^{\\frac{1}{n-1}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "33419e84-08fa-4c1b-8731-6304b33231a1"],
 "\nPor los mismos argumentos que en el inciso anterior, si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fb0ef0ea-e606-49ef-9e37-788538894270"],
 " es par, entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "n-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0c9bf4ad-9319-441c-b8cf-6f0add661fb7"],
 " es impar, el signo de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["p", "TI"], TraditionalForm], "errors" -> {}, "input" -> "p", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e2683cb4-6a93-41bc-bfbd-df9ca6e98d1f"],
 " se conserva, y tenemos una \[UAcute]nica soluci\[OAcute]n distinta de \
cero. Por otro lado, si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7c838f1f-99e4-4218-8dbe-c699a59d28e6"],
 " es impar, entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "n-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e8ebe58a-d7d3-4dae-88ef-8d2e23d9d731"],
 " es par y tenemos dos soluciones, es decir, los puntos de equilibrio son:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0", "\[ForAll]", 
         StyleBox["n", "TI"], ">", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x_1^{\\star}=0\\forall n>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "353f932d-b88d-420b-8bce-3882c8bd6bad"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["p", "TI"], 
          FractionBox["1", 
           RowBox[{
             StyleBox["n", "TI"], "-", "1"}]]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_2^{\\star}=p^{\\frac{1}{n-1}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "863a85e2-171b-4677-82e4-a301a1ecf9f3"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[LongEqual]", "2", 
         StyleBox["k", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "n=2k", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dfb328a3-7b7c-43fb-919d-12ec5ac510d5"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[ForAll]", 
         StyleBox["p", "TI"], "\[Element]", 
         StyleBox["R", FontSlant -> "Plain"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\forall p\\in\\mathbb{R}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ff1b72c5-daaf-4069-bbb3-b10c54e6046b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"2", ",", "3"}], "\[FivePointedStar]"], "\[LongEqual]", 
         "\[PlusMinus]", 
         SuperscriptBox[
          StyleBox["p", "TI"], 
          FractionBox["1", 
           RowBox[{
             StyleBox["n", "TI"], "-", "1"}]]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{2,3}^{\\star}=\\pm p^{\\frac{1}{n-1}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "60c0f8e9-67ca-49b1-b4f3-87273404504a"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[LongEqual]", "2", 
         StyleBox["k", "TI"], "+", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "n=2k+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "65e0e093-cabe-44e1-81c7-7d6d76d86eb9"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "\[GreaterEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "p\\geq 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2f3811cf-ebcf-472e-8512-3119717c5073"],
 "\nComprobamos que las soluciones de equilibrio intercambien estabilidad en \
el punto de bifurcaci\[OAcute]n. \[CapitalEAcute]ste debe ser ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "p=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "800f6a4e-05fb-4cc3-b586-19d8edc79640"],
 " ya que en \[EAcute]ste ambos puntos coinciden. La estabilidad en este caso \
est\[AAcute] dada por ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]", 
         StyleBox["p", "TI"], "-", 
         StyleBox["n", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", 
            StyleBox["n", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "f'(x^{\\star})=p-nx^{\\star n-1}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5ecdf634-94a0-4e07-9819-1dfbc2474f5e"],
 ". Evaluamos en el primer punto de equilibrio que es com\[UAcute]n para \
todos los casos, y obtenemos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", 
         StyleBox["p", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "f'(0)=p", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e73e59fd-cabb-48d2-a85f-3deb91ae7f23"],
 ", por lo que es estable si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "81f59d4b-bb02-451a-bf5b-60ce588b2c75"],
 " e inestable si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ef1de275-6e13-498e-91cd-cba13e7cf5a2"],
 ".\nLa estabilidad de los dem\[AAcute]s puntos de equilibrio est\[AAcute] \
dada por: \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["p", "TI"], 
            FractionBox["1", 
             RowBox[{
               StyleBox["n", "TI"], "-", "1"}]]], ")"}], "\[LongEqual]", 
         StyleBox["p", "TI"], "-", 
         StyleBox["n", "TI"], 
         StyleBox["p", "TI"], "\[LongEqual]", 
         StyleBox["p", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["n", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "f'(p^{\\frac{1}{n-1})=p-np=p(1-n)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "147a325a-cf01-43b0-a888-3b11286d7a61"],
 "\nVemos que, en el caso de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "800c40f7-71a0-4b90-8b80-b92730979b7c"],
 " par, el otro punto de equilibrio siempre existe y como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], ">", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "n>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0cc5aad2-f5d1-49bf-856b-debac0823c58"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "-", 
         StyleBox["n", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "1-n<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a520deac-c80a-4318-8acd-7b2637e4e51b"],
 ", entonces el segundo punto de equilibrio es estable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7c942091-f7d5-4a5b-bfaa-9e98f9aec0b1"],
 " y es inestable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3fb005ba-dd41-4ca6-bce8-0c96934be43c"],
 ", al contrario que con el cero, por lo que s\[IAcute] intercambian \
estabilidad.\nEn el caso de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "05e60923-7dcf-4b96-b75f-864bbd28080c"],
 " impar, los puntos de equilibrio s\[OAcute]lo existen si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["p", "TI"], TraditionalForm], "errors" -> {}, "input" -> "p", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a517d324-a08d-4bd8-947b-dec25c18cef9"],
 " es no negativa. Por lo que, por los mismos criterios anteriores, siempre \
son estables cuando existen, as\[IAcute] que la bifurcaci\[OAcute]n es de \
tridente supercr\[IAcute]tica."
}], "Text",
 CellChangeTimes->{{3.9101917283358297`*^9, 3.910191739404753*^9}, {
  3.910191903469122*^9, 3.9101922500204277`*^9}, {3.910192311035036*^9, 
  3.910192378174631*^9}, {3.910192492269209*^9, 
  3.910192800463925*^9}},ExpressionUUID->"af226a18-eda5-491d-a5ec-\
9480c8c3b93a"],

Cell["Cambiamos los signos", "Item",
 CellChangeTimes->{{3.910192853981247*^9, 
  3.9101928618148813`*^9}},ExpressionUUID->"7f5a7764-ba50-4061-9a77-\
4beab7f44b15"],

Cell[TextData[{
 "Viendo las cuentas de los incisos anteriores, el signo afecta al valor de \
los puntos de equilibrio y al c\[AAcute]lculo de la estabilidad. \nPara el \
primer inciso, el punto de equilibrio sigue existiendo siempre para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fb466977-e5c5-40d0-b526-8016ccaf95e5"],
 " impar, pero los puntos de equilibrio s\[OAcute]lo existen para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "\[LessEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "p\\leq0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fbf0c2a9-30dc-44d4-945c-082ffa60d52d"],
 " en el caso de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c89c1500-33f3-4642-b36c-9c520e175cd8"],
 " par. La estabilidad est\[AAcute] dada en este caso por \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["n", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "f'(x)=nx^{n-1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "91f1be73-4487-43d6-a028-40a25f406c3d"],
 "\npor lo que para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "32efab46-f225-435f-b966-70c4b60f06ba"],
 " impar, el punto de equilibrio siempre es inestable.\nPara el segundo \
inciso, la estabilidad del punto de equilibrio no cambia, pero los puntos de \
equilibrio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["x", "TI"], 
        RowBox[{"2", ",", "3"}], "\[FivePointedStar]"], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{2,3}^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "52cae079-6c12-4a09-b7df-7e78e1942c5b"],
 " s\[OAcute]lo existen en el caso de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "96660e42-fd17-4298-9153-366734793ccc"],
 " impar para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "\[LessEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "p\\leq0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "13a7e58f-1342-4859-981d-ea83570109ab"],
 ", que es cuando el cero es estable, por lo que la bifurcaci\[OAcute]n se \
convierte en una bifurcaci\[OAcute]n de tridente subcr\[IAcute]tica. Para el \
caso de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6bb2bf18-58cb-465c-8ea3-8a95130ffdc4"],
 " par, la estabilidad del segundo punto de equilibrio es  \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"[", 
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{"-", 
                StyleBox["p", "TI"]}], ")"}], 
            FractionBox["1", 
             RowBox[{
               StyleBox["n", "TI"], "-", "1"}]]], "]"}], "\[LongEqual]", 
         StyleBox["p", "TI"], "+", 
         StyleBox["n", "TI"], 
         RowBox[{"(", 
           RowBox[{"-", 
             StyleBox["p", "TI"]}], ")"}], "\[LongEqual]", 
         StyleBox["p", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["n", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "f'[(-p)^{\\frac{1}{n-1}]=p+n(-p)=p(1-n)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c3c1e277-85f3-4cf9-a3a4-998f01051a91"],
 ",\npor lo que, al igual que en el caso anterior, es estable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b98d8fdc-60ec-4e7c-a9f4-86f4e7241ee1"],
 ", y es inestable cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3548d493-3d07-47af-87f5-4576b52f67fd"],
 ", por lo que sigue siendo una bifurcaci\[OAcute]n transcr\[IAcute]tica, con \
los mismos rangos de estabilidad para ambos puntos de equilibrio."
}], "Text",
 CellChangeTimes->{{3.9101929878580604`*^9, 3.910193084092393*^9}, {
  3.9101931241868873`*^9, 3.9101932490735655`*^9}, {3.9101933297863083`*^9, 
  3.910193388985609*^9}, {3.9101934222126617`*^9, 3.9101934616905284`*^9}, {
  3.9101935058843393`*^9, 
  3.910193595608042*^9}},ExpressionUUID->"4d81e0f0-8038-48d1-9b4d-\
a1aa2b9f3a25"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pregunta II", "Section",
 CellChangeTimes->{{3.91019452202967*^9, 
  3.9101945296953883`*^9}},ExpressionUUID->"b042c5e3-7b84-4117-a975-\
fa5489f544c8"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", "1", "+", "\[Mu]", 
        StyleBox["x", "TI"], "+", 
        SuperscriptBox[
         StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
    "input" -> "\\dot{x}=1+\\mu x+x^2", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"3ee96891-e4ea-4fa6-a249-1c432dec9ab7"]], \
"Item",
 CellChangeTimes->{
  3.91019454563992*^9},ExpressionUUID->"8cd4add6-d481-4af1-a8d0-6e607bbe1f54"],

Cell[TextData[{
 "Los puntos de equilibrio est\[AAcute]n dados por \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"1", ",", "2"}], "\[FivePointedStar]"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-", "\[Mu]", "\[PlusMinus]", 
            SqrtBox[
             RowBox[{
               SuperscriptBox["\[Mu]", "2"], "-", "4"}]]}], "2"]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "x_{1,2}^{\\star}=\\frac{-\\mu\\pm\\sqrt{\\mu^2-4}}{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4203ed03-7015-4c06-9d20-31ba4ada0013"],
 "\nVemos que los puntos de equilibrio existen s\[OAcute]lo si\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Mu]", "2"], "-", "4", ">", "0"}], TraditionalForm],
      "errors" -> {}, "input" -> "\\mu^2-4>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8250955b-dec9-432f-91c9-8bac61b2f980"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Mu]", "2"], ">", "4"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu^2>4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a6b0688c-2e69-472f-9c65-79da3d46446b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", "\[Mu]", "|", ">", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|\\mu|>2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "55f8064f-6843-4b85-9155-fa5aca8132d7"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "<", "-2"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mu<-2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f6c426f2-7af0-4ff7-a6b4-9a656e00a85c"],
 " \[OAcute] ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", ">", "2"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu>2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "238f7681-2308-44a7-a6b0-4b99f7997d6b"],
 ",\npor lo que deber\[IAcute]an haber dos bifurcaciones de silla nodo en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "-2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=-2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bc6a651f-883f-43f5-9920-5a7c0f378270"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9ceb91a8-e46f-49d9-b188-417e3cc435fe"],
 ". En efecto, vemos que si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "-2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=-2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "50a9895c-bdd9-4834-a8a1-d44b9992978b"],
 ", entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         "1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_1^{\\star}=x_2^{\\star}=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fda6b2a5-d25b-47d5-9e88-9e7834009f52"],
 ", y si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3f21b6d7-a770-463e-8a2f-55da81ebd1f1"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         "-1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_1^{\\star}=x_2^{\\star}=-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "207a8b18-7325-40d5-9b5a-02537d68c3df"],
 ", por lo que las soluciones en este punto aparecen o se aniquilan."
}], "Text",
 CellChangeTimes->{{3.910194580782178*^9, 3.9101945936255026`*^9}, {
   3.910194661547802*^9, 3.9101946640536327`*^9}, 3.9101947047995234`*^9, {
   3.9101947878503637`*^9, 3.9101949377335253`*^9}, {3.910194984903421*^9, 
   3.9101949996582766`*^9}, {3.910195030488336*^9, 3.910195061342551*^9}, {
   3.9101951263971863`*^9, 
   3.910195126910653*^9}},ExpressionUUID->"b5de7cd7-11e4-47de-a146-\
d6a918e538fe"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", "-", 
        SubscriptBox["\[Mu]", "1"], 
        StyleBox["x", "TI"], "-", 
        SubscriptBox["\[Mu]", "2"], 
        SuperscriptBox[
         StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
    "input" -> "\\dot{x}=-\\mu_1x-\\mu_2x^2", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"eb516d1e-3609-4074-9bd0-9b1664190591"]], \
"Item",
 CellChangeTimes->{
  3.9101951336408567`*^9},ExpressionUUID->"fc1a254e-684e-444d-ab9f-\
d43bc4b6c86e"],

Cell[TextData[{
 "Los puntos de equilibrio son\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "x_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "99f283b9-a5bb-433c-8011-28a394adcea4"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         SubscriptBox["\[Mu]", "1"], "-", 
         SubscriptBox["\[Mu]", "2"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "-\\mu_1-\\mu_2x^{\\star}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7dffbc5e-42b9-4539-a727-76b83e041f05"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         "-", 
         FractionBox[
          SubscriptBox["\[Mu]", "1"], 
          SubscriptBox["\[Mu]", "2"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "x_2^{\\star}=-\\frac{\\mu_1}{\\mu_2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "233004fe-3d1f-439c-bd23-70c1133df6d4"],
 "\nComo los dos puntos de equilibrio siempre existen, deber\[IAcute]a haber \
una bifurcaci\[OAcute]n transcr\[IAcute]tica. Para asegurarnos y encontrar el \
punto cr\[IAcute]tico, determinamos la estabilidad. Tenemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "\[LongEqual]",
          "-", 
         SubscriptBox["\[Mu]", "1"], "-", "2", 
         SubscriptBox["\[Mu]", "2"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "f'(x^{\\star})=-\\mu_1-2\\mu_2x^{\\star}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "29b95a8b-4868-4a49-89ab-2612337b2e92"],
 ". Evaluando en el primer punto de equilibrio, obtenemos que \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", "0", ")"}], "\[LongEqual]", "-", 
         SubscriptBox["\[Mu]", "1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f'(0)=-\\mu_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ee5e8734-6d2d-47ac-ab9c-d107516ee90a"],
 "\npor lo que este punto de equilibrio es estable si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", "1"], ">", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu_1>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3d40a802-5c32-4e53-86e1-b65e8eadb1aa"],
 " e inestable si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", "1"], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu_1<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4c585296-f5ed-4a22-a380-bfdbb657416c"],
 ".\nCon el segundo punto de equilibrio obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           RowBox[{"-", 
             FractionBox[
              SubscriptBox["\[Mu]", "1"], 
              SubscriptBox["\[Mu]", "2"]]}], ")"}], "\[LongEqual]", "-", 
         SubscriptBox["\[Mu]", "1"], "+", "2", 
         SubscriptBox["\[Mu]", "1"], "\[LongEqual]", 
         SubscriptBox["\[Mu]", "1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f'(-\\frac{\\mu_1}{\\mu_2}})=-\\mu_1+2\\mu_1=\\mu_1", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e870e9ef-e6cb-4081-9695-263052973349"],
 "\nas\[IAcute] que este punto de equilibrio es estable si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", "1"], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu_1<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "24cf83bd-7bfa-426d-aafc-67d8b2dda81c"],
 " e inestable si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", "1"], ">", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu_1>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f3418be-95f7-4780-91c9-248c2e8ba666"],
 ". Vemos entonces que el punto cr\[IAcute]tico donde ocurre la bifurcaci\
\[OAcute]n transcr\[IAcute]tica es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", "1"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu_1=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7c8b6739-2ef6-4dd4-8a4b-d2650c85ac85"],
 ", y el par\[AAcute]metro ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Mu]", "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f16ec6f3-4f2b-4f5a-b501-99742b8e0de8"],
 " no es bifurcante."
}], "Text",
 CellChangeTimes->{{3.9101951520767565`*^9, 3.910195196413349*^9}, {
  3.9101952279160194`*^9, 3.9101952356098585`*^9}, {3.91019528435046*^9, 
  3.910195325519043*^9}, {3.9101954050829277`*^9, 3.9101954866473646`*^9}, {
  3.910195528388362*^9, 
  3.9101956000010805`*^9}},ExpressionUUID->"e82343ed-7535-4a47-aa1d-\
8b9df02b3d05"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[LongEqual]", "\[Mu]", 
        StyleBox["x", "TI"], "+", 
        SuperscriptBox[
         StyleBox["x", "TI"], "2"], "-", 
        SuperscriptBox[
         StyleBox["x", "TI"], "3"], "+", 
        SuperscriptBox[
         StyleBox["x", "TI"], "4"]}], TraditionalForm], "errors" -> {}, 
    "input" -> "\\dot{x}=\\mu x+x^2-x^3+x^4", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"0a767d91-62f0-4ffd-b4b1-36154fd99e7b"]], \
"Item",
 CellChangeTimes->{
  3.9101957101066103`*^9},ExpressionUUID->"22c0060c-aca6-4ad4-90ee-\
415f9103c361"],

Cell[TextData[{
 "En este caso s\[OAcute]lo hay un punto de equilibrio que podemos calcular \
con facilidad, que es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x^{\\star}=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ed5296a1-8a77-47aa-87b0-3f9c487725ab"],
 ". Para saber donde ocurre la bifurcaci\[OAcute]n, aproximamos la funci\
\[OAcute]n cerca de este punto de equilibrio, es decir, expandimos en series \
de Taylor cerca de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7b1ce685-7574-4b6d-a008-ca9bae02d5f0"],
 ". En este caso, como es un polinomio, no tenemos que hacer la expansi\
\[OAcute]n por la definici\[OAcute]n, s\[OAcute]lo notamos que, cerca de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b1a91c31-00f8-447b-8336-55e12cd11b5c"],
 ", los t\[EAcute]rminos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["x", "TI"], "3"], TraditionalForm], "errors" -> {}, "input" -> 
     "x^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "de847763-f254-40da-88a0-5f0e7149fec5"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["x", "TI"], "4"], TraditionalForm], "errors" -> {}, "input" -> 
     "x^4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9fb32dac-2fe2-4505-8991-ff76ff4e8265"],
 " son casi cero, en comparaci\[OAcute]n con los otros dos t\[EAcute]rminos, \
por lo que tenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[TildeTilde]", "\[Mu]", 
         StyleBox["x", "TI"], "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)\\approx \\mu x+x^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fededcf1-2770-4803-b98d-ca41f29f7a10"],
 "\nEsta es la forma normal de la bifurcaci\[OAcute]n transcr\[IAcute]tica. \
Vemos que el otro punto de equilibrio tiene aproximadamente el valor ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[TildeTilde]", "-", 
         "\[Mu]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "x^{\\star}\\approx-\\mu", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "368bdba9-761a-46a0-a154-b0013e907183"],
 ", y calculando el criterio de estabilidad para el primer punto, encontramos \
que el punto cr\[IAcute]tico es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ac425a8b-8554-4e18-966f-868dfacb4b95"],
 ", mismo punto donde ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], "2", "\[FivePointedStar]"]}], TraditionalForm],
      "errors" -> {}, "input" -> "x_1^{\\star}=x_2^{\\star}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f5069bb4-595f-4f31-9e65-184508889426"],
 "."
}], "Text",
 CellChangeTimes->{{3.9101963449564238`*^9, 3.910196389793686*^9}, {
  3.910196421793192*^9, 
  3.910196662915225*^9}},ExpressionUUID->"ce65565b-614e-4fd3-9a2b-\
285af06eb58f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pregunta 3", "Section",
 CellChangeTimes->{{3.910198076191351*^9, 
  3.9101980774632607`*^9}},ExpressionUUID->"2cac58a4-2ff0-44e1-8d4f-\
43888324c359"],

Cell["Puntos de equilibrio y bifurcaci\[OAcute]n de silla nodo", "Item",
 CellChangeTimes->{{3.9101981117235117`*^9, 3.9101981144810925`*^9}, {
  3.91019899391225*^9, 
  3.9101990064526677`*^9}},ExpressionUUID->"c97988f5-680a-461b-aa3e-\
a4a80b7aa859"],

Cell[TextData[{
 "Hacemos lo siguiente:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "3"}]], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "5"}]], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "rx^{\\star}+x^{\\star 3}-x^{\\star 5}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fccc6035-7afc-4546-b1d7-31732ee196cc"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "x_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2a50d0f-838c-4565-af33-5ab15516eb0d"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "4"}]], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "r+x^{\\star 2}-x^{\\star 4}=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c8116bbc-5838-4ab2-8dc8-41329a7bd9e2"],
 "\nHacemos el cambio de variable ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y=x^{\\star 2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1dfe0e5f-1346-4cea-afa0-0b527af3a7f6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "+", 
         StyleBox["y", "TI"], "-", 
         SuperscriptBox[
          StyleBox["y", "TI"], "2"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r+y-y^2=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "43aa5150-8e48-452a-91b4-5eaa826cd3fb"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["y", "TI"], "2"], "-", 
         StyleBox["y", "TI"], "-", 
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "y^2-y-r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "73d0d504-d0da-4a61-8b53-0e54de1a9584"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"1", "\[PlusMinus]", 
            SqrtBox[
             RowBox[{"1", "+", "4", 
               StyleBox["r", "TI"]}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y=\\frac{1\\pm\\sqrt{1+4r}}{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "387feef3-af44-464d-91da-56ded7e2aa49"],
 "\nSustituimos el cambio de variable\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"1", "\[PlusMinus]", 
            SqrtBox[
             RowBox[{"1", "+", "4", 
               StyleBox["r", "TI"]}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{\\star 2}=\\frac{1\\pm\\sqrt{1+4r}}{2}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f79079f1-2103-4fbe-86e0-3c4dd768dbe5"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         "\[PlusMinus]", 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "\[PlusMinus]", 
             SqrtBox[
              RowBox[{"1", "+", "4", 
                StyleBox["r", "TI"]}]]}], "2"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "x^{\\star}=\\pm\\sqrt{\\frac{1\\pm\\sqrt{1+4r}}{2}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c107b6a2-1124-4d44-9e3c-6f753d8d5ba7"],
 "\nson cuatro puntos de equilibrio, con cada combinaci\[OAcute]n diferente \
de signos.\nVemos para que valores de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4cc326cb-1229-41e3-9e16-b1bd25f3dabd"],
 " los puntos de equilibrio ya no existen, lo cual se\[NTilde]ala una \
bifurcaci\[OAcute]n de silla-nodo:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "+", "4", 
         StyleBox["r", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "1+4r<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "300f8770-3164-4db0-bf3f-347a741196fd"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"4", 
         StyleBox["r", "TI"], "<", "-1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "4r<-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "de299a03-b4e3-4fea-8b78-3114e1323c57"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", "-", 
         FractionBox["1", "4"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r<-\\frac{1}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "90e3a8b6-05aa-434f-b826-1a5066f25138"],
 "\nEn esta regi\[OAcute]n las soluciones no son reales. Cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "-", 
         FractionBox["1", "4"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r=-\\frac{1}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c38493a6-e54e-4f71-8db2-d21858aa3723"],
 " vemos que de los cuatro  puntos de equilibrio, s\[OAcute]lo tenemos dos, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SqrtBox[
        FractionBox["1", "2"]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\sqrt{\\frac{1}{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "49a95b2e-5e7c-4574-9bd4-7bdbf1f58987"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         SqrtBox[
          FractionBox["1", "2"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "-\\sqrt{\\frac{1}{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f43ee0e7-e909-4983-8973-59a5e21272c6"],
 ", por lo que cada par de puntos de equilibrio est\[AAcute]n en el punto de \
bifurcaci\[OAcute]n de silla-nodo (recordemos que, en la bifurcaci\[OAcute]n \
de silla nodo, tenemos una regi\[OAcute]n donde no existen, otra donde surgen \
como uno solo, y otra donde hay dos, en este caso tenemos un par de \
bifurcaciones de silla nodo, por lo que en cierta regi\[OAcute]n no hay \
puntos de equilibrio, despu\[EAcute]s hay dos, y despu\[EAcute]s se dividen \
en cuatro).\nHay otra regi\[OAcute]n donde las soluciones de equilibrio ya no \
son reales, que es cuando \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "-", 
         SqrtBox[
          RowBox[{"1", "+", "4", 
            StyleBox["r", "TI"]}]], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "1-\\sqrt{1+4r}<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "446011ed-1961-4b23-8973-a8c9b29a2a43"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SqrtBox[
          RowBox[{"1", "+", "4", 
            StyleBox["r", "TI"]}]], ">", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\sqrt{1+4r}>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "738e7a88-ded8-4a30-933d-e6444cad50f6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "+", "4", 
         StyleBox["r", "TI"], ">", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "1+4r>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "91f040fb-4f2f-4a01-8e84-6f83785794ec"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"4", 
         StyleBox["r", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "4r>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fd3e1c6e-65fc-4807-9db7-23a22e213adf"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "77172fce-3c1f-4d69-b869-787514390bd5"],
 ".\nCuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f24ed107-3d0f-4077-ab1e-67bf4cd4b93e"],
 ", vemos que dos de estos puntos de equilibrio no son cero y tienen los \
valores ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[PlusMinus]", 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "+", 
             SqrtBox[
              RowBox[{"1", "+", "4", 
                StyleBox["r", "TI"]}]]}], "2"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\pm\\sqrt{\\frac{1+\\sqrt{1+4r}}{2}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c58ca43c-c832-4c2d-ad0d-a7af945249df"],
 ", y los otros dos puntos de equilibrio se vuelven cero, por lo que tenemos \
tres puntos de equilibrio que coinciden: el cero que calculamos al principio, \
y los otros dos puntos de equilibrio que surgen detener signo negativo dentro \
y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "47bf371a-1639-4f1f-9861-bc18650fd928"],
 ", por lo que esta NO es una bifurcaci\[OAcute]n de silla-nodo, sino de \
tridente. Por lo tanto ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["s", "TI"]], "\[LongEqual]", "-", 
         FractionBox["1", "4"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r_s=-\\frac{1}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3a8cff21-ee6b-407c-9413-e4119dc1eaea"],
 "."
}], "Text",
 CellChangeTimes->{{3.910198182841178*^9, 3.9101983316008625`*^9}, {
  3.910198376549597*^9, 3.9101984241556177`*^9}, {3.9101984962993155`*^9, 
  3.9101988524542017`*^9}, {3.910198888001644*^9, 
  3.910198970605891*^9}},ExpressionUUID->"7b86a059-131a-45cd-acc6-\
94c501ac26f2"],

Cell["Espacio fase", "Item",
 CellChangeTimes->{{3.910199068788221*^9, 
  3.9101990704766912`*^9}},ExpressionUUID->"ce57df35-8465-4ea8-8a4e-\
a3c558edc400"],

Cell[TextData[{
 "Cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "<", "-", 
         FractionBox["1", "4"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "r<-\\frac{1}{4}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "360b013f-2da1-4885-b5a1-9232ab4edc03"],
 ", ya sabemos que s\[OAcute]lo debe haber un cruce con el eje ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6f65a0f9-8924-424e-8888-e1a00f050688"],
 " porque s\[OAcute]lo hay un punto de equilibrio. S\[OAcute]lo basta \
determinar si cruza de arriba hacia abajo o de abajo hacia arriba. Para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         StyleBox["x", "TI"], "|", "\[GreaterGreater]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "|x|\\gg1", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ee117049-55b0-4fe6-afaa-96097c9cd3c1"],
 ", el t\[EAcute]rmino que domina es ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "5"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "-x^5", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "376c597b-e0f8-4adc-925d-bbe2573575b0"],
 ". Por lo tanto, si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[GreaterGreater]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x\\gg1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d00e07b9-0e0a-40fe-944c-266064483997"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "f(x)<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0cd6b891-7d02-44f5-8260-188c20a58de0"],
 " y viceversa para ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LessLess]", "-1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x\\ll-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "830a3ca2-0b6c-4329-b41b-ea2735166226"],
 ". Por lo tanto, la funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1cba346b-52b0-4d71-a7d9-b3b1219b9ed3"],
 " debe cruzar de arriba hacia abajo. Por esta raz\[OAcute]n, el equilibrio \
debe ser estable. El espacio fase debe verse similar al siguiente:"
}], "Text",
 CellChangeTimes->{{3.9101990801094236`*^9, 3.9101992991944013`*^9}, {
  3.9101996057549696`*^9, 
  3.9101996145614696`*^9}},ExpressionUUID->"69097e98-bbda-49fa-ad8a-\
090833b2364c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}]}], "*", "u"}], "+", 
      RowBox[{"u", "^", "3"}], "-", 
      RowBox[{"u", "^", "5"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"Frame", "->", 
      RowBox[{"{", 
       RowBox[{"True", ",", "True", ",", "False", ",", "False"}], "}"}]}], 
     ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], ",", 
        RowBox[{"TraditionalForm", "[", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], ",", "t"}], "]"}], "]"}]}], "}"}]}], 
     ",", 
     RowBox[{"Epilog", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"PointSize", "[", "Medium", "]"}], ",", 
        RowBox[{"Point", "[", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}], "}"}], "]"}]}], "}"}]}]}], "]"}], 
   ",", 
   RowBox[{"NumberLinePlot", "[", 
    RowBox[{
     RowBox[{"Interval", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "Infinity"}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "2"}], ",", 
       RowBox[{"-", "0.5"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
     RowBox[{"Spacings", "\[Rule]", "0"}]}], "]"}], ",", 
   RowBox[{"NumberLinePlot", "[", 
    RowBox[{
     RowBox[{"Interval", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "Infinity"}], ",", "2"}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0.5", ",", "2"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
     RowBox[{"Spacings", "\[Rule]", "0"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9101993933087754`*^9, 3.9101995214658265`*^9}, {
  3.9101995550747256`*^9, 3.9101995985108137`*^9}},
