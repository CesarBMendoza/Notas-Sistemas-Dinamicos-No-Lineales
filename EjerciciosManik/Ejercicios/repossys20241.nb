Cell[BoxData[
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"2", "-", 
         RowBox[{"5.95", "*", 
          RowBox[{"x", "[", "t", "]"}]}], "+", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"4.95", "*", 
          RowBox[{"x", "[", "t", "]"}]}], "-", 
         RowBox[{
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "^", "2"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "2.2"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "2.6"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "100"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9102762503834314`*^9, 3.910276257555602*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"800de24b-a8dd-43de-b507-a05bf3b8010e"],

