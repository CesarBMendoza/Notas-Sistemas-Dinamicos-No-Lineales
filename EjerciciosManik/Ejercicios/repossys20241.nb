Cell[TextData[{
 "2. Cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", "\[Mu]", "|", "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|\\mu|=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9fa67311-4ba9-4e3d-9f37-8342f8ad69cc"],
 " hay exactamente una soluci\[OAcute]n de equilibrio cada que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         FractionBox["\[Pi]", "2"], "+", "2", 
         StyleBox["k", "TI"], "\[Pi]"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r=\\frac{\\pi}{2}+2k\\pi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ce639e9d-39b5-4958-931e-5aa55f66b0b1"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2b2a3afe-26e2-4f70-9f6a-f3d228a87a2a"],
 ", \[OAcute] ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"3", "\[Pi]"}], "2"], "+", "2", 
         StyleBox["k", "TI"], "\[Pi]"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r=\\frac{3\\pi}{2}+2k\\pi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fb008f9d-b981-43b3-b577-d297b22f7d05"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "-1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r=-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ef27c135-a91b-463c-ac71-f7f316e1caaa"],
 ", ya sea en los m\[AAcute]ximos o m\[IAcute]nimos del seno."
}], "Text",
 CellChangeTimes->{{3.9102780708346477`*^9, 
  3.9102782446865835`*^9}},ExpressionUUID->"2a7bbbc6-ca0e-4e9e-aece-\
fb481aeeae89"],

