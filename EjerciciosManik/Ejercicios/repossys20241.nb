Cell[TextData[{
 "Por lo tanto, en el sistema unidimensional hay un n\[UAcute]mero infinito, \
pero numerable, de bifurcaciones de silla-nodo en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d80c28b5-0b7a-47d8-aeac-52fbbcc9bda3"],
 " y tambi\[EAcute]n en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "-1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7fd8cd1c-e13f-4faf-8820-a613c99014c2"],
 ". Traduciendo estos resultados al sistema bidimensional completo, tenemos \
ciclos l\[IAcute]mite circulares con radios cercanos que se aniquilan en \
estos valores del par\[AAcute]metro, por lo que tenemos bifurcaciones de \
silla-nodo de ",
 StyleBox["ciclos",
  FontWeight->"Bold"],
 ". Es importante notar que estas son bifurcaciones globales, en lugar de \
bifurcaciones normales como las que ten\[IAcute]amos en otros casos."
}], "Text",
 CellChangeTimes->{{3.9102784375070343`*^9, 
  3.9102786360486345`*^9}},ExpressionUUID->"36145385-0335-4623-80e3-\
dcc6bc68314a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Parcial IV", "Chapter",
 CellChangeTimes->{{3.910279974967311*^9, 
  3.9102799764772415`*^9}},ExpressionUUID->"3edfa0fb-67be-4e76-bc93-\
3ee1bc153381"],

Cell[CellGroupData[{

Cell["Pregunta I", "Section",
 CellChangeTimes->{{3.910279985041957*^9, 
  3.9102799915471716`*^9}},ExpressionUUID->"9b49edc4-dcd7-4374-a09d-\
967a0eec8f86"],

Cell["Bifurcaci\[OAcute]n de tridente.", "Item",
 CellChangeTimes->{{3.9102871100905113`*^9, 
  3.910287113901945*^9}},ExpressionUUID->"b8cf83dd-5973-4631-97ae-\
0a000b1c9910"],

Cell[TextData[{
 "Calculamos lo puntos de equilibrio. Empezamos con la segunda \
ecuaci\[OAcute]n que dice\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y^{\\star}=x^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "71271c2a-7bf8-4f07-be7f-801f8ab3ceff"],
 "\nSustituyendo en la primera ecuaci\[OAcute]n, obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         StyleBox["d", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "3"}]], "-", 
         StyleBox["b", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "x^{\\star}=dx^{\\star}-x^{\\star 3}-bx^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b4ccbafd-4fe8-480f-882a-76aacb751dcf"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "x_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "914c8571-230c-4efb-8148-b01d0fa18533"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["y", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "y_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2d5f9ffb-f8d2-4e8b-ac35-1e8f107f9ce0"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "\[LongEqual]", 
         StyleBox["d", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "-", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "1=d-x^{\\star 2}-b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b461b7e9-9612-4c79-929b-a2d9c7bd82f1"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]], "\[LongEqual]", 
         StyleBox["d", "TI"], "-", 
         StyleBox["b", "TI"], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "x^{\\star 2}=d-b-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ac1eb7a3-c360-4763-b0d9-0a25900da9e6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{"2", ",", "3"}], "\[FivePointedStar]"], "\[LongEqual]", 
         "\[PlusMinus]", 
         SqrtBox[
          RowBox[{
            StyleBox["d", "TI"], "-", 
            StyleBox["b", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{2,3}^{\\star}=\\pm\\sqrt{d-b-1}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5d5508fd-5a80-4a99-8bc3-5085cbdcc389"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["y", "TI"], 
          RowBox[{"2", ",", "3"}], "\[FivePointedStar]"], "\[LongEqual]", 
         "\[PlusMinus]", 
         SqrtBox[
          RowBox[{
            StyleBox["d", "TI"], "-", 
            StyleBox["b", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y_{2,3}^{\\star}=\\pm\\sqrt{d-b-1}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "464fd369-bd2f-4f68-b80c-5b4af7277cf3"],
 "\nVemos que estos puntos de equilibrio no existen cuando \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "-", 
         StyleBox["b", "TI"], "-", "1", "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "d-b-1<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4a3546f4-34bc-4d0a-af70-26730742ab75"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "<", 
         StyleBox["b", "TI"], "+", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "d<b+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d4c08f7d-cf5e-466f-ac7e-8695ecc656d2"],
 "\nAdem\[AAcute]s, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "\[LongEqual]", 
         StyleBox["b", "TI"], "+", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "d=b+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "766a99ad-ec7d-4f43-a7a3-8f9ca91ca5cb"],
 ", los tres puntos de equilibrio son iguales al ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"0", ",", "0"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "(0,0)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ca33f73c-b741-4556-9e00-b525ad3c25d5"],
 ". Esto nos dice que debe haber una bifurcaci\[OAcute]n de tridente. Debemos \
determinar de qu\[EAcute] tipo es, calculando la estabilidad. La matriz \
Jacobiana en este caso est\[AAcute] dada por"
}], "Text",
 CellChangeTimes->{{3.9102800432156267`*^9, 3.9102800816511374`*^9}, {
  3.910280133661542*^9, 3.910280209656188*^9}, {3.9102802435324*^9, 
  3.910280257539981*^9}, {3.9102803941617174`*^9, 
  3.910280519764393*^9}},ExpressionUUID->"6051ca59-3c91-45cb-9638-\
3f7491dcdab3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"J2", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"d", "*", "x"}], "-", 
         RowBox[{"x", "^", "3"}], "-", 
         RowBox[{"b", "*", "y"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"d", "*", "x"}], "-", 
         RowBox[{"x", "^", "3"}], "-", 
         RowBox[{"b", "*", "y"}]}], ",", "y"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"x", ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{"x", ",", "y"}], "]"}]}], "}"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.910280522211438*^9, 3.9102805882501755`*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"3bfee8a0-1fe8-4f1f-8423-39be39ee4c30"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"d", "-", 
      RowBox[{"3", " ", 
       SuperscriptBox["x", "2"]}]}], ",", 
     RowBox[{"-", "b"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.910280557632761*^9, 3.9102805887232423`*^9},
 CellLabel->"Out[36]=",ExpressionUUID->"3d698bef-9d68-4bc3-a120-44b934072b84"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "[", "J2", "]"}]], "Input",
 NumberMarks->False,
 CellLabel->"In[37]:=",ExpressionUUID->"5530edc1-ab31-4afb-87e5-c69dd5e2bcf9"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"d", "-", 
       RowBox[{"3", " ", 
        SuperscriptBox["x", "2"]}]}], 
      RowBox[{"-", "b"}]},
     {"1", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{{3.910280562078382*^9, 3.9102805912595086`*^9}},
 CellLabel->
  "Out[37]//MatrixForm=",ExpressionUUID->"1f4db7b3-8dd5-4af0-9b3d-\
767676781af5"]
}, Open  ]],

Cell["En el origen, la matriz se reduce a ", "Text",
 CellChangeTimes->{{3.910280609820712*^9, 
  3.9102806166634827`*^9}},ExpressionUUID->"9022b193-820a-4376-a0d3-\
fb7965860bc7"],

