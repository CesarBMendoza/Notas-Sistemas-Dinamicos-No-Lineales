Cell[TextData[{
 "Otra opci\[OAcute]n ser\[IAcute]a la ecuaci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", "cosh", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], "-", "0.5"}], ")"}], "-", "1.12763"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=\\cosh(x-0.5)-1.12763", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f8909afa-a0e0-48d0-8a95-4c496a745025"],
 ", cuyas soluciones se ven de la siguiente forma:"
}], "Text",
 CellChangeTimes->{{3.9101824542648797`*^9, 3.910182462435861*^9}, {
  3.91018249616439*^9, 
  3.9101825022473197`*^9}},ExpressionUUID->"33c06bc1-5e3d-4df5-b476-\
c7e0f06487e2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol4", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"Cosh", "[", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "-", "0.5"}], "]"}], "-", 
         "1.12763"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", 
        RowBox[{"-", "1"}]}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "8"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol5", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"Cosh", "[", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "-", "0.5"}], "]"}], "-", 
         "1.12763"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "0.99"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "8"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol6", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"Cosh", "[", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "-", "0.5"}], "]"}], "-", 
         "1.12763"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "1.01"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "8"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], "/.", "sol4"}], "]"}], ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], "/.", "sol5"}], "]"}], ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], "/.", "sol6"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "8"}], "}"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{"x", "[", "t", "]"}]}], "}"}]}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.910182510981084*^9, 3.9101825585134563`*^9}, {
  3.9101826745218253`*^9, 3.9101826953004436`*^9}, {3.910182738874756*^9, 
  3.9101827910112767`*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"655944d7-6db9-4e1c-a884-74d780b2d6c8"],

