Cell[TextData[{
 "Como en el an\[AAcute]lisis anterior, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "r>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "36b5bc7b-64fa-4e6a-876f-54fdc9e5fd50"],
 ", s\[OAcute]lo sobreviven el punto de equilibrio cero, y dos puntos de \
equilibrio diferentes de cero. Mediante los mismos argumentos anteriores, en \
el primer punto de equilibrio distinto de cero, la funci\[OAcute]n debe \
cruzar de arriba a abajo (estable), en el cero debe cruzar de abajo hacia \
arriba (inestable), y en el \[UAcute]ltimo punto de equilibrio, debe cruzar \
de arriba hacia abajo (estable). El diagrama debe verse como:"
}], "Text",
 CellChangeTimes->{{3.9102650338691835`*^9, 
  3.910265142928237*^9}},ExpressionUUID->"bd5fcfbf-1efc-4593-b060-\
12bf3ae03c81"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], "*", "u"}], "+", 
      RowBox[{"u", "^", "3"}], "-", 
      RowBox[{"u", "^", "5"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"Frame", "->", 
      RowBox[{"{", 
       RowBox[{"True", ",", "True", ",", "False", ",", "False"}], "}"}]}], 
     ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], ",", 
        RowBox[{"TraditionalForm", "[", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], ",", "t"}], "]"}], "]"}]}], "}"}]}], 
     ",", 
     RowBox[{"Epilog", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"PointSize", "[", "Medium", "]"}], ",", 
        RowBox[{"Point", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}], "/", "2"}], "]"}], 
             ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Sqrt", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"1", "+", 
                  RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}], "/", "2"}], 
               "]"}]}], ",", "0"}], "}"}]}], "}"}], "]"}]}], "}"}]}]}], "]"}],
    ",", 
   RowBox[{"NumberLinePlot", "[", 
    RowBox[{
     RowBox[{"Interval", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "Infinity"}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "2"}], ",", 
       RowBox[{"-", "1.5"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
     RowBox[{"Spacings", "\[Rule]", "0"}]}], "]"}], ",", 
   RowBox[{"NumberLinePlot", "[", 
    RowBox[{
     RowBox[{"Interval", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "Infinity"}], ",", 
        RowBox[{"-", "0.1"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "0.8"}], ",", 
       RowBox[{"-", "0.1"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
     RowBox[{"Spacings", "\[Rule]", "0"}]}], "]"}], ",", 
   RowBox[{"NumberLinePlot", "[", 
    RowBox[{
     RowBox[{"Interval", "[", 
      RowBox[{"{", 
       RowBox[{"0.1", ",", "Infinity"}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0.1", ",", "0.8"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
     RowBox[{"Spacings", "\[Rule]", "0"}]}], "]"}], ",", 
   RowBox[{"NumberLinePlot", "[", 
    RowBox[{
     RowBox[{"Interval", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "Infinity"}], ",", "2"}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1.5", ",", "2"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
     RowBox[{"Spacings", "\[Rule]", "0"}]}], "]"}]}], "]"}]], "Input",
