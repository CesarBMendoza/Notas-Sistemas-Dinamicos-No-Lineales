Cell["Cuyo polinomio caracter\[IAcute]stico es ", "Text",
 CellChangeTimes->{{3.910280669637433*^9, 
  3.910280676608181*^9}},ExpressionUUID->"dba92c45-f75e-471f-bd13-\
fa3564c0e274"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CharacteristicPolynomial", "[", 
  RowBox[{
   RowBox[{"J2", "/.", 
    RowBox[{"{", 
     RowBox[{"x", "->", "0"}], "}"}]}], ",", "\[Lambda]"}], "]"}]], "Input",
 CellChangeTimes->{{3.9102806804360414`*^9, 3.9102806986430454`*^9}, {
  3.910280736621484*^9, 3.9102807396912956`*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"8fa41493-548c-491a-aeac-e9b2ee817bf4"],

Cell[BoxData[
 RowBox[{"b", "-", 
  RowBox[{"d", " ", "\[Lambda]"}], "+", 
  SuperscriptBox["\[Lambda]", "2"]}]], "Output",
 CellChangeTimes->{3.9102806993075576`*^9, 3.9102807400171165`*^9},
 CellLabel->"Out[40]=",ExpressionUUID->"35b075de-c902-4f45-bad3-56967dfe0332"]
}, Open  ]],

Cell[TextData[{
 "El criterio de Jury ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SubscriptBox[
          StyleBox["a", "TI"], "1"], "|", "<", 
         SubscriptBox[
          StyleBox["a", "TI"], "2"], "+", "1", "<", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|a_1|<a_2+1<2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8758bb2c-9fb3-49a6-8795-34718d7e665c"],
 " se traduce a\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         StyleBox["d", "TI"], "|", "<", 
         StyleBox["b", "TI"], "+", "1", "<", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|d|<b+1<2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9215e6c7-31b6-40f1-8440-20b49e4f8591"],
 "\nResultando en las desigualdades\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "<", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "b<1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dfa16972-84f6-4464-b80b-6b6d7aecc476"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "<", 
         StyleBox["b", "TI"], "+", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "d<b+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d647377d-ff8d-48bb-9938-6d4242b4811a"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         StyleBox["b", "TI"], "-", "1", "<", 
         StyleBox["d", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "-b-1<d", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "944cd35f-e922-43e7-9960-5777d83a7c3a"],
 "\nLa segunda desigualdad dice que el cero es estable en el rango de par\
\[AAcute]metros en el cual los otros puntos de equilibrio no existen, por lo \
cual ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "\[LongEqual]", 
         StyleBox["b", "TI"], "+", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "d=b+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b74e9d3e-f697-4581-b7e3-7c9146beeefe"],
 " es el punto cr\[IAcute]tico de una bifurcaci\[OAcute]n de tridente supercr\
\[IAcute]tica."
}], "Text",
 CellChangeTimes->{{3.9102807680604944`*^9, 3.9102807706813684`*^9}, {
  3.910280855300292*^9, 3.9102808815946293`*^9}, {3.9102809193296127`*^9, 
  3.910280968304722*^9}, {3.910281007395012*^9, 3.910281037462417*^9}, {
  3.9102810826378937`*^9, 
  3.9102811066061516`*^9}},ExpressionUUID->"9ecddb91-2edf-40bf-a9bb-\
4188b9ebd2af"],

Cell["Bifurcaci\[OAcute]n de flip", "Item",
 CellChangeTimes->{{3.9102871767200923`*^9, 
  3.910287180641239*^9}},ExpressionUUID->"d505d8da-f21b-4198-83e3-\
962f5a04cb5f"],

Cell[TextData[{
 "Sabemos que la bifurcaci\[OAcute]n de flip ocurre cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Lambda]", "\[LongEqual]", "-1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\lambda=-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "66ba172a-3823-415e-92b8-c09a042a20cb"],
 " para alguno de los eigenvalores. Dado el polinomio caracter\[IAcute]stico, \
los eigenvalores est\[AAcute]n dados por\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", 
          RowBox[{"1", ",", "2"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], "\[PlusMinus]", 
            SqrtBox[
             RowBox[{
               SuperscriptBox[
                StyleBox["d", "TI"], "2"], "-", "4", 
               StyleBox["b", "TI"]}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\lambda_{1,2}=\\frac{d\\pm\\sqrt{d^2-4b}}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "97d805eb-0630-4a60-b637-a33155fd60b7"],
 "\nSustituimos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "\[LongEqual]", "-", 
         StyleBox["b", "TI"], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "d=-b-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2a3ed2b-1c05-445a-aa5b-c5a46481f211"],
 " y obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", 
          RowBox[{"1", ",", "2"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-", 
            StyleBox["b", "TI"], "-", "1", "\[PlusMinus]", 
            SqrtBox[
             RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                  RowBox[{"-", 
                    StyleBox["b", "TI"], "-", "1"}], ")"}], "2"], "-", "4", 
               StyleBox["b", "TI"]}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\lambda_{1,2}=\\frac{-b-1\\pm\\sqrt{(-b-1)^2-4b}}{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "54b13b73-4c73-4c5e-9093-cbf410ec1794"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", 
          RowBox[{"1", ",", "2"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-", 
            StyleBox["b", "TI"], "-", "1", "\[PlusMinus]", 
            SqrtBox[
             RowBox[{
               SuperscriptBox[
                StyleBox["b", "TI"], "2"], "+", "2", 
               StyleBox["b", "TI"], "+", "1", "-", "4", 
               StyleBox["b", "TI"]}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\lambda_{1,2}=\\frac{-b-1\\pm\\sqrt{b^2+2b+1-4b}}{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c2da6d49-0541-426b-ab70-ed4664a8b81d"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", 
          RowBox[{"1", ",", "2"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-", 
            StyleBox["b", "TI"], "-", "1", "\[PlusMinus]", 
            SqrtBox[
             RowBox[{
               SuperscriptBox[
                StyleBox["b", "TI"], "2"], "-", "2", 
               StyleBox["b", "TI"], "+", "1"}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\lambda_{1,2}=\\frac{-b-1\\pm\\sqrt{b^2-2b+1}}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d97e05c-0c1a-48af-9996-7bc05fdd3565"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", 
          RowBox[{"1", ",", "2"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-", 
            StyleBox["b", "TI"], "-", "1", "\[PlusMinus]", 
            SqrtBox[
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  StyleBox["b", "TI"], "-", "1"}], ")"}], "2"]]}], "2"]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda_{1,2}=\\frac{-b-1\\pm\\sqrt{(b-1)^2}}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5e4a6535-caf4-4b9b-8470-aece73c2a04d"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", 
          RowBox[{"1", ",", "2"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-", 
            StyleBox["b", "TI"], "-", "1", "\[PlusMinus]", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", "1"}], ")"}]}], "2"]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda_{1,2}=\\frac{-b-1\\pm(b-1)}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e1e9c8e1-abfa-4126-86eb-d23e0342c4df"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", "1"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"-", 
            StyleBox["b", "TI"], "-", "1", "+", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["b", "TI"], "-", "1"}], ")"}]}], "2"]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda_{1}=\\frac{-b-1+(b-1)}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b70a8028-8818-41a4-a84a-9559c2703f32"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", "1"], "\[LongEqual]", 
         FractionBox["-2", "2"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda_1=\\frac{-2}{2}", "state" -> "Boxes"|>,
