Cell["Bifurcaci\[OAcute]n de Hopf", "Item",
 CellChangeTimes->{{3.91028760369893*^9, 
  3.910287607337756*^9}},ExpressionUUID->"431c9c97-8908-4893-8aeb-\
b96097128ad9"],

Cell[TextData[{
 "Necesitamos que los eigenvalores sean complejos, y para esto necesitamos \
que\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["d", "TI"], "2"], "-", "4", 
         StyleBox["b", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "d^2-4b<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "00d3ae73-1482-4a4c-932b-0e1623308b3c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["d", "TI"], "2"], "<", "4", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "d^2<4b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "05450a68-c156-463e-bb96-1a062171b147"],
 "\nS\[OAcute]lo necesitamos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["d", "TI"], TraditionalForm], "errors" -> {}, "input" -> "d", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "087b8445-3b41-4216-8d00-ee35641fca01"],
 " sea suficientemente peque\[NTilde]o. Ahora, suponiendo que estamos en este \
rango de valors de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["d", "TI"], TraditionalForm], "errors" -> {}, "input" -> "d", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "20bc6a41-3d14-43e4-892c-5bdc6d482ee0"],
 ", sabemos que, si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Lambda]", 
        RowBox[{"1", ",", "2"}]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda_{1,2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fe84f3db-9a07-4dc9-a0ce-7880b27ce65c"],
 " son las ra\[IAcute]ces del polinomio caracter\[IAcute]stico, entonces \
\[EAcute]ste puede escribirse como\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{"\[Lambda]", "-", 
             SubscriptBox["\[Lambda]", "1"]}], ")"}], "(", 
         RowBox[{"\[Lambda]", "-", 
           SubscriptBox["\[Lambda]", "2"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(\\lambda-\\lambda_1)(\\lambda-\\lambda_2)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b12df858-0d50-4d28-96fc-32ad9521a0da"],
 "\nDesarrollando este producto obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{"\[Lambda]", "-", 
             SubscriptBox["\[Lambda]", "1"]}], ")"}], "(", 
         RowBox[{"\[Lambda]", "-", 
           SubscriptBox["\[Lambda]", "2"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(\\lambda-\\lambda_1)(\\lambda-\\lambda_2)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7d72f457-1aa6-4238-ad41-59cd4e7ba5cf"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Lambda]", "2"], "-", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Lambda]", "1"], "+", 
             SubscriptBox["\[Lambda]", "2"]}], ")"}], "\[Lambda]", "+", 
         SubscriptBox["\[Lambda]", "1"], 
         SubscriptBox["\[Lambda]", "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\lambda^2-(\\lambda_1+\\lambda_2)\\lambda+\\lambda_1\\lambda_2", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1b6fe4f1-cac9-4d51-b7a2-a593322ad8f3"],
 "\nComparando esta expresi\[OAcute]n con la obtenida anteriormente para el \
polinomio caracter\[IAcute]stico, vemos que\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", "1"], "+", 
         SubscriptBox["\[Lambda]", "2"], "\[LongEqual]", "-", 
         StyleBox["d", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda_1+\\lambda_2=-d", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c7dc416c-6e1b-48cb-a4ce-f4483418e26b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", "1"], 
         SubscriptBox["\[Lambda]", "2"], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda_1\\lambda_2=b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "54d933cd-abb7-4500-9f86-2615d333ddeb"],
 "\nSi los eigenvalores son complejos, sabemos que son complejos conjugados, \
por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Lambda]", "2"], "\[LongEqual]", 
         SubscriptBox[
          OverscriptBox["\[Lambda]", "_"], "1"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\lambda_2=\\bar{\\lambda}_1", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "13f70fa5-714a-4bd2-a7b4-a4ce174fdb62"],
 ". Entonces tenemos que\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SubscriptBox["\[Lambda]", "1"], 
         SuperscriptBox["|", "2"], "\[LongEqual]", 
         SubscriptBox["\[Lambda]", "1"], 
         SubscriptBox[
          OverscriptBox["\[Lambda]", "_"], "1"], "\[LongEqual]", 
         SubscriptBox["\[Lambda]", "1"], 
         SubscriptBox["\[Lambda]", "2"], "\[LongEqual]", 
         StyleBox["b", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "|\\lambda_1|^2=\\lambda_1\\bar{\\lambda}_1=\\lambda_1\\lambda_2=b", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "21629860-4884-4afa-b974-0885d9ca586e"],
 "\nPor lo tanto, cuando los eigenvalores est\[AAcute]n sobre el circulo \
unitario, su m\[OAcute]dulo es uno y por lo tanto ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["b", "TI"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "b=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bd4e2afc-f0c1-4dcd-a4e8-7b1e69a433c3"],
 "."
}], "Text",
 CellChangeTimes->{{3.910287612713991*^9, 3.910287646322683*^9}, {
  3.9102876845943155`*^9, 3.910287958790615*^9}, {3.9102880202354407`*^9, 
  3.9102880421434565`*^9}, {3.910288143391775*^9, 
  3.9102881526524954`*^9}},ExpressionUUID->"5402eec3-0ce7-4122-bfd3-\
16fb3c71d5f4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pregunta II", "Section",
 CellChangeTimes->{{3.910292470138673*^9, 3.9102924716448793`*^9}, {
  3.91029251689818*^9, 
  3.910292517370839*^9}},ExpressionUUID->"5adaf74a-a7f5-49b8-aadb-\
ab950c923d83"],

Cell["\<\
En esta pregunta s\[OAcute]lo hay que dibujar el cobwebbing y el punto de \
equilibrio es superestable, as\[IAcute] que r\[AAcute]pidamente \
deber\[IAcute]a converger al punto de equilibrio.\
\>", "Text",
 CellChangeTimes->{{3.910292475942222*^9, 
  3.910292504737384*^9}},ExpressionUUID->"00efefba-b433-477a-a299-\
062643be31ad"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pregunta III", "Section",
 CellChangeTimes->{{3.910292519780639*^9, 
  3.910292522703063*^9}},ExpressionUUID->"c63159c0-fd0f-457b-b246-\
a2cf7a41071e"],

Cell[TextData[{
 "Calculamos los puntos de equilibrio. De la segunda ecuaci\[OAcute]n \
obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "+", 
         StyleBox["a", "TI"], 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y^{\\star}=x^{\\star}+ay^{\\star}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2bc97520-036c-474f-ae07-c60c6142fa05"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["a", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{\\star}=(1-a)y^{\\star}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6045bf8d-29e3-462d-997c-6bc33ca7b9d4"],
 "\nSustituyendo en la primera ecuaci\[OAcute]n obtenemos\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["a", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         StyleBox["a", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["a", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "-", 
         SuperscriptBox[
          StyleBox["y", "TI"], 
          RowBox[{"\[FivePointedStar]", "2"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "(1-a)y^{\\star}=a(1-a)y^{\\star}-y^{\\star 2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "df613e65-0557-46fe-871d-44b20fc5ab2b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["y", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "y_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2b722d98-8b74-42fa-afb8-c3b0b1e7a071"],
 " y con la ecuaci\[OAcute]n anterior, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "x_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9f1791a0-f07a-4ae1-9362-6993def5d0f2"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["a", "TI"]}], ")"}], "\[LongEqual]", 
         StyleBox["a", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["a", "TI"]}], ")"}], "-", 
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "(1-a)=a(1-a)-y^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b6f7bbee-776e-4d14-b5c6-74f0bed7caf6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         StyleBox["a", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["a", "TI"]}], ")"}], "-", 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["a", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "y^{\\star}=a(1-a)-(1-a)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b040a892-8e34-4b19-b3dd-034254dac822"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["y", "TI"], "\[FivePointedStar]"], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["a", "TI"], "-", "1"}], ")"}], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             StyleBox["a", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "y^{\\star}=(a-1)(1-a)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7dcc3084-428d-4d63-8367-a5236e20223a"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["y", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         "-", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"1", "-", 
              StyleBox["a", "TI"]}], ")"}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "y_2^{\\star}=-(1-a)^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "658bbcb7-bcc7-4e12-98eb-a157a84dc4f5"],
 " y con la ecuaci\[OAcute]n anterior, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["x", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         "-", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"1", "-", 
              StyleBox["a", "TI"]}], ")"}], "3"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_2^{\\star}=-(1-a)^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d7a4cbb3-c05b-4c48-a81c-64988f23f257"],
 "\nVemos que hay dos puntos de equilibrio que siempre existen. Calculamos la \
matriz Jacobiana:"
}], "Text",
 CellChangeTimes->{{3.9102925279526906`*^9, 3.9102925335679235`*^9}, {
  3.910292597872734*^9, 3.910292612706168*^9}, {3.9102926453880024`*^9, 
  3.910292682812046*^9}, {3.910292721506069*^9, 3.9102928050217175`*^9}, {
  3.9102928468413687`*^9, 3.9102928727108727`*^9}, {3.9102929610823936`*^9, 
  3.910293050805125*^9}, {3.9102964366455564`*^9, 
  3.9102964587890205`*^9}},ExpressionUUID->"99f235f6-fd99-40a7-ab9e-\
f7eb84790b06"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"J3", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "*", "x"}], "-", 
         RowBox[{"y", "^", "2"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "*", "x"}], "-", 
         RowBox[{"y", "^", "2"}]}], ",", "y"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", "+", 
         RowBox[{"a", "*", "y"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", "+", 
         RowBox[{"a", "*", "y"}]}], ",", "y"}], "]"}]}], "}"}]}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.910293054205587*^9, 3.9102931103519454`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"8fa3cf19-90cd-427b-a792-1d0c5de4c9bc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", ",", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "y"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "a"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9102931106529818`*^9},
