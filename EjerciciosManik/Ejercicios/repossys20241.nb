Cell["Evaluamos en el primer punto de equilibrio y obtenemos", "Text",
 CellChangeTimes->{{3.9102931299532804`*^9, 
  3.910293139452739*^9}},ExpressionUUID->"ae8913fc-4acc-42c2-aad2-\
9c8ad73a814c"],

