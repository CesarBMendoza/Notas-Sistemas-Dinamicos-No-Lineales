Cell[TextData[{
 "Resolvemos la ecuaci\[OAcute]n de manera exacta:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["x", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\frac{\\mathrm{d}x}{\\mathrm{d}t}=x^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8c2d1010-1deb-45c9-bef3-efc76fb97b27"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["x", "TI"], "-3"], 
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["x", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}]], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{-3}\\frac{\\mathrm{d}x}{\\mathrm{d}t}=1", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a3554267-8b46-44be-bd38-f19600338575"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Integral]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "-3"], 
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["x", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}]], 
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["t", "TI"], "\[LongEqual]", "\[Integral]", 
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\int x^{-3}\\frac{\\mathrm{d}x}{\\mathrm{d}t}\\mathrm{d}t=\\int\\\
mathrm{d}t", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3700dcb6-0a8c-4c2c-8d80-e7b17e6a4864"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         FractionBox["1", "2"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "-2"], "\[LongEqual]", 
         StyleBox["t", "TI"], "+", 
         StyleBox["C", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "-\\frac{1}{2}x^{-2}=t+C", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8b704498-d5db-4611-a27e-83fac6f57208"],
 "\n",
