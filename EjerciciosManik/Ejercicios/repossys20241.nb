72692a28aaad"]
}, Open  ]],

Cell[TextData[{
 "Vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["tr", FontSlant -> "Plain"], 
         StyleBox["J", "TI"], "\[LongEqual]", "2", 
         StyleBox["a", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mathrm{tr}J=2a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8aa2aa49-9e8c-4af5-8ed8-ee9a6c284871"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["det", FontSlant -> "Plain"], 
         StyleBox["J", "TI"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "-", "2", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"1", "-", 
              StyleBox["a", "TI"]}], ")"}], "2"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "-", "2", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "+", "4", 
         StyleBox["a", "TI"], "-", "2", "\[LongEqual]", "-", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "+", "4", 
         StyleBox["a", "TI"], "-", "2"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathrm{det}J=a^2-2(1-a)^2=a^2-2a^2+4a-2=-a^2+4a-2", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "913a2e06-4b51-4691-bd4c-4d414ca63b77"],
 " y obtenemos el polinomio caracter\[IAcute]stico\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Lambda]", "2"], "-", "2", 
         StyleBox["a", "TI"], "\[Lambda]", "-", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "+", "4", 
         StyleBox["a", "TI"], "-", "2"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\lambda^2-2a\\lambda-a^2+4a-2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0bd297ca-e45f-4818-8d2f-1d70840becbb"],
 "\nUsando el criterio de Jury ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SubscriptBox[
          StyleBox["a", "TI"], "1"], "|", "<", 
         SubscriptBox[
          StyleBox["a", "TI"], "2"], "+", "1", "<", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|a_1|<a_2+1<2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d56fb11b-8ed2-4d9a-9fe6-a2ea0b24a940"],
 " , nos enfocamos en la primera desigualdad \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", "-", "2", 
         StyleBox["a", "TI"], "|", "<", "-", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "+", "4", 
         StyleBox["a", "TI"], "-", "2", "+", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|-2a|<-a^2+4a-2+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "39b755da-1b86-4323-8005-bcd9f6250777"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", "-", "2", 
         StyleBox["a", "TI"], "|", "<", "-", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "+", "4", 
         StyleBox["a", "TI"], "-", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "|-2a|<-a^2+4a-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e1c0bb03-848b-4e71-927c-9eb956f5675d"],
 "\nUsamos la desigualdad con signo negativo\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "-", "4", 
         StyleBox["a", "TI"], "+", "1", "<", "-2", 
         StyleBox["a", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "a^2-4a+1<-2a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "31663302-1f25-46e3-942f-d4cede837420"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], "-", "2", 
         StyleBox["a", "TI"], "+", "1", "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "a^2-2a+1<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b2433f6d-f679-4918-9a96-ee86868ed9db"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              StyleBox["a", "TI"], "-", "1"}], ")"}], "2"], "<", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "(a-1)^2<0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5223085b-6f99-4a93-bb6b-1c242e1469ee"],
 "\nComo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "\[Element]", 
         StyleBox["R", FontSlant -> "Plain"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "a\\in\\mathbb{R}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "575d8cf0-cab9-46db-a049-d10f8e2db9c8"],
 ", entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              StyleBox["a", "TI"], "-", "1"}], ")"}], "2"], ">", "0", 
         "\[ForAll]", 
         StyleBox["a", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "(a-1)^2>0\\forall a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1dbbbbd7-593b-4ea9-b70b-a5727dc6dcf3"],
 " y la desigualdad nunca se cumple, por lo cual este punto de equilibrio \
siempre es inestable."
}], "Text",
 CellChangeTimes->{{3.9102945940067415`*^9, 3.910294617818791*^9}, {
   3.9102947565793796`*^9, 3.910294760807971*^9}, {3.910294820293859*^9, 
   3.910294822559656*^9}, {3.910294902861183*^9, 3.9102949043487816`*^9}, {
   3.910294947378793*^9, 3.9102949485273094`*^9}, {3.9102949821799154`*^9, 
   3.9102949832498913`*^9}, {3.9102950266284003`*^9, 3.910295028117322*^9}, {
   3.910295158070222*^9, 3.910295299198566*^9}, 3.9102955027136345`*^9, {
   3.9102962361482334`*^9, 3.9102962499956894`*^9}, {3.9102963017621403`*^9, 
   3.9102963973280954`*^9}, {3.9102965726568136`*^9, 
   3.910296646681883*^9}},ExpressionUUID->"b933e9e7-e08d-42f4-abe1-\
e08e7b0c8165"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
