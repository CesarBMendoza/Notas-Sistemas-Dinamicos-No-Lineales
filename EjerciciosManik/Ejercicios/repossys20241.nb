Cell[TextData[{
 "Cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         FractionBox["1", "4"], "<", 
         StyleBox["r", "TI"], "<", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "-\\frac{1}{4}<r<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b2730c28-79e9-4168-b055-3dc4e6d9804a"],
 ", por el an\[AAcute]lisis anterior sabemos que deben haber cinco puntos de \
equilibrio, es decir, cinco intersecciones con el eje ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "75f2c04b-7ad3-4d38-acb1-b2d89d0bf998"],
 ". El an\[AAcute]lisis anterior para valores extremos de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "11c1445e-c7f5-462a-b3d4-99e48541119e"],
 " sigue siendo v\[AAcute]lido, por lo que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "72a6f6ac-6207-40a3-a847-9acb4484ec8c"],
 " debe ser positiva para valores muy negativos y negativa para valores muy \
positivos. Como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e97ea46b-d444-4636-a88b-2fc4077cf012"],
 " es continua, entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2bd06dca-af61-4824-9dce-0da452719178"],
 " s\[OAcute]lo puede cambiar de signo en estos cruces. Por lo tanto, en el \
primer punto de equilbrio (de izquierda a derecha), ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "eecbd88e-33a0-4da9-8e29-dac658d0d38a"],
 " debe cruzar de arriba hacia abajo (es estable), en el segundo cruza de \
abajo hacia arriba (inestable), en el tercero (que es el cero), cruza de \
arriba hacia abajo (estable), en el cuarto cruza de abajo hacia arriba \
(inestable) y en el \[UAcute]ltimo de arriba hacia abajo (estable). Entonces, \
el espacio fase debe verse como"
}], "Text",
 CellChangeTimes->{{3.9101996424270635`*^9, 
  3.9101998842207003`*^9}},ExpressionUUID->"679dfbbd-0e5f-49bd-946f-\
deed8030a73c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"1", "/", "8"}], ")"}]}], "*", "u"}], "+", 
      RowBox[{"u", "^", "3"}], "-", 
      RowBox[{"u", "^", "5"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"Frame", "->", 
      RowBox[{"{", 
       RowBox[{"True", ",", "True", ",", "False", ",", "False"}], "}"}]}], 
     ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "1"}], "/", "5"}], ",", 
          RowBox[{"1", "/", "5"}]}], "}"}]}], "}"}]}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
