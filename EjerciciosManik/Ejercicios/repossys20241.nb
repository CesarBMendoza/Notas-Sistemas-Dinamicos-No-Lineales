Cell["\<\
Donde se ve que las soluciones con condiciones iniciales positivas siempre \
son crecientes sin tender a ninguna soluci\[OAcute]n de equilibrio.\
\>", "Text",
 CellChangeTimes->{{3.9101792665702105`*^9, 
  3.910179298754918*^9}},ExpressionUUID->"ad08a259-7bc8-42aa-9978-\
5e9ee8fabcff"]
}, Open  ]],

