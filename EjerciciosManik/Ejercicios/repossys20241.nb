Cell["Pregunta II", "Section",
 CellChangeTimes->{{3.910179960770135*^9, 
  3.9101799635411158`*^9}},ExpressionUUID->"94fd1d59-fa94-4e4d-9f5a-\
63e630659177"],

Cell[TextData[{
 "Recordamos que una soluci\[OAcute]n de equilibrio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["x", "TI"], "\[FivePointedStar]"], TraditionalForm], 
     "errors" -> {}, "input" -> "x^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d78880f4-9ccf-4aa4-98fc-788a4942956b"],
 " en un sistema din\[AAcute]mico continuo unidimensional ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{x}=f(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3258bc7d-17f6-49ec-8998-c646092d87d6"],
 " es asint\[OAcute]ticamente estable si  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["f", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["x", "TI"], "\[FivePointedStar]"], ")"}], "<", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{\\mathrm{d}f}{\\mathrm{d}x}(x^{\\star})<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1feb39b0-93fb-401e-b6ac-a5fc829019d4"],
 ". En otras palabras, la pendiente de la recta tangente en el punto de \
equilibrio debe ser negativa. Geom\[EAcute]tricamente, esto quiere decir que \
la gr\[AAcute]fica de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["f", "TI"], TraditionalForm], "errors" -> {}, "input" -> "f", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "76d31316-06a4-4abb-9b8a-b61281df1e6f"],
 " debe cruzar el eje ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cf777bef-5f8e-4b1a-a9f1-b75c106bdd49"],
 " de arriba hacia abajo. Si la ecuaci\[OAcute]n diferencial cumple con el \
teorema de existencia y unicidad, entonces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["f", "TI"], TraditionalForm], "errors" -> {}, "input" -> "f", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "59049830-5579-4deb-8120-713f9d59329f"],
 " es continua y diferenciable. Entonces, si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["f", "TI"], TraditionalForm], "errors" -> {}, "input" -> "f", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "449894d7-2436-49f7-b075-243dba27d5a4"],
 " cruza el eje ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "235287c7-e60a-4b1e-abfa-745f2ad71480"],
 " de arriba hacia abajo en dos puntos, necesariamente debe cruzar el eje ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "49a82f4b-2e39-421f-a432-c16e28488255"],
 " de abajo hacia arriba en un punto intermedio, es decir, debe haber un \
punto de equilibrio inestable entre ellas. De otra manera, esto \
quer\[IAcute]a decir que la funci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["f", "TI"], TraditionalForm], "errors" -> {}, "input" -> "f", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3d41c774-80e6-495a-9c47-f418a388c216"],
 " cambia de signo de positivo a negativo, y despu\[EAcute]s se vuelve \
positiva de nuevo sin cruzar el eje ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6e4aa0f5-d02d-47a4-9060-01fdec131081"],
 ". Esto s\[OAcute]lo ser\[IAcute]a posible si ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["f", "TI"], TraditionalForm], "errors" -> {}, "input" -> "f", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d2bdc8a9-74fc-4595-ab73-d1d90e118311"],
 " tuviera una discontinuidad de salto en un punto intermedio, pero entonces \
no ser\[IAcute]a continua y no cumplir\[IAcute]a con el teorema de existencia \
y unicidad. "
}], "Text",
 CellChangeTimes->{{3.9101799733970537`*^9, 3.9101800481032114`*^9}, {
  3.910180100735564*^9, 
  3.910180366700444*^9}},ExpressionUUID->"d96c9794-936c-4da8-93b7-\
020b0e549236"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pregunta III", "Section",
 CellChangeTimes->{{3.910181895646487*^9, 
  3.9101818991785913`*^9}},ExpressionUUID->"a6832835-5cda-4fad-8c56-\
b23b3fdaea91"],

Cell[TextData[{
 "De la figura se observa que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf71bdd4-69f9-482e-88c8-1af122a1c41c"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=1", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7c94f7ba-2097-4a33-8460-24067473a795"],
 " son soluciones constantes de la ecuaci\[OAcute]n, por lo que son \
soluciones de equilibrio. Vemos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c6e9315c-b9c7-4e9a-a75a-2636d0ac0a25"],
 " atrae a otras soluciones, mientras que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "x(t)=1", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c5613ed8-3e11-4460-8a34-f0378b40e5e3"],
 " las repele, por lo que son estable e inestable, respectivamente. Cualquier \
ecuaci\[OAcute]n que cumpla con estas condiciones es correcta. Por ejemplo, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "-", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=x^2-x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "12136e84-4437-498a-b09b-e8cf1b854eca"],
 " es una opci\[OAcute]n, como se puede comprobar con sus soluciones:"
}], "Text",
 CellChangeTimes->{{3.910181903036508*^9, 
  3.910182027617015*^9}},ExpressionUUID->"3c72c789-32f0-4e93-a540-\
620a007ab341"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}], "-", 
         RowBox[{"x", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", 
        RowBox[{"-", "1"}]}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}], "-", 
         RowBox[{"x", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "0.99"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol3", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "^", "2"}], "-", 
         RowBox[{"x", "[", "t", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "1.01"}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], "/.", "sol1"}], "]"}], ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], "/.", "sol2"}], "]"}], ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], "/.", "sol3"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "4"}], "}"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{"x", "[", "t", "]"}]}], "}"}]}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9101820308586383`*^9, 3.9101821770467167`*^9}, {
  3.910182213827325*^9, 3.910182244822673*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"eb4c88fe-a166-4d83-b87b-89a6553a75df"],

