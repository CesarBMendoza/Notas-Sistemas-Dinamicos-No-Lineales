        RowBox[{
         RowBox[{"4.95", "*", "x"}], "-", 
         RowBox[{"y", "*", 
          RowBox[{"x", "^", "2"}]}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "1.5", ",", "2.5"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "2", ",", "3"}], "}"}]}], "]"}], ",", 
    RowBox[{"ParametricPlot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], ",", 
          RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "sol"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Thick"}], "}"}]}]}], "]"}]}], "}"}], 
  "]"}]], "Input",
