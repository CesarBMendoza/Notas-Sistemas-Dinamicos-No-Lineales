Cell[CellGroupData[{

Cell["Pregunta II", "Section",
 CellChangeTimes->{{3.9102768336503763`*^9, 
  3.910276835069979*^9}},ExpressionUUID->"945de098-bec1-4104-af7b-\
d5490c6b1ded"],

Cell[TextData[{
 "El sistema est\[AAcute] en coordenadas polares por lo que la \
ecuaci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox["\[Theta]", "."], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\dot{\\theta}=1", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bc0168d9-bcf4-4eb5-b25b-a238a3dde565"],
 " s\[OAcute]lo indica que las soluciones giran en direcci\[OAcute]n \
antihoraria. Las bifurcaciones dependen s\[OAcute]lo de la ecuaci\[OAcute]n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["r", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Mu]", "-", "sin", 
             StyleBox["r", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\dot{r}=r(\\mu-\\sin r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "eb68ec07-a81e-426b-a8dc-5b2011bb1914"],
 ", el cual no depende de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Theta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e4b79c4d-80c4-43cd-a0b5-4a6d4434d846"],
 ", por lo que podemos tratarlo como un sistema unidimensional. Los puntos de \
equilibrio de este sistema corresponden a\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["r", "TI"], "\[FivePointedStar]"], 
         RowBox[{"(", 
           RowBox[{"\[Mu]", "-", "sin", 
             SuperscriptBox[
              StyleBox["r", "TI"], "\[FivePointedStar]"]}], ")"}], 
         "\[LongEqual]", "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "r^{\\star}(\\mu-\\sin r^\\star)=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "17ebbcc5-e7e9-4c06-8a3d-e53e9e5ea698"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["r", "TI"], "1", "\[FivePointedStar]"], "\[LongEqual]", 
         "0"}], TraditionalForm], "errors" -> {}, "input" -> "r_1^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "00f6652d-e1c9-4a3f-a8c4-b70e004679a6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["r", "TI"], "2", "\[FivePointedStar]"], "\[LongEqual]", 
         "arcsin", 
         RowBox[{"(", "\[Mu]", ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r_2^{\\star}=\\arcsin(\\mu)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4ba77cd2-f23c-4799-8348-2c597b35e7d4"],
 "\nEl primero nos informa que el punto de equilibrio es el origen. El \
segundo ser\[IAcute]a un ciclo l\[IAcute]mite, ya que es una soluci\[OAcute]n \
que rota a la izquierda con radio constante. Primero, debemos fijarnos que, \
dado que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"sin", 
         StyleBox["x", "TI"], "\[Element]", 
         RowBox[{"[", 
           RowBox[{"-1", ",", "1"}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\sin x\\in[-1,1]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "31f0317d-8692-4bd4-ad21-9dc656e3af17"],
 ", entonces este ciclo l\[IAcute]mite s\[OAcute]lo existe cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[Element]", 
         RowBox[{"[", 
           RowBox[{"-1", ",", "1"}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu\\in[-1,1]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bbdf9cb0-4095-4f8a-82ec-d1966630f29e"],
 ". Segundo, recordamos que este punto de equilibrio surge del requerimiento \
de que \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "-", "sin", 
         SuperscriptBox[
          StyleBox["r", "TI"], "\[FivePointedStar]"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\mu-\\sin r^{\\star}=0",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aa4e3ec5-dbdb-4d41-b6e3-9cdd294a0e62"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", "sin", 
         SuperscriptBox[
          StyleBox["r", "TI"], "\[FivePointedStar]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mu=\\sin r^{\\star}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "02d019d3-772b-4005-9fde-b582a510cc45"],
 "\nGraficamente, estos ciclos l\[IAcute]mite corresponden a la intersecci\
\[OAcute]n entre la recta ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "\[LongEqual]", "\[Mu]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "y=\\mu", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f260f12f-cb92-49db-bc51-3bf7281f569a"],
 " y la curva ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["y", "TI"], "\[LongEqual]", "sin", 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "y=\\sin x", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3fba358e-8919-4099-9870-3ed44149cae1"],
 ". Al variar ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Mu]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f16cd072-11de-4fcd-b7f6-450eebcb329f"],
 ", lo \[UAcute]nico que estamos haciendo es variar la altura de la recta, \
por lo que, recordando la forma de la gr\[AAcute]fica del seno, es \
f\[AAcute]cil ver que:\n1. Cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", ">", "1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu>1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "64a92696-1f16-4966-99bb-1d9ab3c11b34"],
 " \[OAcute] ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "<", "-1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mu<-1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "824920a5-88f8-4423-a2c4-d6e212097a13"],
 " no hay ciclos l\[IAcute]mite"
}], "Text",
 CellChangeTimes->{{3.9102768393855743`*^9, 3.9102769466002045`*^9}, {
  3.9102769775124855`*^9, 3.9102770612257366`*^9}, {3.9102774794190063`*^9, 
  3.9102776305215635`*^9}, {3.91027766493519*^9, 
  3.9102780002979584`*^9}},ExpressionUUID->"a18c2837-feaf-4955-96d1-\
095e9624190e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1.2", ",", 
     RowBox[{"Sin", "[", "r", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
