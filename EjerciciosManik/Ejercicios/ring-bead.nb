Cell[CellGroupData[{
Cell["La cuenta y el aro", "Title",
 CellChangeTimes->{{3.88651001080639*^9, 
  3.8865100137456427`*^9}},ExpressionUUID->"96c75333-eede-4816-8613-\
30ded82dc162"],

Cell[CellGroupData[{

Cell["Diagrama de bifurcaci\[OAcute]n", "Section",
 CellChangeTimes->{{3.8865111431836357`*^9, 
  3.886511147291044*^9}},ExpressionUUID->"f81534f5-de96-42ab-80a7-\
ef12c827dceb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"branch1", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"g", ",", 
       RowBox[{"\[Phi]", "/.", 
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", "\[Phi]", "]"}], "==", 
           RowBox[{"1", "/", "g"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Phi]", ",", 
            RowBox[{"Pi", "/", "2"}]}], "}"}]}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"g", ",", "1.001", ",", "5", ",", "0.001"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"branch2", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"g", ",", 
       RowBox[{"\[Phi]", "/.", 
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", "\[Phi]", "]"}], "==", 
           RowBox[{"1", "/", "g"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Phi]", ",", 
            RowBox[{
             RowBox[{"-", "Pi"}], "/", "2"}]}], "}"}]}], "]"}]}]}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"g", ",", "1.001", ",", "5", ",", "0.001"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.886510350559473*^9, 3.8865104841419754`*^9}, {
  3.8865105469731045`*^9, 3.886510549065201*^9}, {3.886510583692377*^9, 
