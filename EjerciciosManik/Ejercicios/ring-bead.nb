       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "5"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"Ticks", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "Pi"}], ",", 
          RowBox[{
           RowBox[{"-", "Pi"}], "/", "2"}], ",", "0", ",", 
          RowBox[{"Pi", "/", "2"}], ",", "Pi"}], "}"}]}], "}"}]}]}], "]"}], 
   ",", 
