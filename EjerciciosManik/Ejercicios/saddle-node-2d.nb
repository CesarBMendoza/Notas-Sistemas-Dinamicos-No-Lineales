Cell["\<\
Si queremos mostrar fehacientemente que es una bifurcaci\[OAcute]n de nodo \
silla, debemos mostrar que el punto de equilibrio intermedio es un punto \
silla y el de la derecha es un nodo estable. Para esto calculamos la matriz \
jacobiana:\
\>", "Text",
 CellChangeTimes->{{3.8900519652968264`*^9, 
  3.8900520314317865`*^9}},ExpressionUUID->"7fe36831-737a-4291-9364-\
83ffb15ceac0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f1", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "a"}], "*", "x"}], "+", "y"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f2", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", "^", "2"}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"x", "^", "2"}]}], ")"}]}], "-", 
    RowBox[{"b", "*", "y"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"jac", "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{"D", "[", 
        RowBox[{"f1", ",", "x"}], "]"}], 
       RowBox[{"D", "[", 
        RowBox[{"f1", ",", "y"}], "]"}]},
      {
       RowBox[{"D", "[", 
        RowBox[{"f2", ",", "x"}], "]"}], 
       RowBox[{"D", "[", 
        RowBox[{"f2", ",", "y"}], "]"}]}
     }], "\[NoBreak]", ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "jac", "]"}]}], "Input",
 CellChangeTimes->{{3.8900520364208813`*^9, 3.8900521611933365`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"4c85cf9f-aee0-40c5-91a2-70dbdac13491"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"-", "a"}], "1"},
     {
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         RowBox[{"2", " ", 
          SuperscriptBox["x", "3"]}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", "+", 
            SuperscriptBox["x", "2"]}], ")"}], "2"]]}], "+", 
       FractionBox[
        RowBox[{"2", " ", "x"}], 
        RowBox[{"1", "+", 
         SuperscriptBox["x", "2"]}]]}], 
      RowBox[{"-", "b"}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{{3.8900521453948154`*^9, 3.8900521615108895`*^9}},
 CellLabel->
  "Out[16]//MatrixForm=",ExpressionUUID->"32b53420-5957-4f53-9ca5-\
0dbb55445d2a"]
}, Open  ]],

Cell[TextData[{
 "Vemos que la traza siempre es negativa (",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], ",", 
         StyleBox["b", "TI"], ">", "0"}], TraditionalForm], "errors" -> {}, 
     "input" -> "a,b>0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "95509bd2-2f0b-426c-99b5-9970d70ad926"],
 "), as\[IAcute] que los equilibrios siempre son estables o puntos silla. S\
\[OAcute]lo debemos determinar el determinante. Vemos que:"
}], "Text",
 CellChangeTimes->{{3.8900521787263136`*^9, 
  3.890052249334382*^9}},ExpressionUUID->"5152455c-fb52-4c44-babd-\
e963c3d5ab2a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Det", "[", 
  RowBox[{"jac", "/.", 
   RowBox[{"{", 
    RowBox[{"x", "->", "0"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.890052252031243*^9, 3.890052285692239*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"f6876448-4637-4cc6-8a2a-0bcd4e3bee61"],

Cell[BoxData[
 RowBox[{"a", " ", "b"}]], "Output",
 CellChangeTimes->{3.8900522863030167`*^9},
 CellLabel->"Out[17]=",ExpressionUUID->"f984d416-46db-4b78-958c-7da356f24775"]
}, Open  ]],

Cell[TextData[{
 "El origen siempre es un nodo estable (pues ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"-", 
              StyleBox["a", "TI"], "-", 
              StyleBox["b", "TI"]}], ")"}], "2"], "-", "4", 
         StyleBox["a", "TI"], 
         StyleBox["b", "TI"], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              StyleBox["a", "TI"], "-", 
              StyleBox["b", "TI"]}], ")"}], "2"], ">", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "(-a-b)^2-4ab=(a-b)^2>0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f9348f9c-c9bc-4965-bece-df20f18a0bd0"],
 ").\nEl punto de equilibrio del medio cumple:"
}], "Text",
 CellChangeTimes->{{3.890052291993488*^9, 3.8900523000988693`*^9}, {
  3.8900523429302025`*^9, 3.890052380861743*^9}, {3.8900524597339664`*^9, 
  3.8900524733675165`*^9}, {3.8900525295617685`*^9, 
  3.8900525436547937`*^9}},ExpressionUUID->"5d4ed68a-13ee-497f-9c5c-\
c4ff9f030c88"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"Det", "[", 
   RowBox[{"jac", "/.", 
    RowBox[{"{", 
     RowBox[{"x", "\[Rule]", 
      FractionBox[
       RowBox[{"1", "-", 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"4", " ", 
           SuperscriptBox["a", "2"], " ", 
           SuperscriptBox["b", "2"]}]}]]}], 
       RowBox[{"2", " ", "a", " ", "b"}]]}], "}"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.890052475080844*^9, 3.890052493472966*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"b0bbd43c-0d9c-4ed4-a41f-dc49a41590df"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "a"}], " ", "b", " ", 
  SqrtBox[
   RowBox[{"1", "-", 
    RowBox[{"4", " ", 
     SuperscriptBox["a", "2"], " ", 
     SuperscriptBox["b", "2"]}]}]]}]], "Output",
 CellChangeTimes->{3.8900524948534093`*^9},
 CellLabel->"Out[18]=",ExpressionUUID->"069c3df8-41df-4feb-947f-e1879855edb9"]
}, Open  ]],

Cell["\<\
por lo que el determinante es negativo y es un punto silla.
El punto de equilibrio de la derecha cumple:\
\>", "Text",
 CellChangeTimes->{{3.890052556826866*^9, 
  3.890052578517712*^9}},ExpressionUUID->"fc6b330a-1405-4c09-a4fa-\
32351a4c1317"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"Det", "[", 
   RowBox[{"jac", "/.", 
    RowBox[{"{", 
     RowBox[{"x", "\[Rule]", 
      FractionBox[
       RowBox[{"1", "+", 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"4", " ", 
           SuperscriptBox["a", "2"], " ", 
           SuperscriptBox["b", "2"]}]}]]}], 
       RowBox[{"2", " ", "a", " ", "b"}]]}], "}"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.8900525850777454`*^9, 3.8900525858767166`*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"e390664a-8dae-43ab-99f8-d5891c13441d"],

Cell[BoxData[
 RowBox[{"a", " ", "b", " ", 
  SqrtBox[
   RowBox[{"1", "-", 
    RowBox[{"4", " ", 
     SuperscriptBox["a", "2"], " ", 
     SuperscriptBox["b", "2"]}]}]]}]], "Output",
 CellChangeTimes->{3.890052586626628*^9},
 CellLabel->"Out[19]=",ExpressionUUID->"e94df82d-73c8-4cda-ab06-0779403d6c7e"]
}, Open  ]],

Cell["Por lo que es un equilibrio estable.", "Text",
 CellChangeTimes->{{3.8900526208874855`*^9, 
  3.8900526497372637`*^9}},ExpressionUUID->"50079ddf-5f82-4c63-bd36-\
1b876864b422"]
}, Open  ]]
}, Open  ]]
},
