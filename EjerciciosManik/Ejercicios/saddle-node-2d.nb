  3.890051642652952*^9, 3.8900516466694436`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"fbcfb32d-b66d-4154-91b4-35bcef7dd56b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", 
     FractionBox[
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"4", " ", 
          SuperscriptBox["a", "2"], " ", 
          SuperscriptBox["b", "2"]}]}]]}], 
