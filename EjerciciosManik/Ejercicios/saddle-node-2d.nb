Cell[TextData[{
 "Los puntos de equilibrio se encuentran en las intersecciones de las \
ceroclinas, es decir cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], 
         StyleBox["x", "TI"], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["x", "TI"], "2"], 
          RowBox[{
            StyleBox["b", "TI"], "(", 
            RowBox[{"1", "+", 
              SuperscriptBox[
               StyleBox["x", "TI"], "2"]}], ")"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "ax=\\frac{x^2}{b(1+x^2)}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3f68c5ff-f8fd-4a1b-9ab0-067a5161f477"],
 ", o de manera equivalente, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], 
         StyleBox["b", "TI"], "\[LongEqual]", 
         FractionBox[
          StyleBox["x", "TI"], 
          RowBox[{"1", "+", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "ab=\\frac{x}{1+x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f7061257-be1d-4720-922d-a26199bfab2b"],
 ". Resolviendo encontramos:"
}], "Text",
 CellChangeTimes->{{3.89005145768422*^9, 3.8900514792066364`*^9}, {
  3.8900515160218945`*^9, 3.8900515204133663`*^9}, {3.890051555021475*^9, 
  3.890051559421939*^9}},ExpressionUUID->"a6c0931d-3a47-4321-acc5-\
8d5e2a7c0542"],

