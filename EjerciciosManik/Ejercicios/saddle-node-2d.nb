Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"a", "*", "x"}], "==", 
    RowBox[{
     RowBox[{"x", "^", "2"}], "/", 
     RowBox[{"(", 
      RowBox[{"b", "*", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"x", "^", "2"}]}], ")"}]}], ")"}]}]}], ",", "x"}], 
  "]"}]], "Input",
