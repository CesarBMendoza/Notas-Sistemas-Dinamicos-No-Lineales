Cell[TextData[{
 "Vemos que los \[UAcute]ltimos dos puntos de equilibrio son el mismo cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "-", "4", 
         SuperscriptBox[
          StyleBox["a", "TI"], "2"], 
         SuperscriptBox[
          StyleBox["b", "TI"], "2"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "1-4a^2b^2=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2eb83f53-2022-4d44-8662-e2ad838e4746"],
 ", es decir, cuando ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["c", "TI"]], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{"2", 
            StyleBox["b", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "a_c=\\frac{1}{2b}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cc3a3513-4299-49cd-9933-1c9cc862c006"],
 ".\nLas trayectorias del sistema despu\[EAcute]s de la bifurcaci\[OAcute]n \
son: "
}], "Text",
