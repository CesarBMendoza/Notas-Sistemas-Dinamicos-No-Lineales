Cell[CellGroupData[{

Cell[TextData[{
 "Ejemplo II: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         StyleBox["x", "TI"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             FractionBox[
              StyleBox["x", "TI"], 
              StyleBox["k", "TI"]]}], ")"}], "-", 
         StyleBox["H", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\dot{x}=rx\\left(1-\\frac{x}{k}\\right)-H", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4746582b-6594-4161-b769-ebf129bb2ec9"]
}], "Section",
 CellChangeTimes->{{3.8852961557966805`*^9, 
  3.8852961762282486`*^9}},ExpressionUUID->"3959f6e1-332a-42f3-be85-\
59d97f13ba6c"],

Cell[CellGroupData[{

Cell[TextData[{
 "Bifurcaci\[OAcute]n con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> "r", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf366bf4-876e-4cc8-b946-7f6b7adbe2fc"]
}], "Subsection",
 CellChangeTimes->{{3.885296234200555*^9, 
  3.885296240863864*^9}},ExpressionUUID->"ca7c4ea7-2405-45e6-ae0b-\
c1b22e2f4d4b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"r", "*", "x", "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}]}], "-", "1"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"OverDot", "[", "x", "]"}]}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", "2", ",", "6"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.855678262073421*^9, 3.855678287390945*^9}, {
  3.855678332271508*^9, 3.855678335137634*^9}},
 CellLabel->"In[52]:=",ExpressionUUID->"8d9f2f2e-2aa3-430c-bc28-f68b6a99a13a"],

