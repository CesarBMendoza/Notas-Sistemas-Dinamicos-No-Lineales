Cell[CellGroupData[{

Cell[TextData[{
 "Ejemplo III: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], "cosh", 
         StyleBox["x", "TI"], "-", 
         FractionBox[
          StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{x}=r\\cosh x-\\frac{x}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7d917065-04b7-4881-9f13-e703b519b42a"]
}], "Section",
