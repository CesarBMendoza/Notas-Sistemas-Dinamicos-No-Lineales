Cell[CellGroupData[{

Cell[TextData[{
 "Ejemplo I: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], "-", 
         StyleBox["x", "TI"], "-", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["x", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{x}=r-x-e^{-x}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "322abded-4075-4825-9dd2-045d072c4174"]
}], "Section",
 CellChangeTimes->{{3.885295298505024*^9, 
  3.885295322379816*^9}},ExpressionUUID->"a55f1696-f6fd-46ac-a483-\
296b0faf336a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"r", "-", "x"}], ",", 
       RowBox[{"Exp", "[", 
        RowBox[{"-", "x"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"OverDot", "[", "x", "]"}]}], "}"}]}], ",", 
