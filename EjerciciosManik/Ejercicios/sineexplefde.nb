Cell[BoxData[
 RowBox[{
  RowBox[{"eigs", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"sss", "[", 
         RowBox[{"[", "j", "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", 
       RowBox[{"Abs", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"sss", "[", 
           RowBox[{"[", "j", "]"}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"sss", "[", 
             RowBox[{"[", "j", "]"}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "*", 
           RowBox[{
            RowBox[{"sss", "[", 
             RowBox[{"[", "j", "]"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "401"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8363220369436703`*^9, 3.8363220602578373`*^9}, {
  3.8363220978791285`*^9, 3.8363222129747825`*^9}, {3.8363222743416195`*^9, 
