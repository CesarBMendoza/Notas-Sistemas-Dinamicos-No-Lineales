Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"sss", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"w", ",", 
       RowBox[{"x", "/.", 
        RowBox[{"FindRoot", "[", 
         RowBox[{
          RowBox[{"x", "==", 
           RowBox[{"Sin", "[", 
            RowBox[{"w", "*", "x"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"3", "/", "4"}]}], "}"}]}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"w", ",", "1", ",", "5", ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.8363218292758083`*^9, 3.8363219129759502`*^9}, {
  3.8363219553330884`*^9, 3.8363219961804547`*^9}, {3.836322070132491*^9, 
  3.8363220854368277`*^9}},
