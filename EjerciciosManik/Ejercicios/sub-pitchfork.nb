Cell[TextData[{
 "Forma normal 2: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         StyleBox["x", "TI"], "+", 
         SuperscriptBox[
          StyleBox["x", "TI"], "3"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "5"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{x}=rx+x^3-x^5", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "29b81614-4191-431d-aea1-5795a5bac4eb"]
