Cell["Soluciones antes del punto cr\[IAcute]tico y en el punto \
cr\[IAcute]tico", "Subsection",
 CellChangeTimes->{{3.885650656247994*^9, 
  3.885650664321911*^9}},ExpressionUUID->"8551dd55-dc59-4e98-9f06-\
6f9a16175fbc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"sol1", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"x", "[", "t", "]"}]}], "-", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "^", "3"}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", "x", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"sol2", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"-", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "^", "3"}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", "x", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.856431169441022*^9, 3.856431211377316*^9}, {
