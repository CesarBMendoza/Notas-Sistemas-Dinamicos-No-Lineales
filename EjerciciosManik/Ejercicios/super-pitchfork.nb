Cell[TextData[{
 "Forma normal: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         StyleBox["x", "TI"], "-", 
         SuperscriptBox[
          StyleBox["x", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{x}=rx-x^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3eea1f64-2ff6-4076-ae23-1c851ca104de"]
