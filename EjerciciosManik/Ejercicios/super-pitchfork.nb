d668e78c7916"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Series", "[", 
  RowBox[{
   RowBox[{"x", "-", 
    RowBox[{"b", "*", 
     RowBox[{"Tanh", "[", "x", "]"}]}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "3"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.856432967072502*^9, 3.8564329839920006`*^9}, {
  3.885659707456913*^9, 3.8856597103139396`*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"1691c0ce-4f7c-4e5a-a008-1b7d2454d095"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "b"}], ")"}], " ", "x"}], "+", 
   FractionBox[
    RowBox[{"b", " ", 
     SuperscriptBox["x", "3"]}], "3"], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "x", "]"}], "4"],
    SeriesData[$CellContext`x, 0, {}, 1, 4, 1],
    Editable->False]}],
  SeriesData[$CellContext`x, 0, {
   1 - $CellContext`b, 0, Rational[1, 3] $CellContext`b}, 1, 4, 1],
  Editable->False]], "Output",
 CellChangeTimes->{3.856432984422192*^9, 3.88565971127851*^9},
 CellLabel->"Out[46]=",ExpressionUUID->"6370360f-dcd1-4992-a25c-887a1c0f8fc0"]
}, Open  ]],

