Cell[CellGroupData[{

Cell[TextData[{
 "Ejercicio: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "."], "\[LongEqual]", 
         StyleBox["x", "TI"], "-", "\[Beta]", "tanh", 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\dot{x}=x-\\beta\\tanh(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1d7d217e-d1e8-4f9e-866b-22e3157333bc"]
}], "Section",
