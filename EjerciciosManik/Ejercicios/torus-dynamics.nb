Cell[BoxData[
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x1", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"\[Omega]1", "+", 
         RowBox[{"k1", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"x2", "[", "t", "]"}], "-", 
            RowBox[{"x1", "[", "t", "]"}]}], "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"x2", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"\[Omega]2", "+", 
         RowBox[{"k2", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"x1", "[", "t", "]"}], "-", 
            RowBox[{"x2", "[", "t", "]"}]}], "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x1", "[", "0", "]"}], "==", "3"}], ",", 
       RowBox[{
        RowBox[{"x2", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x1", ",", "x2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "50"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9168481296379223`*^9, 3.9168481297255154`*^9}, {
  3.916848166240573*^9, 3.9168481837536564`*^9}, {3.9168524310345535`*^9, 
