Cell[BoxData[
 RowBox[{"Animate", "[", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"ParametricPlot3D", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"t", "/", "2"}], "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"7", "-", 
             RowBox[{"2", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{"Pi", "*", "t"}], "]"}]}]}], ")"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"t", "/", "2"}], "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"7", "-", 
             RowBox[{"2", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{"Pi", "*", "t"}], "]"}]}]}], ")"}]}], ",", 
          RowBox[{"2", "*", 
           RowBox[{"Sin", "[", 
            RowBox[{"Pi", "*", "t"}], "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "\[Tau]"}], "}"}], ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{"Red", ",", "Thick"}], "}"}]}], ",", 
        RowBox[{"PlotPoints", "->", "100"}], ",", 
        RowBox[{"MaxRecursion", "->", "10"}]}], "]"}], ",", 
      RowBox[{"ContourPlot3D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Sqrt", "[", 
               RowBox[{
                RowBox[{"x", "^", "2"}], "+", 
                RowBox[{"y", "^", "2"}]}], "]"}], "-", "7"}], ")"}], "^", 
            "2"}]}], "-", 
          RowBox[{"z", "^", "2"}], "+", "4"}], "==", "0"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"z", ",", 
          RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
        RowBox[{"Mesh", "\[Rule]", "None"}], ",", 
        RowBox[{"ContourStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{"Yellow", ",", 
           RowBox[{"Specularity", "[", 
            RowBox[{"White", ",", "20"}], "]"}], ",", 
           RowBox[{"Opacity", "[", "0.8", "]"}]}], "]"}]}]}], "]"}]}], "}"}], 
    "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Tau]", ",", "0.1", ",", "100"}], "}"}]}], "]"}]], "Input",
