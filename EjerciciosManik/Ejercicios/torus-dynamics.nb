Cell[BoxData[
 RowBox[{
  RowBox[{"sol1", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x1", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"\[Omega]1", "+", 
         RowBox[{"k1", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"x2", "[", "t", "]"}], "-", 
            RowBox[{"x1", "[", "t", "]"}]}], "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"x2", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"\[Omega]2", "+", 
         RowBox[{"k2", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"x1", "[", "t", "]"}], "-", 
            RowBox[{"x2", "[", "t", "]"}]}], "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x1", "[", "0", "]"}], "==", "3"}], ",", 
       RowBox[{
        RowBox[{"x2", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x1", ",", "x2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.916846491507768*^9, 3.9168466436034794`*^9}, {
  3.916847064181158*^9, 3.9168470738893604`*^9}, {3.916847873502178*^9, 
