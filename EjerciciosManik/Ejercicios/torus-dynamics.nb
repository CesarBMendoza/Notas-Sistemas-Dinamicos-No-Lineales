Cell[BoxData[
 RowBox[{
  RowBox[{"solnotlocked", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"x1", "[", "t", "]"}], ",", 
            RowBox[{"2", "*", "Pi"}]}], "]"}], ",", 
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"x2", "[", "t", "]"}], ",", 
            RowBox[{"2", "*", "Pi"}]}], "]"}]}], "}"}], "/.", "sol2"}], "]"}],
       "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "50", ",", "0.001"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
