Cell[BoxData[{
 RowBox[{
  RowBox[{"a1", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b1", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a2", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b2", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d1", "=", "0.4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d2", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"x", "[", "t", "]"}]}], ")"}]}], "-", 
         RowBox[{"a1", "*", 
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"y", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"b1", "*", 
              RowBox[{"x", "[", "t", "]"}]}]}], ")"}]}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"a1", "*", 
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"y", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"b1", "*", 
              RowBox[{"x", "[", "t", "]"}]}]}], ")"}]}]}], "-", 
         RowBox[{"d1", "*", 
          RowBox[{"y", "[", "t", "]"}]}], "-", 
         RowBox[{"a2", "*", 
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"z", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"b2", "*", 
              RowBox[{"y", "[", "t", "]"}]}]}], ")"}]}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"z", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"a2", "*", 
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"z", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"b2", "*", 
              RowBox[{"y", "[", "t", "]"}]}]}], ")"}]}]}], "-", 
         RowBox[{"d2", "*", 
          RowBox[{"z", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "0.81"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "0.11"}], ",", 
       RowBox[{
        RowBox[{"z", "[", "0", "]"}], "==", "12.54"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "1000", ",", "2000"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot3D", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
