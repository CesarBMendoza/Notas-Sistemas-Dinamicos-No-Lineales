     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"x", "[", "t", "]"}]}], ")"}]}], "-", 
         RowBox[{"a1", "*", 
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"y", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"b1", "*", 
              RowBox[{"x", "[", "t", "]"}]}]}], ")"}]}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"a1", "*", 
          RowBox[{"x", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"y", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"b1", "*", 
              RowBox[{"x", "[", "t", "]"}]}]}], ")"}]}]}], "-", 
         RowBox[{"d1", "*", 
          RowBox[{"y", "[", "t", "]"}]}], "-", 
         RowBox[{"a2", "*", 
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"z", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"b2", "*", 
              RowBox[{"y", "[", "t", "]"}]}]}], ")"}]}]}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"z", "'"}], "[", "t", "]"}], "==", 
        RowBox[{
         RowBox[{"a2", "*", 
          RowBox[{"y", "[", "t", "]"}], "*", 
          RowBox[{
           RowBox[{"z", "[", "t", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"b2", "*", 
              RowBox[{"y", "[", "t", "]"}]}]}], ")"}]}]}], "-", 
         RowBox[{"d2", "*", 
          RowBox[{"z", "[", "t", "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "0.81"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "0.11"}], ",", 
       RowBox[{
        RowBox[{"z", "[", "0", "]"}], "==", "12.54"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "1000", ",", "2000"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
